---
interface Trial {
  nctId: string;
  title: string;
  status: string;
  phase: string;
  conditions: string[];
  interventions: string[];
  enrollmentTarget?: number;
  startDate?: string;
  completionDate?: string;
  peptide: string;
}

interface Props {
  trials: Trial[];
}

const { trials } = Astro.props;

// Status badge colors - dark theme
const statusColors: Record<string, { bg: string; text: string; border: string }> = {
  active: { bg: 'bg-emerald-500/20', text: 'text-emerald-300', border: 'border-emerald-500/30' },
  completed: { bg: 'bg-blue-500/20', text: 'text-blue-300', border: 'border-blue-500/30' },
  recruiting: { bg: 'bg-amber-500/20', text: 'text-amber-300', border: 'border-amber-500/30' },
  'not yet recruiting': { bg: 'bg-white/10', text: 'text-white/70', border: 'border-white/20' },
  terminated: { bg: 'bg-red-500/20', text: 'text-red-300', border: 'border-red-500/30' },
  withdrawn: { bg: 'bg-red-500/20', text: 'text-red-300', border: 'border-red-500/30' },
  suspended: { bg: 'bg-orange-500/20', text: 'text-orange-300', border: 'border-orange-500/30' },
};

function getStatusColors(status: string) {
  const key = status.toLowerCase();
  return statusColors[key] || { bg: 'bg-white/10', text: 'text-white/70', border: 'border-white/20' };
}

function formatDate(dateStr?: string): string {
  if (!dateStr) return '-';
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
}
---

<div class="overflow-x-auto">
  <table class="min-w-full divide-y divide-white/10">
    <thead class="bg-gradient-to-r from-[var(--primary)]/15 to-transparent">
      <tr>
        <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-white/90 uppercase tracking-wider">
          NCT ID
        </th>
        <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-white/90 uppercase tracking-wider">
          Title
        </th>
        <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-white/90 uppercase tracking-wider">
          Peptide
        </th>
        <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-white/90 uppercase tracking-wider">
          Phase
        </th>
        <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-white/90 uppercase tracking-wider">
          Status
        </th>
        <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-white/90 uppercase tracking-wider">
          Completion
        </th>
      </tr>
    </thead>
    <tbody class="divide-y divide-white/10">
      {trials.length === 0 ? (
        <tr>
          <td colspan="6" class="px-4 py-8 text-center text-white/60">
            No trials found matching your criteria.
          </td>
        </tr>
      ) : (
        trials.map((trial) => {
          const colors = getStatusColors(trial.status);
          return (
            <tr class="trial-row transition-all duration-300 hover:bg-gradient-to-r hover:from-[var(--primary)]/15 hover:via-[var(--primary)]/10 hover:to-transparent"
                data-status={trial.status.toLowerCase()}
                data-phase={trial.phase}
                data-peptide={trial.peptide.toLowerCase()}>
              <td class="px-4 py-4 whitespace-nowrap">
                <a
                  href={`https://clinicaltrials.gov/study/${trial.nctId}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm font-medium text-white hover:text-[var(--accent)] hover:underline transition-colors"
                >
                  {trial.nctId}
                </a>
              </td>
              <td class="px-4 py-4">
                <div class="text-sm text-white max-w-md line-clamp-2" title={trial.title}>
                  {trial.title}
                </div>
                <div class="mt-1 text-xs text-white/70">
                  {trial.conditions.slice(0, 2).join(', ')}
                  {trial.conditions.length > 2 && ` +${trial.conditions.length - 2} more`}
                </div>
              </td>
              <td class="px-4 py-4 whitespace-nowrap">
                <a
                  href={`/peptides/${trial.peptide.toLowerCase()}`}
                  class="text-sm font-medium text-white hover:text-primary transition-colors"
                >
                  {trial.peptide}
                </a>
              </td>
              <td class="px-4 py-4 whitespace-nowrap">
                <span class="text-sm text-white/80">Phase {trial.phase}</span>
              </td>
              <td class="px-4 py-4 whitespace-nowrap">
                <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border ${colors.bg} ${colors.text} ${colors.border}`}>
                  {trial.status.charAt(0).toUpperCase() + trial.status.slice(1)}
                </span>
              </td>
              <td class="px-4 py-4 whitespace-nowrap text-sm text-white/70">
                {formatDate(trial.completionDate)}
              </td>
            </tr>
          );
        })
      )}
    </tbody>
  </table>
</div>

<!-- Mobile view (cards) -->
<div class="md:hidden space-y-4">
  {trials.map((trial) => {
    const colors = getStatusColors(trial.status);
    return (
      <div class="rounded-xl border border-white/10 bg-white/5 p-4 backdrop-blur-sm trial-card transition-all duration-300 hover:bg-gradient-to-r hover:from-[var(--primary)]/15 hover:via-[var(--primary)]/10 hover:to-transparent hover:border-[var(--primary)]/30"
           data-status={trial.status.toLowerCase()}
           data-phase={trial.phase}
           data-peptide={trial.peptide.toLowerCase()}>
        <div class="flex items-start justify-between gap-2">
          <a
            href={`https://clinicaltrials.gov/study/${trial.nctId}`}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm font-semibold text-white hover:underline"
          >
            {trial.nctId}
          </a>
          <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium border ${colors.bg} ${colors.text} ${colors.border}`}>
            {trial.status.charAt(0).toUpperCase() + trial.status.slice(1)}
          </span>
        </div>
        <h3 class="mt-2 text-sm font-medium text-white line-clamp-2">
          {trial.title}
        </h3>
        <div class="mt-3 flex flex-wrap gap-2 text-xs text-white/60">
          <span class="inline-flex items-center gap-1">
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
            </svg>
            <a href={`/peptides/${trial.peptide.toLowerCase()}`} class="hover:text-primary">
              {trial.peptide}
            </a>
          </span>
          <span>Phase {trial.phase}</span>
          <span>Est. {formatDate(trial.completionDate)}</span>
        </div>
      </div>
    );
  })}
</div>

<style>
  /* Hide desktop table on mobile, hide mobile cards on desktop */
  .overflow-x-auto {
    display: none;
  }

  @media (min-width: 768px) {
    .overflow-x-auto {
      display: block;
    }
    .md\:hidden {
      display: none !important;
    }
  }
</style>
