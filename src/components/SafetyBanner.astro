---
/**
 * SafetyBanner.astro
 * Prominent safety warning displayed at the top of dossier pages
 */

interface Props {
  peptideName: string;
  evidenceStrength: 'high' | 'moderate' | 'low' | 'very-low';
  keyWarnings?: string[];
  fdaStatus?: string;
  wadaStatus?: string;
}

const {
  peptideName,
  evidenceStrength,
  keyWarnings = [],
  fdaStatus = 'Not FDA approved',
  wadaStatus
} = Astro.props;

const evidenceColors = {
  'high': { tint: 'rgba(20,118,74,0.10)', border: 'rgba(20,118,74,0.30)', accent: 'var(--research)', text: 'var(--research)', icon: '✓' },
  'moderate': { tint: 'var(--primary-soft)', border: 'rgba(11,81,127,0.30)', accent: 'var(--primary-c)', text: 'var(--primary-c)', icon: '~' },
  'low': { tint: 'rgba(203,135,52,0.10)', border: 'rgba(203,135,52,0.32)', accent: 'var(--compound)', text: '#9a6418', icon: '!' },
  'very-low': { tint: 'rgba(185,61,66,0.10)', border: 'rgba(185,61,66,0.28)', accent: 'var(--danger)', text: 'var(--danger)', icon: '!!' },
};

const config = evidenceColors[evidenceStrength];

const defaultWarnings = [
  'Not approved for human use by any regulatory agency',
  'Limited human clinical trial data',
  'Consult a healthcare provider before use',
];

const warnings = keyWarnings.length > 0 ? keyWarnings : defaultWarnings;
---

<div class={`safety-banner rounded-xl p-4 mb-8`} style={`background: ${config.tint}; border: 1px solid ${config.border}; border-left: 3px solid ${config.accent};`}>
  <div class="flex flex-col lg:flex-row lg:items-center gap-4">
    <!-- Evidence Level Indicator -->
    <div class="flex items-center gap-3 shrink-0">
      <div class="w-10 h-10 rounded-lg border-2 flex items-center justify-center font-bold text-lg" style={`border-color: ${config.border}; color: ${config.text};`}>
        {config.icon}
      </div>
      <div>
        <div class="eyebrow text-[10px]">Evidence Level</div>
        <div class="font-bold capitalize" style={`color: ${config.text};`}>{evidenceStrength.replace('-', ' ')}</div>
      </div>
    </div>

    <!-- Divider -->
    <div class="hidden lg:block w-px h-10" style="background: var(--border-c);"></div>

    <!-- Key Warnings -->
    <div class="flex-1 flex flex-wrap items-center gap-x-4 gap-y-2">
      {warnings.slice(0, 3).map((warning) => (
        <div class="flex items-center gap-2 text-sm" style="color: var(--ink-muted);">
          <svg class="w-4 h-4 shrink-0" style="color: #9a6418;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
          <span>{warning}</span>
        </div>
      ))}
    </div>

    <!-- Status Badges -->
    <div class="flex items-center gap-2 shrink-0">
      <span class="px-2.5 py-1 rounded-lg text-xs font-semibold" style="background: rgba(185,61,66,0.10); border: 1px solid rgba(185,61,66,0.28); color: var(--danger);">
        {fdaStatus}
      </span>
      {wadaStatus && (
        <span class="px-2.5 py-1 rounded-lg text-xs font-semibold" style="background: rgba(203,135,52,0.12); border: 1px solid rgba(203,135,52,0.32); color: #9a6418;">
          {wadaStatus}
        </span>
      )}
    </div>
  </div>
</div>
