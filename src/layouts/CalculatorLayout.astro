---
import BaseLayout from './BaseLayout.astro';
import ArticleSchema from '../components/SEO/ArticleSchema.astro';
import BreadcrumbSchema from '../components/SEO/BreadcrumbSchema.astro';
import NewsletterForm from '../components/NewsletterForm.astro';

interface Props {
  name: string;
  peptideSlug: string;
  calculatorType: string;
  inputs: string[];
  disclaimer: string;
  lastUpdated: Date;
  metaTitle?: string;
  metaDescription?: string;
}

const {
  name,
  peptideSlug,
  calculatorType,
  inputs,
  disclaimer,
  lastUpdated,
  metaTitle,
  metaDescription,
} = Astro.props;

const siteBase = Astro.site?.toString() || 'https://pepcodex.com';
const breadcrumbItems = [
  { name: 'Home', url: siteBase },
  { name: 'Calculators', url: `${siteBase}calculator/` },
  { name: `${name}`, url: Astro.url.toString() },
];

const articleUrl = Astro.url.toString();
---

<BaseLayout
  title={metaTitle || `${name} — PepCodex`}
  description={metaDescription || `Research calculator for ${name}. Educational tool only.`}
>
  <ArticleSchema
    title={metaTitle || `${name}`}
    description={metaDescription || `Research calculator for ${name}`}
    url={articleUrl}
    dateModified={lastUpdated}
  />
  <BreadcrumbSchema items={breadcrumbItems} />

  <article class="mx-auto max-w-4xl px-4 py-8 sm:px-6 lg:px-8">
    <!-- Header -->
    <header class="mb-8">
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-medium bg-blue-500/20 text-blue-400 border border-blue-500/30">
          {calculatorType.charAt(0).toUpperCase() + calculatorType.slice(1)} Calculator
        </span>
        <span class="text-xs" style="color: var(--text-low);">
          Updated {lastUpdated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4" style="font-family: var(--font-display);">
        {name}
      </h1>
    </header>

    <!-- Disclaimer Banner -->
    <div class="rounded-xl border border-amber-500/20 bg-amber-500/10 p-4 mb-8">
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-amber-400 flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>
        </svg>
        <p class="text-sm text-amber-200/90">{disclaimer}</p>
      </div>
    </div>

    <!-- Calculator Inputs -->
    <div class="rounded-xl border border-white/10 bg-white/5 p-6 mb-8">
      <h2 class="text-lg font-semibold text-white mb-4">Calculator Inputs</h2>
      <ul class="space-y-2">
        {inputs.map((input) => (
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9 12l2 2 4-4"/>
            </svg>
            <span class="text-sm" style="color: var(--text-medium);">{input}</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Content -->
    <div class="prose prose-invert max-w-none">
      <slot />
    </div>

    <!-- Back to peptide -->
    <div class="mt-12 pt-8 border-t border-white/10">
      <a
        href={`/peptides/${peptideSlug}`}
        class="inline-flex items-center gap-2 text-sm text-primary hover:text-primary/80 transition-colors"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        View {name.replace(' Reconstitution Calculator', '')} research dossier
      </a>
    </div>

    <!-- Newsletter -->
    <div class="mt-12">
      <NewsletterForm />
    </div>
  </article>
</BaseLayout>
