---
import BaseLayout from '../../layouts/BaseLayout.astro';

const calculators = [
  {
    title: 'Reconstitution Calculator',
    description: 'Calculate peptide concentrations and draw volumes. Visual syringe shows exact units to draw.',
    href: '/calculator/reconstitution',
    icon: 'beaker',
    color: 'primary',
  },
  {
    title: 'Blend Calculator',
    description: 'Calculate volumes for multi-peptide blends. Determine individual amounts and total volume.',
    href: '/calculator/blend',
    icon: 'flask',
    color: 'cyan',
  },
  {
    title: 'Accumulation Calculator',
    description: 'Track compound buildup based on half-life. Calculate steady-state and accumulation ratios.',
    href: '/calculator/accumulation',
    icon: 'chart',
    color: 'purple',
  },
];
---

<BaseLayout title="Peptide Calculators" description="Research calculators for peptide reconstitution, blending, and pharmacokinetic accumulation calculations.">
  <!-- Header -->
  <section class="py-12 text-center">
    <div class="badge badge--primary mb-6">
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <rect x="4" y="4" width="16" height="16" rx="2"/>
        <path d="M8 8h2v2H8z"/>
        <path d="M14 8h2"/>
        <path d="M8 14h2"/>
        <path d="M14 14h2"/>
      </svg>
      <span>Research Tools</span>
    </div>

    <h1 class="text-4xl md:text-5xl font-bold mb-6 font-display text-glow" style="color: var(--text-high);">
      Peptide Calculators
    </h1>

    <p class="text-xl max-w-2xl mx-auto leading-relaxed" style="color: var(--text-medium);">
      Research-grade calculators for peptide science. Reconstitution, blending, and pharmacokinetic calculations.
    </p>
  </section>

  <!-- Calculator Grid -->
  <section class="py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {calculators.map((calc) => (
        <a href={calc.href} class="glass-card glass-card--hover p-8 group block">
          <div class={`w-14 h-14 rounded-2xl flex items-center justify-center mb-6 transition-colors ${
            calc.color === 'primary' ? 'bg-primary/20 group-hover:bg-primary/30' :
            calc.color === 'cyan' ? 'bg-cyan-400/20 group-hover:bg-cyan-400/30' :
            'bg-purple-400/20 group-hover:bg-purple-400/30'
          }`}>
            {calc.icon === 'beaker' && (
              <svg class={`w-7 h-7 ${calc.color === 'primary' ? 'text-primary' : calc.color === 'cyan' ? 'text-cyan-400' : 'text-purple-400'}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4.5 3h15"/>
                <path d="M6 3v16a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V3"/>
                <path d="M6 14h12"/>
              </svg>
            )}
            {calc.icon === 'flask' && (
              <svg class={`w-7 h-7 ${calc.color === 'primary' ? 'text-primary' : calc.color === 'cyan' ? 'text-cyan-400' : 'text-purple-400'}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"/>
                <path d="M8.5 2h7"/>
                <path d="M7 16h10"/>
              </svg>
            )}
            {calc.icon === 'chart' && (
              <svg class={`w-7 h-7 ${calc.color === 'primary' ? 'text-primary' : calc.color === 'cyan' ? 'text-cyan-400' : 'text-purple-400'}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 3v18h18"/>
                <path d="M18 17V9"/>
                <path d="M13 17V5"/>
                <path d="M8 17v-3"/>
              </svg>
            )}
          </div>

          <h2 class="text-xl font-bold mb-3 font-display group-hover:text-primary transition-colors" style="color: var(--text-high);">
            {calc.title}
          </h2>

          <p class="text-sm leading-relaxed mb-4" style="color: var(--text-medium);">
            {calc.description}
          </p>

          <div class="flex items-center gap-2 text-sm font-medium text-primary">
            <span>Open Calculator</span>
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14"/>
              <path d="m12 5 7 7-7 7"/>
            </svg>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Research Disclaimer -->
  <section class="py-12">
    <div class="glass-card p-6" style="border-color: hsla(45, 90%, 55%, 0.3);">
      <div class="flex items-start gap-4">
        <div class="w-12 h-12 rounded-full flex items-center justify-center flex-shrink-0 bg-yellow-500/20 border border-yellow-500/30">
          <svg class="w-5 h-5 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
          </svg>
        </div>
        <div>
          <h3 class="text-sm font-bold text-yellow-400 uppercase tracking-wider mb-2">For Research Purposes Only</h3>
          <p class="text-sm leading-relaxed" style="color: var(--text-medium);">
            These calculators are provided for educational and research purposes only. They are not intended for medical use and should not be used for self-medication. Always consult qualified healthcare professionals for any medical decisions. The calculations assume ideal conditions and may not account for all real-world variables.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
