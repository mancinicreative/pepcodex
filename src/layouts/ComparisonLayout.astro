---
import BaseLayout from './BaseLayout.astro';
import EvidenceBadge from '../components/EvidenceBadge.astro';

interface Props {
  title: string;
  peptideA: {
    name: string;
    slug: string;
    evidenceStrength: 'high' | 'moderate' | 'low' | 'very-low';
  };
  peptideB: {
    name: string;
    slug: string;
    evidenceStrength: 'high' | 'moderate' | 'low' | 'very-low';
  };
  category: string;
  lastUpdated: Date;
  summary: string;
}

const { title, peptideA, peptideB, category, lastUpdated, summary } = Astro.props;

const categoryLabels: Record<string, string> = {
  'metabolic': 'Metabolic',
  'repair-recovery': 'Repair & Recovery',
  'hormonal': 'Hormonal',
  'longevity': 'Longevity',
  'other': 'Other',
};

const categoryColors: Record<string, string> = {
  'metabolic': 'bg-blue-100 text-blue-800',
  'repair-recovery': 'bg-green-100 text-green-800',
  'hormonal': 'bg-purple-100 text-purple-800',
  'longevity': 'bg-amber-100 text-amber-800',
  'other': 'bg-slate-100 text-slate-800',
};
---

<BaseLayout title={title} description={summary}>
  <article class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <!-- Header -->
    <header class="mb-8">
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <a
          href={`/category/${category}`}
          class={`inline-flex items-center rounded-full px-3 py-1 text-xs font-medium ${categoryColors[category] || categoryColors['other']}`}
        >
          {categoryLabels[category] || 'Other'}
        </a>
        <span class="inline-flex items-center rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-800">
          Comparison
        </span>
      </div>

      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl lg:text-5xl">
        {title}
      </h1>

      <p class="mt-4 text-xl text-slate-700 leading-relaxed max-w-3xl">
        {summary}
      </p>

      <p class="mt-4 text-sm text-slate-500">
        Last updated: {lastUpdated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </p>
    </header>

    <!-- Peptide comparison header cards -->
    <div class="grid gap-6 md:grid-cols-2 mb-8">
      <!-- Peptide A -->
      <div class="rounded-lg border border-slate-200 bg-white p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-2xl font-bold text-slate-900">{peptideA.name}</h2>
          <EvidenceBadge strength={peptideA.evidenceStrength} />
        </div>
        <a
          href={`/peptides/${peptideA.slug}`}
          class="inline-flex items-center text-blue-600 hover:text-blue-800 hover:underline text-sm font-medium"
        >
          View full dossier
          <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>

      <!-- Peptide B -->
      <div class="rounded-lg border border-slate-200 bg-white p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-2xl font-bold text-slate-900">{peptideB.name}</h2>
          <EvidenceBadge strength={peptideB.evidenceStrength} />
        </div>
        <a
          href={`/peptides/${peptideB.slug}`}
          class="inline-flex items-center text-blue-600 hover:text-blue-800 hover:underline text-sm font-medium"
        >
          View full dossier
          <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </div>

    <!-- Main comparison content -->
    <div class="prose prose-slate prose-lg max-w-none">
      <slot />
    </div>

    <!-- Footer links -->
    <div class="mt-12 pt-8 border-t border-slate-200">
      <h3 class="font-semibold text-slate-900 mb-4">View Full Dossiers</h3>
      <div class="flex flex-wrap gap-4">
        <a
          href={`/peptides/${peptideA.slug}`}
          class="inline-flex items-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 transition-colors"
        >
          {peptideA.name} Evidence Dossier
          <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
        <a
          href={`/peptides/${peptideB.slug}`}
          class="inline-flex items-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 transition-colors"
        >
          {peptideB.name} Evidence Dossier
          <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </div>

    <!-- Disclaimer -->
    <div class="mt-8 rounded-lg border border-amber-200 bg-amber-50 p-6">
      <p class="text-amber-800 text-sm">
        <strong>Disclaimer:</strong> This comparison is for educational purposes only and does not constitute medical advice. Individual responses to medications vary. Always consult a qualified healthcare provider before making treatment decisions.
      </p>
    </div>
  </article>
</BaseLayout>
