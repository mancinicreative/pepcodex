---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Blend Calculator" description="Calculate volumes for multi-peptide blends and determine individual draw amounts.">
  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-sm mb-8" style="color: var(--text-medium);">
    <a href="/calculator" class="hover:text-primary transition-colors">Calculators</a>
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="m9 18 6-6-6-6"/>
    </svg>
    <span style="color: var(--text-high);">Blend Calculator</span>
  </nav>

  <!-- Header -->
  <section class="mb-12">
    <div class="flex items-center gap-4 mb-6">
      <div class="w-14 h-14 rounded-2xl bg-cyan-400/20 flex items-center justify-center">
        <svg class="w-7 h-7 text-cyan-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"/>
          <path d="M8.5 2h7"/>
          <path d="M7 16h10"/>
        </svg>
      </div>
      <div>
        <h1 class="text-3xl font-bold font-display" style="color: var(--text-high);">Blend Calculator</h1>
        <p class="text-sm" style="color: var(--text-medium);">Calculate multi-peptide combination volumes</p>
      </div>
    </div>

    <p class="text-sm leading-relaxed max-w-2xl" style="color: var(--text-medium);">
      Add multiple peptides to calculate the total blend volume and individual draw amounts.
      Each peptide is calculated independently, allowing precise multi-compound formulations.
    </p>
  </section>

  <!-- Calculator -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-12">
    <!-- Peptide List Panel -->
    <div class="lg:col-span-2 glass-card p-8">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-lg font-bold font-display" style="color: var(--text-high);">Peptides in Blend</h2>
        <button
          type="button"
          id="addPeptideBtn"
          class="btn btn-sm btn-secondary"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 5v14"/>
            <path d="M5 12h14"/>
          </svg>
          Add Peptide
        </button>
      </div>

      <!-- Peptide Entries Container -->
      <div id="peptideEntries" class="space-y-4">
        <!-- Peptide entries will be added here by JS -->
      </div>

      <!-- Empty State -->
      <div id="emptyState" class="text-center py-12 hidden">
        <div class="w-16 h-16 mx-auto rounded-full bg-white/5 flex items-center justify-center mb-4">
          <svg class="w-8 h-8 text-white/30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"/>
          </svg>
        </div>
        <p class="text-sm" style="color: var(--text-medium);">No peptides added yet.</p>
        <p class="text-xs mt-1" style="color: var(--text-low);">Click "Add Peptide" to get started.</p>
      </div>

      <!-- Common Blend Presets -->
      <div class="mt-8 pt-6 border-t border-white/10">
        <h3 class="text-sm font-medium mb-3" style="color: var(--text-high);">Common Blend Presets</h3>
        <div class="flex flex-wrap gap-2">
          <button type="button" data-blend="healing" class="blend-preset-btn px-3 py-1.5 rounded-lg text-xs font-medium text-white/70 bg-white/5 border border-white/10 hover:bg-white/10 hover:border-white/20 hover:text-white transition-all">
            Healing Stack (BPC + TB)
          </button>
          <button type="button" data-blend="gh" class="blend-preset-btn px-3 py-1.5 rounded-lg text-xs font-medium text-white/70 bg-white/5 border border-white/10 hover:bg-white/10 hover:border-white/20 hover:text-white transition-all">
            GH Secretagogue
          </button>
          <button type="button" data-blend="skincare" class="blend-preset-btn px-3 py-1.5 rounded-lg text-xs font-medium text-white/70 bg-white/5 border border-white/10 hover:bg-white/10 hover:border-white/20 hover:text-white transition-all">
            Skincare Blend
          </button>
        </div>
      </div>
    </div>

    <!-- Results Panel -->
    <div class="glass-card p-8">
      <h2 class="text-lg font-bold mb-6 font-display" style="color: var(--text-high);">Blend Summary</h2>

      <!-- Summary Stats -->
      <div class="space-y-4 mb-8">
        <div class="p-4 rounded-xl bg-white/5 border border-white/10">
          <p class="text-xs uppercase tracking-wider mb-1" style="color: var(--text-low);">Total Peptides</p>
          <p class="text-2xl font-bold text-cyan-400" id="totalPeptides">0</p>
        </div>

        <div class="p-4 rounded-xl bg-white/5 border border-white/10">
          <p class="text-xs uppercase tracking-wider mb-1" style="color: var(--text-low);">Total BAC Water</p>
          <p class="text-2xl font-bold text-primary" id="totalWater">0.00</p>
          <p class="text-xs" style="color: var(--text-medium);">mL recommended</p>
        </div>

        <div class="p-4 rounded-xl bg-white/5 border border-white/10">
          <p class="text-xs uppercase tracking-wider mb-1" style="color: var(--text-low);">Total Draw Volume</p>
          <p class="text-2xl font-bold text-purple-400" id="totalDraw">0.00</p>
          <p class="text-xs" style="color: var(--text-medium);">mL per administration</p>
        </div>

        <div class="p-4 rounded-xl bg-white/5 border border-white/10">
          <p class="text-xs uppercase tracking-wider mb-1" style="color: var(--text-low);">Total Units</p>
          <p class="text-2xl font-bold text-green-400" id="totalUnits">0</p>
          <p class="text-xs" style="color: var(--text-medium);">insulin syringe units</p>
        </div>
      </div>

      <!-- Individual Breakdown -->
      <div id="breakdownSection" class="hidden">
        <h3 class="text-sm font-medium mb-3" style="color: var(--text-high);">Per-Peptide Breakdown</h3>
        <div id="peptideBreakdown" class="space-y-2 text-sm">
          <!-- Populated by JS -->
        </div>
      </div>
    </div>
  </div>

  <!-- Instructions -->
  <section class="mb-12">
    <div class="glass-card p-6">
      <h3 class="text-sm font-bold uppercase tracking-wider mb-4" style="color: var(--text-high);">How Blending Works</h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-sm" style="color: var(--text-medium);">
        <div class="flex gap-3">
          <div class="w-8 h-8 rounded-full bg-cyan-400/20 flex items-center justify-center flex-shrink-0">
            <span class="text-cyan-400 font-bold">1</span>
          </div>
          <div>
            <p class="font-medium mb-1" style="color: var(--text-high);">Add to Shared Vial</p>
            <p class="text-xs">Combine lyophilized peptides in one vial before reconstitution</p>
          </div>
        </div>
        <div class="flex gap-3">
          <div class="w-8 h-8 rounded-full bg-cyan-400/20 flex items-center justify-center flex-shrink-0">
            <span class="text-cyan-400 font-bold">2</span>
          </div>
          <div>
            <p class="font-medium mb-1" style="color: var(--text-high);">Calculate Total Water</p>
            <p class="text-xs">Sum recommended water volumes for each peptide</p>
          </div>
        </div>
        <div class="flex gap-3">
          <div class="w-8 h-8 rounded-full bg-cyan-400/20 flex items-center justify-center flex-shrink-0">
            <span class="text-cyan-400 font-bold">3</span>
          </div>
          <div>
            <p class="font-medium mb-1" style="color: var(--text-high);">Single Injection</p>
            <p class="text-xs">Draw calculated volume for all peptides in one dose</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Research Disclaimer -->
  <section class="py-8">
    <div class="glass-card p-6" style="border-color: hsla(45, 90%, 55%, 0.3);">
      <div class="flex items-start gap-4">
        <div class="w-12 h-12 rounded-full flex items-center justify-center flex-shrink-0 bg-yellow-500/20 border border-yellow-500/30">
          <svg class="w-5 h-5 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
          </svg>
        </div>
        <div>
          <h3 class="text-sm font-bold text-yellow-400 uppercase tracking-wider mb-2">For Research Purposes Only</h3>
          <p class="text-sm leading-relaxed" style="color: var(--text-medium);">
            This calculator is provided for educational and research purposes only. Peptide compatibility in blends varies and should be verified. Some peptides may degrade when mixed. Always consult qualified professionals and relevant literature before combining compounds.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  interface PeptideEntry {
    id: string;
    name: string;
    amount: number; // mg
    waterVolume: number; // mL
    dose: number; // mcg
  }

  let peptides: PeptideEntry[] = [];
  let nextId = 1;

  const entriesContainer = document.getElementById('peptideEntries')!;
  const emptyState = document.getElementById('emptyState')!;
  const addBtn = document.getElementById('addPeptideBtn')!;

  // Result elements
  const totalPeptidesEl = document.getElementById('totalPeptides')!;
  const totalWaterEl = document.getElementById('totalWater')!;
  const totalDrawEl = document.getElementById('totalDraw')!;
  const totalUnitsEl = document.getElementById('totalUnits')!;
  const breakdownSection = document.getElementById('breakdownSection')!;
  const peptideBreakdown = document.getElementById('peptideBreakdown')!;

  // Preset blends
  const blendPresets: Record<string, PeptideEntry[]> = {
    healing: [
      { id: '', name: 'BPC-157', amount: 5, waterVolume: 2, dose: 250 },
      { id: '', name: 'TB-500', amount: 5, waterVolume: 2, dose: 2500 },
    ],
    gh: [
      { id: '', name: 'Ipamorelin', amount: 5, waterVolume: 2.5, dose: 200 },
      { id: '', name: 'CJC-1295', amount: 2, waterVolume: 2, dose: 100 },
    ],
    skincare: [
      { id: '', name: 'GHK-Cu', amount: 50, waterVolume: 5, dose: 200 },
      { id: '', name: 'Epithalon', amount: 10, waterVolume: 2, dose: 500 },
    ],
  };

  function generateId(): string {
    return `peptide-${nextId++}`;
  }

  function createPeptideEntry(entry: PeptideEntry): HTMLElement {
    const div = document.createElement('div');
    div.className = 'peptide-entry p-4 rounded-xl bg-white/5 border border-white/10';
    div.dataset.id = entry.id;

    div.innerHTML = `
      <div class="flex items-start justify-between gap-4 mb-4">
        <input
          type="text"
          value="${entry.name}"
          placeholder="Peptide name"
          class="peptide-name flex-1 px-3 py-2 rounded-lg bg-white/5 border border-white/10 text-white placeholder-white/30 focus:outline-none focus:border-cyan-400/50 focus:ring-2 focus:ring-cyan-400/20 transition-all text-sm font-medium"
        />
        <button type="button" class="remove-btn p-2 rounded-lg bg-red-500/10 border border-red-500/20 text-red-400 hover:bg-red-500/20 transition-all">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 6 6 18"/>
            <path d="m6 6 12 12"/>
          </svg>
        </button>
      </div>
      <div class="grid grid-cols-3 gap-3">
        <div>
          <label class="block text-xs mb-1" style="color: var(--text-low);">Amount (mg)</label>
          <input
            type="number"
            value="${entry.amount}"
            min="0.1"
            step="0.1"
            class="peptide-amount w-full px-3 py-2 rounded-lg bg-white/5 border border-white/10 text-white text-sm focus:outline-none focus:border-cyan-400/50 focus:ring-2 focus:ring-cyan-400/20 transition-all"
          />
        </div>
        <div>
          <label class="block text-xs mb-1" style="color: var(--text-low);">Water (mL)</label>
          <input
            type="number"
            value="${entry.waterVolume}"
            min="0.1"
            step="0.1"
            class="peptide-water w-full px-3 py-2 rounded-lg bg-white/5 border border-white/10 text-white text-sm focus:outline-none focus:border-cyan-400/50 focus:ring-2 focus:ring-cyan-400/20 transition-all"
          />
        </div>
        <div>
          <label class="block text-xs mb-1" style="color: var(--text-low);">Dose (mcg)</label>
          <input
            type="number"
            value="${entry.dose}"
            min="1"
            step="1"
            class="peptide-dose w-full px-3 py-2 rounded-lg bg-white/5 border border-white/10 text-white text-sm focus:outline-none focus:border-cyan-400/50 focus:ring-2 focus:ring-cyan-400/20 transition-all"
          />
        </div>
      </div>
    `;

    // Event listeners
    div.querySelector('.remove-btn')!.addEventListener('click', () => {
      removePeptide(entry.id);
    });

    div.querySelector('.peptide-name')!.addEventListener('input', (e) => {
      const target = e.target as HTMLInputElement;
      updatePeptide(entry.id, 'name', target.value);
    });

    div.querySelector('.peptide-amount')!.addEventListener('input', (e) => {
      const target = e.target as HTMLInputElement;
      updatePeptide(entry.id, 'amount', parseFloat(target.value) || 0);
    });

    div.querySelector('.peptide-water')!.addEventListener('input', (e) => {
      const target = e.target as HTMLInputElement;
      updatePeptide(entry.id, 'waterVolume', parseFloat(target.value) || 0);
    });

    div.querySelector('.peptide-dose')!.addEventListener('input', (e) => {
      const target = e.target as HTMLInputElement;
      updatePeptide(entry.id, 'dose', parseFloat(target.value) || 0);
    });

    return div;
  }

  function addPeptide(preset?: Partial<PeptideEntry>) {
    const entry: PeptideEntry = {
      id: generateId(),
      name: preset?.name || '',
      amount: preset?.amount || 5,
      waterVolume: preset?.waterVolume || 2,
      dose: preset?.dose || 250,
    };

    peptides.push(entry);
    entriesContainer.appendChild(createPeptideEntry(entry));
    updateUI();
  }

  function removePeptide(id: string) {
    peptides = peptides.filter(p => p.id !== id);
    const el = entriesContainer.querySelector(`[data-id="${id}"]`);
    if (el) el.remove();
    updateUI();
  }

  function updatePeptide(id: string, field: keyof PeptideEntry, value: string | number) {
    const peptide = peptides.find(p => p.id === id);
    if (peptide) {
      (peptide as any)[field] = value;
      calculateResults();
    }
  }

  function updateUI() {
    emptyState.classList.toggle('hidden', peptides.length > 0);
    calculateResults();
  }

  function calculateResults() {
    if (peptides.length === 0) {
      totalPeptidesEl.textContent = '0';
      totalWaterEl.textContent = '0.00';
      totalDrawEl.textContent = '0.00';
      totalUnitsEl.textContent = '0';
      breakdownSection.classList.add('hidden');
      return;
    }

    let totalWater = 0;
    let totalDraw = 0;
    const breakdowns: { name: string; draw: number; units: number }[] = [];

    peptides.forEach(p => {
      totalWater += p.waterVolume;

      // Calculate individual draw volume
      const concentration = p.amount / p.waterVolume; // mg/mL
      const drawMl = p.dose / (concentration * 1000); // mL

      totalDraw += drawMl;
      breakdowns.push({
        name: p.name || 'Unnamed',
        draw: drawMl,
        units: drawMl * 100,
      });
    });

    totalPeptidesEl.textContent = peptides.length.toString();
    totalWaterEl.textContent = totalWater.toFixed(2);
    totalDrawEl.textContent = totalDraw.toFixed(4);
    totalUnitsEl.textContent = (totalDraw * 100).toFixed(1);

    // Update breakdown
    breakdownSection.classList.remove('hidden');
    peptideBreakdown.innerHTML = breakdowns.map(b => `
      <div class="flex justify-between items-center p-2 rounded-lg bg-white/5">
        <span style="color: var(--text-medium);">${b.name}</span>
        <span class="font-mono text-cyan-400">${b.draw.toFixed(4)} mL (${b.units.toFixed(1)}u)</span>
      </div>
    `).join('');
  }

  // Add peptide button
  addBtn.addEventListener('click', () => addPeptide());

  // Blend preset buttons
  document.querySelectorAll('.blend-preset-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const blendKey = target.dataset.blend;

      if (blendKey && blendPresets[blendKey]) {
        // Clear existing
        peptides = [];
        entriesContainer.innerHTML = '';

        // Add preset peptides
        blendPresets[blendKey].forEach(preset => addPeptide(preset));
      }
    });
  });

  // Initialize with one empty entry
  addPeptide();
</script>
