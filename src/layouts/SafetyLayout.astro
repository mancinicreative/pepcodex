---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import BreadcrumbSchema from '../components/SEO/BreadcrumbSchema.astro';
import NewsletterForm from '../components/NewsletterForm.astro';

interface Source {
  id: string;
  title: string;
  url?: string;
  type?: 'journal' | 'trial' | 'regulatory' | 'preprint' | 'news';
}

interface Props {
  title: string;
  peptides: string[];
  lastUpdated: Date;
  summary: string;
  sources?: Source[];
}

const { title, peptides, lastUpdated, summary, sources = [] } = Astro.props;

const sourceTypeIcons: Record<string, string> = {
  'journal': 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253',
  'trial': 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  'regulatory': 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  'preprint': 'M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z',
  'news': 'M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z',
};

function getSourceUrl(source: Source): string {
  if (source.url) return source.url;
  const searchTerms = source.title.replace(/[^\w\s]/g, '').split(' ').slice(0, 6).join('+');
  return `https://pubmed.ncbi.nlm.nih.gov/?term=${encodeURIComponent(searchTerms)}`;
}

const siteBase = Astro.site?.toString() || 'https://pepcodex.com';
const breadcrumbItems = [
  { name: 'Home', url: siteBase },
  { name: 'Safety Profiles', url: `${siteBase}safety/` },
  { name: title, url: Astro.url.toString() },
];
---

<BaseLayout title={title} description={summary}>
  <BreadcrumbSchema items={breadcrumbItems} />
  <article class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <!-- Header -->
    <header class="mb-8 relative">
      <div class="absolute inset-0 bg-gradient-to-br from-amber-500/10 via-transparent to-transparent rounded-2xl -z-10"></div>
      <div class="p-6">
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span class="inline-flex items-center rounded-full bg-amber-500/20 px-3 py-1 text-xs font-medium text-amber-400 border border-amber-500/30">
            <svg class="w-3.5 h-3.5 mr-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
            </svg>
            Safety Information
          </span>
        </div>

        <h1 class="text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">
          {title}
        </h1>

        <p class="mt-4 text-xl text-white/80 leading-relaxed max-w-3xl">
          {summary}
        </p>

        <p class="mt-4 text-sm text-white/70">
          Last updated: {lastUpdated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </p>
      </div>
    </header>

    <!-- Important safety notice -->
    <div class="mb-8 rounded-xl border-2 border-amber-500/40 bg-amber-500/10 p-6 backdrop-blur-sm">
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0">
          <svg class="w-8 h-8 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
          </svg>
        </div>
        <div>
          <h2 class="text-lg font-semibold text-amber-400 mb-2">For Educational Purposes Only</h2>
          <p class="text-amber-200/80">
            This safety information is compiled from clinical trial data and regulatory documents for educational purposes. It is <strong class="text-amber-300">not</strong> a substitute for professional medical advice. Always consult your healthcare provider about medication safety, especially regarding your individual circumstances, medical history, and other medications.
          </p>
        </div>
      </div>
    </div>

    <div class="grid gap-8 lg:grid-cols-[1fr,280px]">
      <!-- Main content -->
      <div class="prose prose-invert prose-lg max-w-none">
        <slot />

        <!-- Sources Section -->
        {sources.length > 0 && (
          <section class="mt-12 not-prose">
            <h2 class="text-xl font-bold text-white mb-4 flex items-center gap-2" style="font-family: var(--font-display);">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
              </svg>
              Sources & Citations
            </h2>
            <div class="rounded-xl border border-white/10 bg-white/5 overflow-hidden">
              <ul class="divide-y divide-white/5">
                {sources.map((source, index) => (
                  <li class="p-4 hover:bg-white/5 transition-colors">
                    <div class="flex items-start gap-3">
                      <span class="flex-shrink-0 w-6 h-6 rounded-full bg-[var(--primary)]/20 text-primary text-xs flex items-center justify-center font-medium">
                        {index + 1}
                      </span>
                      <div class="flex-grow min-w-0">
                        <div class="flex items-center gap-2 mb-1">
                          {source.type && (
                            <svg class="w-4 h-4 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={sourceTypeIcons[source.type] || sourceTypeIcons['journal']}></path>
                            </svg>
                          )}
                          <span class="text-xs text-white/40 uppercase tracking-wide">{source.type || 'source'}</span>
                        </div>
                        <a
                          href={getSourceUrl(source)}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-primary hover:text-[var(--accent)] hover:underline transition-colors inline-flex items-center gap-1"
                        >
                          {source.title}
                          <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                          </svg>
                        </a>
                        <p class="text-xs text-white/40 mt-1">{source.id}</p>
                      </div>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          </section>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="hidden lg:block">
        <div class="sticky top-24 space-y-6">
          <TableOfContents />

          {peptides.length > 0 && (
            <div class="rounded-xl border border-white/10 bg-gradient-to-b from-[var(--primary)]/10 to-transparent p-4 backdrop-blur-sm">
              <h3 class="font-semibold text-white mb-3">Related Peptides</h3>
              <ul class="space-y-2">
                {peptides.map(peptide => (
                  <li>
                    <a
                      href={`/peptides/${peptide}`}
                      class="text-sm text-primary hover:text-[var(--accent)] hover:underline transition-colors"
                    >
                      {peptide.charAt(0).toUpperCase() + peptide.slice(1)} Dossier
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <div class="rounded-xl border border-white/10 bg-white/5 p-4 backdrop-blur-sm">
            <h3 class="font-semibold text-white mb-3">Quick Links</h3>
            <ul class="space-y-2">
              <li>
                <a
                  href="/methodology"
                  class="text-sm text-primary hover:text-[var(--accent)] hover:underline transition-colors"
                >
                  Our Methodology
                </a>
              </li>
              <li>
                <a
                  href="/editorial-policy"
                  class="text-sm text-primary hover:text-[var(--accent)] hover:underline transition-colors"
                >
                  Editorial Policy
                </a>
              </li>
            </ul>
          </div>

          <div class="rounded-xl border border-red-500/30 bg-red-500/10 p-4 backdrop-blur-sm">
            <h3 class="font-semibold text-red-400 mb-2">Report Issues</h3>
            <p class="text-sm text-red-200/80">
              If you experience adverse effects from any medication, report them to the FDA MedWatch program or contact your healthcare provider immediately.
            </p>
          </div>
        </div>
      </aside>
    </div>

    <!-- Newsletter CTA -->
    <div class="mt-12">
      <NewsletterForm
        variant="card"
        heading="Safety Alerts"
        description="Get notified about new safety data, FDA decisions, and adverse event reports."
      />
    </div>

    <!-- Footer disclaimer -->
    <div class="mt-12 rounded-xl border-2 border-amber-500/40 bg-amber-500/10 p-6 backdrop-blur-sm">
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0">
          <svg class="w-6 h-6 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
          </svg>
        </div>
        <div>
          <p class="text-amber-200/80 text-sm">
            <strong class="text-amber-400">Important:</strong> Safety information evolves as post-marketing data accumulates. This page reflects data available as of the last update date. Check official FDA and EMA resources for the most current safety information. This content is not intended to diagnose, treat, cure, or prevent any disease.
          </p>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
