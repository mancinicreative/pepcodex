---
import AnnotatedVial from './AnnotatedVial.astro';

interface AminoAcid {
  code: string;
  name: string;
  position: number;
  property: 'hydrophobic' | 'polar' | 'positive' | 'negative' | 'modified';
}

interface MolecularInfo {
  weight: string;
  chainLength: number;
  type: string;
  sequence: string;
  aminoAcids: AminoAcid[];
}

interface Props {
  peptideName: string;
  summary: string;
  aliases?: string[];
  category: string;
  molecularInfo?: MolecularInfo;
  evidenceStrength?: 'high' | 'moderate' | 'low' | 'very-low';
}

const { peptideName, summary, aliases = [], category, molecularInfo, evidenceStrength = 'low' } = Astro.props;

// Property colors for amino acids (biochemical property categorization)
const propertyColors = {
  hydrophobic: { bg: 'bg-[rgba(203,135,52,0.12)]', border: 'border-[rgba(203,135,52,0.32)]', text: 'text-[#9a6418]' },
  polar: { bg: 'bg-[color:var(--primary-soft)]', border: 'border-[color:var(--primary-c)]/30', text: 'text-primary' },
  positive: { bg: 'bg-[rgba(20,118,74,0.10)]', border: 'border-[rgba(20,118,74,0.30)]', text: 'text-[color:var(--research)]' },
  negative: { bg: 'bg-[rgba(185,61,66,0.10)]', border: 'border-[rgba(185,61,66,0.28)]', text: 'text-[color:var(--danger)]' },
  modified: { bg: 'bg-[color:var(--paper-2)]', border: 'border-[color:var(--border-strong)]', text: 'text-[color:var(--ink-muted)]' },
};
---

<section id="overview" class="not-prose">
  <div class="mb-8">
    <p class="eyebrow" style="color: var(--ink-dim);">Identification</p>
    <h2 class="text-3xl tracking-tight mt-1 text-[color:var(--ink)]" style="font-family: var(--font-serif); font-weight: 500;">
      Overview
    </h2>
    <p class="mt-1 text-[color:var(--ink-muted)]">What is {peptideName} and what does the research say?</p>
  </div>

  <div class="rounded-xl border border-[color:var(--border-c)] bg-[color:var(--paper)] overflow-hidden">
    <!-- Identity Section (Top) -->
    <div class="p-6 border-b border-[color:var(--border-c)]">
      <div class="flex items-center gap-2 mb-4">
        <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2" />
        </svg>
        <span class="eyebrow">Identity</span>
      </div>

      <div class={molecularInfo ? 'grid md:grid-cols-[210px_1fr] gap-6 items-start' : ''}>
        {molecularInfo && (
          <div class="flex justify-center md:justify-start md:border-r md:border-[color:var(--border-c)] md:pr-6">
            <AnnotatedVial strength={evidenceStrength} chainLength={molecularInfo.chainLength} weight={molecularInfo.weight} />
          </div>
        )}
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          {aliases.length > 0 && (
            <div class="col-span-2 md:col-span-3">
              <div class="eyebrow mb-1">Also Known As</div>
              <div class="text-[color:var(--ink-muted)] text-sm">{aliases.join(' • ')}</div>
            </div>
          )}
          {molecularInfo && (
            <>
              <div>
                <div class="eyebrow mb-1">Class</div>
                <div class="text-[color:var(--ink)] font-medium">{molecularInfo.type}</div>
              </div>
              <div>
                <div class="eyebrow mb-1">Length</div>
                <div class="text-[color:var(--ink)] font-medium">{molecularInfo.chainLength} amino acids</div>
              </div>
              <div>
                <div class="eyebrow mb-1">Mol. weight</div>
                <div class="text-[color:var(--ink)] font-medium">{molecularInfo.weight}</div>
              </div>
              <div class="col-span-2 md:col-span-3">
                <div class="eyebrow mb-1">Sequence</div>
                <div class="text-[color:var(--ink-muted)] font-mono text-sm break-all">{molecularInfo.sequence}</div>
              </div>
            </>
          )}
        </div>
      </div>
    </div>

    <!-- Molecular Structure Section (Bottom) -->
    {molecularInfo && (
      <div class="p-6">
        <div class="flex items-center gap-2 mb-4">
          <svg class="w-4 h-4 text-[color:var(--ink-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
          </svg>
          <span class="eyebrow">Molecular Structure</span>
        </div>

        <!-- Sequence Visualization -->
        <div class="bg-[color:var(--paper-2)] rounded-xl p-4 border border-[color:var(--border-c)] mb-4">
          <div class="flex flex-wrap gap-2">
            {molecularInfo.aminoAcids.map((aa) => {
              const colors = propertyColors[aa.property];
              return (
                <div
                  class={`min-w-9 h-9 px-2 rounded-lg ${colors.bg} border ${colors.border} flex items-center justify-center cursor-pointer transition-all hover:scale-110`}
                  title={`${aa.name} (${aa.code}) - Position ${aa.position} - ${aa.property}`}
                >
                  <span class={`text-sm font-bold ${colors.text} whitespace-nowrap`}>{aa.code}</span>
                </div>
              );
            })}
          </div>
        </div>

        <!-- Property Legend -->
        <div class="flex flex-wrap gap-x-4 gap-y-2 text-xs">
          <div class="flex items-center gap-1.5">
            <div class="w-3 h-3 rounded bg-[rgba(203,135,52,0.12)] border border-[rgba(203,135,52,0.32)]"></div>
            <span class="text-[color:var(--ink-dim)]">Hydrophobic</span>
          </div>
          <div class="flex items-center gap-1.5">
            <div class="w-3 h-3 rounded bg-[color:var(--primary-soft)] border border-[color:var(--primary-c)]/30"></div>
            <span class="text-[color:var(--ink-dim)]">Polar</span>
          </div>
          <div class="flex items-center gap-1.5">
            <div class="w-3 h-3 rounded bg-[rgba(20,118,74,0.10)] border border-[rgba(20,118,74,0.30)]"></div>
            <span class="text-[color:var(--ink-dim)]">Positive</span>
          </div>
          <div class="flex items-center gap-1.5">
            <div class="w-3 h-3 rounded bg-[rgba(185,61,66,0.10)] border border-[rgba(185,61,66,0.28)]"></div>
            <span class="text-[color:var(--ink-dim)]">Negative</span>
          </div>
        </div>
      </div>
    )}
  </div>
</section>
