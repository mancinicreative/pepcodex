{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/peptide/:slug",
      "destination": "/peptides/:slug",
      "permanent": true
    },
    {
      "source": "/peptide",
      "destination": "/peptides",
      "permanent": true
    },
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap-index.xml",
      "permanent": false
    },
    {
      "source": "/guides",
      "destination": "/guide",
      "permanent": true
    },
    {
      "source": "/guides/:slug",
      "destination": "/guide/:slug",
      "permanent": true
    },
    {
      "source": "/comparisons",
      "destination": "/compare",
      "permanent": true
    },
    {
      "source": "/comparisons/:slug",
      "destination": "/compare/:slug",
      "permanent": true
    },
    {
      "source": "/categories/:slug",
      "destination": "/category/:slug",
      "permanent": true
    },
    {
      "source": "/semaglutide",
      "destination": "/peptides/semaglutide",
      "permanent": true
    },
    {
      "source": "/tirzepatide",
      "destination": "/peptides/tirzepatide",
      "permanent": true
    },
    {
      "source": "/ozempic",
      "destination": "/guide/what-is-ozempic",
      "permanent": true
    },
    {
      "source": "/wegovy",
      "destination": "/guide/what-is-wegovy",
      "permanent": true
    },
    {
      "source": "/mounjaro",
      "destination": "/guide/what-is-mounjaro",
      "permanent": true
    },
    {
      "source": "/zepbound",
      "destination": "/guide/what-is-zepbound",
      "permanent": true
    },
    {
      "source": "/bpc-157",
      "destination": "/peptides/bpc-157",
      "permanent": true
    },
    {
      "source": "/tb-500",
      "destination": "/peptides/tb-500",
      "permanent": true
    },
    {
      "source": "/retatrutide",
      "destination": "/peptides/retatrutide",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "index, follow"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://www.google-analytics.com https://va.vercel-scripts.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://www.google-analytics.com https://analytics.google.com https://region1.google-analytics.com https://va.vercel-scripts.com https://vitals.vercel-insights.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        }
      ]
    }
  ]
}
