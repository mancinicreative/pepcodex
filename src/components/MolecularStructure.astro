---
/**
 * MolecularStructure.astro
 * Displays peptide amino acid sequence with color-coded properties
 * Features: hover tooltips, one-letter/three-letter code toggle
 */

interface AminoAcid {
  code: string;
  name: string;
  position: number;
  property: 'hydrophobic' | 'polar' | 'positive' | 'negative' | 'modified';
}

interface Props {
  molecularInfo: {
    weight: string;
    chainLength: number;
    type: string;
    sequence: string;
    aminoAcids: AminoAcid[];
  };
  peptideName: string;
}

const { molecularInfo, peptideName } = Astro.props;

// Three-letter codes for amino acids
const threeLetterCodes: Record<string, string> = {
  'G': 'Gly', 'A': 'Ala', 'V': 'Val', 'L': 'Leu', 'I': 'Ile',
  'M': 'Met', 'F': 'Phe', 'W': 'Trp', 'P': 'Pro', 'S': 'Ser',
  'T': 'Thr', 'C': 'Cys', 'Y': 'Tyr', 'N': 'Asn', 'Q': 'Gln',
  'D': 'Asp', 'E': 'Glu', 'K': 'Lys', 'R': 'Arg', 'H': 'His',
  'Aib': 'Aib', 'Nal': 'Nal', 'dF': 'dPhe', 'dW': 'dTrp'
};

// Property colors — scientific category labels (not danger/positive signals), mapped to a
// muted editorial palette legible on warm paper:
//   hydrophobic = compound amber, polar = cobalt accent, positive charge = research green,
//   negative charge = danger red, modified = warm ink-dim. Text tones darkened for paper contrast.
const propertyColors: Record<string, { bg: string; border: string; text: string; label: string }> = {
  'hydrophobic': {
    bg: 'rgba(203, 135, 52, 0.12)',
    border: 'rgba(203, 135, 52, 0.40)',
    text: '#9a6418',
    label: 'Hydrophobic'
  },
  'polar': {
    bg: 'rgba(11, 81, 127, 0.10)',
    border: 'rgba(11, 81, 127, 0.40)',
    text: 'var(--primary-c)',
    label: 'Polar'
  },
  'positive': {
    bg: 'rgba(20, 118, 74, 0.10)',
    border: 'rgba(20, 118, 74, 0.40)',
    text: 'var(--research)',
    label: 'Positive Charge'
  },
  'negative': {
    bg: 'rgba(185, 61, 66, 0.10)',
    border: 'rgba(185, 61, 66, 0.40)',
    text: 'var(--danger)',
    label: 'Negative Charge'
  },
  'modified': {
    bg: 'rgba(142, 133, 103, 0.14)',
    border: 'rgba(142, 133, 103, 0.45)',
    text: 'var(--ink-dim)',
    label: 'Modified'
  }
};
---

<div class="molecular-structure-container" data-component="molecular-structure">
  <!-- Header with stats -->
  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
    <div>
      <h3 class="text-xl mb-1" style="font-family: var(--font-serif); font-weight: 500; color: var(--ink);">
        Molecular Structure
      </h3>
      <p class="text-sm" style="color: var(--ink-muted);">
        {molecularInfo.type} ({molecularInfo.chainLength} amino acids)
      </p>
    </div>

    <!-- Code toggle -->
    <div class="flex items-center gap-2 rounded-lg p-1" style="background: var(--paper-2);">
      <button
        class="code-toggle-btn active px-3 py-1.5 rounded-md text-xs font-bold uppercase tracking-wider transition-all"
        data-code-type="one"
      >
        1-Letter
      </button>
      <button
        class="code-toggle-btn px-3 py-1.5 rounded-md text-xs font-bold uppercase tracking-wider transition-all"
        data-code-type="three"
      >
        3-Letter
      </button>
    </div>
  </div>

  <!-- Molecular specs grid -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
    <div class="rounded-lg p-4 border" style="background: var(--paper); border-color: var(--border-c);">
      <div class="text-xs uppercase tracking-wider mb-1" style="color: var(--ink-dim);">Weight</div>
      <div class="text-lg font-mono font-bold" style="color: var(--ink);">{molecularInfo.weight}</div>
    </div>
    <div class="rounded-lg p-4 border" style="background: var(--paper); border-color: var(--border-c);">
      <div class="text-xs uppercase tracking-wider mb-1" style="color: var(--ink-dim);">Chain Length</div>
      <div class="text-lg font-mono font-bold" style="color: var(--ink);">{molecularInfo.chainLength} aa</div>
    </div>
    <div class="rounded-lg p-4 border overflow-hidden" style="background: var(--paper); border-color: var(--border-c);">
      <div class="text-xs uppercase tracking-wider mb-1" style="color: var(--ink-dim);">Type</div>
      <div class="text-xs font-bold truncate" style="color: var(--ink);" title={molecularInfo.type}>{molecularInfo.type}</div>
    </div>
    <div class="rounded-lg p-4 border" style="background: var(--paper); border-color: var(--border-c);">
      <div class="text-xs uppercase tracking-wider mb-1" style="color: var(--ink-dim);">Sequence</div>
      <div class="text-xs font-mono truncate" style="color: var(--ink-muted);" title={molecularInfo.sequence}>
        {molecularInfo.sequence}
      </div>
    </div>
  </div>

  <!-- Amino acid sequence visualization -->
  <div class="sequence-container">
    <div class="text-xs uppercase tracking-wider mb-3" style="color: var(--ink-dim);">Amino Acid Sequence</div>

    <div class="sequence-display flex flex-wrap gap-1.5" data-sequence-display>
      {molecularInfo.aminoAcids.map((aa, index) => {
        const colors = propertyColors[aa.property];
        const threeCode = threeLetterCodes[aa.code] || aa.code;
        return (
          <div
            class="amino-acid-unit group relative"
            data-position={aa.position}
            data-property={aa.property}
            data-one-letter={aa.code}
            data-three-letter={threeCode}
            data-name={aa.name}
            style={`
              background: ${colors.bg};
              border: 1px solid ${colors.border};
            `}
          >
            <span class="aa-code one-letter" style={`color: ${colors.text};`}>
              {aa.code}
            </span>
            <span class="aa-code three-letter hidden" style={`color: ${colors.text};`}>
              {threeCode}
            </span>

            <!-- Position indicator -->
            <span class="position-badge">{aa.position}</span>

            <!-- Tooltip -->
            <div class="aa-tooltip">
              <div class="tooltip-header">
                <span class="tooltip-code" style={`color: ${colors.text};`}>{aa.code}</span>
                <span class="tooltip-name">{aa.name}</span>
              </div>
              <div class="tooltip-info">
                <span class="tooltip-position">Position {aa.position}</span>
                <span class="tooltip-property" style={`color: ${colors.text};`}>
                  {colors.label}
                </span>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>

  <!-- Legend -->
  <div class="legend mt-6 pt-6 border-t" style="border-color: var(--border-c);">
    <div class="text-xs uppercase tracking-wider mb-3" style="color: var(--ink-dim);">Property Legend</div>
    <div class="flex flex-wrap gap-3">
      {Object.entries(propertyColors).map(([key, colors]) => (
        <div class="flex items-center gap-2">
          <div
            class="w-3 h-3 rounded"
            style={`background: ${colors.bg}; border: 1px solid ${colors.border};`}
          ></div>
          <span class="text-xs" style="color: var(--ink-muted);">{colors.label}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Connection lines visualization (optional enhancement) -->
  <div class="chain-visualization mt-6">
    <div class="text-xs uppercase tracking-wider mb-3" style="color: var(--ink-dim);">Peptide Bond Chain</div>
    <div class="chain-line flex items-center overflow-x-auto pb-2">
      <span class="text-xs mr-2" style="color: var(--ink-dim);">N-terminus</span>
      {molecularInfo.aminoAcids.map((aa, index) => {
        const colors = propertyColors[aa.property];
        const isLast = index === molecularInfo.aminoAcids.length - 1;
        return (
          <div class="flex items-center">
            <div
              class="chain-node"
              style={`background: ${colors.text};`}
              title={`${aa.name} (${aa.code})`}
            ></div>
            {!isLast && <div class="chain-bond"></div>}
          </div>
        );
      })}
      <span class="text-xs ml-2" style="color: var(--ink-dim);">C-terminus</span>
    </div>
  </div>
</div>

<style>
  .molecular-structure-container {
    background: var(--paper);
    border: 1px solid var(--border-c);
    border-radius: 0.75rem;
    padding: 1.5rem;
  }

  .code-toggle-btn {
    color: var(--ink-dim);
  }

  .code-toggle-btn.active {
    background: var(--primary-c);
    color: var(--paper);
  }

  .code-toggle-btn:not(.active):hover {
    background: var(--sand);
    color: var(--ink);
  }

  .amino-acid-unit {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 2.5rem;
    height: 2.5rem;
    padding: 0 0.5rem;
    border-radius: 0.5rem;
    cursor: pointer;
    transition: all 0.2s ease;
    position: relative;
  }

  .amino-acid-unit:hover {
    transform: translateY(-2px) scale(1.05);
    z-index: 10;
  }

  .aa-code {
    font-family: var(--font-mono, monospace);
    font-weight: 700;
    font-size: 0.875rem;
    letter-spacing: 0.05em;
  }

  .aa-code.three-letter {
    font-size: 0.7rem;
  }

  .position-badge {
    position: absolute;
    bottom: -0.25rem;
    right: -0.25rem;
    background: var(--charcoal);
    color: rgba(251, 247, 238, 0.9);
    font-size: 0.5rem;
    font-weight: 700;
    padding: 0.1rem 0.25rem;
    border-radius: 0.25rem;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .amino-acid-unit:hover .position-badge {
    opacity: 1;
  }

  /* Tooltip styles */
  .aa-tooltip {
    position: absolute;
    bottom: calc(100% + 0.75rem);
    left: 50%;
    transform: translateX(-50%) scale(0.9);
    background: var(--paper);
    border: 1px solid var(--border-strong);
    border-radius: 0.5rem;
    padding: 0.75rem 1rem;
    min-width: 140px;
    opacity: 0;
    visibility: hidden;
    transition: all 0.2s ease;
    z-index: 100;
    box-shadow: 0 10px 24px rgba(31, 26, 18, 0.15);
    pointer-events: none;
  }

  .aa-tooltip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 6px solid transparent;
    border-top-color: var(--border-strong);
  }

  .amino-acid-unit:hover .aa-tooltip {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) scale(1);
  }

  .tooltip-header {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .tooltip-code {
    font-family: var(--font-mono, monospace);
    font-weight: 700;
    font-size: 1.25rem;
  }

  .tooltip-name {
    color: var(--ink);
    font-weight: 600;
    font-size: 0.875rem;
  }

  .tooltip-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
  }

  .tooltip-position {
    color: var(--ink-dim);
    font-size: 0.7rem;
  }

  .tooltip-property {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Chain visualization */
  .chain-node {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .chain-bond {
    width: 12px;
    height: 2px;
    background: var(--border-strong);
    flex-shrink: 0;
  }

  /* Responsive adjustments */
  @media (max-width: 640px) {
    .amino-acid-unit {
      min-width: 2rem;
      height: 2rem;
    }

    .aa-code {
      font-size: 0.75rem;
    }

    .aa-code.three-letter {
      font-size: 0.6rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const containers = document.querySelectorAll('[data-component="molecular-structure"]');

    containers.forEach(container => {
      const toggleBtns = container.querySelectorAll('.code-toggle-btn');
      const sequenceDisplay = container.querySelector('[data-sequence-display]');

      if (!toggleBtns.length || !sequenceDisplay) return;

      toggleBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const codeType = btn.getAttribute('data-code-type');

          // Update button states
          toggleBtns.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');

          // Update displayed codes
          const units = sequenceDisplay.querySelectorAll('.amino-acid-unit');
          units.forEach(unit => {
            const oneLetter = unit.querySelector('.one-letter');
            const threeLetter = unit.querySelector('.three-letter');

            if (codeType === 'three') {
              oneLetter?.classList.add('hidden');
              threeLetter?.classList.remove('hidden');
            } else {
              oneLetter?.classList.remove('hidden');
              threeLetter?.classList.add('hidden');
            }
          });
        });
      });
    });
  });
</script>
