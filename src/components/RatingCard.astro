---
interface Props {
  ratings: {
    researchDepth: number;
    globalCoverage: number;
    mechanismPlausibility: number;
    anecdotalEvidence: number;
    overall: number;
    lastReviewed: Date;
    reviewNotes?: string;
  };
}

const { ratings } = Astro.props;

// Compute label and color based on overall score
const overallLabel =
  ratings.overall >= 4.0
    ? 'High Evidence'
    : ratings.overall >= 3.0
    ? 'Moderate Evidence'
    : ratings.overall >= 2.0
    ? 'Low Evidence'
    : 'Very Low Evidence';

const overallColor =
  ratings.overall >= 4.0
    ? 'hsl(142 70% 45%)'
    : ratings.overall >= 3.0
    ? 'hsl(260 80% 65%)'
    : ratings.overall >= 2.0
    ? 'hsl(45 90% 55%)'
    : 'hsl(0 70% 55%)';

// Convert 1-5 scale to percentage for progress bar width
const toPercent = (v: number) => `${(v / 5) * 100}%`;

// Format date as "Month YYYY"
const lastReviewedFormatted = ratings.lastReviewed.toLocaleDateString('en-US', {
  month: 'long',
  year: 'numeric',
});

const dimensions = [
  { label: 'Research Depth', value: ratings.researchDepth },
  { label: 'Global Coverage', value: ratings.globalCoverage },
  { label: 'Mechanism Plausibility', value: ratings.mechanismPlausibility },
  { label: 'Community Experience', value: ratings.anecdotalEvidence },
];
---

<div class="space-y-4">
  <!-- Header: title + overall badge -->
  <div class="flex items-center justify-between">
    <span class="text-sm font-semibold text-white/80 uppercase tracking-wider">Evidence Rating</span>
    <span
      class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-bold border"
      style={`color: ${overallColor}; background: ${overallColor}20; border-color: ${overallColor}50;`}
    >
      {overallLabel}
    </span>
  </div>

  <!-- Three progress bars: Research Depth, Global Coverage, Mechanism Plausibility -->
  <div class="space-y-3">
    {dimensions.map((dim) => (
      <div>
        <div class="flex justify-between items-baseline text-xs mb-1">
          <span class="text-white/70">{dim.label}</span>
          <span class="font-mono text-white">{dim.value}/5</span>
        </div>
        <div class="h-1.5 rounded-full bg-white/10">
          <div
            class="h-full rounded-full"
            style={`width: ${toPercent(dim.value)}; background: ${overallColor};`}
          ></div>
        </div>
      </div>
    ))}
  </div>

  <!-- Overall composite score row -->
  <div class="flex items-center justify-between pt-1 border-t border-white/10">
    <span class="text-xs font-semibold text-white/70 uppercase tracking-wider">Overall Score</span>
    <div class="flex items-center gap-2">
      <span
        class="text-2xl font-bold font-mono"
        style={`color: ${overallColor};`}
      >
        {ratings.overall}
      </span>
      <span class="text-xs text-white/40 font-mono">/5</span>
    </div>
  </div>

  <!-- Optional review notes -->
  {ratings.reviewNotes && (
    <p class="text-xs text-white/50 italic leading-relaxed">{ratings.reviewNotes}</p>
  )}

  <!-- Footer: last reviewed date + methodology link -->
  <div class="flex items-center justify-between pt-1">
    <span class="text-xs text-white/40">Last reviewed {lastReviewedFormatted}</span>
    <a
      href="/methodology#how-we-rate"
      class="text-xs text-white/40 hover:text-white/70 transition-colors"
    >
      How we rate &rarr;
    </a>
  </div>
</div>
