---
interface Props {
  title: string;
  slug: string;
  category: string;
  publishDate: Date;
  excerpt: string;
  author?: string;
  tags?: string[];
  featured?: boolean;
}

const {
  title,
  slug,
  category,
  publishDate,
  excerpt,
  author = 'PepCodex Research Team',
  tags = [],
  featured = false
} = Astro.props;

const categoryLabels: Record<string, string> = {
  'weekly-briefing': 'Weekly Briefing',
  'research-digest': 'Research Digest',
  'deep-dive': 'Deep Dive',
  'regulatory': 'Regulatory',
  'explainer': 'Explainer',
  'guide': 'Guide',
  'safety': 'Safety',
};

const categoryColors: Record<string, string> = {
  'weekly-briefing': 'bg-[color:var(--primary-soft)] text-primary border-[color:var(--border-c)]',
  'research-digest': 'bg-[rgba(20,118,74,0.10)] text-[color:var(--research)] border-[rgba(20,118,74,0.30)]',
  'deep-dive': 'bg-[color:var(--primary-soft)] text-primary border-[color:var(--border-c)]',
  'regulatory': 'bg-[color:var(--primary-soft)] text-primary border-[color:var(--border-c)]',
  'explainer': 'bg-[color:var(--primary-soft)] text-primary border-[color:var(--border-c)]',
  'guide': 'bg-[color:var(--primary-soft)] text-primary border-[color:var(--border-c)]',
  'safety': 'bg-[rgba(203,135,52,0.12)] text-[#9a6418] border-[rgba(203,135,52,0.32)]',
};

// Calculate reading time estimate
const readingTime = Math.ceil(excerpt.length / 200) + 5;
---

<a
  href={`/blog/${slug}`}
  class:list={[
    "glass-card glass-card--interactive group relative block h-full",
    featured && "ring-2 ring-[color:var(--primary-c)]/50"
  ]}
>
  <!-- Featured badge -->
  {featured && (
    <div class="absolute top-5 right-4 z-20">
      <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-medium shadow-[var(--shadow-card)]" style="background: var(--primary-c); color: var(--paper);">
        Featured
      </span>
    </div>
  )}

  <!-- Decorative icon -->
  <div class="absolute top-0 right-0 p-4 opacity-[0.06] group-hover:opacity-10 transition-opacity text-primary">
    <svg class="w-20 h-20 rotate-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
      <path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/>
      <path d="M18 14h-8"/>
      <path d="M18 18h-8"/>
      <path d="M18 10h-8"/>
    </svg>
  </div>

  <div class="relative z-10 p-6 flex flex-col h-full">
    <!-- Category and date -->
    <div class="flex flex-wrap items-center gap-2 mb-3">
      <span class={`inline-flex items-center rounded-full px-2.5 py-0.5 text-[11px] uppercase tracking-wider font-medium border ${categoryColors[category] || categoryColors['research-digest']}`} style="font-family: var(--font-mono);">
        {categoryLabels[category] || category}
      </span>
      <span class="text-xs" style="color: var(--ink-dim); font-family: var(--font-mono);">
        {publishDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
      </span>
    </div>

    <!-- Title -->
    <h3 class="text-xl group-hover:text-primary transition-colors line-clamp-2" style="color: var(--ink); font-family: var(--font-serif); font-weight: 500;">
      {title}
    </h3>

    <!-- Excerpt -->
    <p class="mt-3 text-sm line-clamp-3 leading-relaxed flex-grow" style="color: var(--ink-muted);">
      {excerpt}
    </p>

    <!-- Tags -->
    {tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-1.5">
        {tags.slice(0, 3).map(tag => (
          <span class="inline-flex items-center rounded px-2 py-0.5 text-xs" style="color: var(--ink-dim); background: var(--paper-2);">
            #{tag}
          </span>
        ))}
        {tags.length > 3 && (
          <span class="text-xs" style="color: var(--ink-dim);">+{tags.length - 3}</span>
        )}
      </div>
    )}

    <!-- Footer -->
    <div class="pt-4 mt-4 flex items-center justify-between" style="border-top: 1px solid var(--border-glass);">
      <div class="flex items-center gap-2 text-xs" style="color: var(--text-low);">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span>{readingTime} min read</span>
      </div>

      <!-- Arrow -->
      <svg
        class="h-4 w-4 group-hover:text-primary group-hover:translate-x-1 transition-all"
        style="color: var(--text-low);"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7" />
      </svg>
    </div>
  </div>
</a>
