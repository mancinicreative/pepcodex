}
.footer-brand p { margin: 0; color: rgba(251,247,238,0.6); font-size: 13.5px; line-height: 1.6; }
.footer-col h5 {
  font-family: var(--mono); font-size: 11px; font-weight: 700;
  letter-spacing: 1.6px; text-transform: uppercase;
  color: rgba(251,247,238,0.86); margin: 0 0 14px;
}
.footer-col ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
.footer-col a { color: rgba(251,247,238,0.66); font-size: 13.5px; }
.footer-col a:hover { color: var(--ink-paper); }
.footer-bottom {
  max-width: 1240px; margin: 40px auto 0; padding: 18px 32px 0;
  border-top: 1px dashed rgba(251,247,238,0.18);
  display: flex; justify-content: space-between; gap: 24px;
  font-family: var(--mono); font-size: 10px; font-weight: 600;
  letter-spacing: 1.4px; text-transform: uppercase; color: rgba(251,247,238,0.46);
}
.footer-bottom .colophon-tail {
  font-style: italic; font-family: var(--sans);
  text-transform: none; letter-spacing: 0; font-weight: 500; font-size: 12px;
  color: rgba(251,247,238,0.50);
}

@media (max-width: 1024px) {
  .title-block .title-row { grid-template-columns: 1fr; gap: 24px; }
