---
import BaseLayout from './BaseLayout.astro';
import ArticleSchema from '../components/SEO/ArticleSchema.astro';
import BreadcrumbSchema from '../components/SEO/BreadcrumbSchema.astro';
import NewsletterForm from '../components/NewsletterForm.astro';

interface Props {
  name: string;
  peptideSlug: string;
  calculatorType: string;
  inputs: string[];
  disclaimer: string;
  lastUpdated: Date;
  metaTitle?: string;
  metaDescription?: string;
  robots?: 'index' | 'noindex';
}

const {
  name,
  peptideSlug,
  calculatorType,
  inputs,
  disclaimer,
  lastUpdated,
  metaTitle,
  metaDescription,
  robots = 'index',
} = Astro.props;

const siteBase = Astro.site?.toString() || 'https://pepcodex.com';
const peptideName = name.replace(' Reconstitution Calculator', '');
const calculatorLabel = calculatorType.charAt(0).toUpperCase() + calculatorType.slice(1);
const breadcrumbItems = [
  { name: 'Home', url: siteBase },
  { name: 'Calculator explainers', url: `${siteBase}calculator/` },
  { name: `${name}`, url: Astro.url.toString() },
];

const articleUrl = Astro.url.toString();
const fallbackDescription = `${name}: research-use explainer for concentration language, unit concepts, and the PepTracker app calculator boundary.`;
---

<BaseLayout
  title={metaTitle || `${name}: Research Explainer`}
  description={metaDescription || fallbackDescription}
  robots={robots}
>
  <ArticleSchema
    title={metaTitle || `${name}: Research Explainer`}
    description={metaDescription || fallbackDescription}
    url={articleUrl}
    dateModified={lastUpdated}
  />
  <BreadcrumbSchema items={breadcrumbItems} />

  <article class="mx-auto max-w-5xl px-4 py-8 sm:px-6 lg:px-8">
    <!-- Header -->
    <header class="mb-8 rounded-2xl border border-white/10 bg-gradient-to-br from-white/10 via-white/[0.04] to-primary/10 p-6 sm:p-8">
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-medium bg-primary/15 text-primary border border-primary/30">
          {calculatorLabel} explainer
        </span>
        <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-medium border border-amber-500/30 bg-amber-500/10 text-amber-200">
          Calculator available in PepTracker
        </span>
        <span class="text-xs" style="color: var(--text-low);">
          Updated {lastUpdated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </span>
      </div>
      <h1 class="text-3xl sm:text-5xl font-bold text-white mb-4" style="font-family: var(--font-display);">
        {name}
      </h1>
      <p class="max-w-3xl text-lg leading-relaxed" style="color: var(--text-medium);">
        Understand the concentration and unit language before you calculate. PepCodex explains the research context; PepTracker will handle the private calculator, vial inventory, and protocol tools.
      </p>
      <div class="mt-6 flex flex-col sm:flex-row gap-3">
        <a href="#peptracker-calculator" class="btn btn-primary btn-md justify-center">
          Join PepTracker waitlist
        </a>
        <a href={`/peptides/${peptideSlug}`} class="btn btn-ghost btn-md justify-center border border-white/20">
          Read the {peptideName} dossier
        </a>
      </div>
    </header>

    <!-- Boundary Banner -->
    <section class="rounded-xl border border-amber-500/20 bg-amber-500/10 p-5 mb-8" aria-labelledby="calculator-boundary-title">
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-amber-400 flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>
        </svg>
        <div>
          <h2 id="calculator-boundary-title" class="text-base font-semibold text-amber-100 mb-1">PepCodex is not a dosing tool</h2>
          <p class="text-sm text-amber-200/90">{disclaimer}</p>
        </div>
      </div>
    </section>

    <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_320px]">
      <div>
        <!-- App inputs explainer -->
        <section class="rounded-xl border border-white/10 bg-white/5 p-6 mb-8" aria-labelledby="app-inputs-title">
          <p class="text-xs uppercase tracking-[0.2em] mb-2" style="color: var(--text-low);">Conceptual boundary</p>
          <h2 id="app-inputs-title" class="text-xl font-semibold text-white mb-3">What the app calculator will ask for</h2>
          <p class="text-sm mb-5" style="color: var(--text-medium);">
            These are the variables behind reconstitution math. PepCodex explains what the labels mean; it does not produce a dose, protocol, syringe draw, or personalized instruction.
          </p>
          <ul class="space-y-3">
            {inputs.map((input) => (
              <li class="flex items-start gap-3 rounded-lg border border-white/10 bg-black/10 p-3">
                <svg class="w-5 h-5 text-primary flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="M9 12l2 2 4-4"/>
                </svg>
                <span class="text-sm" style="color: var(--text-medium);">{input}</span>
              </li>
            ))}
          </ul>
        </section>

        <!-- Content -->
        <div class="prose prose-invert max-w-none">
          <slot />
        </div>
      </div>

      <aside class="space-y-6 lg:sticky lg:top-28 self-start">
        <section id="peptracker-calculator" class="rounded-2xl border border-primary/30 bg-primary/10 p-6" aria-labelledby="peptracker-title">
          <p class="text-xs uppercase tracking-[0.2em] mb-2" style="color: var(--text-low);">PepTracker boundary</p>
          <h2 id="peptracker-title" class="text-xl font-bold text-white mb-3">Calculate privately. Save nothing on PepCodex.</h2>
          <p class="text-sm leading-relaxed mb-4" style="color: var(--text-medium);">
            The working calculator, vial inventory, reminders, and protocol history are private app features. PepCodex stays the public evidence record.
          </p>
          <NewsletterForm
            variant="card"
            heading="Get PepTracker calculator access"
            description="Join the app waitlist for the private calculator, vial inventory, and protocol tools when PepTracker opens."
          />
        </section>

        <section class="rounded-xl border border-white/10 bg-white/5 p-5" aria-labelledby="faq-title">
          <h2 id="faq-title" class="text-lg font-semibold text-white mb-4">Calculator FAQ</h2>
          <div class="space-y-4 text-sm" style="color: var(--text-medium);">
            <div>
              <h3 class="font-semibold text-white">Is this medical advice?</h3>
              <p>No. This page is research literacy content only.</p>
            </div>
            <div>
              <h3 class="font-semibold text-white">Does PepCodex recommend doses?</h3>
              <p>No. PepCodex does not provide dosing instructions, protocols, vendors, or treatment decisions.</p>
            </div>
            <div>
              <h3 class="font-semibold text-white">Where is the calculator?</h3>
              <p>The working calculator belongs inside PepTracker, not on this public page.</p>
            </div>
          </div>
        </section>
      </aside>
    </div>

    <!-- Back to peptide -->
    <div class="mt-12 pt-8 border-t border-white/10">
      <a
        href={`/peptides/${peptideSlug}`}
        class="inline-flex items-center gap-2 text-sm text-primary hover:text-primary/80 transition-colors"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        View {peptideName} research dossier
      </a>
    </div>
  </article>
</BaseLayout>
