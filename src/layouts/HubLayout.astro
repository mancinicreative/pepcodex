---
import BaseLayout from './BaseLayout.astro';
import BreadcrumbSchema from '../components/SEO/BreadcrumbSchema.astro';

interface Props {
  title: string;
  description: string;
  category?: string;
  showBackLink?: boolean;
}

const { title, description, category, showBackLink = false } = Astro.props;

const siteBase = Astro.site?.toString() || 'https://www.pepcodex.com';
const breadcrumbItems = [
  { name: 'Home', url: siteBase },
  { name: 'Peptides', url: `${siteBase}peptides/` },
  { name: title, url: Astro.url.toString() },
];
---

<BaseLayout title={title} description={description}>
  <BreadcrumbSchema items={breadcrumbItems} />
  <!-- Hero Section -->
  <div class="relative overflow-hidden" style="border-bottom: 1px solid var(--border-c);">
    <div class="relative mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
      {showBackLink && (
        <a href="/peptides" class="group inline-flex items-center gap-2 text-sm mb-6 transition-colors hover:text-[color:var(--ink)]" style="color: var(--ink-muted);">
          <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          Back to Library
        </a>
      )}

      <div class="flex items-center gap-4 mb-4">
        {category && (
          <span class="eyebrow">
            {category.replace('-', ' & ')}
          </span>
        )}
      </div>

      <h1 class="text-4xl sm:text-5xl lg:text-6xl tracking-tight" style="font-family: var(--font-serif); font-weight: 500; color: var(--ink);">
        {title}
      </h1>
      <p class="mt-6 max-w-2xl text-xl leading-relaxed" style="color: var(--ink-muted);">
        {description}
      </p>
    </div>
  </div>

  <!-- Content -->
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <slot />
  </div>
</BaseLayout>
