---
import HubLayout from '../../layouts/HubLayout.astro';
import SearchBar from '../../components/SearchBar.astro';
import PeptideCard from '../../components/PeptideCard.astro';
import EvidenceKey from '../../components/EvidenceKey.astro';
import { getCollection } from 'astro:content';

const allPeptides = await getCollection('peptides');
const peptides = allPeptides
  .filter(p => p?.data?.name)
  .sort((a, b) => (a.data.name || '').localeCompare(b.data.name || ''));

// Group by first letter for A-Z navigation
const grouped = peptides.reduce((acc, peptide) => {
  const name = peptide.data.name || '';
  if (!name) return acc;
  const letter = name[0].toUpperCase();
  if (!acc[letter]) acc[letter] = [];
  acc[letter].push(peptide);
  return acc;
}, {} as Record<string, typeof peptides>);

const letters = Object.keys(grouped).sort();
const categories = ['metabolic', 'repair-recovery', 'hormonal', 'longevity'];
const evidenceLevels = ['high', 'moderate', 'low', 'very-low'];
const compoundTypes = [
  { value: 'peptide', label: 'Peptide' },
  { value: 'bioregulator', label: 'Bioregulator' },
  { value: 'small-molecule', label: 'Small Molecule' },
  { value: 'mrna', label: 'mRNA' },
  { value: 'protein', label: 'Protein' },
  { value: 'glycoprotein', label: 'Glycoprotein' },
];

// Per-value facet counts (total available per value — faceted-browse style; ClinicalTrials.gov/PubChem)
const countBy = (key: 'category' | 'evidenceStrength' | 'compoundType', val: string) =>
  peptides.filter((p) => (p.data as any)[key] === val).length;
---

<HubLayout
  title="All Peptides"
  description="Browse our complete library of evidence-based peptide dossiers, organized A-Z with evidence grading."
>
  <!-- Search and filters -->
  <div class="mb-8">
    <SearchBar placeholder="Search peptides..." />

    <div class="mt-8 space-y-4">
      <!-- Category filter -->
      <div class="flex flex-wrap items-center gap-3">
        <span class="eyebrow" style="color: var(--ink-dim);">Category</span>
        <button
          class="filter-btn filter-active px-4 py-2 rounded-xl text-sm font-medium transition-all duration-300"
          data-filter="category"
          data-value="all"
        >
          All <span class="ml-1 text-[0.7rem] opacity-55" style="font-family: var(--font-mono);">{peptides.length}</span>
        </button>
        {categories.map((cat) => (
          <button
            class="filter-btn filter-inactive px-4 py-2 rounded-xl text-sm font-medium transition-all duration-300"
            data-filter="category"
            data-value={cat}
          >
            {cat.replace('-', ' & ').replace(/\b\w/g, l => l.toUpperCase())} <span class="ml-1 text-[0.7rem] opacity-55" style="font-family: var(--font-mono);">{countBy('category', cat)}</span>
          </button>
        ))}
      </div>

      <!-- Evidence filter -->
      <div class="flex flex-wrap items-center gap-3">
        <span class="eyebrow" style="color: var(--ink-dim);">Evidence</span>
        <button
          class="filter-btn filter-active px-4 py-2 rounded-xl text-sm font-medium transition-all duration-300"
          data-filter="evidence"
          data-value="all"
        >
          All <span class="ml-1 text-[0.7rem] opacity-55" style="font-family: var(--font-mono);">{peptides.length}</span>
        </button>
        {evidenceLevels.map((level) => (
          <button
            class="filter-btn filter-inactive px-4 py-2 rounded-xl text-sm font-medium transition-all duration-300"
            data-filter="evidence"
            data-value={level}
          >
            {level.replace('-', ' ').replace(/\b\w/g, l => l.toUpperCase())} <span class="ml-1 text-[0.7rem] opacity-55" style="font-family: var(--font-mono);">{countBy('evidenceStrength', level)}</span>
          </button>
        ))}
      </div>

      <!-- Compound Type filter -->
      <div class="flex flex-wrap items-center gap-3">
        <span class="eyebrow" style="color: var(--ink-dim);">Type</span>
        <button
          class="filter-btn filter-active px-4 py-2 rounded-xl text-sm font-medium transition-all duration-300"
          data-filter="compound"
          data-value="all"
        >
          All <span class="ml-1 text-[0.7rem] opacity-55" style="font-family: var(--font-mono);">{peptides.length}</span>
        </button>
        {compoundTypes.map((type) => (
          <button
            class="filter-btn filter-inactive px-4 py-2 rounded-xl text-sm font-medium transition-all duration-300"
            data-filter="compound"
            data-value={type.value}
          >
            {type.label} <span class="ml-1 text-[0.7rem] opacity-55" style="font-family: var(--font-mono);">{countBy('compoundType', type.value)}</span>
          </button>
        ))}
      </div>
    </div>
  </div>

  <!-- A-Z Navigation -->
  <div class="mb-8 glass-card-default p-4">
    <div class="flex flex-wrap gap-1 justify-center">
      {[...'ABCDEFGHIJKLMNOPQRSTUVWXYZ'].map((letter) => (
        <a
          href={letters.includes(letter) ? `#letter-${letter}` : undefined}
          class={`az-link w-9 h-9 flex items-center justify-center rounded-lg text-sm font-bold transition-all duration-300 ${
            letters.includes(letter) ? 'az-link--on' : 'az-link--off cursor-not-allowed'
          }`}
        >
          {letter}
        </a>
      ))}
    </div>
  </div>

  <!-- Peptide count + evidence key -->
  <div class="mb-8 flex flex-col sm:flex-row sm:items-center justify-between gap-3 pb-4" style="border-bottom: 1px solid var(--border-c);">
    <p class="text-sm" style="color: var(--ink-muted);">
      Showing <span id="peptide-count" class="font-bold" style="color: var(--ink);">{peptides.length}</span> peptides
    </p>
    <EvidenceKey />
  </div>

  <!-- Peptide list by letter -->
  <div id="peptide-list" class="space-y-16">
    {letters.map((letter) => (
      <section id={`letter-${letter}`} class="scroll-mt-24">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center" style="background: var(--primary-soft); border: 1px solid var(--primary-border);">
            <span class="text-2xl font-serif" style="color: var(--primary-c); font-weight: 500;">{letter}</span>
          </div>
          <div class="flex-1 h-px" style="background: linear-gradient(to right, var(--border-c), transparent);"></div>
        </div>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {grouped[letter].map((peptide) => (
            <div
              class="peptide-item"
              data-category={peptide.data.category}
              data-evidence={peptide.data.evidenceStrength}
              data-compound={peptide.data.compoundType || 'peptide'}
              data-name={peptide.data.name.toLowerCase()}
            >
              <PeptideCard
                name={peptide.data.name}
                slug={peptide.slug}
                category={peptide.data.category}
                compoundType={peptide.data.compoundType || 'peptide'}
                evidenceStrength={peptide.data.evidenceStrength}
                summary={peptide.data.summary}
                aliases={peptide.data.aliases}
              />
            </div>
          ))}
        </div>
      </section>
    ))}
  </div>

  <!-- Empty state -->
  <div id="empty-state" class="hidden py-20 text-center">
    <div class="glass-card-default p-12 max-w-md mx-auto">
      <div class="w-16 h-16 rounded-xl flex items-center justify-center mx-auto mb-6" style="background: var(--primary-soft); border: 1px solid var(--primary-border);">
        <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>
      <p class="text-lg mb-2" style="color: var(--ink);">No peptides match your filters</p>
      <p class="text-sm mb-6" style="color: var(--ink-muted);">Try adjusting your filter criteria</p>
      <button
        id="clear-filters"
        class="btn btn-cobalt btn-md"
      >
        Clear all filters
      </button>
    </div>
  </div>

  <style>
    .filter-active {
      background: var(--ink);
      color: var(--ink-paper);
      border: 1px solid var(--ink);
    }
    .filter-inactive {
      background: var(--paper);
      color: var(--ink-muted);
      border: 1px solid var(--border-c);
    }
    .filter-inactive:hover {
      background: var(--paper-2);
      color: var(--ink);
    }
    .az-link--on {
      background: var(--paper-2);
      color: var(--ink);
      border: 1px solid var(--border-c);
    }
    .az-link--on:hover {
      background: var(--primary-c);
      color: var(--ink-paper);
      border-color: var(--primary-c);
    }
    .az-link--off {
      background: var(--paper);
      color: var(--ink-dim);
      border: 1px solid var(--border-c);
    }
  </style>
</HubLayout>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const peptideItems = document.querySelectorAll('.peptide-item');
  const peptideCount = document.getElementById('peptide-count');
  const emptyState = document.getElementById('empty-state');
  const peptideList = document.getElementById('peptide-list');

  let activeFilters = {
    category: 'all',
    evidence: 'all',
    compound: 'all',
  };

  function applyFilters() {
    let visibleCount = 0;

    peptideItems.forEach((item) => {
      const el = item as HTMLElement;
      const category = el.dataset.category;
      const evidence = el.dataset.evidence;
      const compound = el.dataset.compound;

      const matchesCategory = activeFilters.category === 'all' || category === activeFilters.category;
      const matchesEvidence = activeFilters.evidence === 'all' || evidence === activeFilters.evidence;
      const matchesCompound = activeFilters.compound === 'all' || compound === activeFilters.compound;

      if (matchesCategory && matchesEvidence && matchesCompound) {
        el.classList.remove('hidden');
        visibleCount++;
      } else {
        el.classList.add('hidden');
      }
    });

    // Update count
    if (peptideCount) peptideCount.textContent = String(visibleCount);

    // Show/hide empty state
    if (visibleCount === 0) {
      emptyState?.classList.remove('hidden');
      peptideList?.classList.add('hidden');
    } else {
      emptyState?.classList.add('hidden');
      peptideList?.classList.remove('hidden');
    }

    // Hide empty letter sections
    document.querySelectorAll('#peptide-list > section').forEach((section) => {
      const visibleItems = section.querySelectorAll('.peptide-item:not(.hidden)');
      if (visibleItems.length === 0) {
        section.classList.add('hidden');
      } else {
        section.classList.remove('hidden');
      }
    });
  }

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      const filterType = el.dataset.filter as 'category' | 'evidence' | 'compound';
      const value = el.dataset.value || 'all';

      // Update active filter
      activeFilters[filterType] = value;

      // Update button styles
      document.querySelectorAll(`[data-filter="${filterType}"]`).forEach((b) => {
        b.classList.remove('filter-active');
        b.classList.add('filter-inactive');
      });
      el.classList.remove('filter-inactive');
      el.classList.add('filter-active');

      applyFilters();
    });
  });

  document.getElementById('clear-filters')?.addEventListener('click', () => {
    activeFilters = { category: 'all', evidence: 'all', compound: 'all' };

    filterBtns.forEach((btn) => {
      const el = btn as HTMLElement;
      if (el.dataset.value === 'all') {
        el.classList.remove('filter-inactive');
        el.classList.add('filter-active');
      } else {
        el.classList.remove('filter-active');
        el.classList.add('filter-inactive');
      }
    });

    applyFilters();
  });
</script>
