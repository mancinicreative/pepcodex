---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Us"
  description="Get in touch with the PepCodex team. Questions, feedback, or partnership inquiries welcome."
>
  <!-- Hero Section -->
  <div class="relative">
    <div class="mx-auto max-w-4xl px-4 py-20 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[var(--primary)]/10 border border-[var(--primary)]/30 text-sm font-medium text-white mb-6">
          <svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          Get In Touch
        </div>
        <h1 class="text-5xl md:text-6xl font-bold tracking-tight text-white" style="font-family: var(--font-display);">
          Contact <span class="bg-gradient-to-r from-[var(--primary)] via-purple-400 to-[var(--primary)] bg-clip-text text-transparent drop-shadow-[0_0_25px_rgba(139,92,246,0.5)]">Us</span>
        </h1>
        <p class="mt-6 text-xl text-white/80 max-w-2xl mx-auto leading-relaxed">
          Have a question, feedback, or partnership inquiry? We'd love to hear from you.
        </p>
      </div>

      <!-- Contact Form -->
      <div class="max-w-xl mx-auto">
        <div class="relative rounded-2xl border border-white/10 bg-white/5 backdrop-blur-xl p-8 overflow-hidden">
          <form
            id="contact-form"
            class="space-y-6"
            action="https://formsubmit.co/info@pepcodex.com"
            method="POST"
          >
            <!-- FormSubmit configuration -->
            <input type="hidden" name="_subject" value="New Contact Form Submission - PepCodex">
            <input type="hidden" name="_captcha" value="false">
            <input type="hidden" name="_template" value="table">
            <input type="text" name="_honey" style="display:none">

            <!-- Name -->
            <div>
              <label for="name" class="block text-sm font-medium text-white mb-2">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full rounded-xl px-4 py-3 text-white outline-none focus:ring-2 focus:ring-[var(--primary)]/50 transition-all"
                style="background: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255, 255, 255, 0.15);"
                placeholder="Your name"
              />
            </div>

            <!-- Email -->
            <div>
              <label for="email" class="block text-sm font-medium text-white mb-2">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full rounded-xl px-4 py-3 text-white outline-none focus:ring-2 focus:ring-[var(--primary)]/50 transition-all"
                style="background: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255, 255, 255, 0.15);"
                placeholder="your@email.com"
              />
            </div>

            <!-- Subject -->
            <div>
              <label for="subject" class="block text-sm font-medium text-white mb-2">Subject</label>
              <select
                id="subject"
                name="subject"
                required
                class="w-full rounded-xl px-4 py-3 text-white outline-none focus:ring-2 focus:ring-[var(--primary)]/50 transition-all cursor-pointer"
                style="background: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255, 255, 255, 0.15);"
              >
                <option value="" disabled selected style="background: #1a1a2e;">Select a topic</option>
                <option value="General Inquiry" style="background: #1a1a2e;">General Inquiry</option>
                <option value="Directory Listing Request" style="background: #1a1a2e;">Directory Listing Request</option>
                <option value="Feedback" style="background: #1a1a2e;">Feedback</option>
                <option value="Partnership / Collaboration" style="background: #1a1a2e;">Partnership / Collaboration</option>
                <option value="Content Correction" style="background: #1a1a2e;">Content Correction</option>
                <option value="Other" style="background: #1a1a2e;">Other</option>
              </select>
            </div>

            <!-- Message -->
            <div>
              <label for="message" class="block text-sm font-medium text-white mb-2">Message</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="w-full rounded-xl px-4 py-3 text-white outline-none focus:ring-2 focus:ring-[var(--primary)]/50 transition-all resize-none"
                style="background: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255, 255, 255, 0.15);"
                placeholder="How can we help you?"
              ></textarea>
            </div>

            <!-- Submit Button -->
            <button
              type="submit"
              class="w-full btn btn-primary btn-lg relative overflow-hidden uppercase tracking-wider before:absolute before:inset-0 before:bg-gradient-to-r before:from-transparent before:via-white/20 before:to-transparent before:-translate-x-full hover:before:translate-x-full before:transition-transform before:duration-700"
              style="font-family: var(--font-display);"
            >
              Send Message
            </button>
          </form>

          <!-- Success Message (hidden by default) -->
          <div id="success-message" class="hidden text-center py-8">
            <div class="w-16 h-16 mx-auto rounded-full bg-emerald-500/20 border border-emerald-500/30 flex items-center justify-center mb-4">
              <svg class="w-8 h-8 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-2">Message Sent!</h3>
            <p class="text-white/70">Thank you for reaching out. We'll get back to you soon.</p>
          </div>
        </div>
      </div>

      <!-- Direct Email Option -->
      <div class="max-w-xl mx-auto mt-8 text-center">
        <p class="text-white/60 text-sm">
          Prefer email? Reach us directly at
          <a href="mailto:info@pepcodex.com" class="text-primary hover:underline">info@pepcodex.com</a>
        </p>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMessage = document.getElementById('success-message');

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const originalText = submitButton?.textContent || 'Send Message';

      if (submitButton) {
        submitButton.textContent = 'Sending...';
        submitButton.disabled = true;
      }

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: {
            'Accept': 'application/json'
          }
        });

        if (response.ok) {
          form.classList.add('hidden');
          successMessage?.classList.remove('hidden');
        } else {
          throw new Error('Form submission failed');
        }
      } catch (error) {
        if (submitButton) {
          submitButton.textContent = originalText;
          submitButton.disabled = false;
        }
        alert('Something went wrong. Please try again or email us directly.');
      }
    });
  }
</script>
