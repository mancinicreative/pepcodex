---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

// Get all blog posts, sorted by date (newest first)
const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => {
  const dateDiff = b.data.publishDate.valueOf() - a.data.publishDate.valueOf();
  if (dateDiff !== 0) return dateDiff;
  return a.slug.localeCompare(b.slug);
});

// Separate featured posts
const featuredPosts = sortedPosts.filter(post => post.data.featured);
const regularPosts = sortedPosts.filter(post => !post.data.featured);

// Get unique categories for filtering
const categories = [...new Set(allPosts.map(post => post.data.category))];

const categoryLabels: Record<string, string> = {
  'weekly-briefing': 'Weekly Briefing',
  'research-digest': 'Research Digest',
  'deep-dive': 'Deep Dive',
  'regulatory': 'Regulatory',
  'explainer': 'Explainer',
  'guide': 'Guides',
  'safety': 'Safety',
};
---

<BaseLayout
  title="Blog"
  description="Weekly peptide research briefings, regulatory updates, and deep dives into the latest clinical trials and discoveries."
>
  <div class="space-y-12">
    <!-- Hero Section -->
    <header>
      <div class="py-4">
        <span class="eyebrow">Research Blog</span>

        <h1 class="font-serif mt-3 text-4xl lg:text-5xl mb-4" style="color: var(--ink); font-weight: 500;">
          Peptide Research Briefings
        </h1>

        <p class="text-xl max-w-3xl leading-relaxed" style="color: var(--ink-muted);">
          Weekly updates on clinical trials, regulatory developments, and breakthrough research in peptide therapeutics. Evidence-based analysis with full citations.
        </p>

        <!-- Stats -->
        <div class="mt-8 flex flex-wrap gap-8">
          <div>
            <div class="font-serif text-3xl" style="color: var(--ink); font-weight: 500;">{allPosts.length}</div>
            <div class="eyebrow mt-1" style="color: var(--ink-dim);">Articles</div>
          </div>
          <div>
            <div class="font-serif text-3xl" style="color: var(--ink); font-weight: 500;">{categories.length}</div>
            <div class="eyebrow mt-1" style="color: var(--ink-dim);">Categories</div>
          </div>
          <div>
            <div class="font-serif text-3xl" style="color: var(--primary-c); font-weight: 500;">Weekly</div>
            <div class="eyebrow mt-1" style="color: var(--ink-dim);">Updates</div>
          </div>
        </div>
      </div>
    </header>

    <!-- Category Filters -->
    <div class="flex flex-wrap gap-2">
      <button
        class="filter-btn filter-btn--active filter-active px-4 py-2 rounded-xl text-sm font-medium transition-all duration-300"
        data-category="all"
      >
        All Posts
      </button>
      {categories.map(category => (
        <button
          class="filter-btn filter-inactive px-4 py-2 rounded-xl text-sm font-medium transition-all duration-300"
          data-category={category}
        >
          {categoryLabels[category] || category}
        </button>
      ))}
    </div>

    <!-- Featured Posts -->
    {featuredPosts.length > 0 && (
      <section>
        <h2 class="font-serif text-xl mb-6" style="color: var(--ink); font-weight: 500;">Featured</h2>
        <div class="grid gap-6 md:grid-cols-2">
          {featuredPosts.slice(0, 2).map(post => (
            <BlogCard
              title={post.data.title}
              slug={post.slug}
              category={post.data.category}
              publishDate={post.data.publishDate}
              excerpt={post.data.excerpt}
              author={post.data.author}
              tags={post.data.tags}
              featured={true}
            />
          ))}
        </div>
      </section>
    )}

    <!-- All Posts Grid -->
    <section>
      <h2 class="font-serif text-xl mb-6" style="color: var(--ink); font-weight: 500;">Latest Posts</h2>
      <div id="posts-grid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {regularPosts.map(post => (
          <div data-category={post.data.category}>
            <BlogCard
              title={post.data.title}
              slug={post.slug}
              category={post.data.category}
              publishDate={post.data.publishDate}
              excerpt={post.data.excerpt}
              author={post.data.author}
              tags={post.data.tags}
            />
          </div>
        ))}
      </div>

      {sortedPosts.length === 0 && (
        <div class="text-center py-12">
          <svg class="w-16 h-16 mx-auto mb-4" style="color: var(--ink-dim);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
            <path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/>
          </svg>
          <h3 class="font-serif text-xl mb-2" style="color: var(--ink-muted); font-weight: 500;">No posts yet</h3>
          <p style="color: var(--ink-dim);">Check back soon for peptide research updates.</p>
        </div>
      )}
    </section>

    <!-- Newsletter CTA -->
    <section class="glass-card p-8 lg:p-12">
      <div class="max-w-2xl">
        <h2 class="font-serif text-2xl lg:text-3xl mb-4" style="color: var(--ink); font-weight: 500;">
          Never Miss a Briefing
        </h2>
        <p class="mb-6" style="color: var(--ink-muted);">
          Subscribe to receive weekly peptide research updates, regulatory news, and clinical trial analysis directly in your inbox.
        </p>
        <a href="/newsletter" class="btn btn-cobalt btn-md">
          Subscribe to Newsletter
        </a>
      </div>
    </section>
  </div>

  <style>
    .filter-active {
      background: var(--ink);
      color: var(--ink-paper);
      border: 1px solid var(--ink);
    }
    .filter-inactive {
      background: var(--paper);
      color: var(--ink-muted);
      border: 1px solid var(--border-c);
    }
    .filter-inactive:hover {
      background: var(--paper-2);
      color: var(--ink);
    }
  </style>

  <!-- Client-side filtering script -->
  <script>
    const filterButtons = document.querySelectorAll('.filter-btn');
    const postsGrid = document.getElementById('posts-grid');
    const postItems = postsGrid?.querySelectorAll('[data-category]');

    const activeClasses = ['filter-active'];
    const inactiveClasses = ['filter-inactive'];

    filterButtons.forEach(button => {
      button.addEventListener('click', () => {
        const category = button.getAttribute('data-category');

        // Update active state - swap classes
        filterButtons.forEach(btn => {
          btn.classList.remove('filter-btn--active', ...activeClasses);
          btn.classList.add(...inactiveClasses);
        });
        button.classList.add('filter-btn--active', ...activeClasses);
        button.classList.remove(...inactiveClasses);

        // Filter posts
        postItems?.forEach(item => {
          if (category === 'all' || item.getAttribute('data-category') === category) {
            (item as HTMLElement).style.display = '';
          } else {
            (item as HTMLElement).style.display = 'none';
          }
        });
      });
    });
  </script>
</BaseLayout>
