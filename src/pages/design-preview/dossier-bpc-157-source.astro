  .plate-frame { grid-template-columns: 1fr; }
  .section { grid-template-columns: 1fr; }
  .section-head-col { position: static; }
  .mech-row, .evidence-bento, .q-grid, .adj-grid { grid-template-columns: 1fr; }
  .timeline-h { grid-template-columns: 1fr 1fr; }
