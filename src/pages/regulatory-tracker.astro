---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import BreadcrumbSchema from '../components/SEO/BreadcrumbSchema.astro';
import TrackerSwitcher from '../components/TrackerSwitcher.astro';

const peptides = await getCollection('peptides');

// Group by status
const statusOrder = ['approved', 'investigational', 'compounding-restricted', 'research-only'];
const statusLabels: Record<string, string> = {
  'approved': 'FDA Approved',
  'investigational': 'Investigational',
  'compounding-restricted': 'Compounding Restricted',
  'research-only': 'Research Only',
};
// Status colors mapped to brand signals (inline styles, meaningful):
// approved → research green, investigational → cobalt, compounding-restricted → compound amber, research-only → muted
const statusColors: Record<string, string> = {
  'approved': 'background: rgba(20,118,74,.12); color: var(--research); border: 1px solid rgba(20,118,74,.28);',
  'investigational': 'background: var(--primary-soft); color: var(--primary-c); border: 1px solid var(--primary-border);',
  'compounding-restricted': 'background: rgba(203,135,52,.14); color: #9a6418; border: 1px solid rgba(203,135,52,.30);',
  'research-only': 'background: var(--paper-2); color: var(--ink-muted); border: 1px solid var(--border-c);',
};

// Sort peptides with regulatory status
const sorted = peptides
  .filter(p => p.data.regulatoryStatus)
  .sort((a, b) => {
    const aIdx = statusOrder.indexOf(a.data.regulatoryStatus!.status);
    const bIdx = statusOrder.indexOf(b.data.regulatoryStatus!.status);
    if (aIdx !== bIdx) return aIdx - bIdx;
    return a.data.name.localeCompare(b.data.name);
  });

// Counts
const counts: Record<string, number> = {};
for (const p of sorted) {
  const s = p.data.regulatoryStatus!.status;
  counts[s] = (counts[s] || 0) + 1;
}

// Derived freshness — no hardcoded count/date (staleness-literal sweeper pattern).
const trackedCount = sorted.length;
const lastUpdatedDate = sorted
  .map((p) => p.data.regulatoryStatus?.lastUpdated)
  .filter(Boolean)
  .map((d) => new Date(d as any))
  .sort((a, b) => b.getTime() - a.getTime())[0];
const lastUpdatedLabel = lastUpdatedDate
  ? lastUpdatedDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' })
  : '';
const trackerDescription = `Track FDA approval status, clinical trial phases, and regulatory changes for ${trackedCount} peptides${lastUpdatedLabel ? `. Updated ${lastUpdatedLabel}` : ''}.`;

const categoryLabels: Record<string, string> = {
  'metabolic': 'Metabolic',
  'repair-recovery': 'Recovery',
  'hormonal': 'Hormonal',
  'longevity': 'Longevity',
  'cognitive': 'Cognitive',
  'immune': 'Immune',
  'other': 'Other',
};
---

<BaseLayout
  title="Peptide Regulatory Tracker"
  description="Track FDA approval status, clinical trial phases, and regulatory changes for 92 peptides. Updated February 2026."
>
  <BreadcrumbSchema items={[
    { name: 'Home', url: 'https://www.pepcodex.com/' },
    { name: 'Regulatory Tracker', url: 'https://www.pepcodex.com/regulatory-tracker/' },
  ]} />

  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center gap-2 text-sm mb-4" style="color: var(--ink-dim);">
        <a href="/" class="transition-colors hover:text-[color:var(--ink)]">Home</a>
        <span>/</span>
        <span style="color: var(--ink-muted);">Regulatory Tracker</span>
      </div>
      <h1 class="font-serif text-3xl md:text-4xl mb-3" style="color: var(--ink); font-weight: 500;">
        Peptide Regulatory Tracker
      </h1>
      <p class="text-lg leading-relaxed max-w-3xl" style="color: var(--ink-muted);">
        FDA approval status and regulatory classification for {sorted.length} peptides. Updated as regulatory changes occur.
      </p>
      <div class="mt-5">
        <TrackerSwitcher active="regulatory" />
      </div>
    </div>

    <!-- Status summary cards -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-8">
      {statusOrder.map(status => (
        <button
          data-filter={status}
          class="filter-btn rounded-xl p-4 text-left transition-all hover:scale-[1.02] cursor-pointer"
          style={statusColors[status]}
        >
          <div class="text-2xl font-bold mb-1">{counts[status] || 0}</div>
          <div class="text-sm opacity-80">{statusLabels[status]}</div>
        </button>
      ))}
    </div>

    <!-- Search + filter bar -->
    <div class="flex flex-col sm:flex-row gap-3 mb-6">
      <div class="relative flex-1">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4" style="color: var(--ink-dim);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8" />
          <path d="m21 21-4.3-4.3" />
        </svg>
        <input
          type="search"
          id="reg-search"
          placeholder="Search peptides..."
          class="reg-input w-full pl-10 pr-4 py-2.5 rounded-lg text-sm focus:outline-none focus:border-[var(--primary)]/50"
          style="background: var(--paper-2); border: 1px solid var(--border-c); color: var(--ink);"
        />
      </div>
      <select
        id="reg-category"
        class="px-4 py-2.5 rounded-lg text-sm focus:outline-none focus:border-[var(--primary)]/50"
        style="background: var(--paper-2); border: 1px solid var(--border-c); color: var(--ink);"
      >
        <option value="">All Categories</option>
        {Object.entries(categoryLabels).map(([val, label]) => (
          <option value={val}>{label}</option>
        ))}
      </select>
      <button
        id="reg-reset"
        class="px-4 py-2.5 rounded-lg text-sm transition-colors hidden hover:text-[color:var(--ink)]"
        style="border: 1px solid var(--border-c); color: var(--ink-muted);"
      >
        Clear Filters
      </button>
    </div>

    <!-- Table -->
    <div class="rounded-xl overflow-hidden" style="border: 1px solid var(--border-c);">
      <div class="overflow-x-auto ledger-scroll">
        <table class="w-full text-sm ledger">
          <thead>
            <tr style="border-bottom: 1px solid var(--border-c);">
              <th class="text-left px-4 py-3 font-semibold uppercase tracking-wider cursor-pointer hover:text-[color:var(--ink)]" style="color: var(--ink-muted); font-family: var(--font-mono); font-size: 0.7rem;" data-sort="name">
                Peptide
                <svg class="inline w-3 h-3 ml-1 opacity-40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
              </th>
              <th class="text-left px-4 py-3 font-semibold uppercase tracking-wider" style="color: var(--ink-muted); font-family: var(--font-mono); font-size: 0.7rem;">Status</th>
              <th class="text-left px-4 py-3 font-semibold uppercase tracking-wider hidden md:table-cell" style="color: var(--ink-muted); font-family: var(--font-mono); font-size: 0.7rem;">Category</th>
              <th class="text-left px-4 py-3 font-semibold uppercase tracking-wider hidden lg:table-cell" style="color: var(--ink-muted); font-family: var(--font-mono); font-size: 0.7rem;">Evidence</th>
              <th class="text-left px-4 py-3 font-semibold uppercase tracking-wider hidden md:table-cell" style="color: var(--ink-muted); font-family: var(--font-mono); font-size: 0.7rem;">Notes</th>
            </tr>
          </thead>
          <tbody id="reg-tbody">
            {sorted.map(p => {
              const reg = p.data.regulatoryStatus!;
              return (
                <tr
                  class="reg-row transition-colors"
                  style="border-bottom: 1px solid var(--border-c);"
                  data-name={p.data.name.toLowerCase()}
                  data-status={reg.status}
                  data-category={p.data.category}
                >
                  <td class="px-4 py-3">
                    <a href={`/peptides/${p.id}/`} class="font-medium hover:text-[var(--primary)] transition-colors" style="color: var(--ink);">
                      {p.data.name}
                    </a>
                    {p.data.aliases.length > 0 && (
                      <div class="text-xs mt-0.5" style="color: var(--ink-dim);">
                        {p.data.aliases.slice(0, 2).join(', ')}
                      </div>
                    )}
                  </td>
                  <td class="px-4 py-3">
                    <span class="inline-flex px-2.5 py-1 rounded-full text-xs font-medium" style={statusColors[reg.status]}>
                      {statusLabels[reg.status]}
                    </span>
                  </td>
                  <td class="px-4 py-3 hidden md:table-cell">
                    <span class="text-xs" style="color: var(--ink-muted);">{categoryLabels[p.data.category]}</span>
                  </td>
                  <td class="px-4 py-3 hidden lg:table-cell">
                    <span
                      class="text-xs font-medium"
                      style={
                        p.data.evidenceStrength === 'high' ? 'color: var(--research);' :
                        p.data.evidenceStrength === 'moderate' ? 'color: var(--primary-c);' :
                        p.data.evidenceStrength === 'low' ? 'color: #9a6418;' :
                        'color: var(--ink-dim);'
                      }
                    >
                      {p.data.evidenceStrength.charAt(0).toUpperCase() + p.data.evidenceStrength.slice(1)}
                    </span>
                  </td>
                  <td class="px-4 py-3 hidden md:table-cell">
                    <span class="text-xs leading-relaxed" style="color: var(--ink-dim);">
                      {reg.notes && reg.notes.length > 120 ? reg.notes.slice(0, 120) + '...' : reg.notes}
                    </span>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Results count -->
    <div class="mt-4 text-sm" style="color: var(--ink-dim);">
      <span id="reg-count">{sorted.length}</span> of {sorted.length} peptides shown
    </div>

    <!-- Disclaimer -->
    <div class="mt-8 p-4 rounded-xl" style="border: 1px solid var(--border-c); background: var(--paper-2);">
      <p class="text-xs leading-relaxed" style="color: var(--ink-dim);">
        <strong style="color: var(--ink-muted);">Disclaimer:</strong> This tracker is for informational purposes only. Regulatory status reflects publicly available information from FDA, ClinicalTrials.gov, and manufacturer disclosures. Status may change without notice. This is not medical or legal advice. Always verify current regulatory status through official channels before making any decisions.
      </p>
    </div>
  </div>

  <style>
    .reg-row:hover { background: var(--paper-2); }
    #regulatory-tracker option, .reg-input option { background-color: var(--paper); color: var(--ink); }
    /* Ledger: zebra rows + sticky headers for the 102-row tracker */
    .ledger tbody tr:nth-child(even) { background: rgba(31, 26, 18, 0.018); }
    .ledger thead th {
      position: sticky;
      top: 0;
      z-index: 2;
      background: var(--paper-2);
      box-shadow: inset 0 -1px 0 var(--border-c);
    }
    @media (min-width: 768px) {
      .ledger-scroll { max-height: 72vh; overflow: auto; }
    }
  </style>
</BaseLayout>

<script>
  const search = document.getElementById('reg-search') as HTMLInputElement;
  const categorySelect = document.getElementById('reg-category') as HTMLSelectElement;
  const resetBtn = document.getElementById('reg-reset') as HTMLButtonElement;
  const tbody = document.getElementById('reg-tbody')!;
  const countEl = document.getElementById('reg-count')!;
  const filterBtns = document.querySelectorAll('.filter-btn');

  let activeStatus = '';

  function applyFilters() {
    const query = search.value.toLowerCase().trim();
    const cat = categorySelect.value;
    const rows = tbody.querySelectorAll('tr');
    let visible = 0;

    rows.forEach(row => {
      const el = row as HTMLElement;
      const name = el.dataset.name || '';
      const status = el.dataset.status || '';
      const rowCat = el.dataset.category || '';

      const matchSearch = !query || name.includes(query);
      const matchStatus = !activeStatus || status === activeStatus;
      const matchCat = !cat || rowCat === cat;

      if (matchSearch && matchStatus && matchCat) {
        el.style.display = '';
        visible++;
      } else {
        el.style.display = 'none';
      }
    });

    countEl.textContent = String(visible);
    resetBtn.classList.toggle('hidden', !query && !activeStatus && !cat);

    // Update active filter button styling
    filterBtns.forEach(btn => {
      const el = btn as HTMLElement;
      if (el.dataset.filter === activeStatus) {
        el.style.outline = '2px solid var(--primary-c)';
        el.style.outlineOffset = '2px';
      } else {
        el.style.outline = '';
        el.style.outlineOffset = '';
      }
    });
  }

  search.addEventListener('input', applyFilters);
  categorySelect.addEventListener('change', applyFilters);

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const status = (btn as HTMLElement).dataset.filter || '';
      activeStatus = activeStatus === status ? '' : status;
      applyFilters();
    });
  });

  resetBtn.addEventListener('click', () => {
    search.value = '';
    categorySelect.value = '';
    activeStatus = '';
    applyFilters();
  });
</script>
