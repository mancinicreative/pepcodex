<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>BPC-157 · Source-close Dossier Preview · PepCodex</title>
<meta name="robots" content="noindex,nofollow">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg:           #F6F1E7;
  --bg-grad:      radial-gradient(ellipse 80% 60% at 20% 0%, oklch(0.78 0.04 70 / 0.30), transparent 60%),
                  radial-gradient(ellipse 70% 50% at 100% 100%, oklch(0.82 0.05 55 / 0.20), transparent 60%),
                  #F6F1E7;
  --paper:        #FBF7EE;
  --paper-2:      #EFE8D8;
  --paper-3:      #E0D7C2;
  --border:       #DBD2BC;
  --border-strong:#BFB59C;
  --rule:         #E5DBC4;

  --ink:          #1F1A12;
  --ink-muted:    #5C5341;
  --ink-dim:      #8E8567;
  --ink-paper:    #FBF7EE;

  --primary:        oklch(0.42 0.10 245);
  --primary-deep:   oklch(0.30 0.10 245);
  --primary-soft:   oklch(0.42 0.10 245 / 0.10);
  --primary-border: oklch(0.42 0.10 245 / 0.26);

  --primary-grad:      linear-gradient(135deg, oklch(0.50 0.11 248) 0%, oklch(0.34 0.09 240) 100%);
  --primary-grad-deep: linear-gradient(135deg, oklch(0.30 0.10 245) 0%, oklch(0.20 0.07 235) 100%);
  --hero-grad:         linear-gradient(135deg, oklch(0.42 0.10 245) 0%, oklch(0.46 0.08 200) 100%);
  --positive-grad:     linear-gradient(135deg, oklch(0.62 0.12 152) 0%, oklch(0.44 0.10 168) 100%);
  --warning-grad:      linear-gradient(135deg, oklch(0.78 0.14 78) 0%, oklch(0.58 0.13 42) 100%);
  --danger-grad:       linear-gradient(135deg, oklch(0.62 0.17 32) 0%, oklch(0.46 0.16 6) 100%);

  --recovery:        oklch(0.54 0.08 70);
  --recovery-soft:   oklch(0.54 0.08 70 / 0.14);
  --recovery-border: oklch(0.54 0.08 70 / 0.36);

  --amber:         oklch(0.66 0.13 60);
  --amber-soft:    oklch(0.66 0.13 60 / 0.16);
  --amber-border:  oklch(0.66 0.13 60 / 0.34);
  --amber-grad:    linear-gradient(135deg, oklch(0.78 0.14 78) 0%, oklch(0.58 0.13 42) 100%);

  --bad:           oklch(0.54 0.16 22);
  --bad-soft:      oklch(0.54 0.16 22 / 0.10);

  --sans: "Inter", -apple-system, system-ui, sans-serif;
  --mono: "JetBrains Mono", "SF Mono", ui-monospace, Menlo, monospace;

  --shadow-card: 0 1px 0 rgba(31,26,18,0.02), 0 2px 6px rgba(31,26,18,0.04);
  --shadow-raise: 0 12px 30px rgba(31,26,18,0.10);
}

* { box-sizing: border-box; }
html, body { margin: 0; padding: 0; }
body {
  background: var(--bg-grad);
  background-attachment: fixed;
  color: var(--ink);
  font-family: var(--sans);
  -webkit-font-smoothing: antialiased;
  font-size: 16px;
  line-height: 1.55;
}
a { color: inherit; text-decoration: none; }
.mono-label, .eyebrow {
  font-family: var(--mono);
  font-size: 11px; font-weight: 700;
  letter-spacing: 1.6px; text-transform: uppercase;
  color: var(--ink-muted);
}
.mono-label.s { font-size: 10px; letter-spacing: 1.4px; }

/* ───── MASTHEAD (compact) ───── */
.masthead {
  border-top: 3px solid var(--ink);
  border-bottom: 1px solid var(--border);
  background: color-mix(in oklch, var(--bg) 92%, transparent);
  position: relative;
}
.masthead::after {
  content:""; position: absolute;
  left: 0; right: 0; bottom: -3px;
  height: 1px; background: var(--ink);
}
.masthead-inner {
  max-width: 1240px; margin: 0 auto;
  padding: 14px 32px;
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  align-items: center;
  gap: 24px;
}
.masthead-left, .masthead-right {
  display: flex; align-items: center; gap: 22px;
  font-family: var(--mono); font-size: 11px; font-weight: 700;
  letter-spacing: 1.6px; text-transform: uppercase; color: var(--ink-muted);
}
.masthead-right { justify-content: flex-end; }
.masthead-left a:hover, .masthead-right a:hover { color: var(--ink); }
.masthead-title {
  text-align: center;
  font-family: var(--sans); font-weight: 800;
  font-size: 18px; letter-spacing: -0.4px;
  display: inline-flex; align-items: center; gap: 14px;
}
.masthead-title .fleur {
  font-family: "Times New Roman", "Times", serif;
  font-style: italic;
  font-weight: 400;
  font-size: 18px;
  color: var(--amber);
  transform: translateY(-1px);
  letter-spacing: 0;
}

/* Sub-rule with breadcrumb */
.dateline {
  border-bottom: 1px solid var(--border);
  background: color-mix(in oklch, var(--bg) 96%, transparent);
}
.dateline-inner {
  max-width: 1240px; margin: 0 auto;
  padding: 8px 32px;
  display: flex; justify-content: space-between; align-items: center;
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: 1.6px; text-transform: uppercase; color: var(--ink-muted);
}
.crumbs { display: flex; align-items: center; gap: 10px; }
.crumbs a:hover { color: var(--ink); }
.crumbs .sep { color: var(--ink-dim); }
.crumbs .here { color: var(--ink); }

.util-row { display: flex; gap: 8px; }
.util {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 4px 8px; border: 1px solid var(--border); border-radius: 6px;
  background: var(--paper);
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: 1.3px; text-transform: uppercase; color: var(--ink-muted);
}
.util:hover { color: var(--ink); border-color: var(--border-strong); }

/* ───── NOW-READING TICKER ───── */
.now-reading {
  border-bottom: 1px solid var(--border);
  background: var(--paper);
}
.now-reading-inner {
  max-width: 1240px; margin: 0 auto;
  padding: 10px 32px;
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 20px;
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: 1.4px; text-transform: uppercase;
}
.now-reading-tag {
  display: inline-flex; align-items: center; gap: 8px; color: var(--ink);
}
.now-reading-tag .pulse {
  width: 7px; height: 7px; border-radius: 50%;
  background: var(--good, oklch(0.50 0.11 158));
  box-shadow: 0 0 0 3px oklch(0.50 0.11 158 / 0.20);
  animation: nr-pulse 2s ease-in-out infinite;
}
@keyframes nr-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.55; }
}
.now-reading-list {
  display: flex; gap: 28px;
  overflow: hidden; white-space: nowrap;
  color: var(--ink-muted);
  mask-image: linear-gradient(90deg, transparent 0, #000 4%, #000 96%, transparent 100%);
  -webkit-mask-image: linear-gradient(90deg, transparent 0, #000 4%, #000 96%, transparent 100%);
}
.now-reading-list .item {
  display: inline-flex; align-items: center; gap: 10px; flex-shrink: 0;
}
.now-reading-list .item .v {
  font-family: var(--sans); font-weight: 700; color: var(--ink);
  letter-spacing: 0; font-size: 13px; text-transform: none;
}
.now-reading-list .item .v.italic {
  font-style: italic; font-weight: 500;
}
.now-reading-list .dot {
  width: 4px; height: 4px; border-radius: 50%; background: var(--ink-dim);
}
.now-reading-more { color: var(--ink-muted); }
.now-reading-more:hover { color: var(--ink); }

/* ───── RECORD NAV + DECISION STRIP ───── */
.record-jump {
  position: sticky;
  top: 0;
  z-index: 20;
  border-bottom: 1px solid var(--border);
  background: color-mix(in oklch, var(--paper) 90%, transparent);
  backdrop-filter: blur(16px);
}
.record-jump-inner {
  max-width: 1240px; margin: 0 auto;
  padding: 8px 32px;
  display: flex; align-items: center; justify-content: space-between; gap: 16px;
}
.record-jump .label {
  font-family: var(--mono); font-size: 10px; font-weight: 800;
  letter-spacing: 1.4px; text-transform: uppercase; color: var(--ink-dim);
}
.jump-links { display: flex; gap: 6px; overflow-x: auto; scrollbar-width: none; }
.jump-links::-webkit-scrollbar { display: none; }
.jump-links a {
  min-height: 36px;
  display: inline-flex; align-items: center; justify-content: center;
  padding: 0 12px;
  border: 1px solid var(--border);
  border-radius: 999px;
  background: var(--paper);
  color: var(--ink-muted);
  font-family: var(--mono); font-size: 10px; font-weight: 800;
  letter-spacing: 1.2px; text-transform: uppercase;
  white-space: nowrap;
}
.jump-links a:hover { color: var(--ink); border-color: var(--border-strong); transform: translateY(-1px); }
.decision-strip {
  max-width: 1240px; margin: 0 auto;
  padding: 0 32px 30px;
  display: grid; grid-template-columns: minmax(0, 1.45fr) minmax(260px, .8fr);
  gap: 16px;
}
.decision-card {
  border: 1px solid var(--border-strong);
  border-radius: 18px;
  background: linear-gradient(135deg, var(--paper) 0%, var(--paper-2) 100%);
  box-shadow: var(--shadow-card);
  padding: 18px;
}
.decision-card.primary {
  display: grid; grid-template-columns: auto minmax(0, 1fr); gap: 16px; align-items: start;
  border-top: 3px solid var(--ink);
}
.decision-mark {
  width: 54px; height: 54px; border-radius: 16px;
  background: var(--ink); color: var(--ink-paper);
  display: grid; place-items: center;
  font-size: 26px; font-weight: 900; letter-spacing: -.08em;
}
.decision-card h2 { margin: 0 0 8px; font-size: clamp(22px, 2.2vw, 34px); line-height: 1.02; letter-spacing: -1px; }
.decision-card p { margin: 0; color: var(--ink-muted); }
.decision-meta {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-top: 14px;
}
.decision-meta span {
  border: 1px solid var(--border); border-radius: 12px;
  background: color-mix(in oklch, var(--paper) 70%, var(--paper-2));
  padding: 10px;
  font-family: var(--mono); font-size: 10px; font-weight: 800; letter-spacing: 1.1px; text-transform: uppercase;
  color: var(--ink-muted);
}
.decision-meta strong { display: block; margin-top: 4px; font-family: var(--sans); font-size: 18px; letter-spacing: -.04em; color: var(--ink); text-transform: none; }
.app-boundary-mini { display: flex; flex-direction: column; gap: 12px; }
.app-boundary-mini .cta-row { display: flex; gap: 8px; flex-wrap: wrap; }
.button-mini {
  min-height: 40px; display: inline-flex; align-items: center; justify-content: center;
  border-radius: 999px; padding: 0 14px;
  border: 1px solid var(--ink); background: var(--ink); color: var(--ink-paper);
  font-family: var(--mono); font-size: 10px; font-weight: 800; letter-spacing: 1.1px; text-transform: uppercase;
}
.button-mini.secondary { background: transparent; color: var(--ink); border-color: var(--border-strong); }

/* ───── RECORD BANNER ───── */
.sheet-head {
  max-width: 1240px; margin: 0 auto;
  padding: 40px 32px 24px;
  position: relative;
}
.record-banner {
  display: grid;
  grid-template-columns: auto 1fr auto auto;
  gap: 32px;
  align-items: end;
  padding-bottom: 18px;
  border-bottom: 2px solid var(--ink);
}
.record-banner .record-no {
  font-family: var(--sans); font-style: italic; font-weight: 800;
  font-size: 22px; letter-spacing: -0.2px; color: var(--ink);
}
.record-banner .record-no .roman {
  background: var(--hero-grad);
  -webkit-background-clip: text; background-clip: text; color: transparent;
}
.record-banner .center-label {
  text-align: center;
  font-family: var(--mono); font-size: 11px; font-weight: 700;
  letter-spacing: 2.4px; text-transform: uppercase; color: var(--ink-muted);
}
.record-banner .drawer-tag {
  display: inline-flex; align-items: center; gap: 8px;
  font-family: var(--mono); font-size: 11px; font-weight: 700;
  letter-spacing: 1.6px; text-transform: uppercase;
  padding: 6px 10px; border-radius: 6px;
  background: var(--recovery-soft); border: 1px solid var(--recovery-border);
  color: var(--recovery);
}
.record-banner .drawer-tag .letter {
  width: 16px; height: 16px;
  border-radius: 3px;
  background: var(--positive-grad);
  color: var(--ink-paper);
  display: grid; place-items: center;
  font-size: 9px; font-weight: 700;
}
.record-banner .entry-no {
  font-family: var(--mono); font-size: 11px; font-weight: 700;
  letter-spacing: 1.6px; color: var(--ink-muted);
}

/* ───── TITLE BLOCK ───── */
.title-block {
  max-width: 1240px; margin: 0 auto;
  padding: 24px 32px 48px;
}
.title-block .title-row {
  display: grid;
  grid-template-columns: 1.4fr 0.7fr;
  gap: 48px;
  align-items: end;
}
.title-block .h1-row {
  display: flex; align-items: baseline; gap: 24px;
}
.title-block h1 {
  font-size: clamp(72px, 9vw, 132px);
  font-weight: 800;
  letter-spacing: -3.4px;
  line-height: 0.9;
  margin: 0;
}
.title-block h1 .accent {
  background: var(--hero-grad);
  -webkit-background-clip: text; background-clip: text;
  color: transparent;
  font-style: italic;
}
.title-block .latin-name {
  font-family: var(--sans); font-style: italic;
  font-size: 19px; font-weight: 500;
  color: var(--ink-muted);
  margin-top: 18px;
  letter-spacing: 0;
  max-width: 540px;
  line-height: 1.45;
}
.title-block .aliases {
  font-family: var(--mono); font-size: 12px; font-weight: 500;
  color: var(--ink-dim); letter-spacing: 0.4px; margin-top: 12px;
}
/* Verdict capsule */
.verdict {
  display: flex; flex-direction: column; gap: 14px;
  padding: 18px 20px;
  background: var(--paper); border: 1px solid var(--border-strong);
  border-radius: 14px; position: relative;
  box-shadow: var(--shadow-card);
}
.verdict::before {
  content:""; position: absolute;
  top: 0; left: 0; right: 0; height: 4px;
  background: var(--amber-grad);
}
.verdict .v-head {
  font-family: var(--mono); font-size: 11px; font-weight: 700;
  letter-spacing: 1.6px; text-transform: uppercase; color: var(--ink-muted);
}
.verdict .grade {
  display: flex; align-items: baseline; gap: 14px;
}
.verdict .grade .dots {
  display: inline-flex; gap: 5px;
}
.verdict .grade .d {
  width: 13px; height: 13px; border-radius: 50%;
  border: 2px solid var(--ink); background: transparent;
}
.verdict .grade .d.on { background: var(--ink); }
.verdict .grade .label {
  font-family: var(--sans); font-size: 22px; font-weight: 800;
  letter-spacing: -0.3px; color: var(--ink);
}
.verdict .grade .label .sub {
  display: block; font-family: var(--mono); font-size: 10px;
  font-weight: 700; letter-spacing: 1.4px; text-transform: uppercase;
  color: var(--ink-muted); margin-top: 4px;
}
.verdict-bars { display: flex; flex-direction: column; gap: 8px; padding-top: 14px; border-top: 1px dashed var(--rule); }
.bar-mini {
  display: grid; grid-template-columns: 90px 1fr 36px;
  align-items: center; gap: 12px;
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: 1.2px; color: var(--ink-muted); text-transform: uppercase;
}
.bar-mini .track {
  height: 6px; background: var(--paper-2); border: 1px solid var(--rule); border-radius: 999px; overflow: hidden;
}
.bar-mini .fill { height: 100%; border-radius: 999px; }
.bar-mini.preclinical .fill { background: var(--primary-grad); width: 78%; }
.bar-mini.clinical .fill { background: var(--positive-grad); width: 4%; }
.bar-mini.safety .fill { background: var(--positive-grad); width: 56%; }
.bar-mini .v { color: var(--ink); text-align: right; font-variant-numeric: tabular-nums; }

/* ───── SPECIMEN RECORD — the centerpiece ───── */
.specimen-record {
  max-width: 1240px; margin: 0 auto;
  padding: 0 32px 80px;
}
.plate-frame {
  background: var(--paper);
  border: 1px solid var(--border-strong);
  border-radius: 18px;
  padding: 28px 32px 24px;
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 36px;
  position: relative;
}
.plate-frame .corner {
  position: absolute;
  width: 18px; height: 18px;
  border: 1.5px solid var(--ink-muted);
  opacity: 0.4;
}
.plate-frame .corner.tl { top: 10px; left: 10px; border-right: 0; border-bottom: 0; }
.plate-frame .corner.tr { top: 10px; right: 10px; border-left: 0; border-bottom: 0; }
.plate-frame .corner.bl { bottom: 10px; left: 10px; border-right: 0; border-top: 0; }
.plate-frame .corner.br { bottom: 10px; right: 10px; border-left: 0; border-top: 0; }

.plate-illus-col {
  display: flex; flex-direction: column;
  gap: 16px;
}
.plate-illus-frame {
  flex: 1;
  background: var(--paper-2);
  border: 1px dashed var(--border-strong);
  border-radius: 12px;
  padding: 24px;
  display: grid; place-items: center;
  position: relative;
  min-height: 380px;
}
.plate-illus-frame .placeholder-label {
  position: absolute;
  bottom: 14px; left: 16px;
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: 1.4px; text-transform: uppercase; color: var(--ink-dim);
}
.plate-illus-frame .scale {
  position: absolute;
  top: 14px; right: 16px;
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: 1.2px; color: var(--ink-dim);
}
.plate-illus-frame svg { width: 100%; height: 100%; max-height: 360px; }

.plate-caption {
  font-family: var(--sans); font-style: italic;
  font-size: 13px; line-height: 1.55; color: var(--ink-muted);
  text-align: center; padding: 0 24px;
}
.plate-caption strong { color: var(--ink); font-style: normal; font-weight: 700; }

/* Right side — labelled spec sheet */
.spec-sheet {
  display: flex; flex-direction: column; gap: 18px;
}
.spec-sheet h3 {
  font-size: 13px;
  font-family: var(--mono);
  font-weight: 700; letter-spacing: 1.6px;
  text-transform: uppercase;
  color: var(--ink-muted);
  margin: 0 0 4px;
  padding-bottom: 6px;
  border-bottom: 1px solid var(--rule);
}
.spec-rows {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 8px 20px;
  align-items: baseline;
  font-size: 14px;
}
.spec-rows .k {
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: 1.4px; text-transform: uppercase; color: var(--ink-dim);
  white-space: nowrap;
}
.spec-rows .v { color: var(--ink); font-weight: 600; }
.spec-rows .v.mono { font-family: var(--mono); font-size: 12.5px; letter-spacing: 0.2px; }
.spec-rows .v.muted { color: var(--ink-muted); font-weight: 500; }

/* Sequence ribbon */
.seq-ribbon {
  background: var(--paper-2);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 14px 16px;
  display: flex; flex-direction: column; gap: 10px;
}
.seq-ribbon .seq-row {
  display: grid;
  grid-template-columns: repeat(15, 1fr);
  gap: 4px;
}
.seq-ribbon .aa {
  display: flex; flex-direction: column; align-items: center; gap: 3px;
}
.seq-ribbon .aa .tick {
  font-family: var(--mono); font-size: 8px; font-weight: 600;
  color: var(--ink-dim); font-variant-numeric: tabular-nums;
}
.seq-ribbon .aa .letter {
  width: 100%; aspect-ratio: 1;
  display: grid; place-items: center;
  background: var(--paper); border: 1px solid var(--border);
  border-radius: 4px;
  font-family: var(--mono); font-weight: 700; font-size: 13px;
  color: var(--ink);
}
.seq-ribbon .aa[data-prop="acidic"] .letter { background: oklch(0.93 0.05 22); border-color: oklch(0.78 0.08 22); }
.seq-ribbon .aa[data-prop="basic"]  .letter { background: oklch(0.93 0.05 295); border-color: oklch(0.78 0.08 295); }
.seq-ribbon .aa[data-prop="special"] .letter { background: oklch(0.94 0.05 78); border-color: oklch(0.78 0.09 78); }
.seq-ribbon .seq-foot {
  display: flex; justify-content: space-between;
  font-family: var(--mono); font-size: 9px; font-weight: 700;
  letter-spacing: 1.2px; text-transform: uppercase; color: var(--ink-dim);
}

/* ───── BODY · multi-column editorial ───── */
.editorial {
  max-width: 1240px; margin: 0 auto;
  padding: 0 32px 80px;
}

.section {
  padding: 56px 0;
  border-top: 1px solid var(--border);
  display: grid;
  grid-template-columns: 220px 1fr;
  gap: 48px;
  align-items: start;
}
.section:first-child { border-top: 0; padding-top: 24px; }
.section-head-col {
  position: sticky; top: 16px;
  display: flex; flex-direction: column; gap: 10px;
}
.section-head-col .ornament {
  font-family: "Times New Roman", "Times", serif;
  font-style: italic; font-weight: 400;
  font-size: 22px;
  color: var(--amber);
  letter-spacing: 0;
  line-height: 1;
  margin-bottom: -2px;
}
.section-head-col .num {
  font-family: var(--sans); font-style: italic; font-weight: 800;
  font-size: 56px; letter-spacing: -1.6px; line-height: 0.9;
  background: var(--hero-grad);
  -webkit-background-clip: text; background-clip: text; color: transparent;
}
.section-head-col .label {
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: 1.6px; text-transform: uppercase; color: var(--ink-dim);
}
.section-head-col h2 {
  font-size: 26px; font-weight: 800; letter-spacing: -0.4px;
  margin: 0;
}
.section-head-col .marginalia {
  font-family: var(--sans); font-style: italic;
  font-size: 13px; line-height: 1.55; color: var(--ink-muted);
  padding-top: 14px; margin-top: 14px;
  border-top: 1px dashed var(--rule);
}
.section-body { display: flex; flex-direction: column; gap: 20px; min-width: 0; }

/* Editorial prose */
.prose { font-size: 17px; line-height: 1.72; color: var(--ink); }
.prose p { margin: 0 0 14px; color: var(--ink-muted); }
.prose p:first-of-type::first-letter {
  font-family: var(--sans); font-weight: 800; font-style: italic;
  font-size: 58px; line-height: 0.9;
  float: left; padding: 8px 12px 0 0;
  background: var(--hero-grad);
  -webkit-background-clip: text; background-clip: text; color: transparent;
  letter-spacing: -1.5px;
}
.prose strong { color: var(--ink); font-weight: 700; }
.prose .cite {
  font-family: var(--mono); font-size: 9px; font-weight: 700;
  letter-spacing: 0.6px; color: var(--primary);
  padding: 1px 4px; background: var(--primary-soft); border-radius: 4px;
  vertical-align: super; margin-left: 2px;
}

/* Pull quote */
.pullquote {
  font-family: var(--sans); font-style: italic; font-weight: 500;
  font-size: 26px; line-height: 1.35;
  color: var(--ink);
  padding: 24px 0;
  border-top: 2px solid var(--ink);
  border-bottom: 2px solid var(--ink);
  margin: 24px 0;
  letter-spacing: -0.3px;
  text-wrap: pretty;
}
.pullquote .attribution {
  display: block;
  font-family: var(--mono); font-style: normal; font-weight: 700;
  font-size: 10px; letter-spacing: 1.4px; text-transform: uppercase;
  color: var(--ink-muted); margin-top: 14px;
}

/* Mechanism cards — gentler version */
.mech-row {
  display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px;
}
.mech {
  background: var(--paper);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 18px 20px;
  display: flex; flex-direction: column; gap: 8px;
  position: relative;
}
.mech .roman {
  position: absolute; top: 14px; right: 18px;
  font-family: var(--sans); font-style: italic; font-weight: 800;
  font-size: 22px; letter-spacing: -0.3px;
  color: var(--ink-dim); opacity: 0.7;
}
.mech .head {
  display: flex; align-items: center; gap: 10px;
}
.mech .icon {
  width: 32px; height: 32px; border-radius: 8px;
  display: grid; place-items: center; color: var(--ink-paper);
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.18);
}
.mech[data-mech="1"] .icon { background: var(--primary-grad); }
.mech[data-mech="2"] .icon { background: var(--positive-grad); }
.mech[data-mech="3"] .icon { background: linear-gradient(135deg, oklch(0.66 0.15 305), oklch(0.48 0.14 285)); }
.mech[data-mech="4"] .icon { background: var(--warning-grad); }
.mech .name {
  font-size: 15px; font-weight: 700; color: var(--ink);
  letter-spacing: -0.15px;
}
.mech p { font-size: 13.5px; color: var(--ink-muted); line-height: 1.55; margin: 0; }

/* Pathway */
.pathway {
  background: var(--ink); color: var(--ink-paper);
  border-radius: 14px; padding: 22px 24px;
  display: flex; flex-direction: column; gap: 12px;
  position: relative; overflow: hidden;
}
.pathway::before {
  content:""; position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 60% 80% at 0% 0%, oklch(0.42 0.10 245 / 0.30), transparent 60%),
    radial-gradient(ellipse 60% 80% at 100% 100%, oklch(0.66 0.13 60 / 0.18), transparent 60%);
  pointer-events: none;
}
.pathway > * { position: relative; z-index: 1; }
.pathway .label {
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: 1.4px; text-transform: uppercase;
  color: rgba(251,247,238,0.66);
}
.pathway-chain {
  display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
  font-family: var(--mono); font-size: 13px; font-weight: 700;
}
.pathway-chain .node {
  background: rgba(251,247,238,0.06);
  border: 1px solid rgba(251,247,238,0.16);
  padding: 8px 12px; border-radius: 8px;
}
.pathway-chain .node.input { border-color: oklch(0.78 0.14 78 / 0.50); color: oklch(0.86 0.14 78); }
.pathway-chain .node.target {
  border-color: oklch(0.62 0.13 152 / 0.50); color: oklch(0.86 0.16 152);
  background: oklch(0.62 0.13 152 / 0.10);
}
.pathway-chain .arrow {
  color: rgba(251,247,238,0.46); font-family: var(--mono); font-size: 14px;
}
.pathway-result {
  border-top: 1px dashed rgba(251,247,238,0.18); padding-top: 12px;
  font-size: 13.5px; color: rgba(251,247,238,0.86); line-height: 1.55;
}

/* Evidence panel — bento style */
.evidence-bento {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
}
.evidence-card {
  background: var(--paper);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 18px 20px;
  display: flex; flex-direction: column; gap: 10px;
}
.evidence-card .e-head {
  display: flex; align-items: center; justify-content: space-between;
}
.evidence-card .e-name {
  font-size: 16px; font-weight: 700; letter-spacing: -0.2px;
  display: inline-flex; align-items: center; gap: 10px;
}
.evidence-card .e-name .ico {
  width: 28px; height: 28px; border-radius: 7px;
  background: var(--primary-grad);
  display: grid; place-items: center; color: var(--ink-paper);
}
.evidence-card[data-tone="gi"]      .e-name .ico { background: var(--warning-grad); }
.evidence-card[data-tone="brain"]   .e-name .ico { background: linear-gradient(135deg, oklch(0.66 0.15 305), oklch(0.48 0.14 285)); }
.evidence-card[data-tone="vascular"] .e-name .ico { background: var(--primary-grad); }
.evidence-card[data-tone="skin"]    .e-name .ico { background: var(--danger-grad); }
.evidence-card[data-tone="tendon"]  .e-name .ico { background: var(--positive-grad); }

.evidence-card .dots {
  display: inline-flex; gap: 4px;
}
.evidence-card .dots .d {
  width: 9px; height: 9px; border-radius: 50%;
  border: 1.5px solid var(--ink); background: transparent;
}
.evidence-card .dots .d.on { background: var(--ink); }
.evidence-card .e-meta {
  display: flex; gap: 8px; flex-wrap: wrap;
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: 1.3px; text-transform: uppercase; color: var(--ink-muted);
}
.evidence-card .e-meta .pill {
  padding: 3px 7px; border-radius: 5px; background: var(--paper-2); border: 1px solid var(--border);
}
.evidence-card .e-meta .pill.preclinical { background: var(--amber-soft); color: oklch(0.42 0.13 50); border-color: var(--amber-border); }
.evidence-card .e-meta .pill.case        { background: var(--primary-soft); color: var(--primary); border-color: var(--primary-border); }
.evidence-card p {
  font-size: 13.5px; color: var(--ink-muted); line-height: 1.55; margin: 0;
}

/* Timeline — compact horizontal */
.timeline-h {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
  position: relative;
}
.timeline-h::before {
  content:""; position: absolute;
  left: 16px; right: 16px; top: 24px;
  height: 2px;
  background: repeating-linear-gradient(90deg, var(--border) 0 8px, transparent 8px 14px);
}
.tlh {
  display: flex; flex-direction: column; gap: 10px;
  background: var(--paper); border: 1px solid var(--border);
  border-radius: 12px;
  padding: 14px 16px 16px;
  position: relative; z-index: 1;
}
.tlh .pin {
  display: flex; align-items: center; gap: 8px;
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: 1.4px; text-transform: uppercase; color: var(--ink-muted);
}
.tlh .pin .dot {
  width: 14px; height: 14px; border-radius: 50%;
  border: 2px solid var(--border-strong);
  background: var(--paper);
  display: grid; place-items: center;
  font-family: var(--mono); font-size: 8px; font-weight: 700;
  color: var(--ink-muted);
}
.tlh[data-state="peak"] .pin .dot { background: var(--positive-grad); border-color: oklch(0.40 0.10 168); color: var(--ink-paper); }
.tlh[data-state="started"] .pin .dot { background: var(--primary-grad); border-color: var(--primary-deep); color: var(--ink-paper); }
.tlh .when { font-size: 14px; font-weight: 700; color: var(--ink); }
.tlh p { font-size: 13px; color: var(--ink-muted); line-height: 1.55; margin: 0; }

/* Quality lists — minimal */
.q-grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px;
}
.q-block {
  background: var(--paper); border: 1px solid var(--border);
  border-radius: 12px; padding: 18px;
  display: flex; flex-direction: column; gap: 12px;
}
.q-block[data-kind="good"] { border-top: 3px solid oklch(0.50 0.11 158); }
.q-block[data-kind="warn"] { border-top: 3px solid var(--amber); }
.q-block[data-kind="bad"]  { border-top: 3px solid var(--bad); }
.q-block h5 {
  font-size: 16px; font-weight: 700; margin: 0;
  display: flex; align-items: center; gap: 10px;
}
.q-block h5 .badge {
  width: 26px; height: 26px; border-radius: 50%;
  display: grid; place-items: center; color: var(--ink-paper);
  font-family: var(--mono); font-weight: 700; font-size: 13px;
}
.q-block[data-kind="good"] h5 .badge { background: var(--positive-grad); }
.q-block[data-kind="warn"] h5 .badge { background: var(--amber-grad); }
.q-block[data-kind="bad"]  h5 .badge { background: var(--danger-grad); }
.q-block ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
.q-block li {
  display: flex; gap: 10px;
  font-size: 13px; color: var(--ink-muted); line-height: 1.5;
  padding-left: 14px; position: relative;
}
.q-block li::before {
  content:""; position: absolute; left: 0; top: 8px;
  width: 6px; height: 6px; border-radius: 50%;
}
.q-block[data-kind="good"] li::before { background: var(--positive-grad); }
.q-block[data-kind="warn"] li::before { background: var(--amber-grad); }
.q-block[data-kind="bad"]  li::before { background: var(--danger-grad); }

/* References — editorial endnotes */
.endnotes {
  display: flex; flex-direction: column; gap: 10px;
  padding-top: 8px;
}
.endnote {
  display: grid;
  grid-template-columns: 36px 1fr auto;
  gap: 14px;
  padding: 12px 0;
  border-bottom: 1px dashed var(--rule);
  align-items: baseline;
  font-size: 14px;
  line-height: 1.55;
}
.endnote:last-child { border-bottom: 0; }
.endnote .n {
  font-family: var(--mono); font-size: 11px; font-weight: 700;
  color: var(--ink-dim); font-variant-numeric: tabular-nums; letter-spacing: 0.4px;
}
.endnote .body { color: var(--ink); }
.endnote .body .authors { color: var(--ink-muted); }
.endnote .body .pub {
  font-family: var(--mono); font-size: 10px; font-weight: 600;
  letter-spacing: 0.3px; color: var(--ink-dim); display: block; margin-top: 2px;
}
.endnote .type {
  font-family: var(--mono); font-size: 9px; font-weight: 700;
  letter-spacing: 1.3px; text-transform: uppercase;
  padding: 3px 7px; border-radius: 5px;
  background: var(--paper-2); border: 1px solid var(--border); color: var(--ink-muted);
  white-space: nowrap; align-self: center;
}
.endnote .type[data-kind="clinical"]    { background: oklch(0.50 0.11 158 / 0.14); color: oklch(0.50 0.11 158); border-color: oklch(0.50 0.11 158 / 0.34); }
.endnote .type[data-kind="preclinical"] { background: var(--amber-soft); color: oklch(0.42 0.13 50); border-color: var(--amber-border); }
.endnote .type[data-kind="review"]      { background: var(--primary-soft); color: var(--primary); border-color: var(--primary-border); }

/* ───── EDITOR SIGNATURE BLOCK ───── */
.signature {
  max-width: 1240px;
  margin: 0 auto 80px;
  padding: 0 32px;
}
.signature-card {
  display: grid;
  grid-template-columns: 220px 1fr auto;
  gap: 36px 48px;
  padding: 36px 0 0;
  border-top: 2px solid var(--ink);
  align-items: start;
}
.signature-card .changelog {
  grid-column: 1 / -1;
}
.signature-card .marginalia-col {
  display: flex; flex-direction: column; gap: 10px;
}
.signature-card .marginalia-col .ornament {
  font-family: "Times New Roman", "Times", serif;
  font-style: italic; font-weight: 400;
  font-size: 22px; color: var(--amber);
}
.signature-card .marginalia-col .label {
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: 1.6px; text-transform: uppercase; color: var(--ink-dim);
}
.signature-card .marginalia-col h3 {
  font-size: 22px; font-weight: 800; letter-spacing: -0.3px;
  margin: 0;
}
.signature-card .editorial-note {
  font-family: var(--sans); font-style: italic;
  font-size: 18px; line-height: 1.55; color: var(--ink-muted);
  text-wrap: pretty;
  margin: 0;
}
.signature-card .editorial-note strong { color: var(--ink); font-style: normal; font-weight: 700; }
.signature-card .signed {
  display: flex; flex-direction: column; gap: 10px;
  align-items: flex-end;
  min-width: 200px;
}
.signature-card .signed .name {
  font-family: "Times New Roman", "Times", serif;
  font-style: italic; font-weight: 400;
  font-size: 28px;
  letter-spacing: -0.4px;
  color: var(--ink);
  border-bottom: 1px solid var(--ink-muted);
  padding-bottom: 4px;
}
.signature-card .signed .role,
.signature-card .signed .where {
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: 1.4px; text-transform: uppercase; color: var(--ink-muted);
}
.signature-card .signed .stamp {
  margin-top: 10px;
  width: 92px; height: 92px;
  border: 2px solid var(--amber);
  color: var(--amber);
  border-radius: 50%;
  display: grid; place-items: center;
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: 1.4px;
  text-transform: uppercase;
  position: relative;
  transform: rotate(-7deg);
  opacity: 0.84;
}
.signature-card .signed .stamp::before {
  content:""; position: absolute; inset: 4px;
  border: 1px dashed var(--amber);
  border-radius: 50%; opacity: 0.7;
}
.signature-card .signed .stamp .stamp-text {
  text-align: center; line-height: 1.25;
}
.signature-card .signed .stamp .stamp-text .big {
  font-family: "Times New Roman", "Times", serif;
  font-style: italic; font-weight: 400;
  font-size: 26px; letter-spacing: 0;
  text-transform: none;
  display: block; margin: 4px 0 2px;
  color: var(--amber);
}

@media (max-width: 1024px) {
  .signature-card { grid-template-columns: 1fr; }
  .signature-card .signed { align-items: flex-start; }
}

/* ───── ANECDOTAL EVIDENCE — community reports ───── */
.anec-intro {
  background: var(--paper);
  border: 1px solid var(--border);
  border-left: 4px solid var(--amber);
  border-radius: 12px;
  padding: 18px 22px;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 20px;
  align-items: center;
}
.anec-intro p {
  margin: 0;
  font-size: 14px;
  line-height: 1.6;
  color: var(--ink-muted);
}
.anec-intro p strong { color: var(--ink); }
.weight-badge {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  padding: 10px 14px;
  border-radius: 10px;
  background: var(--amber-soft);
  border: 1px solid var(--amber-border);
  min-width: 110px;
}
.weight-badge .v {
  font-family: "Times New Roman", "Times", serif;
  font-style: italic; font-weight: 400;
  font-size: 26px;
  color: oklch(0.42 0.13 50);
  line-height: 1;
}
.weight-badge .k {
  font-family: var(--mono); font-size: 9px; font-weight: 700;
  letter-spacing: 1.4px; text-transform: uppercase;
  color: oklch(0.42 0.13 50);
  text-align: center;
  line-height: 1.3;
}

.anec-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
}
.anec-card {
  background: var(--paper);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 20px 22px;
  display: flex; flex-direction: column; gap: 14px;
  position: relative;
}
.anec-card::before {
  content:"";
  position: absolute;
  top: 14px; right: 16px;
  font-family: "Times New Roman", "Times", serif;
  font-style: italic;
  font-size: 32px;
  color: var(--paper-3);
  line-height: 1;
}
.anec-card .src-row {
  display: flex; align-items: center; gap: 10px;
  padding-bottom: 12px;
  border-bottom: 1px dashed var(--rule);
}
.anec-card .src-ico {
  width: 28px; height: 28px; border-radius: 7px;
  display: grid; place-items: center;
  background: var(--paper-2);
  border: 1px solid var(--border);
  font-family: var(--mono); font-size: 11px; font-weight: 700;
  color: var(--ink);
}
.anec-card[data-src="reddit"]  .src-ico { background: oklch(0.93 0.06 28); color: oklch(0.50 0.18 28); border-color: oklch(0.50 0.18 28 / 0.30); }
.anec-card[data-src="forum"]   .src-ico { background: var(--primary-soft); color: var(--primary); border-color: var(--primary-border); }
.anec-card[data-src="podcast"] .src-ico { background: oklch(0.92 0.05 305); color: oklch(0.46 0.14 285); border-color: oklch(0.46 0.14 285 / 0.30); }
.anec-card[data-src="blog"]    .src-ico { background: var(--good-soft, oklch(0.50 0.11 158 / 0.14)); color: oklch(0.50 0.11 158); border-color: oklch(0.50 0.11 158 / 0.34); }

.anec-card .src-info {
  display: flex; flex-direction: column; gap: 3px;
  flex: 1; min-width: 0;
}
.anec-card .src-info .name {
  font-family: var(--mono); font-size: 11px; font-weight: 700;
  letter-spacing: 1.3px; text-transform: uppercase; color: var(--ink);
}
.anec-card .src-info .meta {
  font-family: var(--mono); font-size: 9px; font-weight: 600;
  letter-spacing: 1.2px; text-transform: uppercase; color: var(--ink-dim);
}
.anec-card .freq {
  font-family: var(--mono); font-size: 9px; font-weight: 700;
  letter-spacing: 1.2px; text-transform: uppercase;
  padding: 3px 7px; border-radius: 5px;
  background: var(--paper-2); border: 1px solid var(--border); color: var(--ink-muted);
  white-space: nowrap;
}
.anec-card .freq[data-level="common"]   { background: var(--ink); color: var(--ink-paper); border-color: var(--ink); }
.anec-card .freq[data-level="frequent"] { background: var(--primary-grad); color: var(--ink-paper); border-color: transparent; }
.anec-card .freq[data-level="rare"]     { background: var(--paper-2); }

.anec-card .pattern {
  font-size: 15px; font-weight: 700; letter-spacing: -0.15px;
  color: var(--ink); margin: 0;
}

.anec-card .quote {
  font-family: "Times New Roman", "Times", serif;
  font-style: italic; font-weight: 400;
  font-size: 17px; line-height: 1.5;
  color: var(--ink-muted);
  padding: 10px 14px 10px 18px;
  border-left: 2px solid var(--amber);
  background: var(--paper-2);
  border-radius: 0 8px 8px 0;
  margin: 0;
  text-wrap: pretty;
}
.anec-card .quote-attr {
  font-family: var(--mono); font-style: normal; font-size: 9px; font-weight: 700;
  letter-spacing: 1.3px; text-transform: uppercase; color: var(--ink-dim);
  margin-top: 8px; display: block;
}
.anec-card .read {
  display: flex; align-items: center; justify-content: space-between;
  padding-top: 10px;
  border-top: 1px dashed var(--rule);
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: 1.3px; text-transform: uppercase; color: var(--ink-muted);
}
.anec-card .read .verdict { color: var(--ink); }

.anec-caveat {
  font-family: var(--sans); font-style: italic;
  font-size: 15px; line-height: 1.55;
  color: var(--ink-muted);
  padding: 18px 22px;
  background: var(--paper-2);
  border-radius: 10px;
  text-wrap: pretty;
}
.anec-caveat strong { color: var(--ink); font-style: normal; font-weight: 700; }

/* ───── COUNTER-EVIDENCE — dissenting cards ───── */
.objection-list { display: flex; flex-direction: column; gap: 12px; }
.objection {
  background: var(--paper);
  border: 1px solid var(--border);
  border-left: 3px solid var(--bad);
  border-radius: 12px;
  padding: 18px 20px;
  display: grid;
  grid-template-columns: 36px 1fr auto;
  gap: 16px;
  align-items: start;
}
.objection .num {
  font-family: var(--sans); font-style: italic; font-weight: 800;
  font-size: 22px; letter-spacing: -0.3px;
  color: var(--bad);
  line-height: 1.05;
}
.objection .body { display: flex; flex-direction: column; gap: 6px; }
.objection .body h4 {
  font-size: 16px; font-weight: 700; margin: 0;
  letter-spacing: -0.2px;
}
.objection .body p {
  font-size: 13.5px; color: var(--ink-muted); margin: 0; line-height: 1.55;
}
.objection .body .src {
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: 1.2px; text-transform: uppercase; color: var(--ink-dim);
  margin-top: 4px;
}
.objection .severity {
  font-family: var(--mono); font-size: 9px; font-weight: 700;
  letter-spacing: 1.3px; text-transform: uppercase;
  padding: 4px 8px; border-radius: 5px;
  background: var(--bad-soft); color: var(--bad); border: 1px solid oklch(0.54 0.16 22 / 0.32);
  white-space: nowrap;
}
.objection .severity[data-level="moderate"] { background: var(--amber-soft); color: oklch(0.42 0.13 50); border-color: var(--amber-border); }
.objection .severity[data-level="open"]     { background: var(--primary-soft); color: var(--primary); border-color: var(--primary-border); }

/* ───── ACTIVE TRIALS — registry ledger ───── */
.trial-ledger {
  background: var(--paper);
  border: 1px solid var(--border);
  border-radius: 14px;
  overflow: hidden;
}
.trial-ledger .head-row,
.trial-ledger .row {
  display: grid;
  grid-template-columns: 96px 76px 1fr 88px 88px 60px;
  gap: 14px;
  padding: 12px 18px;
  align-items: center;
  font-size: 13px;
}
.trial-ledger .head-row {
  background: var(--ink);
  color: var(--ink-paper);
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: 1.4px; text-transform: uppercase;
  border-bottom: 1px solid var(--ink);
}
.trial-ledger .row { border-bottom: 1px dashed var(--rule); }
.trial-ledger .row:last-child { border-bottom: 0; }
.trial-ledger .row:hover { background: color-mix(in oklch, var(--paper-2) 50%, transparent); }

.trial-ledger .nct {
  font-family: var(--mono); font-size: 12px; font-weight: 700;
  letter-spacing: 0.4px; color: var(--ink);
  font-variant-numeric: tabular-nums;
}
.trial-ledger .phase {
  font-family: var(--mono); font-size: 11px; font-weight: 700;
  letter-spacing: 1.3px; text-transform: uppercase;
  padding: 3px 8px; border-radius: 5px;
  border: 1px solid var(--border); background: var(--paper-2);
  color: var(--ink); text-align: center;
  justify-self: start; width: max-content;
}
.trial-ledger .phase[data-level="2"] { background: var(--primary-soft); color: var(--primary); border-color: var(--primary-border); }
.trial-ledger .phase[data-level="1"] { background: var(--amber-soft); color: oklch(0.42 0.13 50); border-color: var(--amber-border); }
.trial-ledger .phase[data-level="reg"] { background: var(--paper-3); color: var(--ink); border-color: var(--border-strong); }

.trial-ledger .endpoint { color: var(--ink); font-weight: 500; line-height: 1.4; }
.trial-ledger .endpoint .sponsor {
  display: block;
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: 1.2px; text-transform: uppercase; color: var(--ink-dim);
  margin-top: 4px;
}
.trial-ledger .country {
  font-family: var(--mono); font-size: 11px; font-weight: 700;
  letter-spacing: 1.2px; text-transform: uppercase; color: var(--ink-muted);
}
.trial-ledger .status {
  font-family: var(--mono); font-size: 9px; font-weight: 700;
  letter-spacing: 1.3px; text-transform: uppercase;
  padding: 4px 8px; border-radius: 5px;
  background: var(--paper-2); color: var(--ink-muted); border: 1px solid var(--border);
  text-align: center;
  justify-self: start; width: max-content;
}
.trial-ledger .status[data-state="recruiting"] { background: var(--good-soft, oklch(0.50 0.11 158 / 0.14)); color: oklch(0.50 0.11 158); border-color: oklch(0.50 0.11 158 / 0.34); }
.trial-ledger .status[data-state="active"]     { background: var(--primary-soft); color: var(--primary); border-color: var(--primary-border); }
.trial-ledger .status[data-state="halted"]     { background: var(--bad-soft); color: var(--bad); border-color: oklch(0.54 0.16 22 / 0.32); }
.trial-ledger .status[data-state="reg"]        { background: var(--paper-3); color: var(--ink); border-color: var(--border-strong); }

.trial-ledger .row .go {
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: 1.3px; text-transform: uppercase;
  color: var(--ink-muted); text-align: right;
}
.trial-ledger .row:hover .go { color: var(--ink); }

.trial-foot {
  padding: 10px 18px;
  background: var(--paper-2);
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: 1.4px; text-transform: uppercase; color: var(--ink-muted);
  display: flex; justify-content: space-between; align-items: center;
  border-top: 1px solid var(--border);
}

/* ───── REVISION LOG (sidebar in signature) ───── */
.changelog {
  background: var(--paper);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 16px 18px;
  display: flex; flex-direction: column; gap: 12px;
}
.changelog h4 {
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: 1.6px; text-transform: uppercase; color: var(--ink-muted);
  margin: 0; padding-bottom: 8px; border-bottom: 1px dashed var(--rule);
}
.changelog ul {
  list-style: none; padding: 0; margin: 0;
  display: flex; flex-direction: column; gap: 10px;
}
.changelog li {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 12px;
  font-size: 12.5px; line-height: 1.45; color: var(--ink-muted);
}
.changelog li .v {
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: 1.2px;
  padding: 2px 6px; border-radius: 4px;
  white-space: nowrap; align-self: start;
  background: var(--paper-2); border: 1px solid var(--border); color: var(--ink);
}
.changelog li .v.minor { background: var(--paper-2); }
.changelog li .v.major { background: var(--primary-grad); color: var(--ink-paper); border-color: transparent; }
.changelog li .v.fix   { background: var(--amber-grad); color: var(--ink-paper); border-color: transparent; }

/* ───── COLOPHON CTA ───── */
.alerts-band {
  max-width: 1240px; margin: 0 auto 80px;
  padding: 0 32px;
}
.alerts-card {
  background: var(--primary-grad-deep);
  color: var(--ink-paper);
  border-radius: 22px;
  padding: 44px;
  display: grid; grid-template-columns: 1.2fr 1fr;
  gap: 32px; align-items: center;
  position: relative; overflow: hidden;
  box-shadow: 0 24px 60px rgba(31,26,18,0.20);
}
.alerts-card::before {
  content:""; position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 70% 80% at 0% 0%, oklch(0.62 0.16 248 / 0.40), transparent 60%),
    radial-gradient(ellipse 70% 80% at 100% 100%, oklch(0.66 0.13 60 / 0.24), transparent 60%);
  pointer-events: none;
}
.alerts-card > * { position: relative; z-index: 1; }
.alerts-card h3 {
  font-size: 28px; font-weight: 800; letter-spacing: -0.5px;
  margin: 8px 0 8px;
}
.alerts-card .sub {
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: 2px; text-transform: uppercase;
  color: rgba(251,247,238,0.66);
}
.alerts-card p {
  margin: 0; color: rgba(251,247,238,0.7);
  font-size: 14px; line-height: 1.55; max-width: 460px;
}
.alerts-card .form { display: flex; flex-direction: column; gap: 12px; }
.alerts-card .row { display: flex; gap: 10px; }
.alerts-card input {
  flex: 1; padding: 14px 16px; border-radius: 10px;
  background: rgba(251,247,238,0.08); border: 1px solid rgba(251,247,238,0.18);
  color: var(--ink-paper); font-family: var(--sans); font-size: 14px;
}
.alerts-card input::placeholder { color: rgba(251,247,238,0.4); }
.alerts-card .btn-amber {
  background: var(--amber-grad); color: var(--ink);
  border: 1px solid oklch(0.46 0.13 50);
  font-family: var(--mono); font-size: 11px; font-weight: 700;
  letter-spacing: 1.4px; text-transform: uppercase;
  padding: 14px 18px; border-radius: 10px; cursor: pointer;
}
.alerts-card .fine {
  font-family: var(--mono); font-size: 10px; font-weight: 600;
  letter-spacing: 1.3px; text-transform: uppercase; color: rgba(251,247,238,0.5);
}

/* Adjacent records */
.adjacent {
  max-width: 1240px; margin: 0 auto 80px;
  padding: 0 32px;
}
.adj-band {
  display: flex; align-items: center; gap: 20px;
  padding-bottom: 18px; margin-bottom: 18px;
  border-bottom: 1px solid var(--ink);
}
.adj-band h3 {
  font-size: 22px; font-weight: 800; letter-spacing: -0.3px;
  margin: 0;
}
.adj-band .rule { flex: 1; height: 1px; background: var(--ink); }
.adj-band .label {
  font-family: var(--mono); font-size: 11px; font-weight: 700;
  letter-spacing: 1.6px; text-transform: uppercase; color: var(--ink-muted);
}
.adj-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
.adj-card {
  background: var(--paper); border: 1px solid var(--border);
  border-radius: 14px; padding: 18px 20px;
  display: flex; align-items: center; gap: 16px;
  cursor: pointer; transition: border-color 120ms ease;
}
.adj-card:hover { border-color: var(--primary-border); }
.adj-card .vial {
  width: 48px; flex-shrink: 0;
}
.adj-card .vial svg { width: 100%; height: 100%; display: block; }
.adj-card .info { flex: 1; min-width: 0; }
.adj-card .pre {
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: 1.4px; text-transform: uppercase; color: var(--ink-muted);
}
.adj-card .name { font-size: 17px; font-weight: 700; letter-spacing: -0.2px; }
.adj-card .meta {
  font-family: var(--mono); font-size: 10px; font-weight: 700;
  letter-spacing: 1.3px; text-transform: uppercase; color: var(--ink-dim); margin-top: 4px;
}

/* ───── FOOTER ───── */
.site-footer {
  background: var(--ink); color: var(--ink-paper);
  padding: 48px 0 28px;
}
.footer-inner {
  max-width: 1240px; margin: 0 auto; padding: 0 32px;
  display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr; gap: 48px;
}
.footer-brand { display: flex; flex-direction: column; gap: 14px; max-width: 320px; }
.footer-brand .wordmark {
  font-family: var(--sans); font-weight: 800; font-size: 20px;
  letter-spacing: -0.4px;
  display: inline-flex; align-items: center; gap: 12px;
}
.footer-brand .wordmark .vial {
  width: 14px; height: 14px;
  background: var(--primary-grad);
