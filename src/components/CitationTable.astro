---
interface Source {
  id: string;
  title: string;
  authors?: string[];
  journal?: string;
  year: number;
  country?: string;
  studyType: string;
  keyFindings: string;
  access: 'open' | 'paywalled' | 'unknown';
  url?: string;
}

interface Props {
  sources: Source[];
  title?: string;
}

const { sources, title = 'Evidence Library' } = Astro.props;

const accessBadge = {
  'open': { class: 'bg-emerald-500/30 text-emerald-300 border border-emerald-500/40', label: 'Open Access' },
  'paywalled': { class: 'bg-amber-500/30 text-amber-300 border border-amber-500/40', label: 'Paywalled' },
  'unknown': { class: 'bg-white/15 text-white/70 border border-white/20', label: 'Unknown' },
};

const studyTypeBadge = {
  'RCT': 'bg-[var(--primary)]/30 text-purple-300 border border-[var(--primary)]/40',
  'observational': 'bg-blue-500/30 text-blue-300 border border-blue-500/40',
  'case-report': 'bg-cyan-500/30 text-cyan-300 border border-cyan-500/40',
  'animal': 'bg-orange-500/30 text-orange-300 border border-orange-500/40',
  'in-vitro': 'bg-pink-500/30 text-pink-300 border border-pink-500/40',
  'review': 'bg-white/15 text-white/70 border border-white/20',
  'meta-analysis': 'bg-indigo-500/30 text-indigo-300 border border-indigo-500/40',
};
---

<div class="my-8">
  <h2 id="evidence-library" class="text-2xl font-bold text-white mb-4">{title}</h2>

  <div class="overflow-x-auto rounded-xl border border-white/15 bg-gradient-to-b from-[var(--primary)]/5 to-transparent backdrop-blur-xl">
    <table class="min-w-full divide-y divide-white/10">
      <thead class="bg-gradient-to-r from-[var(--primary)]/15 to-transparent">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-semibold text-white/90 uppercase tracking-wider">Source</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-white/90 uppercase tracking-wider">Type</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-white/90 uppercase tracking-wider">Year</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-white/90 uppercase tracking-wider">Key Finding</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-white/90 uppercase tracking-wider">Access</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-white/10">
        {sources.map((source) => (
          <tr class="hover:bg-[var(--primary)]/10 transition-colors">
            <td class="px-4 py-4">
              <div class="max-w-xs">
                {source.url ? (
                  <a
                    href={source.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-sm font-medium text-[var(--primary)] hover:text-[var(--accent)] hover:underline transition-colors"
                  >
                    {source.title}
                  </a>
                ) : (
                  <span class="text-sm font-medium text-white">{source.title}</span>
                )}
                {source.journal && (
                  <div class="text-xs text-white/60 mt-1">{source.journal}</div>
                )}
                <div class="text-xs text-white/60 mt-0.5 font-mono">{source.id}</div>
              </div>
            </td>
            <td class="px-4 py-4">
              <span class={`inline-flex rounded-full px-2 py-1 text-xs font-medium ${studyTypeBadge[source.studyType as keyof typeof studyTypeBadge] || 'bg-white/15 text-white/70 border border-white/20'}`}>
                {source.studyType}
              </span>
            </td>
            <td class="px-4 py-4 text-sm text-white/80">
              {source.year}
              {source.country && (
                <div class="text-xs text-white/70">{source.country}</div>
              )}
            </td>
            <td class="px-4 py-4">
              <p class="text-sm text-white/75 max-w-md">{source.keyFindings}</p>
            </td>
            <td class="px-4 py-4">
              <span class={`inline-flex rounded-full px-2 py-1 text-xs font-medium ${accessBadge[source.access].class}`}>
                {accessBadge[source.access].label}
              </span>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <p class="mt-3 text-sm text-white/60">
    Showing {sources.length} sources. Open access sources can be read freely; paywalled sources may require institutional access.
  </p>
</div>
