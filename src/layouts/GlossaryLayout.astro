---
import BaseLayout from './BaseLayout.astro';
import ArticleSchema from '../components/SEO/ArticleSchema.astro';
import BreadcrumbSchema from '../components/SEO/BreadcrumbSchema.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import { getCollection } from 'astro:content';

interface Props {
  term: string;
  definition: string;
  aliases?: string[];
  relatedPeptides?: string[];
  relatedTerms?: string[];
  category?: string;
  lastUpdated: Date;
  metaTitle?: string;
  metaDescription?: string;
}

const {
  term,
  definition,
  aliases = [],
  relatedPeptides = [],
  relatedTerms = [],
  category = 'general',
  lastUpdated,
  metaTitle,
  metaDescription,
} = Astro.props;

const categoryLabels: Record<string, string> = {
  'mechanism': 'Mechanism',
  'administration': 'Administration',
  'research': 'Research',
  'regulatory': 'Regulatory',
  'general': 'General',
};

const categoryColors: Record<string, string> = {
  'mechanism': 'bg-purple-500/20 text-purple-400 border-purple-500/30',
  'administration': 'bg-blue-500/20 text-blue-400 border-blue-500/30',
  'research': 'bg-emerald-500/20 text-emerald-400 border-emerald-500/30',
  'regulatory': 'bg-amber-500/20 text-amber-400 border-amber-500/30',
  'general': 'bg-white/10 text-white/80 border-white/20',
};

// SEO: Breadcrumb data
const breadcrumbItems = [
  { name: 'Home', url: Astro.site?.toString() || 'https://pepcodex.com' },
  { name: 'Glossary', url: `${Astro.site || 'https://pepcodex.com'}glossary/` },
  { name: term, url: Astro.url.toString() }
];

const articleUrl = Astro.url.toString();

// Get related peptide data for linking
const allPeptides = await getCollection('peptides');
const relatedPeptideData = relatedPeptides
  .map(slug => allPeptides.find(p => p.slug === slug))
  .filter(Boolean);

// Get related glossary term data
const allGlossary = await getCollection('glossary');
const relatedTermData = relatedTerms
  .map(slug => allGlossary.find(t => t.slug === slug))
  .filter(Boolean);
---

<BaseLayout
  title={metaTitle || `${term} — Peptide Glossary`}
  description={metaDescription || definition.slice(0, 160)}
>
  <!-- Structured Data -->
  <ArticleSchema
    title={`${term}: Definition & Explanation`}
    description={definition}
    url={articleUrl}
    dateModified={lastUpdated}
  />
  <BreadcrumbSchema items={breadcrumbItems} />

  <article class="mx-auto max-w-4xl px-4 py-8 sm:px-6 lg:px-8">
    <!-- Back Link -->
    <a href="/glossary" class="group inline-flex items-center text-sm font-medium text-white/70 hover:text-white transition-all mb-8">
      <div class="mr-3 w-8 h-8 rounded-full border border-white/10 flex items-center justify-center group-hover:border-[var(--primary)]/50 group-hover:bg-[var(--primary)]/5 transition-all">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m12 19-7-7 7-7"/>
          <path d="M19 12H5"/>
        </svg>
      </div>
      Back to Glossary
    </a>

    <!-- Header -->
    <header class="mb-8">
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <span class={`inline-flex items-center rounded-full px-3 py-1 text-xs font-medium border ${categoryColors[category]}`}>
          {categoryLabels[category]}
        </span>
        <span class="inline-flex items-center rounded-full bg-cyan-500/20 px-3 py-1 text-xs font-medium text-cyan-400 border border-cyan-500/30">
          Definition
        </span>
      </div>

      <h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl" style="font-family: var(--font-display);">
        {term}
      </h1>

      {aliases.length > 0 && (
        <p class="mt-3 text-white/70">
          Also known as: <span class="text-white">{aliases.join(', ')}</span>
        </p>
      )}

      <!-- Definition Box - optimized for featured snippets -->
      <div class="mt-6 p-6 rounded-2xl bg-[var(--primary)]/10 border border-[var(--primary)]/30">
        <p class="text-lg text-white leading-relaxed">
          <strong class="text-primary">{term}</strong> {definition}
        </p>
      </div>

      <p class="mt-4 text-sm text-white/60">
        Last updated: {lastUpdated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </p>
    </header>

    <!-- Main Content -->
    <div class="prose prose-invert prose-lg max-w-none mb-12">
      <slot />
    </div>

    <!-- Related Peptides -->
    {relatedPeptideData.length > 0 && (
      <section class="mb-8">
        <h2 class="text-xl font-bold text-white mb-4" style="font-family: var(--font-display);">
          Related Peptides
        </h2>
        <div class="grid gap-3 sm:grid-cols-2">
          {relatedPeptideData.map((peptide) => peptide && (
            <a
              href={`/peptides/${peptide.slug}`}
              class="glass-card-interactive p-4 flex items-center gap-3 group"
            >
              <div class="w-10 h-10 rounded-lg bg-[var(--primary)]/10 border border-[var(--primary)]/30 flex items-center justify-center group-hover:bg-[var(--primary)]/20 transition-all">
                <svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2" />
                </svg>
              </div>
              <div>
                <span class="font-medium text-white group-hover:text-primary transition-colors">
                  {peptide.data.name}
                </span>
                <p class="text-xs text-white/60">View evidence dossier</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Related Terms -->
    {relatedTermData.length > 0 && (
      <section class="mb-8">
        <h2 class="text-xl font-bold text-white mb-4" style="font-family: var(--font-display);">
          Related Terms
        </h2>
        <div class="flex flex-wrap gap-2">
          {relatedTermData.map((glossaryTerm) => glossaryTerm && (
            <a
              href={`/glossary/${glossaryTerm.slug}`}
              class="inline-flex items-center px-4 py-2 rounded-full bg-white/5 border border-white/10 text-white/80 hover:bg-white/10 hover:text-white hover:border-white/20 transition-all text-sm"
            >
              {glossaryTerm.data.term}
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Newsletter CTA -->
    <div class="mt-8">
      <NewsletterForm variant="inline" />
    </div>

    <!-- Disclaimer -->
    <div class="mt-8 rounded-xl border border-amber-500/30 bg-amber-500/10 p-6 backdrop-blur-sm">
      <p class="text-amber-200 text-sm">
        <strong class="text-amber-400">Disclaimer:</strong> This glossary entry is for educational purposes only and does not constitute medical advice. Always consult a qualified healthcare provider for medical questions.
      </p>
    </div>
  </article>
</BaseLayout>
