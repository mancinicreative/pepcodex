---
import EvidenceBadge from './EvidenceBadge.astro';
import Vial from './Vial.astro';

interface Props {
  name: string;
  slug: string;
  category: string;
  compoundType?: 'peptide' | 'small-molecule' | 'mrna' | 'protein' | 'glycoprotein';
  evidenceStrength: 'high' | 'moderate' | 'low' | 'very-low';
  summary: string;
  aliases?: string[];
}

const { name, slug, category, compoundType = 'peptide', evidenceStrength, summary, aliases = [] } = Astro.props;

const categoryLabels: Record<string, string> = {
  'metabolic': 'Metabolic',
  'repair-recovery': 'Repair & Recovery',
  'hormonal': 'Hormonal',
  'longevity': 'Longevity',
  'cognitive': 'Cognitive',
  'immune': 'Immune',
  'other': 'Other',
};

const compoundTypeLabels: Record<string, string> = {
  'small-molecule': 'Small Molecule',
  'mrna': 'mRNA',
  'protein': 'Protein',
  'glycoprotein': 'Glycoprotein',
};
const showCompoundType = compoundType !== 'peptide';

// Two-tone name — trailing token containing a digit rendered in accent
let namePrefix = name;
let nameSuffix = '';
const _lastDash = name.lastIndexOf('-');
if (_lastDash > 0 && /\d/.test(name.slice(_lastDash + 1))) {
  namePrefix = name.slice(0, _lastDash + 1);
  nameSuffix = name.slice(_lastDash + 1);
}
---

<a
  href={`/peptides/${slug}`}
  class="glass-card glass-card--hover group relative block h-full"
>
  <div class="relative z-10 p-5 flex flex-col h-full">
    <!-- Header: category + name (left), vial (right) -->
    <div class="flex items-start justify-between gap-3">
      <div class="min-w-0">
        <span class="eyebrow">{categoryLabels[category] || category}</span>
        <h3 class="font-serif text-[1.7rem] leading-tight mt-1 transition-colors group-hover:text-[color:var(--primary-c)]" style="color: var(--ink); font-weight: 500;">
          {namePrefix}{nameSuffix && <em style="color: var(--primary-c);">{nameSuffix}</em>}
        </h3>
      </div>
      <Vial strength={evidenceStrength} size="md" class="shrink-0 -mt-1" />
    </div>

    <!-- Aliases -->
    {aliases.length > 0 && (
      <p class="mt-1.5 text-xs" style="color: var(--ink-dim); font-family: var(--font-mono);">
        {aliases.slice(0, 3).join(' · ')}{aliases.length > 3 && ` +${aliases.length - 3}`}
      </p>
    )}

    <!-- Description -->
    <p class="mt-3 text-sm line-clamp-3 leading-relaxed flex-grow" style="color: var(--ink-muted);">
      {summary}
    </p>

    <!-- Footer -->
    <div class="pt-4 mt-4 flex items-center justify-between gap-2" style="border-top: 1px solid var(--border-c);">
      <div class="flex flex-wrap items-center gap-2">
        <EvidenceBadge strength={evidenceStrength} showLabel={false} />
        {showCompoundType && (
          <span class="badge badge--muted">{compoundTypeLabels[compoundType]}</span>
        )}
      </div>
      <span class="inline-flex items-center gap-1 text-[0.68rem] uppercase tracking-[0.12em] transition-colors group-hover:text-[color:var(--primary-c)]" style="color: var(--ink-dim); font-family: var(--font-mono);">
        See dossier
        <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      </span>
    </div>
  </div>
</a>
