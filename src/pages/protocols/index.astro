---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const protocols = await getCollection('protocols');

// Sort by title
const sortedProtocols = protocols.sort((a, b) =>
  a.data.title.localeCompare(b.data.title)
);

// Study type badge colors
const studyTypeBadges: Record<string, { bg: string; text: string; label: string }> = {
  'human-rct': { bg: 'bg-emerald-500/20', text: 'text-emerald-400', label: 'Human RCT' },
  'human-observational': { bg: 'bg-blue-500/20', text: 'text-blue-400', label: 'Human Observational' },
  'animal': { bg: 'bg-amber-500/20', text: 'text-amber-400', label: 'Animal Study' },
  'in-vitro': { bg: 'bg-purple-500/20', text: 'text-purple-400', label: 'In Vitro' },
};

// Count study types
function getStudyTypeCounts(studies: Array<{ studyType: string }>) {
  const counts: Record<string, number> = {};
  studies.forEach(study => {
    counts[study.studyType] = (counts[study.studyType] || 0) + 1;
  });
  return counts;
}
---

<BaseLayout
  title="Multi-Peptide Research Overviews"
  description="Research documentation on peptide combinations studied in scientific literature. Study citations, mechanisms, and research context - not dosing guides."
>
  <!-- Hero -->
  <div class="relative overflow-hidden border-b border-white/5">
    <div class="absolute inset-0 bg-gradient-to-br from-[var(--primary)]/10 via-transparent to-transparent"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-[var(--primary)]/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>

    <div class="relative mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <span class="inline-flex items-center rounded-full bg-[var(--primary)]/20 px-3 py-1 text-xs font-medium text-primary border border-[var(--primary)]/30">
          <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Research Documentation
        </span>
      </div>
      <h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl lg:text-6xl" style="font-family: var(--font-display);">
        Multi-Peptide Research Overviews
      </h1>
      <p class="mt-6 max-w-2xl text-xl text-white/80 leading-relaxed">
        Documentation of what researchers have studied regarding peptide combinations. These pages summarize published research with citations - they are not dosing guides or protocol recommendations.
      </p>
    </div>
  </div>

  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Research disclaimer callout -->
    <div class="mb-8 glass-card-default p-6 border-blue-500/30">
      <div class="flex gap-4">
        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-blue-500/10 text-blue-400">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div>
          <h4 class="font-bold text-blue-400 mb-1">Research Documentation, Not Protocols</h4>
          <p class="text-white/80 text-sm leading-relaxed">
            These pages document <strong class="text-white">what researchers have studied</strong> in peer-reviewed literature. Doses mentioned are those used <strong class="text-white">in specific studies</strong>, not recommendations. This is educational content about research findings, not treatment guidance.
          </p>
        </div>
      </div>
    </div>

    <p class="mb-8 text-white/70">
      Showing <span class="text-white font-bold">{sortedProtocols.length}</span> research overviews
    </p>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-1">
      {sortedProtocols.map((protocol) => {
        const studyCounts = getStudyTypeCounts(protocol.data.studies);
        return (
          <a
            href={`/protocols/${protocol.data.slug}`}
            class="glass-card-interactive p-6 group"
          >
            <div class="flex flex-col lg:flex-row lg:items-start justify-between gap-6">
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-[var(--primary)]/10 text-primary">
                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                  </div>
                  <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-bold uppercase tracking-wider border text-[var(--primary)] bg-[var(--primary)]/10 border-[var(--primary)]/30">
                    Research Overview
                  </span>
                  <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-medium border text-white/70 bg-white/5 border-white/10">
                    {protocol.data.studies.length} Studies
                  </span>
                </div>

                <h2 class="text-xl font-bold text-white group-hover:text-primary transition-colors">
                  {protocol.data.title}
                </h2>

                <p class="mt-2 text-sm text-white/70 line-clamp-2">
                  {protocol.data.description}
                </p>

                <!-- Peptides involved -->
                <div class="mt-4 flex flex-wrap gap-2">
                  {protocol.data.peptides.map((peptide: string) => (
                    <span class="inline-block rounded-lg bg-[var(--accent)]/10 border border-[var(--accent)]/20 px-2 py-1 text-xs text-[var(--accent)]">
                      {peptide.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join('-')}
                    </span>
                  ))}
                </div>
              </div>

              <!-- Study type breakdown -->
              <div class="flex flex-wrap lg:flex-col gap-2 lg:w-48 lg:shrink-0">
                {Object.entries(studyCounts).map(([type, count]) => (
                  <span class={`inline-flex items-center rounded-full px-2 py-1 text-xs font-medium ${studyTypeBadges[type]?.bg || 'bg-white/10'} ${studyTypeBadges[type]?.text || 'text-white/70'} border border-current/20`}>
                    {count} {studyTypeBadges[type]?.label || type}
                  </span>
                ))}
              </div>

              <div class="hidden lg:flex w-10 h-10 rounded-xl bg-white/5 border border-white/10 items-center justify-center group-hover:bg-[var(--primary)]/10 group-hover:border-[var(--primary)]/30 transition-all flex-shrink-0">
                <svg class="h-5 w-5 text-white/60 group-hover:text-primary group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </div>
          </a>
        );
      })}
    </div>

    <!-- Legend -->
    <div class="mt-12 glass-card-default p-6">
      <h3 class="font-bold text-white mb-4">Study Type Legend</h3>
      <div class="flex flex-wrap gap-4">
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-emerald-500"></span>
          <span class="text-sm text-white/80">Human RCT - Randomized controlled trials in humans</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-blue-500"></span>
          <span class="text-sm text-white/80">Human Observational - Non-randomized human studies</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-amber-500"></span>
          <span class="text-sm text-white/80">Animal Study - Preclinical animal research</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-purple-500"></span>
          <span class="text-sm text-white/80">In Vitro - Cell culture or laboratory studies</span>
        </div>
      </div>
    </div>

    <!-- Disclaimer -->
    <div class="mt-8 rounded-xl border-2 border-blue-500/40 bg-blue-500/10 p-6 backdrop-blur-sm">
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0">
          <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div>
          <p class="text-blue-200/80 text-sm">
            <strong class="text-blue-400">Disclaimer:</strong> This information is for educational purposes only. It does not constitute medical advice, treatment recommendations, or dosing guidance. Many peptides discussed are not approved for human use. Always consult qualified healthcare providers for medical decisions.
          </p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
