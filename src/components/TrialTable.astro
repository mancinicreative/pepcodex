---
interface Trial {
  nctId: string;
  title: string;
  status: string;
  phase: string;
  conditions: string[];
  interventions: string[];
  enrollmentTarget?: number;
  startDate?: string;
  completionDate?: string;
  peptide: string;
}

interface Props {
  trials: Trial[];
}

const { trials } = Astro.props;

// Status badge colors
const statusColors: Record<string, { bg: string; text: string }> = {
  active: { bg: 'bg-green-100', text: 'text-green-800' },
  completed: { bg: 'bg-blue-100', text: 'text-blue-800' },
  recruiting: { bg: 'bg-amber-100', text: 'text-amber-800' },
  'not yet recruiting': { bg: 'bg-slate-100', text: 'text-slate-800' },
  terminated: { bg: 'bg-red-100', text: 'text-red-800' },
  withdrawn: { bg: 'bg-red-100', text: 'text-red-800' },
  suspended: { bg: 'bg-orange-100', text: 'text-orange-800' },
};

function getStatusColors(status: string) {
  const key = status.toLowerCase();
  return statusColors[key] || { bg: 'bg-slate-100', text: 'text-slate-700' };
}

function formatDate(dateStr?: string): string {
  if (!dateStr) return '-';
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
}
---

<div class="overflow-x-auto">
  <table class="min-w-full divide-y divide-slate-200">
    <thead class="bg-slate-50">
      <tr>
        <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">
          NCT ID
        </th>
        <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">
          Title
        </th>
        <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">
          Peptide
        </th>
        <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">
          Phase
        </th>
        <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">
          Status
        </th>
        <th scope="col" class="px-4 py-3 text-left text-xs font-semibold text-slate-600 uppercase tracking-wider">
          Completion
        </th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-slate-100">
      {trials.length === 0 ? (
        <tr>
          <td colspan="6" class="px-4 py-8 text-center text-slate-500">
            No trials found matching your criteria.
          </td>
        </tr>
      ) : (
        trials.map((trial) => {
          const colors = getStatusColors(trial.status);
          return (
            <tr class="hover:bg-slate-50 transition-colors trial-row"
                data-status={trial.status.toLowerCase()}
                data-phase={trial.phase}
                data-peptide={trial.peptide.toLowerCase()}>
              <td class="px-4 py-4 whitespace-nowrap">
                <a
                  href={`https://clinicaltrials.gov/study/${trial.nctId}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm font-medium text-blue-600 hover:text-blue-800 hover:underline"
                >
                  {trial.nctId}
                </a>
              </td>
              <td class="px-4 py-4">
                <div class="text-sm text-slate-900 max-w-md line-clamp-2" title={trial.title}>
                  {trial.title}
                </div>
                <div class="mt-1 text-xs text-slate-500">
                  {trial.conditions.slice(0, 2).join(', ')}
                  {trial.conditions.length > 2 && ` +${trial.conditions.length - 2} more`}
                </div>
              </td>
              <td class="px-4 py-4 whitespace-nowrap">
                <a
                  href={`/peptides/${trial.peptide.toLowerCase()}`}
                  class="text-sm font-medium text-slate-900 hover:text-blue-600"
                >
                  {trial.peptide}
                </a>
              </td>
              <td class="px-4 py-4 whitespace-nowrap">
                <span class="text-sm text-slate-900">Phase {trial.phase}</span>
              </td>
              <td class="px-4 py-4 whitespace-nowrap">
                <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${colors.bg} ${colors.text}`}>
                  {trial.status.charAt(0).toUpperCase() + trial.status.slice(1)}
                </span>
              </td>
              <td class="px-4 py-4 whitespace-nowrap text-sm text-slate-600">
                {formatDate(trial.completionDate)}
              </td>
            </tr>
          );
        })
      )}
    </tbody>
  </table>
</div>

<!-- Mobile view (cards) -->
<div class="md:hidden space-y-4">
  {trials.map((trial) => {
    const colors = getStatusColors(trial.status);
    return (
      <div class="bg-white rounded-lg border border-slate-200 p-4 shadow-sm trial-card"
           data-status={trial.status.toLowerCase()}
           data-phase={trial.phase}
           data-peptide={trial.peptide.toLowerCase()}>
        <div class="flex items-start justify-between gap-2">
          <a
            href={`https://clinicaltrials.gov/study/${trial.nctId}`}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm font-semibold text-blue-600 hover:underline"
          >
            {trial.nctId}
          </a>
          <span class={`inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium ${colors.bg} ${colors.text}`}>
            {trial.status.charAt(0).toUpperCase() + trial.status.slice(1)}
          </span>
        </div>
        <h3 class="mt-2 text-sm font-medium text-slate-900 line-clamp-2">
          {trial.title}
        </h3>
        <div class="mt-3 flex flex-wrap gap-2 text-xs text-slate-600">
          <span class="inline-flex items-center gap-1">
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
            </svg>
            <a href={`/peptides/${trial.peptide.toLowerCase()}`} class="hover:text-blue-600">
              {trial.peptide}
            </a>
          </span>
          <span>Phase {trial.phase}</span>
          <span>Est. {formatDate(trial.completionDate)}</span>
        </div>
      </div>
    );
  })}
</div>

<style>
  /* Hide desktop table on mobile, hide mobile cards on desktop */
  .overflow-x-auto {
    display: none;
  }

  @media (min-width: 768px) {
    .overflow-x-auto {
      display: block;
    }
    .md\:hidden {
      display: none !important;
    }
  }
</style>
