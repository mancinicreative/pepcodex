---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const comparisons = await getCollection('comparisons');

// Sort by title
const sortedComparisons = comparisons.sort((a, b) =>
  a.data.title.localeCompare(b.data.title)
);

const categoryColors: Record<string, string> = {
  'metabolic': 'var(--primary-c)',
  'repair-recovery': 'var(--research)',
  'hormonal': 'var(--primary-deep)',
  'longevity': '#9a6418',
  'other': 'var(--ink-dim)',
};

const categoryLabels: Record<string, string> = {
  'metabolic': 'Metabolic',
  'repair-recovery': 'Repair & Recovery',
  'hormonal': 'Hormonal',
  'longevity': 'Longevity',
  'other': 'Other',
};
---

<BaseLayout
  title="Peptide Comparisons"
  description="Side-by-side comparisons of popular peptides. Understand the differences between similar compounds."
>
  <!-- Hero -->
  <div class="border-b border-[color:var(--border-c)]">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
      <span class="eyebrow">Comparisons</span>
      <h1 class="font-serif mt-4 text-4xl tracking-tight sm:text-5xl lg:text-6xl" style="color: var(--ink); font-weight: 500;">
        Peptide Comparisons
      </h1>
      <p class="mt-6 max-w-2xl text-xl leading-relaxed" style="color: var(--ink-muted);">
        Side-by-side evidence comparisons to help you understand the differences between similar compounds.
      </p>
    </div>
  </div>

  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <p class="mb-8" style="color: var(--ink-muted);">
      Showing <span class="font-bold" style="color: var(--ink);">{sortedComparisons.length}</span> comparisons
    </p>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {sortedComparisons.map((comparison) => {
        const color = categoryColors[comparison.data.category] || categoryColors.other;
        return (
          <a
            href={`/compare/${comparison.slug}`}
            class="glass-card-interactive p-6 group"
          >
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <span
                  class="inline-flex items-center rounded-full px-3 py-1 text-xs font-bold uppercase tracking-wider border mb-3"
                  style={`color: ${color}; background: ${color}15; border-color: ${color}30;`}
                >
                  {categoryLabels[comparison.data.category]}
                </span>
                <h2 class="text-lg font-serif group-hover:text-[color:var(--primary-c)] transition-colors" style="color: var(--ink); font-weight: 500;">
                  {comparison.data.title}
                </h2>
                <p class="mt-2 text-sm line-clamp-2" style="color: var(--ink-muted);">
                  {comparison.data.summary}
                </p>
                <div class="mt-4 flex items-center gap-2 text-xs" style="color: var(--ink-muted);">
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                  </svg>
                  <span>{comparison.data.peptideA} vs {comparison.data.peptideB}</span>
                </div>
              </div>
              <div class="w-10 h-10 rounded-xl flex items-center justify-center transition-all flex-shrink-0" style="background: var(--paper-2); border: 1px solid var(--border-c);">
                <svg class="h-5 w-5 group-hover:text-primary group-hover:translate-x-0.5 transition-all" style="color: var(--ink-dim);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</BaseLayout>
