---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  category?: string;
  showBackLink?: boolean;
}

const { title, description, category, showBackLink = false } = Astro.props;

// Category-specific accent colors for the dark theme
const categoryAccents: Record<string, string> = {
  'metabolic': 'var(--primary)',
  'repair-recovery': 'var(--accent)',
  'hormonal': 'hsl(280 80% 60%)',
  'longevity': 'hsl(45 90% 55%)',
};

const accentColor = category ? categoryAccents[category] || 'var(--primary)' : 'var(--primary)';
---

<BaseLayout title={title} description={description}>
  <!-- Hero Section -->
  <div class="relative overflow-hidden border-b border-white/5">
    <!-- Background Effects -->
    <div class="absolute inset-0 bg-gradient-to-br from-[var(--primary)]/10 via-transparent to-cyan-500/5"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-[var(--primary)]/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-cyan-500/10 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"></div>

    <div class="relative mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
      {showBackLink && (
        <a href="/peptides" class="group inline-flex items-center gap-2 text-sm text-white/70 hover:text-white mb-6 transition-colors">
          <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
          Back to Library
        </a>
      )}

      <div class="flex items-center gap-4 mb-4">
        {category && (
          <span
            class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider border"
            style={`color: ${accentColor}; background: ${accentColor}15; border-color: ${accentColor}30;`}
          >
            {category.replace('-', ' & ')}
          </span>
        )}
      </div>

      <h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl lg:text-6xl" style="font-family: var(--font-display);">
        {title}
      </h1>
      <p class="mt-6 max-w-2xl text-xl text-white/80 leading-relaxed">
        {description}
      </p>
    </div>
  </div>

  <!-- Content -->
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <slot />
  </div>
</BaseLayout>
