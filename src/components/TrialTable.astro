---
interface Trial {
  nctId: string;
  title: string;
  status: string;
  phase: string;
  conditions: string[];
  interventions: string[];
  enrollmentTarget?: number;
  startDate?: string;
  completionDate?: string;
  peptide: string;
}

interface Props {
  trials: Trial[];
}

const { trials } = Astro.props;

// Status badge colors - light editorial theme. Status carries meaning:
//   active/completed = positive (research green), recruiting = caution (compound amber),
//   terminated/withdrawn/suspended = negative (danger red), not-yet-recruiting = neutral ink.
const RESEARCH = 'background: rgba(20,118,74,0.10); color: var(--research); border-color: rgba(20,118,74,0.30);';
const COMPOUND = 'background: rgba(203,135,52,0.12); color: #9a6418; border-color: rgba(203,135,52,0.32);';
const DANGER = 'background: rgba(185,61,66,0.10); color: var(--danger); border-color: rgba(185,61,66,0.28);';
const NEUTRAL = 'background: var(--paper-2); color: var(--ink-muted); border-color: var(--border-c);';

const statusColors: Record<string, string> = {
  active: RESEARCH,
  completed: RESEARCH,
  recruiting: COMPOUND,
  'not yet recruiting': NEUTRAL,
  terminated: DANGER,
  withdrawn: DANGER,
  suspended: DANGER,
};

function getStatusStyle(status: string): string {
  const key = status.toLowerCase();
  return statusColors[key] || NEUTRAL;
}

function formatDate(dateStr?: string): string {
  if (!dateStr) return '-';
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' });
}
---

<div class="overflow-x-auto">
  <table class="min-w-full">
    <thead>
      <tr style="border-bottom: 1px solid var(--border-strong);">
        <th scope="col" class="px-4 py-3 text-left text-xs uppercase" style="font-family: var(--font-mono); letter-spacing: .1em; color: var(--ink-muted);">
          NCT ID
        </th>
        <th scope="col" class="px-4 py-3 text-left text-xs uppercase" style="font-family: var(--font-mono); letter-spacing: .1em; color: var(--ink-muted);">
          Title
        </th>
        <th scope="col" class="px-4 py-3 text-left text-xs uppercase" style="font-family: var(--font-mono); letter-spacing: .1em; color: var(--ink-muted);">
          Peptide
        </th>
        <th scope="col" class="px-4 py-3 text-left text-xs uppercase" style="font-family: var(--font-mono); letter-spacing: .1em; color: var(--ink-muted);">
          Phase
        </th>
        <th scope="col" class="px-4 py-3 text-left text-xs uppercase" style="font-family: var(--font-mono); letter-spacing: .1em; color: var(--ink-muted);">
          Status
        </th>
        <th scope="col" class="px-4 py-3 text-left text-xs uppercase" style="font-family: var(--font-mono); letter-spacing: .1em; color: var(--ink-muted);">
          Completion
        </th>
      </tr>
    </thead>
    <tbody>
      {trials.length === 0 ? (
        <tr>
          <td colspan="6" class="px-4 py-8 text-center" style="color: var(--ink-muted);">
            No trials found matching your criteria.
          </td>
        </tr>
      ) : (
        trials.map((trial) => {
          const statusStyle = getStatusStyle(trial.status);
          return (
            <tr class="trial-row transition-colors"
                style="border-top: 1px solid var(--border-c);"
                data-status={trial.status.toLowerCase()}
                data-phase={trial.phase}
                data-peptide={trial.peptide.toLowerCase()}>
              <td class="px-4 py-4 whitespace-nowrap">
                <a
                  href={`https://clinicaltrials.gov/study/${trial.nctId}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm font-medium text-primary hover:underline transition-colors"
                >
                  {trial.nctId}
                </a>
              </td>
              <td class="px-4 py-4">
                <div class="text-sm max-w-md line-clamp-2" style="color: var(--ink);" title={trial.title}>
                  {trial.title}
                </div>
                <div class="mt-1 text-xs" style="color: var(--ink-muted);">
                  {trial.conditions.slice(0, 2).join(', ')}
                  {trial.conditions.length > 2 && ` +${trial.conditions.length - 2} more`}
                </div>
              </td>
              <td class="px-4 py-4 whitespace-nowrap">
                <a
                  href={`/peptides/${trial.peptide.toLowerCase()}`}
                  class="text-sm font-medium text-primary hover:underline transition-colors"
                >
                  {trial.peptide}
                </a>
              </td>
              <td class="px-4 py-4 whitespace-nowrap">
                <span class="text-sm" style="color: var(--ink-muted);">Phase {trial.phase}</span>
              </td>
              <td class="px-4 py-4 whitespace-nowrap">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium border" style={statusStyle}>
                  {trial.status.charAt(0).toUpperCase() + trial.status.slice(1)}
                </span>
              </td>
              <td class="px-4 py-4 whitespace-nowrap text-sm" style="color: var(--ink-muted);">
                {formatDate(trial.completionDate)}
              </td>
            </tr>
          );
        })
      )}
    </tbody>
  </table>
</div>

<!-- Mobile view (cards) -->
<div class="md:hidden space-y-4">
  {trials.map((trial) => {
    const statusStyle = getStatusStyle(trial.status);
    return (
      <div class="rounded-lg border p-4 trial-card transition-colors"
           style="border-color: var(--border-c); background: var(--paper);"
           data-status={trial.status.toLowerCase()}
           data-phase={trial.phase}
           data-peptide={trial.peptide.toLowerCase()}>
        <div class="flex items-start justify-between gap-2">
          <a
            href={`https://clinicaltrials.gov/study/${trial.nctId}`}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm font-semibold text-primary hover:underline"
          >
            {trial.nctId}
          </a>
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium border" style={statusStyle}>
            {trial.status.charAt(0).toUpperCase() + trial.status.slice(1)}
          </span>
        </div>
        <h3 class="mt-2 text-sm font-medium line-clamp-2" style="color: var(--ink);">
          {trial.title}
        </h3>
        <div class="mt-3 flex flex-wrap gap-2 text-xs" style="color: var(--ink-muted);">
          <span class="inline-flex items-center gap-1">
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
            </svg>
            <a href={`/peptides/${trial.peptide.toLowerCase()}`} class="hover:text-primary">
              {trial.peptide}
            </a>
          </span>
          <span>Phase {trial.phase}</span>
          <span>Est. {formatDate(trial.completionDate)}</span>
        </div>
      </div>
    );
  })}
</div>

<style>
  .trial-row:hover {
    background: var(--paper-2);
  }

  .trial-card:hover {
    background: var(--paper-2);
    border-color: var(--border-strong);
  }

  /* Hide desktop table on mobile, hide mobile cards on desktop */
  .overflow-x-auto {
    display: none;
  }

  @media (min-width: 768px) {
    .overflow-x-auto {
      display: block;
    }
    .md\:hidden {
      display: none !important;
    }
  }
</style>
