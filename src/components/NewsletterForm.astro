---
interface Props {
  variant?: 'inline' | 'card' | 'full';
  heading?: string;
  description?: string;
}

const {
  variant = 'card',
  heading = 'Get Research Alerts',
  description = 'New dossiers and major study summaries delivered to your inbox. No spam, just evidence.'
} = Astro.props;
---

{variant === 'inline' && (
  <form
    class="flex gap-2"
    action="/api/subscribe"
    method="POST"
    data-newsletter-form
  >
    <input type="text" name="website" autocomplete="off" tabindex="-1" aria-hidden="true" style="position:absolute;left:-9999px;opacity:0;height:0;width:0;" />
    <input
      type="email"
      name="email"
      placeholder="your@email.com"
      required
      class="flex-1 rounded-xl px-4 py-2 text-sm text-[color:var(--ink)] placeholder-[color:var(--ink-dim)] outline-none focus:border-[color:var(--primary-c)] focus:ring-2 focus:ring-[var(--primary-c)]/20"
      style="background: var(--paper); border: 1px solid var(--border-c);"
    />
    <button
      type="submit"
      class="btn btn-cobalt btn-sm"
    >
      Subscribe
    </button>
  </form>
)}

{variant === 'card' && (
  <div class="glass-card p-6">
    <h3 class="text-lg font-semibold" style="color: var(--text-high);">{heading}</h3>
    <p class="mt-2 text-sm" style="color: var(--text-medium);">{description}</p>
    <form
      class="mt-4 flex gap-2"
      action="/api/subscribe"
      method="POST"
      data-newsletter-form
    >
      <input type="text" name="website" autocomplete="off" tabindex="-1" aria-hidden="true" style="position:absolute;left:-9999px;opacity:0;height:0;width:0;" />
      <input
        type="email"
        name="email"
        placeholder="your@email.com"
        required
        class="flex-1 rounded-xl px-4 py-2 text-sm text-[color:var(--ink)] placeholder-[color:var(--ink-dim)] outline-none focus:border-[color:var(--primary-c)] focus:ring-2 focus:ring-[var(--primary-c)]/20"
        style="background: var(--paper); border: 1px solid var(--border-c);"
      />
      <button
        type="submit"
        class="btn btn-cobalt btn-sm"
      >
        Subscribe
      </button>
    </form>
    <p class="mt-3 text-xs" style="color: var(--text-medium);">No spam. Unsubscribe anytime.</p>
  </div>
)}

{variant === 'full' && (
  <div class="relative rounded-2xl border border-[color:var(--border-c)] bg-[color:var(--paper)] p-8 overflow-hidden" style="box-shadow: var(--shadow-raise);">
    <!-- Cobalt accent rule -->
    <div class="absolute top-0 left-0 right-0 h-1 bg-[color:var(--primary-c)]"></div>

    <div class="relative max-w-xl mx-auto text-center">
      <h2 class="font-serif text-2xl font-medium" style="color: var(--ink);">{heading}</h2>
      <p class="mt-3" style="color: var(--ink-muted);">{description}</p>
      <form
        class="mt-6 flex flex-col sm:flex-row gap-3 max-w-md mx-auto"
        action="/api/subscribe"
        method="POST"
        data-newsletter-form
      >
        <input type="text" name="website" autocomplete="off" tabindex="-1" aria-hidden="true" style="position:absolute;left:-9999px;opacity:0;height:0;width:0;" />
        <input
          type="email"
          name="email"
          placeholder="your@email.com"
          required
          class="flex-1 rounded-xl px-4 py-3 text-[color:var(--ink)] placeholder-[color:var(--ink-dim)] outline-none focus:border-[color:var(--primary-c)] focus:ring-2 focus:ring-[var(--primary-c)]/20"
          style="background: var(--paper); border: 1px solid var(--border-c);"
        />
        <button
          type="submit"
          class="btn btn-cobalt btn-md"
        >
          Subscribe
        </button>
      </form>
      <p class="mt-4 text-xs" style="color: var(--ink-dim);">No spam. Unsubscribe anytime.</p>
    </div>
  </div>
)}

<script>
  document.querySelectorAll('[data-newsletter-form]').forEach(form => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formEl = e.target as HTMLFormElement;
      const formData = new FormData(formEl);
      const email = formData.get('email');
      const website = formData.get('website');
      const button = formEl.querySelector('button');
      const originalButtonText = button?.textContent || 'Subscribe';

      if (button) {
        button.textContent = 'Subscribing...';
        button.setAttribute('disabled', 'true');
      }

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, source: 'website_form', website }),
        });

        const data = await res.json();

        if (data.success) {
          // Success - show confirmation message without injecting API text as HTML
          formEl.replaceChildren();
          const successEl = document.createElement('p');
          successEl.className = 'text-[color:var(--ink)] font-bold py-3 text-center w-full';
          successEl.textContent = data.message || 'Successfully subscribed! Check your email.';
          formEl.appendChild(successEl);
        } else {
          // API returned an error message
          if (button) {
            button.textContent = originalButtonText;
            button.removeAttribute('disabled');
          }
          // Show error below the form
          const existingError = formEl.querySelector('[data-error]');
          if (existingError) existingError.remove();
          const errorEl = document.createElement('p');
          errorEl.setAttribute('data-error', 'true');
          errorEl.className = 'text-[color:var(--danger)] text-sm mt-2';
          errorEl.textContent = data.message;
          formEl.appendChild(errorEl);
        }
      } catch (err) {
        if (button) {
          button.textContent = originalButtonText;
          button.removeAttribute('disabled');
        }
        // Show generic error
        const existingError = formEl.querySelector('[data-error]');
        if (existingError) existingError.remove();
        const errorEl = document.createElement('p');
        errorEl.setAttribute('data-error', 'true');
        errorEl.className = 'text-[color:var(--danger)] text-sm mt-2';
        errorEl.textContent = 'Something went wrong. Please try again.';
        formEl.appendChild(errorEl);
      }
    });
  });
</script>
