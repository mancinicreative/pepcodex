---
interface Props {
  name: string;
  slug: string;
  city: string;
  state: string;
  address?: string;
  phone?: string;
  website?: string;
  services: string[];
  peptides?: string[];
  verifiedListing?: boolean;
  description?: string;
}

const {
  name,
  slug,
  city,
  state,
  address,
  phone,
  website,
  services,
  peptides = [],
  verifiedListing = false,
  description
} = Astro.props;
---

<div class="glass-card group relative block h-full overflow-hidden border-2 border-primary/30">
  <!-- Featured badge ribbon -->
  <div class="absolute top-0 right-0 z-20">
    <div class="bg-gradient-to-r from-primary to-purple-600 text-white text-xs font-bold uppercase tracking-wider px-4 py-1 transform rotate-0 shadow-lg">
      Featured
    </div>
  </div>

  <!-- Purple gradient overlay for visual interest -->
  <div class="absolute inset-0 bg-gradient-to-br from-primary/15 via-transparent to-cyan-500/10 opacity-100"></div>

  <!-- Decorative glow effect -->
  <div class="absolute -top-20 -right-20 w-40 h-40 bg-primary/20 rounded-full blur-3xl"></div>

  <div class="relative z-10 p-6 flex flex-col h-full">
    <!-- Header with name and verified badge -->
    <div class="flex items-start justify-between gap-4 mb-3 pr-16">
      <h3 class="text-2xl font-bold text-primary transition-colors font-display">
        {name}
      </h3>
      {verifiedListing && (
        <span class="badge badge--success flex items-center gap-1 shrink-0">
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12" />
          </svg>
          Verified
        </span>
      )}
    </div>

    <!-- Location -->
    <div class="flex items-center gap-2 mb-3" style="color: var(--text-high);">
      <svg class="w-4 h-4 shrink-0 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
        <circle cx="12" cy="10" r="3"/>
      </svg>
      <span class="text-sm font-medium">{city}, {state}</span>
    </div>

    <!-- Address if available -->
    {address && (
      <p class="text-sm mb-2" style="color: var(--text-medium);">
        {address}
      </p>
    )}

    <!-- Description -->
    {description && (
      <p class="text-sm line-clamp-3 mb-4 leading-relaxed" style="color: var(--text-medium);">
        {description}
      </p>
    )}

    <!-- Services - show all for featured -->
    <div class="mb-4">
      <p class="text-xs uppercase tracking-wider mb-2 font-semibold" style="color: var(--text-low);">Services</p>
      <div class="flex flex-wrap gap-1.5">
        {services.map((service) => (
          <span class="badge badge--muted text-xs normal-case">
            {service}
          </span>
        ))}
      </div>
    </div>

    <!-- Peptides offered - show all for featured -->
    {peptides.length > 0 && (
      <div class="mb-4">
        <p class="text-xs uppercase tracking-wider mb-2 font-semibold" style="color: var(--text-low);">Peptides Offered</p>
        <div class="flex flex-wrap gap-1.5">
          {peptides.map((peptide) => (
            <span class="badge badge--primary text-xs normal-case">
              {peptide}
            </span>
          ))}
        </div>
      </div>
    )}

    <!-- Contact Actions - more prominent for featured -->
    <div class="mt-auto pt-4 flex flex-wrap gap-3" style="border-top: 1px solid var(--border-glass);">
      {phone && (
        <a
          href={`tel:${phone.replace(/[^0-9+]/g, '')}`}
          class="btn btn-secondary btn-md flex-1 min-w-[120px]"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          Call Now
        </a>
      )}
      {website && (
        <a
          href={website}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary btn-md flex-1 min-w-[120px]"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
          Visit Website
        </a>
      )}
    </div>
  </div>
</div>
