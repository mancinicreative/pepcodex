---
import BaseLayout from './BaseLayout.astro';
import EvidenceBadge from '../components/EvidenceBadge.astro';
import FAQSchema from '../components/SEO/FAQSchema.astro';
import BreadcrumbSchema from '../components/SEO/BreadcrumbSchema.astro';
import NewsletterForm from '../components/NewsletterForm.astro';

interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  peptideA: {
    name: string;
    slug: string;
    evidenceStrength: 'high' | 'moderate' | 'low' | 'very-low';
  };
  peptideB: {
    name: string;
    slug: string;
    evidenceStrength: 'high' | 'moderate' | 'low' | 'very-low';
  };
  category: string;
  lastUpdated: Date;
  summary: string;
  faqs?: FAQItem[];
  metaTitle?: string;
  metaDescription?: string;
}

const { title, peptideA, peptideB, category, lastUpdated, summary, faqs = [], metaTitle, metaDescription } = Astro.props;

const categoryLabels: Record<string, string> = {
  'metabolic': 'Metabolic',
  'repair-recovery': 'Repair & Recovery',
  'hormonal': 'Hormonal',
  'longevity': 'Longevity',
  'other': 'Other',
};

// All categories use the single cobalt accent as a paper-theme badge (one accent only)
const categoryColors: Record<string, string> = {
  'metabolic': 'badge badge--primary',
  'repair-recovery': 'badge badge--primary',
  'hormonal': 'badge badge--primary',
  'longevity': 'badge badge--primary',
  'other': 'badge badge--muted',
};

const siteBase = Astro.site?.toString() || 'https://www.pepcodex.com';
const breadcrumbItems = [
  { name: 'Home', url: siteBase },
  { name: 'Comparisons', url: `${siteBase}compare/` },
  { name: title, url: Astro.url.toString() },
];
---

<BaseLayout title={metaTitle || title} description={metaDescription || summary}>
  <BreadcrumbSchema items={breadcrumbItems} />
  {faqs && faqs.length > 0 && <FAQSchema items={faqs} />}
  <article class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <!-- Header -->
    <header class="mb-8 relative">
      <div class="p-6">
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <a
            href={`/category/${category}`}
            class={categoryColors[category] || categoryColors['other']}
          >
            {categoryLabels[category] || 'Other'}
          </a>
          <span class="badge badge--primary">
            Comparison
          </span>
        </div>

        <h1 class="text-3xl sm:text-4xl lg:text-5xl tracking-tight" style="font-family: var(--font-serif); font-weight: 500; color: var(--ink);">
          {title}
        </h1>

        <p class="mt-4 text-xl leading-relaxed max-w-3xl" style="color: var(--ink-muted);">
          {summary}
        </p>

        <p class="mt-4 text-sm" style="color: var(--ink-dim);">
          Last updated: {lastUpdated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </p>
      </div>
    </header>

    <!-- Peptide comparison header cards -->
    <div class="grid gap-6 md:grid-cols-2 mb-8">
      <!-- Peptide A -->
      <div class="glass-card p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-2xl" style="font-family: var(--font-serif); font-weight: 500; color: var(--ink);">{peptideA.name}</h2>
          <EvidenceBadge strength={peptideA.evidenceStrength} />
        </div>
        <a
          href={`/peptides/${peptideA.slug}`}
          class="inline-flex items-center text-primary hover:text-[color:var(--primary-deep)] hover:underline text-sm font-medium transition-colors"
        >
          View full dossier
          <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>

      <!-- Peptide B -->
      <div class="glass-card p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-2xl" style="font-family: var(--font-serif); font-weight: 500; color: var(--ink);">{peptideB.name}</h2>
          <EvidenceBadge strength={peptideB.evidenceStrength} />
        </div>
        <a
          href={`/peptides/${peptideB.slug}`}
          class="inline-flex items-center text-primary hover:text-[color:var(--primary-deep)] hover:underline text-sm font-medium transition-colors"
        >
          View full dossier
          <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </div>

    <!-- Main comparison content -->
    <div class="prose prose-invert prose-lg max-w-none">
      <slot />
    </div>

    <!-- Footer links -->
    <div class="mt-12 pt-8" style="border-top: 1px solid var(--border-c);">
      <h3 class="font-semibold mb-4" style="color: var(--ink);">View Full Dossiers</h3>
      <div class="flex flex-wrap gap-4">
        <a
          href={`/peptides/${peptideA.slug}`}
          class="inline-flex items-center rounded-lg px-4 py-2 text-sm font-medium transition-colors hover:opacity-80" style="background: var(--primary-soft); border: 1px solid var(--primary-border); color: var(--primary-c);"
        >
          {peptideA.name} Evidence Dossier
          <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
        <a
          href={`/peptides/${peptideB.slug}`}
          class="inline-flex items-center rounded-lg px-4 py-2 text-sm font-medium transition-colors hover:opacity-80" style="background: var(--primary-soft); border: 1px solid var(--primary-border); color: var(--primary-c);"
        >
          {peptideB.name} Evidence Dossier
          <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </div>

    <!-- Newsletter CTA -->
    <div class="mt-12">
      <NewsletterForm
        variant="card"
        heading="Stay Updated on Peptide Comparisons"
        description="Get notified when we publish new comparison dossiers and evidence reviews."
      />
    </div>

    <!-- Disclaimer -->
    <div class="mt-8 rounded-xl p-6" style="background: rgba(203,135,52,0.10); border: 1px solid rgba(203,135,52,0.32);">
      <p class="text-sm" style="color: var(--ink-muted);">
        <strong style="color: #9a6418;">Disclaimer:</strong> This comparison is for educational purposes only and does not constitute medical advice. Individual responses to medications vary. Always consult a qualified healthcare provider before making treatment decisions.
      </p>
    </div>
  </article>
</BaseLayout>
