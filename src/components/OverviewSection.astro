---
interface AminoAcid {
  code: string;
  name: string;
  position: number;
  property: 'hydrophobic' | 'polar' | 'positive' | 'negative' | 'modified';
}

interface MolecularInfo {
  weight: string;
  chainLength: number;
  type: string;
  sequence: string;
  aminoAcids: AminoAcid[];
}

interface Props {
  peptideName: string;
  summary: string;
  aliases?: string[];
  category: string;
  molecularInfo?: MolecularInfo;
}

const { peptideName, summary, aliases = [], category, molecularInfo } = Astro.props;

// Property colors for amino acids
const propertyColors = {
  hydrophobic: { bg: 'bg-amber-500/20', border: 'border-amber-500/30', text: 'text-amber-400' },
  polar: { bg: 'bg-cyan-500/20', border: 'border-cyan-500/30', text: 'text-cyan-400' },
  positive: { bg: 'bg-blue-500/20', border: 'border-blue-500/30', text: 'text-blue-400' },
  negative: { bg: 'bg-rose-500/20', border: 'border-rose-500/30', text: 'text-rose-400' },
  modified: { bg: 'bg-violet-500/20', border: 'border-violet-500/30', text: 'text-violet-400' },
};
---

<section id="overview" class="not-prose">
  <div class="space-y-2 mb-8">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-primary/30 to-primary/10 flex items-center justify-center border border-primary/30">
        <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
      </div>
      <h2 class="text-3xl font-bold text-white tracking-tight" style="font-family: var(--font-display);">
        Overview
      </h2>
    </div>
    <p class="text-white/60 ml-[52px]">What is {peptideName} and what does the research say?</p>
  </div>

  <div class="rounded-2xl border border-white/10 bg-gradient-to-br from-white/5 to-transparent overflow-hidden">
    <!-- Identity Section (Top) -->
    <div class="p-6 border-b border-white/10">
      <div class="flex items-center gap-2 mb-4">
        <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2" />
        </svg>
        <span class="text-sm font-semibold text-white uppercase tracking-wider">Identity</span>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {aliases.length > 0 && (
          <div class="col-span-2 md:col-span-4">
            <div class="text-xs text-white/40 uppercase tracking-wider mb-1">Also Known As</div>
            <div class="text-white/70 text-sm">{aliases.join(' • ')}</div>
          </div>
        )}
        {molecularInfo && (
          <>
            <div>
              <div class="text-xs text-white/40 uppercase tracking-wider mb-1">Type</div>
              <div class="text-white font-medium">{molecularInfo.type}</div>
            </div>
            <div>
              <div class="text-xs text-white/40 uppercase tracking-wider mb-1">Length</div>
              <div class="text-white font-medium">{molecularInfo.chainLength} amino acids</div>
            </div>
            <div>
              <div class="text-xs text-white/40 uppercase tracking-wider mb-1">Weight</div>
              <div class="text-white font-medium">{molecularInfo.weight}</div>
            </div>
            <div>
              <div class="text-xs text-white/40 uppercase tracking-wider mb-1">Sequence</div>
              <div class="text-white/70 font-mono text-sm">{molecularInfo.sequence}</div>
            </div>
          </>
        )}
      </div>
    </div>

    <!-- Molecular Structure Section (Bottom) -->
    {molecularInfo && (
      <div class="p-6">
        <div class="flex items-center gap-2 mb-4">
          <svg class="w-4 h-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
          </svg>
          <span class="text-sm font-semibold text-white uppercase tracking-wider">Molecular Structure</span>
        </div>

        <!-- Sequence Visualization -->
        <div class="bg-white/5 rounded-xl p-4 border border-white/10 mb-4">
          <div class="flex flex-wrap gap-2">
            {molecularInfo.aminoAcids.map((aa) => {
              const colors = propertyColors[aa.property];
              return (
                <div
                  class={`min-w-9 h-9 px-2 rounded-lg ${colors.bg} border ${colors.border} flex items-center justify-center cursor-pointer transition-all hover:scale-110`}
                  title={`${aa.name} (${aa.code}) - Position ${aa.position} - ${aa.property}`}
                >
                  <span class={`text-sm font-bold ${colors.text} whitespace-nowrap`}>{aa.code}</span>
                </div>
              );
            })}
          </div>
        </div>

        <!-- Property Legend -->
        <div class="flex flex-wrap gap-x-4 gap-y-2 text-xs">
          <div class="flex items-center gap-1.5">
            <div class="w-3 h-3 rounded bg-amber-500/30 border border-amber-500/40"></div>
            <span class="text-white/50">Hydrophobic</span>
          </div>
          <div class="flex items-center gap-1.5">
            <div class="w-3 h-3 rounded bg-cyan-500/30 border border-cyan-500/40"></div>
            <span class="text-white/50">Polar</span>
          </div>
          <div class="flex items-center gap-1.5">
            <div class="w-3 h-3 rounded bg-blue-500/30 border border-blue-500/40"></div>
            <span class="text-white/50">Positive</span>
          </div>
          <div class="flex items-center gap-1.5">
            <div class="w-3 h-3 rounded bg-rose-500/30 border border-rose-500/40"></div>
            <span class="text-white/50">Negative</span>
          </div>
        </div>
      </div>
    )}
  </div>
</section>
