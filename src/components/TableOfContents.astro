---
// Table of Contents - auto-generates from page headings via client JS
---

<nav class="rounded-xl border border-[color:var(--border-c)] bg-[color:var(--paper)] p-4" id="toc" aria-label="Table of contents">
  <h2 class="font-serif font-medium text-[color:var(--ink)] mb-3">On This Page</h2>
  <ul class="space-y-2 text-sm" id="toc-list">
    <!-- Populated by JavaScript -->
  </ul>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const tocList = document.getElementById('toc-list');
    const article = document.querySelector('article');

    if (!tocList || !article) return;

    const headings = article.querySelectorAll('h2, h3');

    headings.forEach((heading, index) => {
      // Ensure heading has an ID
      if (!heading.id) {
        heading.id = `heading-${index}`;
      }

      const li = document.createElement('li');
      const a = document.createElement('a');

      a.href = `#${heading.id}`;
      a.textContent = heading.textContent;
      a.className = heading.tagName === 'H3'
        ? 'text-[color:var(--ink-muted)] hover:text-primary pl-4 block transition-colors'
        : 'text-[color:var(--ink)] hover:text-primary font-medium block transition-colors';

      li.appendChild(a);
      tocList.appendChild(li);
    });

    // Hide TOC if no headings
    if (headings.length === 0) {
      document.getElementById('toc')?.classList.add('hidden');
    }
  });
</script>
