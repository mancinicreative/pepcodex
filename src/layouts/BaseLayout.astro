---
import '../styles/global.css';
import OrganizationSchema from '../components/SEO/OrganizationSchema.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  robots?: 'index' | 'noindex';
}

const {
  title,
  description = 'Evidence-based peptide research library. Comprehensive dossiers with citations, not advice.',
  ogImage,
  robots = 'index'
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteName = 'PepCodex';

// Google Analytics 4 - set in environment variable
const GA_TRACKING_ID = import.meta.env.PUBLIC_GA_TRACKING_ID;

// Get current path for nav highlighting
const currentPath = Astro.url.pathname;
const isActive = (path: string) => currentPath === path || (path !== '/' && currentPath.startsWith(path));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title} | {siteName}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {robots === 'noindex' && <meta name="robots" content="noindex, nofollow" />}

    <!-- Structured Data -->
    <OrganizationSchema />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />

    <!-- Google Analytics 4 -->
    {GA_TRACKING_ID && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_TRACKING_ID}`}></script>
        <script is:inline define:vars={{ GA_TRACKING_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', GA_TRACKING_ID);
        </script>
      </>
    )}
  </head>
  <body class="min-h-screen text-[var(--foreground)] antialiased selection:bg-[var(--primary)]/30" style="font-family: var(--font-sans);">
    <!-- Header -->
    <nav class="fixed top-0 left-0 right-0 z-50 border-b border-white/5 bg-[var(--background)]/60 backdrop-blur-xl supports-[backdrop-filter]:bg-[var(--background)]/20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 group">
          <div class="relative w-8 h-8 flex items-center justify-center bg-[var(--primary)]/10 rounded-lg group-hover:bg-[var(--primary)]/20 transition-colors border border-[var(--primary)]/20">
            <svg class="w-5 h-5 text-[var(--primary)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2" />
              <path d="M8.5 2h7" />
              <path d="M7 16h10" />
            </svg>
          </div>
          <span class="font-bold text-xl tracking-wide bg-clip-text text-transparent bg-gradient-to-r from-[var(--primary)] via-purple-400 to-[var(--primary)]" style="font-family: var(--font-display);">
            PEPCODEX
          </span>
        </a>

        <!-- Desktop Nav -->
        <div class="hidden md:flex items-center gap-1">
          <a
            href="/peptides"
            class:list={[
              "flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-all duration-300",
              isActive('/peptides') || isActive('/category')
                ? "bg-white/10 text-white shadow-[0_0_15px_rgba(255,255,255,0.1)] border border-white/10"
                : "text-white/85 hover:text-white hover:bg-white/5"
            ]}
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2" />
            </svg>
            Peptides
          </a>
          <a
            href="/trials"
            class:list={[
              "flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-all duration-300",
              isActive('/trials')
                ? "bg-white/10 text-white shadow-[0_0_15px_rgba(255,255,255,0.1)] border border-white/10"
                : "text-white/85 hover:text-white hover:bg-white/5"
            ]}
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
            </svg>
            Trials
          </a>
          <a
            href="/glossary"
            class:list={[
              "flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-all duration-300",
              isActive('/glossary')
                ? "bg-white/10 text-white shadow-[0_0_15px_rgba(255,255,255,0.1)] border border-white/10"
                : "text-white/85 hover:text-white hover:bg-white/5"
            ]}
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20" />
            </svg>
            Glossary
          </a>
          <a
            href="/blog"
            class:list={[
              "flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-all duration-300",
              isActive('/blog')
                ? "bg-white/10 text-white shadow-[0_0_15px_rgba(255,255,255,0.1)] border border-white/10"
                : "text-white/85 hover:text-white hover:bg-white/5"
            ]}
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/>
              <path d="M18 14h-8"/>
              <path d="M18 18h-8"/>
              <path d="M18 10h-8"/>
            </svg>
            Blog
          </a>
        </div>

        <!-- Right side actions -->
        <div class="hidden md:flex items-center gap-3">
          <button class="btn btn-ghost rounded-full p-2" style="color: var(--text-medium);">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8" />
              <path d="m21 21-4.3-4.3" />
            </svg>
          </button>
          <a
            href="/newsletter"
            class="btn btn-primary btn-md relative overflow-hidden uppercase tracking-wider before:absolute before:inset-0 before:bg-gradient-to-r before:from-transparent before:via-white/20 before:to-transparent before:-translate-x-full hover:before:translate-x-full before:transition-transform before:duration-700"
            style="font-family: var(--font-display);"
          >
            Subscribe
          </a>
        </div>

        <!-- Mobile Menu Button -->
        <button
          type="button"
          id="mobile-menu-btn"
          class="flex h-10 w-10 items-center justify-center rounded-lg text-white md:hidden hover:bg-white/10 transition-colors"
          aria-expanded="false"
          aria-label="Open menu"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>

      <!-- Mobile navigation -->
      <div id="mobile-nav" class="hidden bg-[var(--background)]/95 backdrop-blur-2xl border-t border-white/5 p-4 md:hidden">
        <div class="flex flex-col gap-2">
          <a
            href="/peptides"
            class:list={[
              "flex items-center gap-3 px-4 py-3 rounded-xl text-lg font-medium transition-colors",
              isActive('/peptides')
                ? "bg-[var(--primary)]/10 text-[var(--primary)] border border-[var(--primary)]/20"
                : "text-white/85 hover:text-white hover:bg-white/5"
            ]}
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2" />
            </svg>
            Peptides
          </a>
          <a
            href="/trials"
            class:list={[
              "flex items-center gap-3 px-4 py-3 rounded-xl text-lg font-medium transition-colors",
              isActive('/trials')
                ? "bg-[var(--primary)]/10 text-[var(--primary)] border border-[var(--primary)]/20"
                : "text-white/85 hover:text-white hover:bg-white/5"
            ]}
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
            </svg>
            Trials
          </a>
          <a
            href="/glossary"
            class:list={[
              "flex items-center gap-3 px-4 py-3 rounded-xl text-lg font-medium transition-colors",
              isActive('/glossary')
                ? "bg-[var(--primary)]/10 text-[var(--primary)] border border-[var(--primary)]/20"
                : "text-white/85 hover:text-white hover:bg-white/5"
            ]}
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20" />
            </svg>
            Glossary
          </a>
          <a
            href="/blog"
            class:list={[
              "flex items-center gap-3 px-4 py-3 rounded-xl text-lg font-medium transition-colors",
              isActive('/blog')
                ? "bg-[var(--primary)]/10 text-[var(--primary)] border border-[var(--primary)]/20"
                : "text-white/85 hover:text-white hover:bg-white/5"
            ]}
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/>
              <path d="M18 14h-8"/>
              <path d="M18 18h-8"/>
              <path d="M18 10h-8"/>
            </svg>
            Blog
          </a>
        </div>
      </div>
    </nav>

    <main class="pt-24 pb-12 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 min-h-[calc(100vh-4rem)]">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-white/5 bg-black/20 backdrop-blur-lg mt-auto">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
          <!-- Brand -->
          <div>
            <div class="flex items-center gap-2 mb-4">
              <div class="w-6 h-6 bg-primary/20 rounded flex items-center justify-center">
                <svg class="w-3 h-3 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2" />
                </svg>
              </div>
              <span class="font-bold text-lg bg-clip-text text-transparent bg-gradient-to-r from-primary via-purple-400 to-primary" style="font-family: var(--font-display);">PEPCODEX</span>
            </div>
            <p class="text-sm leading-relaxed" style="color: var(--text-medium);">
              Evidence-based peptide research platform. Synthesizing peer-reviewed literature for informed decisions.
            </p>
          </div>

          <!-- Browse -->
          <div>
            <h4 class="font-bold text-white mb-4 uppercase tracking-wider text-sm" style="font-family: var(--font-display);">Browse</h4>
            <ul class="space-y-2 text-sm" style="color: var(--text-medium);">
              <li><a href="/peptides" class="hover:text-primary transition-colors">All Peptides</a></li>
              <li><a href="/category/metabolic" class="hover:text-primary transition-colors">Metabolic</a></li>
              <li><a href="/category/repair-recovery" class="hover:text-primary transition-colors">Recovery</a></li>
              <li><a href="/category/hormonal" class="hover:text-primary transition-colors">Hormonal</a></li>
            </ul>
          </div>

          <!-- Research -->
          <div>
            <h4 class="font-bold text-white mb-4 uppercase tracking-wider text-sm" style="font-family: var(--font-display);">Research</h4>
            <ul class="space-y-2 text-sm" style="color: var(--text-medium);">
              <li><a href="/trials" class="hover:text-primary transition-colors">Clinical Trials</a></li>
              <li><a href="/compare" class="hover:text-primary transition-colors">Comparisons</a></li>
              <li><a href="/guide" class="hover:text-primary transition-colors">Guides</a></li>
              <li><a href="/safety" class="hover:text-primary transition-colors">Safety Profiles</a></li>
              <li><a href="/blog" class="hover:text-primary transition-colors">Blog</a></li>
            </ul>
          </div>

          <!-- Disclaimer -->
          <div>
            <h4 class="font-bold text-white mb-4 uppercase tracking-wider text-sm" style="font-family: var(--font-display);">Disclaimer</h4>
            <p class="text-xs leading-relaxed" style="color: var(--text-medium);">
              Educational purposes only. Not medical advice. Always consult a healthcare professional.
            </p>
          </div>
        </div>

        <div class="pt-8 border-t border-white/5 text-center md:text-left flex flex-col md:flex-row justify-between items-center text-xs" style="color: var(--text-low);">
          <p>&copy; {new Date().getFullYear()} PepCodex. All rights reserved.</p>
          <div class="flex gap-4 mt-4 md:mt-0">
            <a href="/about" class="hover:text-white transition-colors">About</a>
            <a href="/methodology" class="hover:text-white transition-colors">Methodology</a>
            <a href="/editorial-policy" class="hover:text-white transition-colors">Editorial Policy</a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Mobile menu script -->
    <script>
      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileNav = document.getElementById('mobile-nav');

      if (menuBtn && mobileNav) {
        menuBtn.addEventListener('click', () => {
          const isExpanded = menuBtn.getAttribute('aria-expanded') === 'true';
          menuBtn.setAttribute('aria-expanded', String(!isExpanded));
          mobileNav.classList.toggle('hidden');
        });
      }
    </script>
  </body>
</html>
