---
/**
 * QualityChecklist.astro - Traffic light styled quality evaluation checklist
 * Helps researchers evaluate peptide product quality with visual indicators
 * Green = good signs, Yellow = warning signs, Red = bad signs
 */

interface QualityChecklistData {
  goodSigns: string[];
  warningSigns: string[];
  badSigns: string[];
}

interface Props {
  checklist: QualityChecklistData;
  peptideName: string;
}

const { checklist, peptideName } = Astro.props;

// Don't render if no checklist data
if (!checklist) {
  return null;
}

const { goodSigns, warningSigns, badSigns } = checklist;
---

<section class="quality-checklist-section my-12">
  <div class="mb-8">
    <p class="eyebrow" style="color: var(--ink-dim);">Quality</p>
    <h3 class="text-3xl tracking-tight mt-1 text-[color:var(--ink)]" style="font-family: var(--font-serif); font-weight: 500;">
      Quality Checklist
    </h3>
    <p class="mt-1 text-[color:var(--ink-muted)] text-sm">
      Visual indicators to help evaluate {peptideName} product quality
    </p>
  </div>

  <!-- Expandable Sections -->
  <div class="space-y-4">
    <!-- Good Signs (Green) -->
    {goodSigns && goodSigns.length > 0 && (
      <details class="quality-details group" open>
        <summary class="flex items-center gap-3 p-4 rounded-xl bg-[rgba(20,118,74,0.10)] border border-[rgba(20,118,74,0.30)] cursor-pointer hover:bg-[rgba(20,118,74,0.16)] transition-all duration-300 select-none">
          <div class="w-8 h-8 rounded-lg bg-[rgba(20,118,74,0.16)] flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-[color:var(--research)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20,6 9,17 4,12"></polyline>
            </svg>
          </div>
          <div class="flex-1">
            <span class="font-semibold text-[color:var(--research)] text-base">Good Signs</span>
            <span class="text-[color:var(--ink-dim)] text-sm ml-2">({goodSigns.length} indicators)</span>
          </div>
          <div class="w-6 h-6 rounded-full bg-[rgba(20,118,74,0.16)] flex items-center justify-center transition-transform duration-300 group-open:rotate-180">
            <svg class="w-4 h-4 text-[color:var(--research)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6,9 12,15 18,9"></polyline>
            </svg>
          </div>
        </summary>
        <div class="mt-3 pl-4 space-y-2">
          {goodSigns.map((sign) => (
            <div class="flex items-start gap-3 p-3 rounded-lg bg-[color:var(--paper)] border border-[color:var(--border-c)] hover:border-[rgba(20,118,74,0.30)] transition-colors">
              <div class="w-5 h-5 rounded-full bg-[rgba(20,118,74,0.16)] flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-[color:var(--research)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                  <polyline points="20,6 9,17 4,12"></polyline>
                </svg>
              </div>
              <span class="text-[color:var(--ink)] text-[15px] leading-relaxed">{sign}</span>
            </div>
          ))}
        </div>
      </details>
    )}

    <!-- Warning Signs (Yellow/Amber) -->
    {warningSigns && warningSigns.length > 0 && (
      <details class="quality-details group">
        <summary class="flex items-center gap-3 p-4 rounded-xl bg-[rgba(203,135,52,0.12)] border border-[rgba(203,135,52,0.32)] cursor-pointer hover:bg-[rgba(203,135,52,0.18)] transition-all duration-300 select-none">
          <div class="w-8 h-8 rounded-lg bg-[rgba(203,135,52,0.18)] flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-[#9a6418]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
              <line x1="12" y1="9" x2="12" y2="13"></line>
              <line x1="12" y1="17" x2="12.01" y2="17"></line>
            </svg>
          </div>
          <div class="flex-1">
            <span class="font-semibold text-[#9a6418] text-base">Warning Signs</span>
            <span class="text-[color:var(--ink-dim)] text-sm ml-2">({warningSigns.length} indicators)</span>
          </div>
          <div class="w-6 h-6 rounded-full bg-[rgba(203,135,52,0.18)] flex items-center justify-center transition-transform duration-300 group-open:rotate-180">
            <svg class="w-4 h-4 text-[#9a6418]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6,9 12,15 18,9"></polyline>
            </svg>
          </div>
        </summary>
        <div class="mt-3 pl-4 space-y-2">
          {warningSigns.map((sign) => (
            <div class="flex items-start gap-3 p-3 rounded-lg bg-[color:var(--paper)] border border-[color:var(--border-c)] hover:border-[rgba(203,135,52,0.32)] transition-colors">
              <div class="w-5 h-5 rounded-full bg-[rgba(203,135,52,0.18)] flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-[#9a6418]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <line x1="12" y1="8" x2="12" y2="12"></line>
                  <line x1="12" y1="16" x2="12.01" y2="16"></line>
                </svg>
              </div>
              <span class="text-[color:var(--ink)] text-[15px] leading-relaxed">{sign}</span>
            </div>
          ))}
        </div>
      </details>
    )}

    <!-- Bad Signs (Red) -->
    {badSigns && badSigns.length > 0 && (
      <details class="quality-details group">
        <summary class="flex items-center gap-3 p-4 rounded-xl bg-[rgba(185,61,66,0.10)] border border-[rgba(185,61,66,0.28)] cursor-pointer hover:bg-[rgba(185,61,66,0.16)] transition-all duration-300 select-none">
          <div class="w-8 h-8 rounded-lg bg-[rgba(185,61,66,0.16)] flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-[color:var(--danger)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </div>
          <div class="flex-1">
            <span class="font-semibold text-[color:var(--danger)] text-base">Bad Signs</span>
            <span class="text-[color:var(--ink-dim)] text-sm ml-2">({badSigns.length} indicators)</span>
          </div>
          <div class="w-6 h-6 rounded-full bg-[rgba(185,61,66,0.16)] flex items-center justify-center transition-transform duration-300 group-open:rotate-180">
            <svg class="w-4 h-4 text-[color:var(--danger)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6,9 12,15 18,9"></polyline>
            </svg>
          </div>
        </summary>
        <div class="mt-3 pl-4 space-y-2">
          {badSigns.map((sign) => (
            <div class="flex items-start gap-3 p-3 rounded-lg bg-[color:var(--paper)] border border-[color:var(--border-c)] hover:border-[rgba(185,61,66,0.28)] transition-colors">
              <div class="w-5 h-5 rounded-full bg-[rgba(185,61,66,0.16)] flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-[color:var(--danger)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                  <line x1="18" y1="6" x2="6" y2="18"></line>
                  <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
              </div>
              <span class="text-[color:var(--ink)] text-[15px] leading-relaxed">{sign}</span>
            </div>
          ))}
        </div>
      </details>
    )}
  </div>

  <!-- Traffic Light Legend -->
  <div class="mt-6 p-4 rounded-xl bg-[color:var(--paper)] border border-[color:var(--border-c)]">
    <div class="flex flex-wrap items-center justify-center gap-6 text-sm">
      <div class="flex items-center gap-2">
        <div class="w-3 h-3 rounded-full bg-[color:var(--research)]"></div>
        <span class="text-[color:var(--ink-muted)]">Positive quality indicator</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="w-3 h-3 rounded-full bg-[color:var(--compound)]"></div>
        <span class="text-[color:var(--ink-muted)]">Requires evaluation</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="w-3 h-3 rounded-full bg-[color:var(--danger)]"></div>
        <span class="text-[color:var(--ink-muted)]">Potential quality issue</span>
      </div>
    </div>
  </div>

  <!-- Disclaimer -->
  <div class="mt-6 p-4 rounded-xl bg-[color:var(--paper-2)] border border-[color:var(--border-c)]">
    <div class="flex gap-3">
      <div class="flex-shrink-0 w-8 h-8 rounded-lg bg-[color:var(--primary-soft)] flex items-center justify-center">
        <svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"></circle>
          <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
          <line x1="12" y1="17" x2="12.01" y2="17"></line>
        </svg>
      </div>
      <div>
        <p class="text-[color:var(--ink)] text-sm font-medium mb-1">For Research Evaluation Only</p>
        <p class="text-[color:var(--ink-muted)] text-xs leading-relaxed">
          These quality indicators are general guidelines based on typical peptide characteristics.
          Professional laboratory testing (HPLC, mass spectrometry) provides definitive quality verification.
          This checklist is for initial visual evaluation only.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .quality-details summary::-webkit-details-marker {
    display: none;
  }

  .quality-details summary::marker {
    display: none;
    content: '';
  }

  .quality-details[open] > summary {
    border-bottom-left-radius: 0.5rem;
    border-bottom-right-radius: 0.5rem;
  }

  /* Smooth animation for content */
  .quality-details > div {
    animation: quality-slide-down 0.3s ease-out;
  }

  @keyframes quality-slide-down {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Hover effect on individual items */
  .quality-details div:hover {
    box-shadow: 0 0 0 1px var(--border-c);
  }
</style>
