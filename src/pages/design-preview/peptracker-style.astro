---
const title = 'PepCodex × PepTracker Design Preview';
const description = 'Private noindex preview route exploring the PepTracker-inspired PepCodex catalogue and dossier direction.';

const plates = [
  { n: 'I', category: 'Metabolic', name: 'Semaglutide', aliases: 'Ozempic · Wegovy · Rybelsus', summary: 'GLP-1 receptor agonist with extensive human clinical evidence across diabetes, obesity, cardiovascular risk, and MASH.', sources: 412, grade: 'A', safety: '2', tone: 'metabolic' },
  { n: 'II', category: 'Metabolic', name: 'Tirzepatide', aliases: 'Mounjaro · Zepbound', summary: 'Dual GIP/GLP-1 agonist with strong phase 3 evidence for type 2 diabetes, weight management, and sleep apnea.', sources: 387, grade: 'A', safety: '2', tone: 'metabolic' },
  { n: 'III', category: 'Recovery', name: 'BPC-157', aliases: 'Body Protection Compound', summary: 'Popular recovery peptide with a coherent rodent mechanism story, sparse human evidence, and unresolved long-term safety questions.', sources: 94, grade: 'D', safety: '4', tone: 'recovery' },
  { n: 'IV', category: 'Recovery', name: 'TB-500', aliases: 'Thymosin β-4 fragment', summary: 'Marketed for tissue repair; parent compound has human research, but the fragment itself lacks dedicated clinical evidence.', sources: 128, grade: 'D', safety: '4', tone: 'recovery' },
];

const drawers = [
  { letter: 'A', name: 'Metabolic', desc: 'GLP-1, amylin, incretin, and weight-management compounds.', count: 18, tone: 'metabolic' },
  { letter: 'B', name: 'Recovery', desc: 'Soft-tissue, wound, tendon, and musculoskeletal repair candidates.', count: 22, tone: 'recovery' },
  { letter: 'C', name: 'Hormonal', desc: 'GHRH analogues, secretagogues, melanocortin and endocrine signals.', count: 14, tone: 'hormonal' },
  { letter: 'D', name: 'Longevity', desc: 'Bioregulators, senolytic candidates, and aging-adjacent claims.', count: 16, tone: 'longevity' },
];

const concerns = [
  'Sparse independent human replication.',
  'No specific receptor has been identified.',
  'Long-term safety remains genuinely unstudied.',
  'Some rodent effect sizes strain biological plausibility.',
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="preview-ribbon">
      <strong>Design preview</strong>
      <span>Noindex route · not wired into production navigation · used to evaluate the PepTracker → PepCodex direction.</span>
      <a href="/">Back to current site</a>
    </div>

    <header class="masthead" id="top">
      <div class="masthead-inner">
        <nav class="masthead-left" aria-label="Primary">
          <a href="#catalogue">Catalogue</a>
          <a href="#plates">Plates</a>
          <a href="#dossier">Dossier</a>
        </nav>
        <a class="brand" href="#top" aria-label="PepCodex preview home">
          <span>❧</span>
          <strong>PEPCODEX</strong>
          <span>❧</span>
        </a>
        <nav class="masthead-right" aria-label="Actions">
          <a href="#methodology">Methodology</a>
          <a href="#tracker">PepTracker</a>
          <a class="kbd" href="#search">⌘K</a>
        </nav>
      </div>
      <div class="issue-strip">
        <span>Vol. IV · Preview 01</span>
        <span>102 dossiers indexed</span>
        <span>2,684 cited sources</span>
        <span>Living research catalogue</span>
      </div>
    </header>

    <main>
      <section class="hero" id="catalogue" aria-labelledby="home-title">
        <div class="hero-copy">
          <p class="eyebrow">A catalogue of bioregulators & synthetic peptides</p>
          <h1 id="home-title">A catalogue of <em>peptides,</em> referenced.</h1>
          <p class="lede">PepCodex is the public research layer: evidence-weighted peptide dossiers, source trails, safety uncertainty, and revision history without clinic hype.</p>
          <form class="search-card" id="search" action="/search" role="search">
            <label for="q">Search peptides, trials, sources, or safety signals</label>
            <div>
              <input id="q" name="q" type="search" placeholder="Try BPC-157, semaglutide, safety profile..." />
              <button type="submit">Search</button>
            </div>
          </form>
          <div class="cta-row">
            <a class="btn primary" href="#plates">Browse the plates</a>
            <a class="btn ghost" href="#methodology">Read methodology</a>
          </div>
        </div>
        <aside class="volume-card" aria-label="Current volume status">
          <div class="card-topline">This volume</div>
          <div class="volume-no">IV</div>
          <div class="volume-grid">
            <div><strong>12</strong><span>revised entries</span></div>
            <div><strong>4</strong><span>evidence downgrades</span></div>
            <div><strong>31</strong><span>new citations</span></div>
            <div><strong>6</strong><span>safety notes</span></div>
          </div>
          <p>Designed as a living catalogue: each dossier can be watched, cited, compared, and revised as the literature changes.</p>
        </aside>
      </section>

      <section class="section" id="plates" aria-labelledby="plates-title">
        <div class="section-head">
          <p class="eyebrow">Featured peptide dossiers</p>
          <h2 id="plates-title">The plates</h2>
          <p>Editorial catalogue cards with app-style evidence metadata. The metaphor adds brand; the metadata keeps the page useful.</p>
        </div>
        <div class="plates-grid">
          {plates.map((plate) => (
            <article class={`plate-card tone-${plate.tone}`}>
              <div class="plate-meta"><span>Plate {plate.n}</span><span>{plate.category}</span></div>
              <div class="vial" aria-hidden="true"><span></span></div>
              <h3>{plate.name}</h3>
              <p class="aliases">{plate.aliases}</p>
              <p>{plate.summary}</p>
              <div class="evidence-row">
                <span>{plate.sources} sources</span>
                <span>Evidence {plate.grade}</span>
                <span>Safety {plate.safety}/5</span>
              </div>
              <a href="#dossier">Read plate →</a>
            </article>
          ))}
        </div>
      </section>

      <section class="section split" aria-labelledby="drawers-title">
        <div class="section-head sticky-copy">
          <p class="eyebrow">Browse by research class</p>
          <h2 id="drawers-title">The drawers</h2>
          <p>Keep the drawer language, but always pair it with plain-English labels so the catalogue remains searchable and understandable.</p>
        </div>
        <div class="drawer-stack">
          {drawers.map((drawer) => (
            <a class={`drawer-card tone-${drawer.tone}`} href="/category/repair-recovery">
              <span class="drawer-letter">{drawer.letter}</span>
              <div>
                <strong>{drawer.name}</strong>
                <p>{drawer.desc}</p>
              </div>
              <span>{drawer.count} entries →</span>
            </a>
          ))}
        </div>
      </section>

      <section class="dossier-preview" id="dossier" aria-labelledby="dossier-title">
        <div class="dossier-hero">
          <div>
            <p class="eyebrow">Specimen sheet · Drawer B · Recovery</p>
            <h2 id="dossier-title">BPC-<em>157</em></h2>
            <p>Candidate recovery peptide with a strong online narrative, a preclinical-heavy literature base, and unresolved human safety questions.</p>
            <div class="cta-row compact">
              <a class="btn primary" href="#tracker">Watch updates</a>
              <a class="btn ghost" href="#concerns">Jump to concerns</a>
            </div>
          </div>
          <aside class="snapshot-card" aria-label="Evidence snapshot">
            <div class="card-topline">Evidence snapshot</div>
            <div class="snapshot-grid">
              <div><span>Overall</span><strong>Limited</strong></div>
              <div><span>Human evidence</span><strong>Very low</strong></div>
              <div><span>Preclinical</span><strong>Moderate</strong></div>
              <div><span>Safety confidence</span><strong>Low</strong></div>
            </div>
            <p class="notice">Doses and routes in PepCodex are study context only, not recommendations.</p>
          </aside>
        </div>

        <div class="specimen-grid">
          <article class="specimen-card">
            <p class="eyebrow">Bottom line</p>
            <ul>
              <li>Rodent literature suggests several tissue-repair mechanisms.</li>
              <li>Human evidence is sparse and not enough for clinical certainty.</li>
              <li>Long-term safety, receptor biology, and reproducibility remain open questions.</li>
            </ul>
          </article>
          <article class="specimen-card" id="concerns">
            <p class="eyebrow">Where the case weakens</p>
            <div class="concern-list">
              {concerns.map((concern, i) => <div><span>{String(i + 1).padStart(2, '0')}</span>{concern}</div>)}
            </div>
          </article>
        </div>
      </section>

      <section class="tracker-tease" id="tracker" aria-labelledby="tracker-title">
        <div>
          <p class="eyebrow">PepTracker boundary</p>
          <h2 id="tracker-title">Public evidence here. Personal tools in the app.</h2>
          <p>PepCodex can capture high-intent searches for calculators, protocols, and tracking, but the full utility layer should live inside PepTracker.</p>
        </div>
        <div class="app-card">
          <span class="status-chip">Early access</span>
          <strong>Track evidence updates, calculators, and protocol context in PepTracker.</strong>
          <p>CTA direction: “Get notified when the app utility is ready,” not “calculate your dose here.”</p>
          <form class="mini-form">
            <input type="email" placeholder="your@email.com" aria-label="Email" />
            <button type="button">Join waitlist</button>
          </form>
        </div>
      </section>

      <section class="methodology" id="methodology">
        <p class="eyebrow">Methodology preview</p>
        <h2>Evidence strength and safety confidence are separate.</h2>
        <div class="method-grid">
          <div><strong>A–E</strong><span>Evidence strength by outcome, separating human trials from animal and mechanistic evidence.</span></div>
          <div><strong>1–5</strong><span>Safety confidence, so plausible benefit does not imply safety certainty.</span></div>
          <div><strong>Living</strong><span>Revision logs, source counts, and watch alerts make PepCodex feel maintained.</span></div>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    --bg: #f6f1e7;
    --bg-grad: radial-gradient(ellipse 80% 60% at 18% 0%, oklch(0.78 0.04 70 / 0.34), transparent 62%), radial-gradient(ellipse 70% 50% at 100% 100%, oklch(0.82 0.05 55 / 0.22), transparent 62%), #f6f1e7;
    --paper: #fbf7ee;
    --paper-2: #efe8d8;
    --paper-3: #e0d7c2;
    --border: #dbd2bc;
    --border-strong: #bfb59c;
    --ink: #1f1a12;
    --muted: #5c5341;
    --dim: #8e8567;
    --primary: oklch(0.42 0.10 245);
    --primary-deep: oklch(0.30 0.10 245);
    --primary-soft: oklch(0.42 0.10 245 / 0.10);
    --recovery: oklch(0.50 0.13 158);
    --metabolic: oklch(0.66 0.13 60);
    --hormonal: oklch(0.55 0.13 296);
    --longevity: oklch(0.50 0.10 205);
    --danger: oklch(0.54 0.16 22);
    --sans: 'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
    --mono: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    --shadow-card: 0 1px 0 rgba(31,26,18,0.03), 0 12px 30px rgba(31,26,18,0.08);
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    margin: 0;
    background: var(--bg-grad);
    background-attachment: fixed;
    color: var(--ink);
    font-family: var(--sans);
    -webkit-font-smoothing: antialiased;
    line-height: 1.5;
  }
  a { color: inherit; text-decoration: none; }
  button, input { font: inherit; }

  .preview-ribbon {
    position: sticky;
    top: 0;
    z-index: 50;
    display: flex;
    gap: 14px;
    align-items: center;
    justify-content: center;
    padding: 10px 18px;
    background: var(--ink);
    color: var(--paper);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: .04em;
    text-transform: uppercase;
  }
  .preview-ribbon span { color: rgba(251,247,238,.72); text-transform: none; letter-spacing: 0; }
  .preview-ribbon a { color: #fff; border-bottom: 1px solid rgba(255,255,255,.45); }

  .masthead {
    border-top: 3px solid var(--ink);
    border-bottom: 1px solid var(--border);
    background: color-mix(in oklch, var(--bg) 92%, transparent);
  }
  .masthead-inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 20px 28px 16px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 22px;
  }
  .masthead nav { display: flex; gap: 22px; align-items: center; font-family: var(--mono); font-size: 11px; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 1.4px; }
  .masthead-right { justify-content: flex-end; }
  .brand { display: inline-flex; align-items: center; gap: 12px; font-weight: 800; letter-spacing: .18em; }
  .brand span { color: var(--metabolic); font-family: Georgia, serif; font-style: italic; }
  .kbd { border: 1px solid var(--border); border-radius: 8px; padding: 5px 8px; background: var(--paper); }
  .issue-strip { display: flex; justify-content: center; flex-wrap: wrap; gap: 18px; padding: 10px 20px; border-top: 1px solid var(--border); font-family: var(--mono); font-size: 10px; color: var(--dim); text-transform: uppercase; letter-spacing: 1.2px; }

  main { max-width: 1240px; margin: 0 auto; padding: 64px 28px 100px; }
  .hero { display: grid; grid-template-columns: minmax(0, 1.25fr) 380px; gap: 56px; align-items: center; min-height: 62vh; }
  .eyebrow, .card-topline { font-family: var(--mono); font-size: 11px; font-weight: 800; letter-spacing: 1.6px; text-transform: uppercase; color: var(--muted); margin: 0 0 14px; }
  h1, h2, h3, p { margin-top: 0; }
  h1 { font-size: clamp(58px, 9vw, 132px); line-height: .86; letter-spacing: -.075em; margin-bottom: 28px; max-width: 830px; }
  h1 em, h2 em { font-family: Georgia, serif; color: var(--primary); font-weight: 400; letter-spacing: -.04em; }
  .lede { font-size: clamp(18px, 2vw, 24px); color: var(--muted); max-width: 690px; margin-bottom: 28px; }
  .search-card, .volume-card, .plate-card, .drawer-card, .snapshot-card, .specimen-card, .app-card, .methodology { background: color-mix(in oklch, var(--paper) 94%, white); border: 1px solid var(--border); border-radius: 26px; box-shadow: var(--shadow-card); }
  .search-card { padding: 14px; max-width: 760px; margin-bottom: 22px; }
  .search-card label { display: block; margin: 0 0 10px; font-family: var(--mono); font-size: 10px; font-weight: 800; letter-spacing: 1.2px; color: var(--dim); text-transform: uppercase; }
  .search-card div { display: flex; gap: 10px; }
  .search-card input, .mini-form input { flex: 1; min-width: 0; border: 1px solid var(--border); background: #fffaf1; color: var(--ink); border-radius: 18px; padding: 15px 16px; outline: none; }
  .search-card input:focus, .mini-form input:focus { border-color: var(--primary); box-shadow: 0 0 0 4px var(--primary-soft); }
  .search-card button, .mini-form button, .btn { border: 0; border-radius: 999px; padding: 14px 18px; font-weight: 800; font-size: 13px; cursor: pointer; }
  .cta-row { display: flex; gap: 12px; flex-wrap: wrap; }
  .btn.primary, .search-card button, .mini-form button { background: linear-gradient(135deg, oklch(0.50 0.11 248), oklch(0.34 0.09 240)); color: white; }
  .btn.ghost { background: transparent; border: 1px solid var(--border-strong); color: var(--ink); }
  .compact .btn { padding: 11px 15px; }
  .volume-card { padding: 26px; position: relative; overflow: hidden; }
  .volume-no { font-family: Georgia, serif; font-size: 92px; line-height: .85; color: var(--primary); margin-bottom: 22px; }
  .volume-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 18px; }
  .volume-grid div { border-top: 1px solid var(--border); padding-top: 12px; }
  .volume-grid strong { display: block; font-size: 28px; letter-spacing: -.04em; }
  .volume-grid span { display: block; color: var(--dim); font-size: 12px; }
  .volume-card p, .section-head p, .plate-card p, .drawer-card p, .snapshot-card p, .specimen-card, .tracker-tease p, .method-grid span { color: var(--muted); }

  .section { padding: 84px 0 20px; }
  .section-head { max-width: 720px; margin-bottom: 28px; }
  .section-head h2, .dossier-hero h2, .tracker-tease h2, .methodology h2 { font-size: clamp(38px, 5vw, 72px); line-height: .92; letter-spacing: -.06em; margin-bottom: 16px; }
  .plates-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 18px; }
  .plate-card { min-height: 420px; padding: 20px; display: flex; flex-direction: column; transition: transform .2s ease, box-shadow .2s ease; }
  .plate-card:hover { transform: translateY(-3px); box-shadow: 0 18px 40px rgba(31,26,18,.12); }
  .plate-meta, .evidence-row { display: flex; justify-content: space-between; gap: 10px; font-family: var(--mono); font-size: 10px; font-weight: 800; color: var(--dim); text-transform: uppercase; letter-spacing: 1px; }
  .vial { height: 92px; display: flex; align-items: center; justify-content: center; margin: 18px 0; }
  .vial span { width: 42px; height: 82px; display: block; border: 2px solid color-mix(in oklch, var(--primary), var(--border) 40%); border-radius: 14px 14px 18px 18px; background: linear-gradient(to bottom, transparent 0 38%, color-mix(in oklch, var(--primary) 20%, var(--paper)) 38% 100%); box-shadow: inset 0 0 0 5px rgba(255,255,255,.35); }
  .plate-card h3 { font-size: 26px; margin-bottom: 4px; letter-spacing: -.035em; }
  .aliases { font-size: 13px; color: var(--dim) !important; }
  .plate-card .evidence-row { margin-top: auto; padding-top: 16px; border-top: 1px solid var(--border); }
  .plate-card > a { margin-top: 16px; font-weight: 800; color: var(--primary); }
  .tone-recovery { --primary: var(--recovery); }
  .tone-metabolic { --primary: var(--metabolic); }
  .tone-hormonal { --primary: var(--hormonal); }
  .tone-longevity { --primary: var(--longevity); }

  .split { display: grid; grid-template-columns: 330px 1fr; gap: 54px; align-items: start; }
  .sticky-copy { position: sticky; top: 84px; }
  .drawer-stack { display: grid; gap: 12px; }
  .drawer-card { display: grid; grid-template-columns: 62px 1fr auto; gap: 18px; align-items: center; padding: 18px; }
  .drawer-letter { width: 52px; height: 52px; border-radius: 18px; display: grid; place-items: center; background: var(--primary-soft); color: var(--primary); font-family: var(--mono); font-weight: 900; }
  .drawer-card strong { font-size: 20px; }
  .drawer-card p { margin: 4px 0 0; }
  .drawer-card > span:last-child { font-family: var(--mono); font-size: 11px; font-weight: 800; text-transform: uppercase; color: var(--dim); }

  .dossier-preview { margin-top: 90px; border-top: 3px solid var(--ink); padding-top: 46px; }
  .dossier-hero { display: grid; grid-template-columns: minmax(0, 1fr) 420px; gap: 42px; align-items: start; }
  .dossier-hero h2 { font-size: clamp(72px, 12vw, 156px); }
  .dossier-hero > div > p:not(.eyebrow) { font-size: 20px; color: var(--muted); max-width: 760px; }
  .snapshot-card { padding: 24px; }
  .snapshot-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .snapshot-grid div { background: var(--paper-2); border: 1px solid var(--border); border-radius: 18px; padding: 13px; }
  .snapshot-grid span { display: block; font-family: var(--mono); font-size: 9px; color: var(--dim); text-transform: uppercase; font-weight: 800; letter-spacing: 1px; }
  .snapshot-grid strong { display: block; margin-top: 4px; font-size: 18px; }
  .notice { margin: 14px 0 0; padding: 12px; background: oklch(0.66 0.13 60 / .12); border: 1px solid oklch(0.66 0.13 60 / .28); border-radius: 16px; font-size: 13px; }
  .specimen-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; margin-top: 28px; }
  .specimen-card { padding: 24px; }
  .specimen-card li { margin: 0 0 10px; }
  .concern-list { display: grid; gap: 10px; }
  .concern-list div { display: flex; gap: 12px; padding: 13px; border-radius: 16px; background: oklch(0.54 0.16 22 / .08); border: 1px solid oklch(0.54 0.16 22 / .20); color: var(--ink); }
  .concern-list span { font-family: var(--mono); font-size: 11px; font-weight: 900; color: var(--danger); }

  .tracker-tease { margin-top: 84px; display: grid; grid-template-columns: 1fr 420px; gap: 40px; align-items: center; padding: 36px; border-radius: 32px; background: var(--ink); color: var(--paper); }
  .tracker-tease .eyebrow, .tracker-tease p { color: rgba(251,247,238,.72); }
  .app-card { padding: 22px; color: var(--ink); }
  .app-card strong { display: block; font-size: 24px; line-height: 1.1; letter-spacing: -.04em; margin: 12px 0; }
  .app-card p { color: var(--muted); }
  .status-chip { display: inline-flex; border-radius: 999px; background: var(--primary-soft); color: var(--primary-deep); padding: 7px 10px; font-family: var(--mono); font-size: 10px; font-weight: 900; text-transform: uppercase; letter-spacing: 1px; }
  .mini-form { display: flex; gap: 8px; margin-top: 16px; }

  .methodology { margin-top: 84px; padding: 36px; }
  .method-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .method-grid div { border-top: 1px solid var(--border); padding-top: 16px; }
  .method-grid strong { display: block; font-size: 32px; color: var(--primary); }
  .method-grid span { display: block; }

  @media (max-width: 980px) {
    .masthead-inner { grid-template-columns: 1fr; text-align: center; }
    .masthead nav { justify-content: center; flex-wrap: wrap; }
    .hero, .dossier-hero, .tracker-tease { grid-template-columns: 1fr; }
    .plates-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .split { grid-template-columns: 1fr; }
    .sticky-copy { position: static; }
  }
  @media (max-width: 640px) {
    .preview-ribbon { align-items: flex-start; flex-direction: column; }
    main { padding: 42px 16px 70px; }
    h1 { font-size: 62px; }
    .search-card div, .mini-form, .cta-row { flex-direction: column; }
    .plates-grid, .specimen-grid, .method-grid { grid-template-columns: 1fr; }
    .drawer-card { grid-template-columns: 48px 1fr; }
    .drawer-card > span:last-child { grid-column: 2; }
    .volume-card, .tracker-tease, .methodology { padding: 22px; border-radius: 24px; }
  }
</style>
