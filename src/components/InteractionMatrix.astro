---
/**
 * InteractionMatrix.astro
 * Displays peptide interactions with color-coded badges
 * Types: synergistic (green), compatible (blue), caution (yellow), avoid (red)
 */

interface Interaction {
  peptide: string;
  type: 'synergistic' | 'compatible' | 'caution' | 'avoid';
  description: string;
  source?: string;
}

interface Props {
  interactions: Interaction[];
  currentPeptide: string;
}

const { interactions, currentPeptide } = Astro.props;

// Sort interactions by type priority: synergistic > compatible > caution > avoid
const typePriority = { synergistic: 0, compatible: 1, caution: 2, avoid: 3 };
const sortedInteractions = [...interactions].sort((a, b) =>
  typePriority[a.type] - typePriority[b.type]
);

// Group interactions by type for organized display
const groupedInteractions = {
  synergistic: sortedInteractions.filter(i => i.type === 'synergistic'),
  compatible: sortedInteractions.filter(i => i.type === 'compatible'),
  caution: sortedInteractions.filter(i => i.type === 'caution'),
  avoid: sortedInteractions.filter(i => i.type === 'avoid'),
};

const typeConfig = {
  synergistic: {
    label: 'Synergistic',
    description: 'May enhance effects when combined',
    bgClass: 'bg-emerald-500/10',
    borderClass: 'border-emerald-500/30',
    textClass: 'text-emerald-400',
    badgeClass: 'bg-emerald-500/20 text-emerald-300 border-emerald-500/40',
    dotClass: 'bg-emerald-500',
    icon: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>`,
  },
  compatible: {
    label: 'Compatible',
    description: 'Generally safe to combine based on known mechanisms',
    bgClass: 'bg-blue-500/10',
    borderClass: 'border-blue-500/30',
    textClass: 'text-blue-400',
    badgeClass: 'bg-blue-500/20 text-blue-300 border-blue-500/40',
    dotClass: 'bg-blue-500',
    icon: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg>`,
  },
  caution: {
    label: 'Caution',
    description: 'Potential interactions warrant careful consideration',
    bgClass: 'bg-amber-500/10',
    borderClass: 'border-amber-500/30',
    textClass: 'text-amber-400',
    badgeClass: 'bg-amber-500/20 text-amber-300 border-amber-500/40',
    dotClass: 'bg-amber-500',
    icon: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 9v4m0 4h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/></svg>`,
  },
  avoid: {
    label: 'Avoid',
    description: 'Known or theoretical contraindications',
    bgClass: 'bg-red-500/10',
    borderClass: 'border-red-500/30',
    textClass: 'text-red-400',
    badgeClass: 'bg-red-500/20 text-red-300 border-red-500/40',
    dotClass: 'bg-red-500',
    icon: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12"/></svg>`,
  },
};

// Helper to format peptide slug to display name
function formatPeptideName(slug: string): string {
  return slug
    .split('-')
    .map(word => {
      // Handle special cases like "bpc", "ghk", "ghrp"
      if (['bpc', 'ghk', 'ghrp', 'cjc', 'mk', 'tb', 'pt', 'll', 'aod'].includes(word.toLowerCase())) {
        return word.toUpperCase();
      }
      // Handle roman numerals
      if (['ii', 'iii', 'iv'].includes(word.toLowerCase())) {
        return word.toUpperCase();
      }
      // Handle numbers
      if (/^\d+$/.test(word)) {
        return word;
      }
      // Capitalize first letter
      return word.charAt(0).toUpperCase() + word.slice(1);
    })
    .join('-');
}
---

{interactions.length > 0 && (
  <section id="peptide-interactions" class="mt-12 pt-8 border-t border-white/10">
    <div class="space-y-2 mb-8">
      <h3 class="text-3xl font-bold text-white tracking-tight" style="font-family: var(--font-display);">
        Peptide Interactions
      </h3>
      <div class="h-1 w-20 bg-[var(--primary)] rounded-full"></div>
      <p class="text-white/70 text-sm mt-4">
        Known and theoretical interactions when combining {currentPeptide} with other peptides. Based on published research and mechanistic considerations.
      </p>
    </div>

    <!-- Legend -->
    <div class="flex flex-wrap gap-3 mb-8">
      {Object.entries(typeConfig).map(([type, config]) => (
        <div class={`flex items-center gap-2 px-3 py-1.5 rounded-lg ${config.bgClass} ${config.borderClass} border`}>
          <div class={`w-2 h-2 rounded-full ${config.dotClass}`}></div>
          <span class={`text-xs font-medium ${config.textClass}`}>{config.label}</span>
        </div>
      ))}
    </div>

    <!-- Interaction Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {sortedInteractions.map((interaction) => {
        const config = typeConfig[interaction.type];
        return (
          <div class={`group relative rounded-2xl ${config.bgClass} ${config.borderClass} border p-5 transition-all duration-300 hover:scale-[1.02]`}>
            <!-- Header with peptide name and badge -->
            <div class="flex items-start justify-between gap-4 mb-3">
              <a
                href={`/peptides/${interaction.peptide}`}
                class="flex items-center gap-3 group/link"
              >
                <div class={`w-10 h-10 rounded-xl ${config.bgClass} border ${config.borderClass} flex items-center justify-center ${config.textClass} group-hover/link:scale-110 transition-transform`}>
                  <Fragment set:html={config.icon} />
                </div>
                <div>
                  <h4 class="font-bold text-white group-hover/link:text-[var(--primary)] transition-colors">
                    {formatPeptideName(interaction.peptide)}
                  </h4>
                  <span class={`text-xs font-medium ${config.textClass}`}>
                    {config.label}
                  </span>
                </div>
              </a>

              <!-- Type badge -->
              <span class={`shrink-0 px-3 py-1 rounded-full text-xs font-semibold border ${config.badgeClass}`}>
                {interaction.type.charAt(0).toUpperCase() + interaction.type.slice(1)}
              </span>
            </div>

            <!-- Description -->
            <p class="text-white/80 text-sm leading-relaxed mb-3">
              {interaction.description}
            </p>

            <!-- Source citation if available -->
            {interaction.source && (
              <div class="flex items-center gap-2 text-xs text-white/50">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
                  <polyline points="14,2 14,8 20,8"/>
                </svg>
                <a
                  href={`https://pubmed.ncbi.nlm.nih.gov/${interaction.source}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-[var(--primary)] transition-colors"
                >
                  PMID: {interaction.source}
                </a>
              </div>
            )}

            <!-- Hover arrow indicator -->
            <div class="absolute bottom-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity">
              <svg class={`w-5 h-5 ${config.textClass}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="m9 18 6-6-6-6"/>
              </svg>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Disclaimer -->
    <div class="mt-8 rounded-xl bg-white/5 border border-white/10 p-4">
      <div class="flex gap-3">
        <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-white/10 text-white/60">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div>
          <p class="text-white/70 text-xs leading-relaxed">
            <strong class="text-white/90">Research Note:</strong> Interaction data is based on published literature, mechanistic understanding, and theoretical considerations. Most peptide combinations lack direct clinical study. This information is for educational purposes only and does not constitute medical advice. Always consult qualified healthcare providers.
          </p>
        </div>
      </div>
    </div>
  </section>
)}
