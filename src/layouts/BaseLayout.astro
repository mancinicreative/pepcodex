---
import '../styles/global.css';
import OrganizationSchema from '../components/SEO/OrganizationSchema.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import CookieConsent from '../components/CookieConsent.astro';
import SearchModal from '../components/SearchModal.astro';
import ExitIntentPopup from '../components/ExitIntentPopup.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  robots?: 'index' | 'noindex';
}

const {
  title,
  description = 'Evidence-based peptide research library. Comprehensive dossiers with citations, not advice.',
  ogImage,
  robots = 'index'
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteName = 'PepCodex';

// Google Analytics 4 - set in environment variable
const GA_TRACKING_ID = import.meta.env.PUBLIC_GA_TRACKING_ID;

// Get current path for nav highlighting
const currentPath = Astro.url.pathname;
const isActive = (path: string) => currentPath === path || (path !== '/' && currentPath.startsWith(path));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Font loading: preconnect + non-blocking stylesheet (4 weights: 400-700) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&display=swap" /></noscript>

    <!-- Google Search Console Verification -->
    <meta name="google-site-verification" content="8sNDsQp-DdfE1yFsY3N2xVcS2cnc4ecvACgyY6ON3LQ" />

    <!-- SEO -->
    <title>{title} | {siteName}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {robots === 'noindex' && <meta name="robots" content="noindex, nofollow" />}

    <!-- Structured Data -->
    <OrganizationSchema />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage || `${Astro.site}og-default.png`} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage || `${Astro.site}og-default.png`} />

    <!-- Google Analytics 4 -->
    {GA_TRACKING_ID && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_TRACKING_ID}`}></script>
        <script is:inline define:vars={{ GA_TRACKING_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', GA_TRACKING_ID);
        </script>
      </>
    )}
  </head>
  <body class="min-h-screen text-[var(--foreground)] antialiased selection:bg-[var(--primary)]/30" style="font-family: var(--font-sans);">
    <!-- Skip to main content -->
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <!-- Header -->
    <nav class="fixed top-0 left-0 right-0 z-50 border-b border-white/5 bg-[var(--background)]/60 backdrop-blur-xl supports-[backdrop-filter]:bg-[var(--background)]/20" aria-label="Main navigation">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 group">
          <div class="relative w-8 h-8 flex items-center justify-center bg-[var(--primary)]/10 rounded-lg group-hover:bg-[var(--primary)]/20 transition-colors border border-[var(--primary)]/20">
            <svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2" />
              <path d="M8.5 2h7" />
              <path d="M7 16h10" />
            </svg>
          </div>
          <span class="font-bold text-lg bg-clip-text text-transparent bg-gradient-to-r from-primary via-purple-400 to-primary" style="font-family: var(--font-display);">PEPCODEX</span>
        </a>

        <!-- Desktop Nav -->
        <div class="hidden md:flex items-center gap-1">
          <a
            href="/peptides"
            aria-current={isActive('/peptides') || isActive('/category') ? 'page' : undefined}
            class:list={[
              "flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-all duration-300",
              isActive('/peptides') || isActive('/category')
                ? "bg-white/10 text-white shadow-[0_0_15px_rgba(255,255,255,0.1)] border border-white/10"
                : "text-white/85 hover:text-white hover:bg-white/5"
            ]}
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2" />
            </svg>
            Peptides
          </a>
          <a
            href="/trials"
            aria-current={isActive('/trials') ? 'page' : undefined}
            class:list={[
              "flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-all duration-300",
              isActive('/trials')
                ? "bg-white/10 text-white shadow-[0_0_15px_rgba(255,255,255,0.1)] border border-white/10"
                : "text-white/85 hover:text-white hover:bg-white/5"
            ]}
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
            </svg>
            Trials
          </a>
          <!-- Research Dropdown -->
          <div class="relative group">
            <button
              class:list={[
                "flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-all duration-300",
                ['/compare', '/guide', '/safety', '/glossary', '/conditions', '/bioregulators'].some(p => currentPath.startsWith(p))
                  ? "bg-white/10 text-white shadow-[0_0_15px_rgba(255,255,255,0.1)] border border-white/10"
                  : "text-white/85 hover:text-white hover:bg-white/5"
              ]}
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
              </svg>
              Research
              <svg class="w-3 h-3 transition-transform group-hover:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </button>
            <div class="absolute top-full left-0 mt-1 w-56 rounded-xl border border-white/10 bg-[var(--background)]/95 backdrop-blur-xl shadow-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
              <div class="p-2">
                <a href="/compare" class:list={["flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm transition-colors", isActive('/compare') ? "bg-white/10 text-white" : "text-white/70 hover:text-white hover:bg-white/5"]}>
                  <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 3h5v5M8 3H3v5M21 3L14 10M3 3l7 7M21 21l-7-7M3 21l7-7M16 21h5v-5M8 21H3v-5"/></svg>
                  Comparisons
                </a>
                <a href="/guide" class:list={["flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm transition-colors", isActive('/guide') ? "bg-white/10 text-white" : "text-white/70 hover:text-white hover:bg-white/5"]}>
                  <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
                  Guides
                </a>
                <a href="/safety" class:list={["flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm transition-colors", isActive('/safety') ? "bg-white/10 text-white" : "text-white/70 hover:text-white hover:bg-white/5"]}>
                  <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                  Safety Profiles
                </a>
                <a href="/glossary" class:list={["flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm transition-colors", isActive('/glossary') ? "bg-white/10 text-white" : "text-white/70 hover:text-white hover:bg-white/5"]}>
                  <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                  Glossary
                </a>
                <a href="/conditions" class:list={["flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm transition-colors", isActive('/conditions') ? "bg-white/10 text-white" : "text-white/70 hover:text-white hover:bg-white/5"]}>
                  <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                  Conditions
                </a>
                <a href="/bioregulators" class:list={["flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm transition-colors", isActive('/bioregulators') ? "bg-white/10 text-white" : "text-white/70 hover:text-white hover:bg-white/5"]}>
                  <svg class="w-4 h-4 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2zm0 14a4 4 0 1 1 4-4 4 4 0 0 1-4 4z"/></svg>
                  Bioregulators
                </a>
              </div>
            </div>
          </div>
          <a
            href="/calculator"
            aria-current={isActive('/calculator') ? 'page' : undefined}
            class:list={[
              "flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-all duration-300",
              isActive('/calculator')
                ? "bg-white/10 text-white shadow-[0_0_15px_rgba(255,255,255,0.1)] border border-white/10"
                : "text-white/85 hover:text-white hover:bg-white/5"
            ]}
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="4" y="2" width="16" height="20" rx="2"/>
              <line x1="8" y1="6" x2="16" y2="6"/>
              <line x1="8" y1="10" x2="16" y2="10"/>
              <line x1="8" y1="14" x2="11" y2="14"/>
              <line x1="8" y1="18" x2="11" y2="18"/>
            </svg>
            Calculators
          </a>
          <a
            href="/blog"
            aria-current={isActive('/blog') ? 'page' : undefined}
            class:list={[
              "flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-all duration-300",
              isActive('/blog')
                ? "bg-white/10 text-white shadow-[0_0_15px_rgba(255,255,255,0.1)] border border-white/10"
                : "text-white/85 hover:text-white hover:bg-white/5"
            ]}
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/>
              <path d="M18 14h-8"/>
              <path d="M18 18h-8"/>
              <path d="M18 10h-8"/>
            </svg>
            Blog
          </a>
          <a
            href="/directory"
            aria-current={isActive('/directory') ? 'page' : undefined}
            class:list={[
              "flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-all duration-300",
              isActive('/directory')
                ? "bg-white/10 text-white shadow-[0_0_15px_rgba(255,255,255,0.1)] border border-white/10"
                : "text-white/85 hover:text-white hover:bg-white/5"
            ]}
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
            Directory
          </a>
        </div>

        <!-- Right side actions -->
        <div class="hidden md:flex items-center gap-3">
          <button id="header-search-btn" class="btn btn-ghost rounded-full p-2" style="color: var(--text-medium);" aria-label="Search (Ctrl+K)">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8" />
              <path d="m21 21-4.3-4.3" />
            </svg>
          </button>
          <a
            href="/contact"
            class="btn btn-md relative overflow-hidden uppercase tracking-wider border border-white/30 text-white hover:bg-white/10 transition-colors"
            style="font-family: var(--font-display);"
          >
            Contact
          </a>
          <a
            href="/newsletter"
            class="btn btn-primary btn-md relative overflow-hidden uppercase tracking-wider before:absolute before:inset-0 before:bg-gradient-to-r before:from-transparent before:via-white/20 before:to-transparent before:-translate-x-full hover:before:translate-x-full before:transition-transform before:duration-700"
            style="font-family: var(--font-display);"
          >
            Subscribe
          </a>
        </div>

        <!-- Mobile Menu Button -->
        <button
          type="button"
          id="mobile-menu-btn"
          class="flex h-10 w-10 items-center justify-center rounded-lg text-white md:hidden hover:bg-white/10 transition-colors"
          aria-expanded="false"
          aria-label="Open menu"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>

      <!-- Mobile navigation -->
      <div id="mobile-nav" class="mobile-nav-panel bg-[var(--background)]/95 backdrop-blur-2xl border-t border-white/5 p-4 md:hidden" aria-label="Mobile navigation">
        <div class="flex flex-col gap-2">
          <a
            href="/peptides"
            class:list={[
              "flex items-center gap-3 px-4 py-3 rounded-xl text-lg font-medium transition-colors",
              isActive('/peptides')
                ? "bg-[var(--primary)]/10 text-primary border border-[var(--primary)]/20"
                : "text-white/85 hover:text-white hover:bg-white/5"
            ]}
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2" />
            </svg>
            Peptides
          </a>
          <a
            href="/trials"
            class:list={[
              "flex items-center gap-3 px-4 py-3 rounded-xl text-lg font-medium transition-colors",
              isActive('/trials')
                ? "bg-[var(--primary)]/10 text-primary border border-[var(--primary)]/20"
                : "text-white/85 hover:text-white hover:bg-white/5"
            ]}
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
            </svg>
            Trials
          </a>
          <a
            href="/calculator"
            class:list={[
              "flex items-center gap-3 px-4 py-3 rounded-xl text-lg font-medium transition-colors",
              isActive('/calculator')
                ? "bg-[var(--primary)]/10 text-primary border border-[var(--primary)]/20"
                : "text-white/85 hover:text-white hover:bg-white/5"
            ]}
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="4" y="2" width="16" height="20" rx="2"/>
              <line x1="8" y1="6" x2="16" y2="6"/>
              <line x1="8" y1="10" x2="16" y2="10"/>
              <line x1="8" y1="14" x2="11" y2="14"/>
              <line x1="8" y1="18" x2="11" y2="18"/>
            </svg>
            Calculators
          </a>
          <a
            href="/blog"
            class:list={[
              "flex items-center gap-3 px-4 py-3 rounded-xl text-lg font-medium transition-colors",
              isActive('/blog')
                ? "bg-[var(--primary)]/10 text-primary border border-[var(--primary)]/20"
                : "text-white/85 hover:text-white hover:bg-white/5"
            ]}
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/>
              <path d="M18 14h-8"/>
              <path d="M18 18h-8"/>
              <path d="M18 10h-8"/>
            </svg>
            Blog
          </a>
          <a
            href="/directory"
            class:list={[
              "flex items-center gap-3 px-4 py-3 rounded-xl text-lg font-medium transition-colors",
              isActive('/directory')
                ? "bg-[var(--primary)]/10 text-primary border border-[var(--primary)]/20"
                : "text-white/85 hover:text-white hover:bg-white/5"
            ]}
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
            Directory
          </a>
          <!-- Research (expandable) -->
          <details class="group/research">
            <summary class:list={[
              "flex items-center justify-between px-4 py-3 rounded-xl text-lg font-medium transition-colors cursor-pointer list-none",
              ['/compare', '/guide', '/safety', '/glossary', '/conditions', '/bioregulators'].some(p => currentPath.startsWith(p))
                ? "bg-[var(--primary)]/10 text-primary border border-[var(--primary)]/20"
                : "text-white/85 hover:text-white hover:bg-white/5"
            ]}>
              <span class="flex items-center gap-3">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                  <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
                </svg>
                Research
              </span>
              <svg class="w-4 h-4 transition-transform group-open/research:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </summary>
            <div class="pl-4 mt-1 space-y-1">
              <a href="/compare" class:list={["flex items-center gap-3 px-4 py-2.5 rounded-lg text-base transition-colors", isActive('/compare') ? "text-primary" : "text-white/70 hover:text-white hover:bg-white/5"]}>
                Comparisons
              </a>
              <a href="/guide" class:list={["flex items-center gap-3 px-4 py-2.5 rounded-lg text-base transition-colors", isActive('/guide') ? "text-primary" : "text-white/70 hover:text-white hover:bg-white/5"]}>
                Guides
              </a>
              <a href="/safety" class:list={["flex items-center gap-3 px-4 py-2.5 rounded-lg text-base transition-colors", isActive('/safety') ? "text-primary" : "text-white/70 hover:text-white hover:bg-white/5"]}>
                Safety Profiles
              </a>
              <a href="/glossary" class:list={["flex items-center gap-3 px-4 py-2.5 rounded-lg text-base transition-colors", isActive('/glossary') ? "text-primary" : "text-white/70 hover:text-white hover:bg-white/5"]}>
                Glossary
              </a>
              <a href="/conditions" class:list={["flex items-center gap-3 px-4 py-2.5 rounded-lg text-base transition-colors", isActive('/conditions') ? "text-primary" : "text-white/70 hover:text-white hover:bg-white/5"]}>
                Conditions
              </a>
              <a href="/bioregulators" class:list={["flex items-center gap-3 px-4 py-2.5 rounded-lg text-base transition-colors", isActive('/bioregulators') ? "text-primary" : "text-white/70 hover:text-white hover:bg-white/5"]}>
                Bioregulators
              </a>
            </div>
          </details>
          <div class="flex gap-2 mt-4 pt-4 border-t border-white/10">
            <a
              href="/contact"
              class="flex-1 btn btn-md text-center border border-white/30 text-white hover:bg-white/10 transition-colors"
            >
              Contact
            </a>
            <a
              href="/newsletter"
              class="flex-1 btn btn-primary btn-md text-center"
            >
              Subscribe
            </a>
          </div>
        </div>
      </div>
    </nav>

    <main id="main-content" class="pt-24 pb-12 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 min-h-[calc(100vh-4rem)]">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-white/5 bg-black/20 backdrop-blur-lg mt-auto">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
          <!-- Brand -->
