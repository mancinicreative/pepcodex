---
interface Props {
  strength: 'high' | 'moderate' | 'low' | 'very-low';
  showLabel?: boolean;
}

const { strength, showLabel = true } = Astro.props;

const config = {
  'high': {
    color: 'var(--research)',
    tint: 'rgba(20, 118, 74, 0.10)',
    border: 'rgba(20, 118, 74, 0.30)',
    icon: '●●●●',
    label: 'High Evidence',
    description: 'Multiple high-quality human RCTs with consistent results',
  },
  'moderate': {
    color: 'var(--primary-c)',
    tint: 'rgba(11, 81, 127, 0.10)',
    border: 'rgba(11, 81, 127, 0.28)',
    icon: '●●●○',
    label: 'Moderate Evidence',
    description: 'Human studies exist but with limitations or inconsistencies',
  },
  'low': {
    color: '#9a6418',
    tint: 'rgba(203, 135, 52, 0.12)',
    border: 'rgba(203, 135, 52, 0.32)',
    icon: '●●○○',
    label: 'Low Evidence',
    description: 'Limited human data; primarily preclinical evidence',
  },
  'very-low': {
    color: 'var(--danger)',
    tint: 'rgba(185, 61, 66, 0.10)',
    border: 'rgba(185, 61, 66, 0.28)',
    icon: '●○○○',
    label: 'Very Low Evidence',
    description: 'Minimal or no human data; mostly theoretical or animal studies',
  },
};

const { color, tint, border, icon, label } = config[strength];
---

<div class="relative inline-flex items-center">
  <span
    class="inline-flex items-center gap-1.5 rounded-md px-2 py-1 text-xs uppercase border"
    style={`color: ${color}; background: ${tint}; border-color: ${border}; font-family: var(--font-mono); letter-spacing: 0.06em;`}
    role="status"
    aria-label={`Evidence strength: ${label}`}
  >
    <span class="text-[11px] tracking-tight" aria-hidden="true">{icon}</span>
    {showLabel && <span>{label}</span>}
  </span>
</div>
