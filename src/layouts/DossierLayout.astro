---
import { getCollection } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import ArticleSchema from '../components/SEO/ArticleSchema.astro';
import BreadcrumbSchema from '../components/SEO/BreadcrumbSchema.astro';
import FAQSchema from '../components/SEO/FAQSchema.astro';
import DrugSchema from '../components/SEO/DrugSchema.astro';
import RelatedEntities from '../components/RelatedEntities.astro';
import PeptideCard from '../components/PeptideCard.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import SafetyBanner from '../components/SafetyBanner.astro';
import OverviewSection from '../components/OverviewSection.astro';
import EvidenceChain from '../components/EvidenceChain.astro';
import InteractionMatrix from '../components/InteractionMatrix.astro';
import Timeline from '../components/Timeline.astro';
import QualityChecklist from '../components/QualityChecklist.astro';
import RatingCard from '../components/RatingCard.astro';

// Type definitions for peptide interactions
interface Interaction {
  peptide: string;
  type: 'synergistic' | 'compatible' | 'caution' | 'avoid';
  description: string;
  source?: string;
}

// Type definitions for new schemas
interface AminoAcid {
  code: string;
  name: string;
  position: number;
  property: 'hydrophobic' | 'polar' | 'positive' | 'negative' | 'modified';
}

interface MolecularInfo {
  weight: string;
  chainLength: number;
  type: string;
  sequence: string;
  aminoAcids: AminoAcid[];
}

interface KeyFinding {
  study: string;
  type: 'human-rct' | 'human-observational' | 'animal' | 'in-vitro';
  finding: string;
  pmid?: string;
}

interface EvidenceChainedBenefit {
  mechanism: {
    action: string;
    confidence: 'established' | 'supported' | 'emerging';
    directStudies: number;
  };
  benefit: {
    claim: string;
    qualifier: 'may' | 'appears to' | 'suggested to' | 'shown to';
  };
  evidence: {
    level: 'high' | 'moderate' | 'low' | 'very-low';
    humanStudies: number;
    animalStudies: number;
    cellStudies: number;
    keyFindings: KeyFinding[];
  };
}

// Timeline entry for "What to Expect" section
interface TimelineEntry {
  period: string;
  effects: string;
  source?: string;
}

// Quality Checklist for evaluating peptide products
interface QualityChecklistData {
  goodSigns: string[];
  warningSigns: string[];
  badSigns: string[];
}

// FAQ item for schema markup
interface FAQItem {
  question: string;
  answer: string;
}

// Safety warnings for banner
interface SafetyInfo {
  keyWarnings?: string[];
  fdaStatus?: string;
  wadaStatus?: string;
}

interface Props {
  name: string;
  aliases: string[];
  category: string;
  // Safety info for banner
  safetyInfo?: SafetyInfo;
  evidenceStrength: 'high' | 'moderate' | 'low' | 'very-low';
  lastUpdated: Date;
  summary: string;
  sources: {
    count: number;
    human: number;
    preclinical: number;
    openAccess: number;
  };
  comparators: string[];
  pharmacokinetics?: {
    halfLife?: string;
    bioavailability?: string;
    metabolism?: string;
  };
  relatedPeptides?: string[];
  // NEW: Molecular information for structure display
  molecularInfo?: MolecularInfo;
  // NEW: Evidence-chained benefits for detailed research breakdown
  evidenceChainedBenefits?: EvidenceChainedBenefit[];
  // NEW: Peptide interactions
  interactions?: Interaction[];
  // NEW: Timeline for "What to Expect" section
  timeline?: TimelineEntry[];
  // NEW: Quality checklist for product evaluation
  qualityChecklist?: QualityChecklistData;
  // NEW: FAQ items for schema markup (Phase 24)
  faqs?: FAQItem[];
  // Regulatory status
  regulatoryStatus?: {
    status: 'approved' | 'investigational' | 'compounding-restricted' | 'research-only';
    lastUpdated?: Date;
    notes?: string;
  };
  // NEW: Multi-dimension ratings (optional — backward compat with existing dossiers)
  ratings?: {
    researchDepth: number;
    globalCoverage: number;
    mechanismPlausibility: number;
    overall: number;
    lastReviewed: Date;
    reviewNotes?: string;
  };
  metaTitle?: string;
  metaDescription?: string;
}

const {
  name,
  aliases,
  category,
  evidenceStrength,
  lastUpdated,
  summary,
  sources,
  comparators,
  pharmacokinetics,
  relatedPeptides = [],
  molecularInfo,
  evidenceChainedBenefits,
  interactions = [],
  timeline,
  qualityChecklist,
  faqs = [],
  regulatoryStatus,
  ratings,
  metaTitle,
  metaDescription,
} = Astro.props;

const categoryLabels: Record<string, string> = {
  'metabolic': 'Metabolic',
  'repair-recovery': 'Repair & Recovery',
  'hormonal': 'Hormonal',
  'longevity': 'Longevity',
  'other': 'Other',
};

const evidenceConfig: Record<string, { dots: number; label: string; color: string }> = {
  'high': { dots: 4, label: 'High Evidence', color: 'hsl(142 70% 45%)' },
  'moderate': { dots: 3, label: 'Moderate Evidence', color: 'var(--primary)' },
  'low': { dots: 2, label: 'Low Evidence', color: 'hsl(45 90% 55%)' },
  'very-low': { dots: 1, label: 'Very Low Evidence', color: 'hsl(0 70% 55%)' },
};

const currentEvidence = evidenceConfig[evidenceStrength];

const regulatoryConfig: Record<string, { label: string; color: string; bg: string; border: string }> = {
  'approved': { label: 'FDA Approved', color: 'text-emerald-400', bg: 'bg-emerald-500/15', border: 'border-emerald-500/30' },
  'investigational': { label: 'Investigational', color: 'text-blue-400', bg: 'bg-blue-500/15', border: 'border-blue-500/30' },
  'compounding-restricted': { label: 'Compounding Restricted', color: 'text-amber-400', bg: 'bg-amber-500/15', border: 'border-amber-500/30' },
  'research-only': { label: 'Research Only', color: 'text-white/60', bg: 'bg-white/5', border: 'border-white/20' },
};
const regConfig = regulatoryStatus ? regulatoryConfig[regulatoryStatus.status] : null;

// Section navigation - CONSOLIDATED STRUCTURE
// Order: Overview (includes molecular) → Mechanism → Evidence → Timeline → Quality → Interactions → References
const allSections = [
  { id: 'overview', label: 'Overview', always: true },
  { id: 'mechanism-of-action', label: 'Mechanism', always: true },
  { id: 'evidence-chain', label: 'Evidence', requires: 'evidenceChainedBenefits' },
  { id: 'timeline', label: 'What to Expect', requires: 'timeline' },
  { id: 'quality-checklist', label: 'Quality', requires: 'qualityChecklist' },
  { id: 'peptide-interactions', label: 'Interactions', requires: 'interactions' },
  { id: 'references', label: 'References', always: true },
];

// Filter sections based on available data and assign numbers
const dataAvailability: Record<string, boolean> = {
  timeline: Boolean(timeline && timeline.length > 0),
  evidenceChainedBenefits: Boolean(evidenceChainedBenefits && evidenceChainedBenefits.length > 0),
  interactions: Boolean(interactions && interactions.length > 0),
  qualityChecklist: Boolean(qualityChecklist),
};

const sections = allSections
  .filter(section => section.always || (section.requires && dataAvailability[section.requires]))
  .map((section, index) => ({
    ...section,
    num: String(index + 1).padStart(2, '0'),
  }));

// Tags from category and evidence
const tags = [categoryLabels[category], currentEvidence.label, `${sources.count} Sources`];

// Build comparison lookup: find actual comparison slugs for this peptide
const allComparisons = await getCollection('comparisons');
const allPeptides = await getCollection('peptides');
const peptideNameMap = new Map(allPeptides.map(p => [p.slug, p.data.name]));
const currentSlug = name.toLowerCase().replace(/\s+/g, '-');

function findComparisonSlug(compSlug: string): string | null {
  // Check both orderings
  const optionA = `${currentSlug}-vs-${compSlug}`;
  const optionB = `${compSlug}-vs-${currentSlug}`;
  const match = allComparisons.find(c => c.slug === optionA || c.slug === optionB);
  return match ? match.slug : null;
}

// Load calculator presets to check if this peptide has calculator pages
let hasCalculatorPreset = false;
try {
  const presetData = await import('../../data/calculator-presets.json');
  hasCalculatorPreset = presetData.presets?.some((p: any) => p.slug === currentSlug) ?? false;
} catch { /* presets not available */ }

// SEO: Breadcrumb data
const breadcrumbItems = [
  { name: 'Home', url: Astro.site?.toString() || 'https://pepcodex.com' },
  { name: 'Peptides', url: `${Astro.site || 'https://pepcodex.com'}peptides/` },
  { name: name, url: Astro.url.toString() }
];

// SEO: Article URL
const articleUrl = Astro.url.toString();
---

<BaseLayout title={metaTitle || name} description={metaDescription || summary}>
  <!-- Structured Data -->
  <ArticleSchema
    title={`${name}: Evidence Dossier`}
    description={summary}
    url={articleUrl}
    dateModified={lastUpdated}
  />
  <BreadcrumbSchema items={breadcrumbItems} />
  {faqs && faqs.length > 0 && <FAQSchema items={faqs} />}
  <DrugSchema
    name={name}
    alternateName={aliases}
    description={summary}
    drugClass={categoryLabels[category]}
    administrationRoute="Subcutaneous injection"
    legalStatus="Research use only - not FDA approved for human use"
    molecularWeight={molecularInfo?.weight}
    url={articleUrl}
  />

  <div class="max-w-7xl mx-auto pb-20">
    <!-- Header with Navigation -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-12">
      <a href="/peptides" class="group flex items-center text-sm font-medium text-white/70 hover:text-white transition-all">
        <div class="mr-3 w-8 h-8 rounded-full border border-white/10 flex items-center justify-center group-hover:border-[var(--primary)]/50 group-hover:bg-[var(--primary)]/5 transition-all">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m12 19-7-7 7-7"/>
            <path d="M19 12H5"/>
          </svg>
        </div>
        Back to Library
      </a>
      <div class="flex items-center gap-2">
        <span class="bg-[var(--primary)]/5 border border-[var(--primary)]/20 text-primary px-3 py-1 rounded-full uppercase tracking-widest text-[10px] font-bold">
          ID: {name.toUpperCase().replace(/\s+/g, '-')}
        </span>
        <span class="bg-white/5 border border-white/10 text-white/70 px-3 py-1 rounded-full uppercase tracking-widest text-[10px] font-bold">
          STATUS: ACTIVE
        </span>
      </div>
    </div>

    <!-- Hero Layout - 12 column grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 mb-20">
      <!-- Left: Title and description (7 columns) -->
      <div class="lg:col-span-7">
        <h1 class="text-6xl md:text-8xl font-bold text-white mb-6 tracking-tighter leading-tight text-glow" style="font-family: var(--font-display);">
          {name}
        </h1>

        {/* Regulatory badge */}
        {regConfig && (
          <a href="/regulatory-tracker/" class:list={["inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium border mb-4 transition-colors hover:opacity-80", regConfig.bg, regConfig.color, regConfig.border]}>
            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              {regulatoryStatus!.status === 'approved' ? (
                <><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></>
              ) : regulatoryStatus!.status === 'investigational' ? (
                <><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></>
              ) : (
                <><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></>
              )}
            </svg>
            {regConfig.label}
          </a>
        )}

        <!-- Aliases -->
        {aliases.length > 0 && (
          <p class="text-lg text-white/70 mb-4">
            Also known as: <span class="font-medium text-white">{aliases.join(', ')}</span>
          </p>
        )}

        <p class="text-xl md:text-2xl text-white/80 leading-relaxed max-w-2xl">
          {summary}
        </p>

        <!-- Tags -->
        <div class="flex flex-wrap gap-3 mt-8">
          <!-- Category tag - purple -->
          <span class="px-4 py-2 rounded-full bg-gradient-to-r from-[var(--primary)]/20 to-purple-600/20 border border-[var(--primary)]/40 text-sm font-medium text-white shadow-[0_0_15px_rgba(139,92,246,0.2)]">
            {categoryLabels[category]}
          </span>
          <!-- Evidence tag - colored by level -->
          <span
            class="px-4 py-2 rounded-full text-sm font-medium text-white border"
            style={`background: linear-gradient(135deg, ${currentEvidence.color}20, ${currentEvidence.color}10); border-color: ${currentEvidence.color}60; box-shadow: 0 0 15px ${currentEvidence.color}30;`}
          >
            {currentEvidence.label}
          </span>
          <!-- Sources tag - cyan accent -->
          <span class="px-4 py-2 rounded-full bg-gradient-to-r from-cyan-500/20 to-blue-500/20 border border-cyan-400/40 text-sm font-medium text-white shadow-[0_0_15px_rgba(34,211,238,0.2)]">
            {sources.count} Sources
          </span>
        </div>
      </div>

      <!-- Right: Molecular Specifications Card (5 columns) -->
      <div class="lg:col-span-5">
        <div class="glass-card-default p-8 h-full flex flex-col justify-between overflow-hidden relative group">
          <!-- Decorative flask icon -->
          <div class="absolute top-0 right-0 p-8 opacity-5 group-hover:opacity-10 transition-opacity">
            <svg class="w-48 h-48 rotate-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
              <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2" />
              <path d="M8.5 2h7" />
              <path d="M7 16h10" />
            </svg>
          </div>

          <div class="relative z-10 space-y-6">
            <h3 class="text-xs font-bold text-white uppercase tracking-[0.2em]">Research Statistics</h3>
            <div class="space-y-4">
              <!-- Stats rows -->
              <div class="flex items-center justify-between group/item">
                <div class="flex items-center gap-3 text-white/70 group-hover/item:text-white transition-colors">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
                    <polyline points="14,2 14,8 20,8"/>
                  </svg>
                  <span class="text-sm">Total Sources</span>
                </div>
                <span class="font-mono text-sm text-white">{sources.count}</span>
              </div>

              <div class="flex items-center justify-between group/item">
                <div class="flex items-center gap-3 text-white/70 group-hover/item:text-white transition-colors">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                  </svg>
                  <span class="text-sm">Human Studies</span>
                </div>
                <span class="font-mono text-sm" style="color: hsl(142 70% 45%);">{sources.human}</span>
              </div>

              <div class="flex items-center justify-between group/item">
                <div class="flex items-center gap-3 text-white/70 group-hover/item:text-white transition-colors">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"/>
                    <path d="M8.5 2h7"/>
                  </svg>
                  <span class="text-sm">Preclinical</span>
                </div>
                <span class="font-mono text-sm" style="color: hsl(280 80% 60%);">{sources.preclinical}</span>
              </div>

              {ratings ? (
                <div class="pt-2 border-t border-white/10">
                  <RatingCard ratings={ratings} />
                </div>
              ) : (
                <div class="flex items-center justify-between group/item">
                  <div class="flex items-center gap-3 text-white/70 group-hover/item:text-white transition-colors">
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/>
                    </svg>
                    <span class="text-sm">Evidence Level</span>
                  </div>
                  <div class="flex items-center gap-2">
                    <div class="flex gap-1">
                      {[1, 2, 3, 4].map((n) => (
                        <div
                          class="w-2 h-2 rounded-full"
                          style={`background: ${n <= currentEvidence.dots ? currentEvidence.color : currentEvidence.color + '40'}`}
                        ></div>
                      ))}
                    </div>
                  </div>
                </div>
              )}
            </div>
          </div>

          <!-- Share button -->
          <div class="mt-12 relative z-10">
            <button
              id="share-btn"
              class="w-full flex items-center justify-center gap-3 bg-white text-black font-bold py-4 rounded-xl text-sm uppercase tracking-widest hover:bg-[var(--primary)] hover:text-white transition-all duration-500"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="18" cy="5" r="3"/>
                <circle cx="6" cy="12" r="3"/>
                <circle cx="18" cy="19" r="3"/>
                <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
                <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
              </svg>
              <span id="share-text">Share Dossier</span>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Safety Banner -->
    <SafetyBanner
      peptideName={name}
      evidenceStrength={evidenceStrength}
      fdaStatus="Not FDA Approved"
      wadaStatus="WADA Prohibited"
    />

    <!-- Research Dossier Section -->
    <section class="space-y-8">
      <div class="flex items-center justify-between border-b border-white/10 pb-4">
        <h2 class="text-2xl font-bold text-white" style="font-family: var(--font-display);">Research Dossier</h2>
        <div class="flex items-center gap-4 text-sm text-white/70 font-medium">
          <span class="text-primary" id="current-section">01</span>
          <span class="opacity-30">/</span>
          <span>{sections.length}</span>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-[200px_1fr] xl:grid-cols-[220px_1fr] gap-8">
        <!-- Section Navigation (fixed width narrow column) -->
        <div class="space-y-1 lg:sticky lg:top-24 lg:self-start lg:max-h-[calc(100vh-8rem)] lg:overflow-y-auto scrollbar-none">
          {sections.map((section, index) => (
            <a
              href={`#${section.id}`}
              data-section-btn={section.id}
              data-section-num={section.num}
              class="section-btn w-full text-left px-3 py-2.5 rounded-xl transition-all duration-300 flex items-center gap-3 group text-white/60 hover:text-white hover:bg-white/5 border border-transparent"
            >
              <span class="w-7 h-7 rounded-md flex items-center justify-center text-[10px] font-bold border bg-white/5 border-white/10 text-white/50 section-num shrink-0">
                {section.num}
              </span>
              <span class="font-semibold uppercase tracking-wide text-[11px] truncate">{section.label}</span>
              {section.isNew && (
                <span class="px-1 py-0.5 text-[8px] font-bold uppercase bg-emerald-500/20 border border-emerald-500/40 text-emerald-400 rounded shrink-0">
                  New
                </span>
              )}
            </a>
          ))}
        </div>

        <!-- Main Content (takes remaining width) -->
        <div>
          <div class="glass-card-default p-10 md:p-16 relative overflow-hidden min-h-[500px]">
            <div class="absolute top-0 right-0 w-full h-full bg-gradient-to-br from-[var(--primary)]/5 to-transparent pointer-events-none"></div>

            <div class="relative z-10 prose prose-invert prose-lg max-w-none">
              <!-- Overview Section (includes molecular info) -->
              <OverviewSection
                peptideName={name}
                summary={summary}
                aliases={aliases}
                category={category}
                molecularInfo={molecularInfo}
              />

              <!-- MDX content contains: Mechanism section -->
              <slot />

              <!-- ENHANCED SECTIONS (rendered after MDX content) -->
              <!-- Order: Evidence → Timeline → Quality → Interactions → References -->

              <!-- Evidence-Chained Benefits -->
              {evidenceChainedBenefits && evidenceChainedBenefits.length > 0 && (
                <section id="evidence-chain" class="not-prose mt-12 pt-8 border-t border-white/10">
                  <div class="space-y-2 mb-8">
                    <h2 class="text-3xl font-bold text-white tracking-tight" style="font-family: var(--font-display);">
                      Evidence-Chained Benefits
                    </h2>
                    <div class="h-1 w-20 bg-gradient-to-r from-emerald-500 to-cyan-500 rounded-full"></div>
                  </div>
                  <EvidenceChain benefits={evidenceChainedBenefits} peptideName={name} />
                </section>
              )}

              <!-- Timeline "What to Expect" -->
              {timeline && timeline.length > 0 && (
                <section id="timeline" class="not-prose mt-12 pt-8 border-t border-white/10">
                  <Timeline timeline={timeline} peptideName={name} />
                </section>
              )}

              <!-- Quality Checklist -->
              {qualityChecklist && (
                <section id="quality-checklist" class="not-prose mt-12 pt-8 border-t border-white/10">
                  <QualityChecklist checklist={qualityChecklist} peptideName={name} />
                </section>
              )}

              <!-- Peptide Interactions -->
              {interactions && interactions.length > 0 && (
                <section id="peptide-interactions" class="not-prose mt-12 pt-8 border-t border-white/10">
                  <InteractionMatrix interactions={interactions} currentPeptide={name} />
                </section>
              )}

              <!-- References Section -->
              <section id="references" class="not-prose mt-12 pt-8 border-t border-white/10">
                <div class="space-y-2 mb-8">
                  <h2 class="text-3xl font-bold text-white tracking-tight" style="font-family: var(--font-display);">
                    References
                  </h2>
                  <div class="h-1 w-20 bg-gradient-to-r from-emerald-500 to-cyan-500 rounded-full"></div>
                </div>

                <div class="rounded-2xl bg-white/5 border border-white/10 p-6">
                  <div class="flex items-center gap-4 mb-6">
                    <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-emerald-500/10 border border-emerald-500/20">
                      <svg class="w-4 h-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                      </svg>
                      <span class="text-sm font-medium text-emerald-400">{sources.count} Sources</span>
                    </div>
                    <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-blue-500/10 border border-blue-500/20">
                      <svg class="w-4 h-4 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                      </svg>
                      <span class="text-sm font-medium text-blue-400">{sources.human} Human</span>
                    </div>
                    <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-violet-500/10 border border-violet-500/20">
                      <svg class="w-4 h-4 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
                      </svg>
                      <span class="text-sm font-medium text-violet-400">{sources.preclinical} Preclinical</span>
                    </div>
                  </div>

                  {evidenceChainedBenefits && evidenceChainedBenefits.length > 0 && (
                    <div class="space-y-4">
                      <h3 class="text-lg font-semibold text-white">Key Studies Cited</h3>
                      <div class="grid gap-2">
                        {(() => {
                          // Collect unique studies from evidence chain
                          const studies = new Map();
                          evidenceChainedBenefits.forEach(benefit => {
                            benefit.evidence.keyFindings.forEach(finding => {
                              if (finding.pmid && !studies.has(finding.pmid)) {
                                studies.set(finding.pmid, {
                                  study: finding.study,
                                  type: finding.type,
                                  finding: finding.finding,
                                  pmid: finding.pmid
                                });
                              }
                            });
                          });
                          return Array.from(studies.values()).map(study => (
                            <a
                              href={`https://pubmed.ncbi.nlm.nih.gov/${study.pmid}/`}
                              target="_blank"
                              rel="noopener noreferrer"
                              class="flex items-center justify-between p-3 rounded-lg bg-white/5 border border-white/10 hover:border-primary/30 hover:bg-white/10 transition-all group"
                            >
                              <div class="flex items-center gap-3">
                                <span class={`px-2 py-0.5 text-[10px] font-bold uppercase rounded ${
                                  study.type === 'human-rct' ? 'bg-emerald-500/20 text-emerald-400' :
                                  study.type === 'human-observational' ? 'bg-blue-500/20 text-blue-400' :
                                  study.type === 'animal' ? 'bg-violet-500/20 text-violet-400' :
                                  'bg-amber-500/20 text-amber-400'
                                }`}>
                                  {study.type === 'human-rct' ? 'RCT' :
                                   study.type === 'human-observational' ? 'Human' :
                                   study.type === 'animal' ? 'Animal' : 'In Vitro'}
                                </span>
                                <span class="text-sm text-white font-medium">{study.study}</span>
                              </div>
                              <div class="flex items-center gap-2 text-white/50 group-hover:text-primary">
                                <span class="text-xs">PMID:{study.pmid}</span>
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                </svg>
                              </div>
                            </a>
                          ));
                        })()}
                      </div>
                    </div>
                  )}

                  <p class="mt-6 text-sm text-white/50">
                    Full reference list available on request. All citations link to PubMed for verification.
                  </p>
                </div>
              </section>

              <!-- Methodology Note -->
              <section id="methodology-note" class="mt-12 pt-8 border-t border-white/10">
                <div class="space-y-2 mb-8">
                  <h3 class="text-3xl font-bold text-white tracking-tight" style="font-family: var(--font-display);">
                    Methodology Note
                  </h3>
                  <div class="h-1 w-20 bg-[var(--primary)] rounded-full"></div>
                </div>

                <div class="rounded-2xl bg-white/5 border border-white/10 p-6">
                  <p class="text-white/80 mb-4">
                    This dossier synthesizes available evidence from peer-reviewed literature, regulatory documents, and clinical trial registries. Evidence strength ratings follow a modified GRADE approach.
                  </p>
                  <p class="text-white/80">
                    For complete methodology details, see our <a href="/methodology" class="font-medium text-primary hover:underline">Methodology page</a>.
                  </p>
                </div>
              </section>

              <!-- Disclaimer -->
              <div class="mt-8 rounded-2xl border border-[var(--accent)]/30 bg-[var(--accent)]/5 p-6">
                <div class="flex gap-4">
                  <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-[var(--accent)]/10 text-[var(--accent)]">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                    </svg>
                  </div>
                  <div>
                    <h4 class="font-bold text-[var(--accent)] mb-1 text-base">Important Disclaimer</h4>
                    <p class="text-white/80 text-sm leading-relaxed">
                      This dossier is for <strong class="text-white">educational purposes only</strong> and does not constitute medical advice. Always consult a qualified healthcare provider before making health decisions.
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Newsletter CTA -->
    <section class="mt-20">
      <NewsletterForm
        variant="full"
        heading="Get Research Alerts"
        description="New dossiers and major study summaries delivered to your inbox. Evidence-graded, citation-backed research you can trust."
      />
    </section>

    <!-- Compare Section -->
    {comparators.length > 0 && (
      <section class="mt-20">
        <div class="flex items-center justify-between border-b border-white/10 pb-4 mb-8">
          <h2 class="text-2xl font-bold" style="font-family: var(--font-display);">Compare {name}</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {comparators.map(comp => {
            const comparisonSlug = findComparisonSlug(comp);
            const compName = peptideNameMap.get(comp) || comp.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
            return comparisonSlug ? (
              <a
                href={`/compare/${comparisonSlug}`}
                class="glass-card-hoverable p-6 flex items-center gap-4 group"
              >
                <div class="w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center group-hover:bg-[var(--primary)]/10 group-hover:border-[var(--primary)]/30 transition-all">
                  <svg class="w-6 h-6 text-[var(--muted-foreground)] group-hover:text-primary transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M16 3h5v5M8 3H3v5M21 3L14 10M3 3l7 7M21 21l-7-7M3 21l7-7M16 21h5v-5M8 21H3v-5" />
                  </svg>
                </div>
                <div>
                  <div class="font-bold text-white group-hover:text-primary transition-colors">{name} vs {compName}</div>
                  <div class="text-sm text-white/70">View comparison</div>
                </div>
              </a>
            ) : null;
          })}
        </div>
      </section>
    )}

    <!-- Calculator Links -->
    {hasCalculatorPreset && (
      <section class="mt-12">
        <div class="flex items-center justify-between border-b border-white/10 pb-4 mb-8">
          <h2 class="text-2xl font-bold" style="font-family: var(--font-display);">{name} Calculators</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <a href={`/calculator/reconstitution/${currentSlug}`} class="glass-card-hoverable p-6 flex items-center gap-4 group">
            <div class="w-12 h-12 rounded-xl bg-primary/10 border border-primary/20 flex items-center justify-center group-hover:bg-primary/20 transition-all">
              <svg class="w-6 h-6 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4.5 3h15"/><path d="M6 3v16a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V3"/><path d="M6 14h12"/>
              </svg>
            </div>
            <div>
              <div class="font-bold text-white group-hover:text-primary transition-colors">Reconstitution</div>
              <div class="text-sm text-white/70">Calculate concentrations</div>
            </div>
          </a>
          <a href={`/calculator/blend/${currentSlug}`} class="glass-card-hoverable p-6 flex items-center gap-4 group">
            <div class="w-12 h-12 rounded-xl bg-cyan-400/10 border border-cyan-400/20 flex items-center justify-center group-hover:bg-cyan-400/20 transition-all">
              <svg class="w-6 h-6 text-cyan-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"/>
                <path d="M8.5 2h7"/><path d="M7 16h10"/>
              </svg>
            </div>
            <div>
              <div class="font-bold text-white group-hover:text-cyan-400 transition-colors">Blend Calculator</div>
              <div class="text-sm text-white/70">Multi-peptide volumes</div>
            </div>
          </a>
          <a href={`/calculator/accumulation/${currentSlug}`} class="glass-card-hoverable p-6 flex items-center gap-4 group">
            <div class="w-12 h-12 rounded-xl bg-purple-400/10 border border-purple-400/20 flex items-center justify-center group-hover:bg-purple-400/20 transition-all">
              <svg class="w-6 h-6 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 3v18h18"/><path d="M18 17V9"/><path d="M13 17V5"/><path d="M8 17v-3"/>
              </svg>
            </div>
            <div>
              <div class="font-bold text-white group-hover:text-purple-400 transition-colors">Accumulation</div>
              <div class="text-sm text-white/70">Steady-state calculations</div>
            </div>
          </a>
        </div>
      </section>
    )}

    <!-- Related Peptides (same category) -->
    {(() => {
      const comparatorSlugs = new Set(comparators.map(c => c.toLowerCase().replace(/\s+/g, '-')));
      const related = allPeptides
        .filter(p => p.data.category === category && p.slug !== currentSlug && !comparatorSlugs.has(p.slug))
        .slice(0, 6);
      return related.length > 0 ? (
        <section class="mt-12">
          <div class="flex items-center justify-between border-b border-white/10 pb-4 mb-8">
            <h2 class="text-2xl font-bold" style="font-family: var(--font-display);">Related Peptides</h2>
          </div>
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {related.map(p => (
              <PeptideCard
                name={p.data.name}
                slug={p.slug}
                category={p.data.category}
                evidenceStrength={p.data.evidenceStrength}
                summary={p.data.summary}
                aliases={p.data.aliases}
              />
            ))}
          </div>
        </section>
      ) : null;
    })()}

    <!-- Related Content (Internal Linking) -->
    <RelatedEntities
      currentPeptide={name.toLowerCase().replace(/\s+/g, '-')}
      category={category}
      relatedPeptides={comparators.map(c => c.toLowerCase().replace(/\s+/g, '-'))}
    />
  </div>
</BaseLayout>

<style>
  .section-btn.active {
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.2), rgba(139, 92, 246, 0.1));
    border-color: rgba(139, 92, 246, 0.4);
    color: white;
    box-shadow: 0 0 15px rgba(139, 92, 246, 0.2);
  }

  .section-btn.active .section-num {
    background: var(--primary);
    border-color: var(--primary);
    color: white;
    box-shadow: 0 0 10px rgba(139, 92, 246, 0.4);
  }
</style>

<script>
  // Section highlighting based on scroll
  document.addEventListener('DOMContentLoaded', () => {
    const sectionBtns = document.querySelectorAll('.section-btn');
    const currentSectionDisplay = document.getElementById('current-section');

    if (sectionBtns.length === 0) return;

    // Get section IDs that actually exist in both the sidebar AND the content
    const validSections: { id: string; element: Element; btn: Element }[] = [];
    sectionBtns.forEach(btn => {
      const id = btn.getAttribute('data-section-btn');
      if (id) {
        const element = document.getElementById(id);
        if (element) {
          validSections.push({ id, element, btn });
        }
      }
    });

    // If no valid sections found, try to match buttons to actual h2 elements
    if (validSections.length === 0) {
      const allH2s = document.querySelectorAll('.prose-invert h2[id]');
      allH2s.forEach((h2, index) => {
        const id = h2.getAttribute('id');
        if (id) {
          const btn = document.querySelector(`[data-section-btn="${id}"]`);
          if (btn) {
            validSections.push({ id, element: h2, btn });
          }
        }
      });
    }

    if (validSections.length === 0) return;

    let currentActive: Element | null = validSections[0]?.btn || null;
    if (currentActive) currentActive.classList.add('active');

    // Scroll-based section detection
    function updateActiveSection() {
      const scrollY = window.scrollY;
      const offset = window.innerHeight * 0.4; // Trigger at 40% from top

      let activeSection: typeof validSections[0] | null = null;

      // Find which section is currently in view (iterate backwards to find the last one that's passed)
      for (let i = validSections.length - 1; i >= 0; i--) {
        const section = validSections[i];
        const rect = section.element.getBoundingClientRect();
        const sectionTop = rect.top + scrollY - offset;

        if (scrollY >= sectionTop) {
          activeSection = section;
          break;
        }
      }

      // Default to first section if at top
      if (!activeSection && validSections.length > 0) {
        activeSection = validSections[0];
      }

      if (activeSection && activeSection.btn !== currentActive) {
        if (currentActive) {
          currentActive.classList.remove('active');
        }
        activeSection.btn.classList.add('active');
        currentActive = activeSection.btn;

        // Update the counter
        const num = activeSection.btn.getAttribute('data-section-num');
        if (currentSectionDisplay && num) {
          currentSectionDisplay.textContent = num;
        }

        // Scroll the active button into view in the sidebar if needed
        const sidebar = activeSection.btn.closest('.lg\\:overflow-y-auto');
        if (sidebar) {
          const btnRect = activeSection.btn.getBoundingClientRect();
          const sidebarRect = sidebar.getBoundingClientRect();

          if (btnRect.top < sidebarRect.top || btnRect.bottom > sidebarRect.bottom) {
            activeSection.btn.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          }
        }
      }
    }

    // Throttle scroll events for performance
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          updateActiveSection();
          ticking = false;
        });
        ticking = true;
      }
    });

    // Initial check
    updateActiveSection();

    // Smooth scroll on click
    sectionBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const href = (btn as HTMLAnchorElement).getAttribute('href');
        if (href) {
          const target = document.querySelector(href);
          if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            history.pushState(null, '', href);
          }
        }
      });
    });

    // Share button functionality
    const shareBtn = document.getElementById('share-btn');
    const shareText = document.getElementById('share-text');

    if (shareBtn && shareText) {
      shareBtn.addEventListener('click', async () => {
        const url = window.location.href;
        const title = document.title;

        // Try native share API first (mobile)
        if (navigator.share) {
          try {
            await navigator.share({ title, url });
            return;
          } catch (err) {
            // User cancelled or share failed, fall back to clipboard
          }
        }

        // Fall back to clipboard copy
        try {
          await navigator.clipboard.writeText(url);
          shareText.textContent = 'Link Copied!';
          shareBtn.classList.add('bg-green-500');
          setTimeout(() => {
            shareText.textContent = 'Share Dossier';
            shareBtn.classList.remove('bg-green-500');
          }, 2000);
        } catch (err) {
          // Fallback for older browsers
          const textArea = document.createElement('textarea');
          textArea.value = url;
          document.body.appendChild(textArea);
          textArea.select();
          document.execCommand('copy');
          document.body.removeChild(textArea);
          shareText.textContent = 'Link Copied!';
          setTimeout(() => {
            shareText.textContent = 'Share Dossier';
          }, 2000);
        }
      });
    }
  });
</script>
