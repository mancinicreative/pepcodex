---
import { getCollection, getEntry } from 'astro:content';
import ComparisonLayout from '../../layouts/ComparisonLayout.astro';

export async function getStaticPaths() {
  const comparisons = await getCollection('comparisons');
  return comparisons.map((comparison) => ({
    params: { slug: comparison.slug },
    props: { comparison },
  }));
}

// Support both static and SSR modes
let comparison = Astro.props.comparison;
if (!comparison) {
  const { slug } = Astro.params;
  comparison = await getEntry('comparisons', slug as string);
}

if (!comparison) {
  return Astro.redirect('/404');
}

const { Content } = await comparison.render();

// Dynamic lookup from peptides collection — replaces hardcoded 4-entry map
const allPeptides = await getCollection('peptides');
const peptideMap = new Map(allPeptides.map(p => [p.slug, p.data]));

function getPeptideDisplay(slug: string) {
  const data = peptideMap.get(slug);
  return {
    name: data?.name || slug.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase()),
    slug,
    evidenceStrength: data?.evidenceStrength || 'low' as const,
  };
}

const peptideA = getPeptideDisplay(comparison.data.peptideA);
const peptideB = getPeptideDisplay(comparison.data.peptideB);
---

<ComparisonLayout
  title={comparison.data.title}
  peptideA={peptideA}
  peptideB={peptideB}
  category={comparison.data.category}
  lastUpdated={comparison.data.lastUpdated}
  summary={comparison.data.summary}
  faqs={comparison.data.faqs}
>
  <Content />
</ComparisonLayout>
