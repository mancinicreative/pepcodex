---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import BreadcrumbSchema from '../components/SEO/BreadcrumbSchema.astro';
import NewsletterForm from '../components/NewsletterForm.astro';

interface Source {
  id: string;
  title: string;
  url?: string;
  type?: 'journal' | 'trial' | 'regulatory' | 'preprint' | 'news';
}

interface Props {
  title: string;
  peptides: string[];
  lastUpdated: Date;
  summary: string;
  sources?: Source[];
  metaTitle?: string;
  metaDescription?: string;
}

const { title, peptides, lastUpdated, summary, sources = [], metaTitle, metaDescription } = Astro.props;

const sourceTypeIcons: Record<string, string> = {
  'journal': 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253',
  'trial': 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  'regulatory': 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  'preprint': 'M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z',
  'news': 'M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z',
};

function getSourceUrl(source: Source): string {
  if (source.url) return source.url;
  const searchTerms = source.title.replace(/[^\w\s]/g, '').split(' ').slice(0, 6).join('+');
  return `https://pubmed.ncbi.nlm.nih.gov/?term=${encodeURIComponent(searchTerms)}`;
}

const siteBase = Astro.site?.toString() || 'https://www.pepcodex.com';
const breadcrumbItems = [
  { name: 'Home', url: siteBase },
  { name: 'Safety Profiles', url: `${siteBase}safety/` },
  { name: title, url: Astro.url.toString() },
];
---

<BaseLayout title={metaTitle || title} description={metaDescription || summary}>
  <BreadcrumbSchema items={breadcrumbItems} />
  <article class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <!-- Header -->
    <header class="mb-8 relative">
      <div class="p-6">
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-medium border" style="background: rgba(203,135,52,0.16); color: #9a6418; border-color: rgba(203,135,52,0.32);">
            <svg class="w-3.5 h-3.5 mr-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
            </svg>
            Safety Information
          </span>
        </div>

        <h1 class="text-3xl tracking-tight sm:text-4xl lg:text-5xl" style="font-family: var(--font-serif); font-weight: 500; color: var(--ink);">
          {title}
        </h1>

        <p class="mt-4 text-xl leading-relaxed max-w-3xl text-[color:var(--ink-muted)]">
          {summary}
        </p>

        <p class="mt-4 text-sm text-[color:var(--ink-muted)]">
          Last updated: {lastUpdated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </p>
      </div>
    </header>

    <!-- Important safety notice (amber = meaningful caution) -->
    <div class="mb-8 rounded-xl border-2 p-6" style="border-color: rgba(203,135,52,0.45); background: rgba(203,135,52,0.10);">
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0">
          <svg class="w-8 h-8" style="color: #9a6418;" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
          </svg>
        </div>
        <div>
          <h2 class="text-lg font-semibold mb-2" style="color: #9a6418;">For Educational Purposes Only</h2>
          <p class="text-[color:var(--ink-muted)]">
            This safety information is compiled from clinical trial data and regulatory documents for educational purposes. It is <strong style="color: #9a6418;">not</strong> a substitute for professional medical advice. Always consult your healthcare provider about medication safety, especially regarding your individual circumstances, medical history, and other medications.
          </p>
        </div>
      </div>
    </div>

    <div class="grid gap-8 lg:grid-cols-[1fr,280px]">
      <!-- Main content -->
      <div class="prose prose-invert prose-lg max-w-none">
        <slot />

        <!-- Sources Section -->
        {sources.length > 0 && (
          <section class="mt-12 not-prose">
            <h2 class="text-xl mb-4 flex items-center gap-2" style="font-family: var(--font-serif); font-weight: 500; color: var(--ink);">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
              </svg>
              Sources & Citations
            </h2>
            <div class="rounded-xl overflow-hidden" style="background: var(--paper-2); border: 1px solid var(--border-c);">
              <ul style="--tw-divide-opacity: 1;" class="divide-y divide-[color:var(--border-c)]">
                {sources.map((source, index) => (
                  <li class="p-4 transition-colors hover:bg-[color:var(--paper)]">
                    <div class="flex items-start gap-3">
                      <span class="flex-shrink-0 w-6 h-6 rounded-full text-primary text-xs flex items-center justify-center font-medium" style="background: var(--primary-soft);">
                        {index + 1}
                      </span>
                      <div class="flex-grow min-w-0">
                        <div class="flex items-center gap-2 mb-1">
                          {source.type && (
                            <svg class="w-4 h-4 text-[color:var(--ink-dim)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={sourceTypeIcons[source.type] || sourceTypeIcons['journal']}></path>
                            </svg>
                          )}
                          <span class="text-xs text-[color:var(--ink-dim)] uppercase tracking-wide">{source.type || 'source'}</span>
                        </div>
                        <a
                          href={getSourceUrl(source)}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-primary hover:text-[color:var(--primary-deep)] hover:underline transition-colors inline-flex items-center gap-1"
                        >
                          {source.title}
                          <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                          </svg>
                        </a>
                        <p class="text-xs text-[color:var(--ink-dim)] mt-1">{source.id}</p>
                      </div>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          </section>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="hidden lg:block">
        <div class="sticky top-24 space-y-6">
          <TableOfContents />

          {peptides.length > 0 && (
            <div class="rounded-xl p-4" style="background: var(--primary-soft); border: 1px solid var(--primary-border);">
              <h3 class="font-semibold mb-3" style="font-family: var(--font-serif); font-weight: 500; color: var(--ink);">Related Peptides</h3>
              <ul class="space-y-2">
                {peptides.map(peptide => (
                  <li>
                    <a
                      href={`/peptides/${peptide}`}
                      class="text-sm text-primary hover:text-[color:var(--primary-deep)] hover:underline transition-colors"
                    >
                      {peptide.charAt(0).toUpperCase() + peptide.slice(1)} Dossier
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <div class="rounded-xl p-4" style="background: var(--paper-2); border: 1px solid var(--border-c);">
            <h3 class="font-semibold mb-3" style="font-family: var(--font-serif); font-weight: 500; color: var(--ink);">Quick Links</h3>
            <ul class="space-y-2">
              <li>
                <a
                  href="/methodology"
                  class="text-sm text-primary hover:text-[color:var(--primary-deep)] hover:underline transition-colors"
                >
                  Our Methodology
                </a>
              </li>
              <li>
                <a
                  href="/editorial-policy"
                  class="text-sm text-primary hover:text-[color:var(--primary-deep)] hover:underline transition-colors"
                >
                  Editorial Policy
                </a>
              </li>
            </ul>
          </div>

          <!-- Report Issues (red = meaningful danger / adverse events) -->
          <div class="rounded-xl p-4" style="background: rgba(185,61,66,0.10); border: 1px solid rgba(185,61,66,0.30);">
            <h3 class="font-semibold mb-2" style="font-family: var(--font-serif); font-weight: 500; color: var(--danger);">Report Issues</h3>
            <p class="text-sm" style="color: var(--ink-muted);">
              If you experience adverse effects from any medication, report them to the FDA MedWatch program or contact your healthcare provider immediately.
            </p>
          </div>
        </div>
      </aside>
    </div>

    <!-- Newsletter CTA -->
    <div class="mt-12">
      <NewsletterForm
        variant="card"
        heading="Safety Alerts"
        description="Get notified about new safety data, FDA decisions, and adverse event reports."
      />
    </div>

    <!-- Footer disclaimer (amber = meaningful caution) -->
    <div class="mt-12 rounded-xl border-2 p-6" style="border-color: rgba(203,135,52,0.45); background: rgba(203,135,52,0.10);">
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0">
          <svg class="w-6 h-6" style="color: #9a6418;" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
          </svg>
        </div>
        <div>
          <p class="text-sm text-[color:var(--ink-muted)]">
            <strong style="color: #9a6418;">Important:</strong> Safety information evolves as post-marketing data accumulates. This page reflects data available as of the last update date. Check official FDA and EMA resources for the most current safety information. This content is not intended to diagnose, treat, cure, or prevent any disease.
          </p>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
