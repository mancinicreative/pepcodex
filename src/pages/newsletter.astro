---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
---

<BaseLayout
  title="Newsletter"
  description="Subscribe to the PepCodex newsletter for weekly evidence synthesis delivered to your inbox."
>
  <!-- Hero Section -->
  <div>
    <div class="mx-auto max-w-4xl px-4 py-20 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="text-center mb-12">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium mb-6" style="background: var(--primary-soft); border: 1px solid var(--primary-border); color: var(--primary-c);">
          <svg class="w-4 h-4" style="color: var(--primary-c);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
          Weekly Newsletter
        </div>
        <h1 class="text-5xl md:text-6xl tracking-tight" style="font-family: var(--font-serif); font-weight: 500; color: var(--ink);">
          Stay <em class="italic" style="color: var(--primary-c);">Evidence-Based</em>
        </h1>
        <p class="mt-6 text-xl text-[color:var(--ink-muted)] max-w-2xl mx-auto leading-relaxed">
          Weekly synthesis of peptide research delivered to your inbox. No hype, just citations.
        </p>
      </div>

      <!-- Newsletter Form (Full variant) -->
      <div class="max-w-2xl mx-auto">
        <NewsletterForm variant="full" />
      </div>
    </div>
  </div>

  <!-- Features Section -->
  <div class="mx-auto max-w-5xl px-4 py-20 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-2xl" style="font-family: var(--font-serif); font-weight: 500; color: var(--ink);">What You'll Get</h2>
      <div class="mt-3 h-0.5 w-16 rounded-full mx-auto" style="background: var(--primary-c);"></div>
    </div>

    <div class="grid gap-6 sm:grid-cols-3">
      <!-- Feature 1 -->
      <div class="group">
        <div class="glass-card-default p-8 text-center h-full">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-xl" style="background: var(--primary-soft); border: 1px solid var(--primary-border); color: var(--primary-c);">
            <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h3 class="mt-6 text-lg" style="font-family: var(--font-serif); font-weight: 500; color: var(--ink);">New Research</h3>
          <p class="mt-3 text-sm text-[color:var(--ink-muted)] leading-relaxed">
            The most important peptide studies from the past week, summarized and cited.
          </p>
        </div>
      </div>

      <!-- Feature 2 -->
      <div class="group">
        <div class="glass-card-default p-8 text-center h-full">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-xl" style="background: var(--primary-soft); border: 1px solid var(--primary-border); color: var(--primary-c);">
            <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
            </svg>
          </div>
          <h3 class="mt-6 text-lg" style="font-family: var(--font-serif); font-weight: 500; color: var(--ink);">Trial Updates</h3>
          <p class="mt-3 text-sm text-[color:var(--ink-muted)] leading-relaxed">
            Clinical trial progress, new registrations, and regulatory developments.
          </p>
        </div>
      </div>

      <!-- Feature 3 -->
      <div class="group">
        <div class="glass-card-default p-8 text-center h-full">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-xl" style="background: var(--primary-soft); border: 1px solid var(--primary-border); color: var(--primary-c);">
            <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="mt-6 text-lg" style="font-family: var(--font-serif); font-weight: 500; color: var(--ink);">Deep Dives</h3>
          <p class="mt-3 text-sm text-[color:var(--ink-muted)] leading-relaxed">
            Occasional long-form analysis of complex topics and emerging research areas.
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- What to Expect Section -->
  <div class="mx-auto max-w-4xl px-4 pb-20 sm:px-6 lg:px-8">
    <div>
      <div class="glass-card-default p-8 md:p-10">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: var(--primary-soft); border: 1px solid var(--primary-border);">
            <svg class="w-5 h-5" style="color: var(--primary-c);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/>
            </svg>
          </div>
          <h3 class="text-xl" style="font-family: var(--font-serif); font-weight: 500; color: var(--ink);">What to Expect</h3>
        </div>

        <div class="grid gap-4 sm:grid-cols-3">
          <div class="flex items-start gap-3 p-4 rounded-xl" style="background: var(--paper-2); border: 1px solid var(--border-c);">
            <div class="flex-shrink-0 w-6 h-6 rounded-full flex items-center justify-center" style="background: rgba(20,118,74,0.14);">
              <svg class="h-4 w-4" style="color: var(--research);" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            </div>
            <div>
              <span class="font-medium text-sm" style="color: var(--ink);">Weekly delivery</span>
              <p class="text-[color:var(--ink-dim)] text-xs mt-1">Every Tuesday morning</p>
            </div>
          </div>

          <div class="flex items-start gap-3 p-4 rounded-xl" style="background: var(--paper-2); border: 1px solid var(--border-c);">
            <div class="flex-shrink-0 w-6 h-6 rounded-full flex items-center justify-center" style="background: rgba(20,118,74,0.14);">
              <svg class="h-4 w-4" style="color: var(--research);" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            </div>
            <div>
              <span class="font-medium text-sm" style="color: var(--ink);">No spam</span>
              <p class="text-[color:var(--ink-dim)] text-xs mt-1">We never sell your data</p>
            </div>
          </div>

          <div class="flex items-start gap-3 p-4 rounded-xl" style="background: var(--paper-2); border: 1px solid var(--border-c);">
            <div class="flex-shrink-0 w-6 h-6 rounded-full flex items-center justify-center" style="background: rgba(20,118,74,0.14);">
              <svg class="h-4 w-4" style="color: var(--research);" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            </div>
            <div>
              <span class="font-medium text-sm" style="color: var(--ink);">Easy unsubscribe</span>
              <p class="text-[color:var(--ink-dim)] text-xs mt-1">One click, anytime</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
