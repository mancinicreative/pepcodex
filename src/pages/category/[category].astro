---
import HubLayout from '../../layouts/HubLayout.astro';
import PeptideCard from '../../components/PeptideCard.astro';
import { getCollection } from 'astro:content';
import { getCategoryMeta } from '../../data/category-meta';

export async function getStaticPaths() {
  const { getCategoryMeta } = await import('../../data/category-meta');
  const meta = getCategoryMeta();
  return Object.keys(meta).map(cat => ({
    params: { category: cat },
    props: { meta: meta[cat] },
  }));
}

const { category } = Astro.params;
const { meta } = Astro.props;

const allPeptides = await getCollection('peptides');
const peptides = allPeptides
  .filter(p => p.data.category === category)
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<HubLayout
  title={meta.title}
  description={meta.description}
  category={category}
>
  <div class="mb-12">
    <p class="text-lg text-white/80 max-w-3xl leading-relaxed">
      {meta.intro}
    </p>
  </div>

  {peptides.length > 0 ? (
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {peptides.map((peptide) => (
        <PeptideCard
          name={peptide.data.name}
          slug={peptide.slug}
          category={peptide.data.category}
          evidenceStrength={peptide.data.evidenceStrength}
          summary={peptide.data.summary}
          aliases={peptide.data.aliases}
        />
      ))}
    </div>
  ) : (
    <div class="glass-card-default p-16 text-center">
      <div class="w-16 h-16 rounded-2xl bg-[var(--primary)]/10 border border-[var(--primary)]/20 flex items-center justify-center mx-auto mb-6">
        <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
        </svg>
      </div>
      <p class="text-lg text-white mb-2">Dossiers Being Prepared</p>
      <p class="text-white/70 mb-6">
        {meta.title} dossiers are being prepared. Check back soon.
      </p>
      <a href="/peptides" class="btn btn-primary">
        Browse all peptides
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  )}

  <div class="mt-16 glass-card-default p-8">
    <h3 class="font-bold text-white mb-4 text-lg">About This Category</h3>
    <div class="prose prose-invert prose-sm max-w-none text-white/80">
      <p>{meta.about}</p>
    </div>
  </div>
</HubLayout>
