---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';

interface Props {
  title: string;
  peptides: string[];
  lastUpdated: Date;
  summary: string;
}

const { title, peptides, lastUpdated, summary } = Astro.props;
---

<BaseLayout title={title} description={summary}>
  <article class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <!-- Header -->
    <header class="mb-8 relative">
      <div class="absolute inset-0 bg-gradient-to-br from-amber-500/10 via-transparent to-transparent rounded-2xl -z-10"></div>
      <div class="p-6">
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span class="inline-flex items-center rounded-full bg-amber-500/20 px-3 py-1 text-xs font-medium text-amber-400 border border-amber-500/30">
            <svg class="w-3.5 h-3.5 mr-1" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
            </svg>
            Safety Information
          </span>
        </div>

        <h1 class="text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">
          {title}
        </h1>

        <p class="mt-4 text-xl text-white/80 leading-relaxed max-w-3xl">
          {summary}
        </p>

        <p class="mt-4 text-sm text-white/70">
          Last updated: {lastUpdated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </p>
      </div>
    </header>

    <!-- Important safety notice -->
    <div class="mb-8 rounded-xl border-2 border-amber-500/40 bg-amber-500/10 p-6 backdrop-blur-sm">
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0">
          <svg class="w-8 h-8 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
          </svg>
        </div>
        <div>
          <h2 class="text-lg font-semibold text-amber-400 mb-2">For Educational Purposes Only</h2>
          <p class="text-amber-200/80">
            This safety information is compiled from clinical trial data and regulatory documents for educational purposes. It is <strong class="text-amber-300">not</strong> a substitute for professional medical advice. Always consult your healthcare provider about medication safety, especially regarding your individual circumstances, medical history, and other medications.
          </p>
        </div>
      </div>
    </div>

    <div class="grid gap-8 lg:grid-cols-[1fr,280px]">
      <!-- Main content -->
      <div class="prose prose-invert prose-lg max-w-none">
        <slot />
      </div>

      <!-- Sidebar -->
      <aside class="hidden lg:block">
        <div class="sticky top-24 space-y-6">
          <TableOfContents />

          {peptides.length > 0 && (
            <div class="rounded-xl border border-white/10 bg-gradient-to-b from-[var(--primary)]/10 to-transparent p-4 backdrop-blur-sm">
              <h3 class="font-semibold text-white mb-3">Related Peptides</h3>
              <ul class="space-y-2">
                {peptides.map(peptide => (
                  <li>
                    <a
                      href={`/peptides/${peptide}`}
                      class="text-sm text-[var(--primary)] hover:text-[var(--accent)] hover:underline transition-colors"
                    >
                      {peptide.charAt(0).toUpperCase() + peptide.slice(1)} Dossier
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <div class="rounded-xl border border-white/10 bg-white/5 p-4 backdrop-blur-sm">
            <h3 class="font-semibold text-white mb-3">Quick Links</h3>
            <ul class="space-y-2">
              <li>
                <a
                  href="/methodology"
                  class="text-sm text-[var(--primary)] hover:text-[var(--accent)] hover:underline transition-colors"
                >
                  Our Methodology
                </a>
              </li>
              <li>
                <a
                  href="/editorial-policy"
                  class="text-sm text-[var(--primary)] hover:text-[var(--accent)] hover:underline transition-colors"
                >
                  Editorial Policy
                </a>
              </li>
            </ul>
          </div>

          <div class="rounded-xl border border-red-500/30 bg-red-500/10 p-4 backdrop-blur-sm">
            <h3 class="font-semibold text-red-400 mb-2">Report Issues</h3>
            <p class="text-sm text-red-200/80">
              If you experience adverse effects from any medication, report them to the FDA MedWatch program or contact your healthcare provider immediately.
            </p>
          </div>
        </div>
      </aside>
    </div>

    <!-- Footer disclaimer -->
    <div class="mt-12 rounded-xl border-2 border-amber-500/40 bg-amber-500/10 p-6 backdrop-blur-sm">
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0">
          <svg class="w-6 h-6 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
          </svg>
        </div>
        <div>
          <p class="text-amber-200/80 text-sm">
            <strong class="text-amber-400">Important:</strong> Safety information evolves as post-marketing data accumulates. This page reflects data available as of the last update date. Check official FDA and EMA resources for the most current safety information. This content is not intended to diagnose, treat, cure, or prevent any disease.
          </p>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
