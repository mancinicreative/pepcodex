---
import BaseLayout from './BaseLayout.astro';
import EvidenceBadge from '../components/EvidenceBadge.astro';
import FAQSchema from '../components/SEO/FAQSchema.astro';
import BreadcrumbSchema from '../components/SEO/BreadcrumbSchema.astro';
import NewsletterForm from '../components/NewsletterForm.astro';

interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  peptideA: {
    name: string;
    slug: string;
    evidenceStrength: 'high' | 'moderate' | 'low' | 'very-low';
  };
  peptideB: {
    name: string;
    slug: string;
    evidenceStrength: 'high' | 'moderate' | 'low' | 'very-low';
  };
  category: string;
  lastUpdated: Date;
  summary: string;
  faqs?: FAQItem[];
}

const { title, peptideA, peptideB, category, lastUpdated, summary, faqs = [] } = Astro.props;

const categoryLabels: Record<string, string> = {
  'metabolic': 'Metabolic',
  'repair-recovery': 'Repair & Recovery',
  'hormonal': 'Hormonal',
  'longevity': 'Longevity',
  'other': 'Other',
};

const categoryColors: Record<string, string> = {
  'metabolic': 'bg-blue-500/20 text-blue-400 border border-blue-500/30',
  'repair-recovery': 'bg-emerald-500/20 text-emerald-400 border border-emerald-500/30',
  'hormonal': 'bg-purple-500/20 text-purple-400 border border-purple-500/30',
  'longevity': 'bg-amber-500/20 text-amber-400 border border-amber-500/30',
  'other': 'bg-white/20 text-white/80 border border-white/20',
};

const siteBase = Astro.site?.toString() || 'https://pepcodex.com';
const breadcrumbItems = [
  { name: 'Home', url: siteBase },
  { name: 'Comparisons', url: `${siteBase}compare/` },
  { name: title, url: Astro.url.toString() },
];
---

<BaseLayout title={title} description={summary}>
  <BreadcrumbSchema items={breadcrumbItems} />
  {faqs && faqs.length > 0 && <FAQSchema items={faqs} />}
  <article class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <!-- Header with purple gradient background -->
    <header class="mb-8 relative">
      <div class="absolute inset-0 bg-gradient-to-br from-[var(--primary)]/10 via-transparent to-cyan-500/5 rounded-2xl -z-10"></div>
      <div class="p-6">
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <a
            href={`/category/${category}`}
            class={`inline-flex items-center rounded-full px-3 py-1 text-xs font-medium ${categoryColors[category] || categoryColors['other']}`}
          >
            {categoryLabels[category] || 'Other'}
          </a>
          <span class="inline-flex items-center rounded-full bg-[var(--primary)]/20 px-3 py-1 text-xs font-medium text-primary border border-[var(--primary)]/30">
            Comparison
          </span>
        </div>

        <h1 class="text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">
          {title}
        </h1>

        <p class="mt-4 text-xl text-white/80 leading-relaxed max-w-3xl">
          {summary}
        </p>

        <p class="mt-4 text-sm text-white/70">
          Last updated: {lastUpdated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </p>
      </div>
    </header>

    <!-- Peptide comparison header cards -->
    <div class="grid gap-6 md:grid-cols-2 mb-8">
      <!-- Peptide A -->
      <div class="rounded-xl border border-white/10 bg-gradient-to-br from-[var(--primary)]/10 to-transparent p-6 backdrop-blur-sm">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-2xl font-bold text-white">{peptideA.name}</h2>
          <EvidenceBadge strength={peptideA.evidenceStrength} />
        </div>
        <a
          href={`/peptides/${peptideA.slug}`}
          class="inline-flex items-center text-primary hover:text-[var(--accent)] hover:underline text-sm font-medium transition-colors"
        >
          View full dossier
          <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>

      <!-- Peptide B -->
      <div class="rounded-xl border border-white/10 bg-gradient-to-br from-cyan-500/10 to-transparent p-6 backdrop-blur-sm">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-2xl font-bold text-white">{peptideB.name}</h2>
          <EvidenceBadge strength={peptideB.evidenceStrength} />
        </div>
        <a
          href={`/peptides/${peptideB.slug}`}
          class="inline-flex items-center text-primary hover:text-[var(--accent)] hover:underline text-sm font-medium transition-colors"
        >
          View full dossier
          <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </div>

    <!-- Main comparison content -->
    <div class="prose prose-invert prose-lg max-w-none">
      <slot />
    </div>

    <!-- Footer links -->
    <div class="mt-12 pt-8 border-t border-white/10">
      <h3 class="font-semibold text-white mb-4">View Full Dossiers</h3>
      <div class="flex flex-wrap gap-4">
        <a
          href={`/peptides/${peptideA.slug}`}
          class="inline-flex items-center rounded-lg border border-[var(--primary)]/30 bg-[var(--primary)]/10 px-4 py-2 text-sm font-medium text-white hover:bg-[var(--primary)]/20 transition-colors"
        >
          {peptideA.name} Evidence Dossier
          <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
        <a
          href={`/peptides/${peptideB.slug}`}
          class="inline-flex items-center rounded-lg border border-[var(--primary)]/30 bg-[var(--primary)]/10 px-4 py-2 text-sm font-medium text-white hover:bg-[var(--primary)]/20 transition-colors"
        >
          {peptideB.name} Evidence Dossier
          <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </div>

    <!-- Newsletter CTA -->
    <div class="mt-12">
      <NewsletterForm
        variant="card"
        heading="Stay Updated on Peptide Comparisons"
        description="Get notified when we publish new comparison dossiers and evidence reviews."
      />
    </div>

    <!-- Disclaimer -->
    <div class="mt-8 rounded-xl border border-amber-500/30 bg-amber-500/10 p-6 backdrop-blur-sm">
      <p class="text-amber-200 text-sm">
        <strong class="text-amber-400">Disclaimer:</strong> This comparison is for educational purposes only and does not constitute medical advice. Individual responses to medications vary. Always consult a qualified healthcare provider before making treatment decisions.
      </p>
    </div>
  </article>
</BaseLayout>
