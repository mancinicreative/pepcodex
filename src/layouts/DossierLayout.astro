---
import { getCollection } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';
import BaseLayout from './BaseLayout.astro';
import ArticleSchema from '../components/SEO/ArticleSchema.astro';
import BreadcrumbSchema from '../components/SEO/BreadcrumbSchema.astro';
import FAQSchema from '../components/SEO/FAQSchema.astro';
import DrugSchema from '../components/SEO/DrugSchema.astro';
import RelatedEntities from '../components/RelatedEntities.astro';
import PeptideCard from '../components/PeptideCard.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import SafetyBanner from '../components/SafetyBanner.astro';
import OverviewSection from '../components/OverviewSection.astro';
import EvidenceChain from '../components/EvidenceChain.astro';
import InteractionMatrix from '../components/InteractionMatrix.astro';
import Timeline from '../components/Timeline.astro';
import QualityChecklist from '../components/QualityChecklist.astro';
import RatingCard from '../components/RatingCard.astro';
import Vial from '../components/Vial.astro';
import TrialTable from '../components/TrialTable.astro';
import SectionAside from '../components/SectionAside.astro';
import MechanismPathways from '../components/MechanismPathways.astro';

// Type definitions for peptide interactions
interface Interaction {
  peptide: string;
  type: 'synergistic' | 'compatible' | 'caution' | 'avoid';
  description: string;
  source?: string;
}

// Type definitions for new schemas
interface AminoAcid {
  code: string;
  name: string;
  position: number;
  property: 'hydrophobic' | 'polar' | 'positive' | 'negative' | 'modified';
}

interface MolecularInfo {
  weight: string;
  chainLength: number;
  type: string;
  sequence: string;
  aminoAcids: AminoAcid[];
  cas?: string;
  halfLife?: string;
  routes?: string;
  isoelectricPoint?: string;
}

interface AnecdotalReports {
  positive: string[];
  negative: string[];
  communityNotes?: string;
}

interface KeyFinding {
  study: string;
  type: 'human-rct' | 'human-observational' | 'animal' | 'in-vitro' | 'meta-analysis' | 'review';
  finding: string;
  pmid?: string;
}

interface EvidenceChainedBenefit {
  mechanism: {
    action: string;
    confidence: 'established' | 'supported' | 'emerging';
    directStudies: number;
  };
  benefit: {
    claim: string;
    qualifier: 'may' | 'appears to' | 'suggested to' | 'shown to';
  };
  evidence: {
    level: 'high' | 'moderate' | 'low' | 'very-low';
    humanStudies: number;
    animalStudies: number;
    cellStudies: number;
    keyFindings: KeyFinding[];
  };
}

// Timeline entry for "What to Expect" section
interface TimelineEntry {
  period: string;
  effects: string;
  source?: string;
}

// Quality Checklist for evaluating peptide products
interface QualityChecklistData {
  goodSigns: string[];
  warningSigns: string[];
  badSigns: string[];
}

// FAQ item for schema markup
interface FAQItem {
  question: string;
  answer: string;
}

// Safety warnings for banner
interface SafetyInfo {
  keyWarnings?: string[];
  fdaStatus?: string;
  wadaStatus?: string;
}

interface Props {
  name: string;
  slug?: string;
  aliases: string[];
  category: string;
  anecdotalReports?: AnecdotalReports;
  limitations?: string[];
  mechanismPathways?: {
    name: string;
    label?: string;
    steps: string[];
    outcome?: string;
    outcomeSignal?: 'research' | 'compound' | 'primary' | 'neutral';
    netEffect?: string;
  }[];
  // Safety info for banner
  safetyInfo?: SafetyInfo;
  evidenceStrength: 'high' | 'moderate' | 'low' | 'very-low';
  lastUpdated: Date;
  summary: string;
  sources: {
    count: number;
    human: number;
    preclinical: number;
    openAccess: number;
  };
  comparators: string[];
  pharmacokinetics?: {
    halfLife?: string;
    bioavailability?: string;
    metabolism?: string;
  };
  relatedPeptides?: string[];
  // NEW: Molecular information for structure display
  molecularInfo?: MolecularInfo;
  // NEW: Evidence-chained benefits for detailed research breakdown
  evidenceChainedBenefits?: EvidenceChainedBenefit[];
  // NEW: Peptide interactions
  interactions?: Interaction[];
  // NEW: Timeline for "What to Expect" section
  timeline?: TimelineEntry[];
  // NEW: Quality checklist for product evaluation
  qualityChecklist?: QualityChecklistData;
  // NEW: FAQ items for schema markup (Phase 24)
  faqs?: FAQItem[];
  // Regulatory status
  regulatoryStatus?: {
    status: 'approved' | 'investigational' | 'compounding-restricted' | 'research-only';
    lastUpdated?: Date;
    notes?: string;
  };
  // NEW: Multi-dimension ratings (optional — backward compat with existing dossiers)
  ratings?: {
    researchDepth: number;
    globalCoverage: number;
    mechanismPlausibility: number;
    overall: number;
    lastReviewed: Date;
    reviewNotes?: string;
  };
  // NEW: two-axis scoring (rubric v2.4) — preferred when present
  scoring?: any;
  metaTitle?: string;
  metaDescription?: string;
}

const {
  name,
  slug: slugProp,
  aliases,
  category,
  anecdotalReports,
  limitations = [],
  mechanismPathways = [],
  evidenceStrength,
  lastUpdated,
  summary,
  sources,
  comparators,
  pharmacokinetics,
  relatedPeptides = [],
  molecularInfo,
  evidenceChainedBenefits,
  interactions = [],
  timeline,
  qualityChecklist,
  faqs = [],
  regulatoryStatus,
  ratings,
  scoring,
  metaTitle,
  metaDescription,
} = Astro.props;

const categoryLabels: Record<string, string> = {
  'metabolic': 'Metabolic',
  'repair-recovery': 'Repair & Recovery',
  'hormonal': 'Hormonal',
  'longevity': 'Longevity',
  'cognitive': 'Cognitive',
  'immune': 'Immune',
  'other': 'Other',
};

const evidenceConfig: Record<string, { dots: number; label: string; color: string }> = {
  'high': { dots: 4, label: 'High Evidence', color: 'var(--research)' },
  'moderate': { dots: 3, label: 'Moderate Evidence', color: 'var(--primary-c)' },
  'low': { dots: 2, label: 'Low Evidence', color: 'var(--compound)' },
  'very-low': { dots: 1, label: 'Very Low Evidence', color: 'var(--danger)' },
};

const currentEvidence = evidenceConfig[evidenceStrength];

const regulatoryConfig: Record<string, { label: string; color: string; bg: string; border: string }> = {
  'approved': { label: 'FDA Approved', color: 'text-[color:var(--research)]', bg: 'bg-[rgba(20,118,74,0.10)]', border: 'border-[rgba(20,118,74,0.30)]' },
  'investigational': { label: 'Investigational', color: 'text-[color:var(--primary-c)]', bg: 'bg-[color:var(--primary-soft)]', border: 'border-[rgba(11,81,127,0.28)]' },
  'compounding-restricted': { label: 'Compounding Restricted', color: 'text-[#9a6418]', bg: 'bg-[rgba(203,135,52,0.12)]', border: 'border-[rgba(203,135,52,0.32)]' },
  'research-only': { label: 'Research Only', color: 'text-[color:var(--ink-dim)]', bg: 'bg-[color:var(--paper-2)]', border: 'border-[color:var(--border-c)]' },
};
const regConfig = regulatoryStatus ? regulatoryConfig[regulatoryStatus.status] : null;

// Roman numeral for entry framing (hybrid editorial accent)
const catLabel = categoryLabels[category] || category;

// Load this peptide's registered clinical trials from its source pack (if one exists)
const dossierSlug = (Astro.props.slug as string) || name.toLowerCase().replace(/\s+/g, '-');
let peptideTrials: any[] = [];
try {
  const packPath = path.join(process.cwd(), 'data', 'source-packs', `${dossierSlug}.json`);
  if (fs.existsSync(packPath)) {
    const pack = JSON.parse(fs.readFileSync(packPath, 'utf-8'));
    peptideTrials = (pack.trials || []).map((t: any) => ({
      nctId: t.nctId || t.id || 'Unknown',
      title: t.title,
      status: t.status || 'unknown',
      phase: t.phase || 'N/A',
      conditions: t.conditions || [],
      interventions: t.interventions || [],
      enrollmentTarget: t.enrollmentTarget,
      startDate: t.startDate,
      completionDate: t.completionDate,
      peptide: name,
    }));
  }
} catch (e) { peptideTrials = []; }

const hasTrials = peptideTrials.length > 0;
const hasAnecdotal = Boolean(anecdotalReports && (((anecdotalReports.positive || []).length + (anecdotalReports.negative || []).length) > 0));
const hasLimitations = limitations.length > 0;

// Section navigation - CONSOLIDATED STRUCTURE
// Order: Overview (includes molecular) → Mechanism → Evidence → Timeline → Quality → Interactions → References
const allSections = [
  { id: 'overview', label: 'Overview', always: true },
  { id: 'mechanism-of-action', label: 'Mechanism', always: true },
  { id: 'evidence-chain', label: 'Evidence', requires: 'evidenceChainedBenefits' },
  { id: 'anecdotal', label: 'Community', requires: 'anecdotal' },
  { id: 'limitations', label: 'Critique', requires: 'limitations' },
  { id: 'trials', label: 'Trials', requires: 'trials' },
  { id: 'timeline', label: 'Timeline', requires: 'timeline' },
  { id: 'quality-checklist', label: 'Quality', requires: 'qualityChecklist' },
  { id: 'peptide-interactions', label: 'Interactions', requires: 'interactions' },
  { id: 'references', label: 'References', always: true },
];

// Filter sections based on available data and assign numbers
const dataAvailability: Record<string, boolean> = {
  timeline: Boolean(timeline && timeline.length > 0),
  evidenceChainedBenefits: Boolean(evidenceChainedBenefits && evidenceChainedBenefits.length > 0),
  interactions: Boolean(interactions && interactions.length > 0),
  qualityChecklist: Boolean(qualityChecklist),
  limitations: hasLimitations,
  trials: hasTrials,
  anecdotal: hasAnecdotal,
};

function toRomanNav(n: number): string {
  const map: [number, string][] = [[10,'X'],[9,'IX'],[5,'V'],[4,'IV'],[1,'I']];
  let r = ''; let x = n;
  for (const [v, s] of map) { while (x >= v) { r += s; x -= v; } }
  return r;
}

const sections = allSections
  .filter(section => section.always || (section.requires && dataAvailability[section.requires]))
  .map((section, index) => ({
    ...section,
    num: String(index + 1).padStart(2, '0'),
    roman: toRomanNav(index + 1),
  }));

// Roman-numeral lookup by section id (drives the specimen-sheet section asides)
const romanById = new Map(sections.map(s => [s.id, s.roman]));
// Methodology appendix sits after the numbered sections
const methodologyRoman = toRomanNav(sections.length + 1);

// Tags from category and evidence
const tags = [categoryLabels[category], currentEvidence.label, `${sources.count} Sources`];

// Build comparison lookup: find actual comparison slugs for this peptide
const allComparisons = await getCollection('comparisons');
const allPeptides = await getCollection('peptides');
const peptideNameMap = new Map(allPeptides.map(p => [p.slug, p.data.name]));
const currentSlug = name.toLowerCase().replace(/\s+/g, '-');

function findComparisonSlug(compSlug: string): string | null {
  // Check both orderings
  const optionA = `${currentSlug}-vs-${compSlug}`;
  const optionB = `${compSlug}-vs-${currentSlug}`;
  const match = allComparisons.find(c => c.slug === optionA || c.slug === optionB);
  return match ? match.slug : null;
}


// SEO: Breadcrumb data
const breadcrumbItems = [
  { name: 'Home', url: Astro.site?.toString() || 'https://www.pepcodex.com' },
  { name: 'Peptides', url: `${Astro.site || 'https://www.pepcodex.com'}peptides/` },
  { name: name, url: Astro.url.toString() }
];

// SEO: Article URL
const articleUrl = Astro.url.toString();

// === Editorial chrome (all derived from real data) ===
const drawerLetters: Record<string, string> = {
  'metabolic': 'A', 'repair-recovery': 'B', 'hormonal': 'C',
  'longevity': 'D', 'cognitive': 'E', 'immune': 'F', 'other': 'G',
};
const drawerLetter = drawerLetters[category] || '—';

// Stable entry number from alphabetical catalogue order
const sortedPeptides = [...allPeptides].sort((a, b) => a.data.name.localeCompare(b.data.name));
const entryNum = Math.max(1, sortedPeptides.findIndex(p => p.slug === currentSlug) + 1);
const totalEntries = allPeptides.length;

// Two-tone display name: trailing token containing a digit rendered in accent italic
let namePrefix = name;
let nameSuffix = '';
const _lastDash = name.lastIndexOf('-');
if (_lastDash > 0 && /\d/.test(name.slice(_lastDash + 1))) {
  namePrefix = name.slice(0, _lastDash + 1);
  nameSuffix = name.slice(_lastDash + 1);
}

// Verdict descriptor from real source mix
const _humanN = sources.human || 0;
const verdictLine = _humanN === 0
  ? 'Preclinical evidence only'
  : _humanN >= 3
    ? `${_humanN} human studies`
    : `Mostly preclinical · ${_humanN} human stud${_humanN === 1 ? 'y' : 'ies'}`;

// Last revised, formatted
const lastRevised = lastUpdated
  ? new Date(lastUpdated).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
  : null;

// Citation string for the Cite action
const citationText = `PepCodex. ${name}: Evidence Dossier. Retrieved ${new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}, from ${articleUrl}`;

// Connective tissue: how many comparisons actually exist for this peptide
const comparisonCount = comparators.filter(c => findComparisonSlug(c)).length;

// Verdict card evidence mix (real shares of the cited source base)
const preclinicalPct = sources.count ? Math.round((sources.preclinical / sources.count) * 100) : 0;
const clinicalPct = sources.count ? Math.round((sources.human / sources.count) * 100) : 0;
---

<BaseLayout title={metaTitle || name} description={metaDescription || summary}>
  <!-- Structured Data -->
  <ArticleSchema
    title={`${name}: Evidence Dossier`}
    description={summary}
    url={articleUrl}
    dateModified={lastUpdated}
  />
  <BreadcrumbSchema items={breadcrumbItems} />
  {faqs && faqs.length > 0 && <FAQSchema items={faqs} />}
  <DrugSchema
    name={name}
    alternateName={aliases}
    description={summary}
    drugClass={categoryLabels[category]}
    administrationRoute="Subcutaneous injection"
    legalStatus="Research use only - not FDA approved for human use"
    molecularWeight={molecularInfo?.weight}
    url={articleUrl}
  />

  <div class="max-w-7xl mx-auto pb-20">
    <!-- Breadcrumb + actions -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-3 mb-3">
      <nav class="flex items-center gap-2 text-[0.7rem] uppercase tracking-[0.12em]" style="font-family: var(--font-mono); color: var(--ink-dim);" aria-label="Breadcrumb">
        <a href="/peptides" class="hover:text-[color:var(--ink)] transition-colors">Catalogue</a>
        <span aria-hidden="true">/</span>
        <a href={`/category/${category}`} class="hover:text-[color:var(--ink)] transition-colors">{catLabel}</a>
        <span aria-hidden="true">/</span>
        <span style="color: var(--ink);">{name}</span>
      </nav>
      <div class="flex items-center gap-1 text-[0.64rem] uppercase tracking-[0.1em]" style="font-family: var(--font-mono);" data-citation={citationText}>
        <button type="button" class="dossier-action" data-action="cite" aria-label="Copy citation">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 8h10M7 12h6M3 5v14l4-3h14V5z"/></svg>
          <span>Cite</span>
        </button>
        <button type="button" class="dossier-action" data-action="share" aria-label="Copy link">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.6" y1="13.5" x2="15.4" y2="17.5"/><line x1="15.4" y1="6.5" x2="8.6" y2="10.5"/></svg>
          <span>Share</span>
        </button>
        <button type="button" class="dossier-action" data-action="save" aria-label="Save to reading list">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
          <span data-save-label>Save</span>
        </button>
      </div>
    </div>

    <!-- Status strip (real data only) -->
    <div class="flex flex-wrap items-center gap-x-5 gap-y-2 mb-10 pb-4 text-[0.66rem] uppercase tracking-[0.1em]" style="border-bottom: 1px solid var(--border-c); font-family: var(--font-mono); color: var(--ink-dim);">
      <span class="inline-flex items-center gap-1.5"><span class="signal-dot signal-dot--research"></span>Now reading</span>
      <span>Entry <span style="color: var(--ink);">{String(entryNum).padStart(3, '0')}</span> / {totalEntries}</span>
      {lastRevised && <span>Last revised <span style="color: var(--ink);">{lastRevised}</span></span>}
      <span><span style="color: var(--ink);">{sources.count}</span> sources</span>
      {comparisonCount > 0 && <a href="#compare" class="transition-colors hover:text-[color:var(--ink)]"><span style="color: var(--ink);">{comparisonCount}</span> comparisons</a>}
      <a href="/methodology" class="transition-colors hover:text-[color:var(--ink)] md:ml-auto">Methodology →</a>
    </div>

    <!-- Specimen sheet hero -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-12 mb-16">
      <!-- Left: identity -->
      <div class="lg:col-span-7">
        <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
          <span class="eyebrow" style="color: var(--ink-dim);">A specimen of the {catLabel} drawer</span>
          <span class="badge badge--primary">Drawer {drawerLetter} · {catLabel}</span>
        </div>

        <h1 class="font-serif text-6xl md:text-8xl leading-[0.95] tracking-[-0.02em]" style="color: var(--ink); font-weight: 500;">
          {namePrefix}{nameSuffix && <em style="color: var(--primary-c);">{nameSuffix}</em>}
        </h1>

        {/* Regulatory badge */}
        {regConfig && (
          <a href="/regulatory-tracker/" class:list={["inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md text-xs font-medium border mt-4 transition-opacity hover:opacity-80", regConfig.bg, regConfig.color, regConfig.border]} style="font-family: var(--font-mono);">
            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              {regulatoryStatus!.status === 'approved' ? (
                <><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></>
              ) : regulatoryStatus!.status === 'investigational' ? (
                <><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></>
              ) : (
                <><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></>
              )}
            </svg>
            {regConfig.label}
          </a>
        )}

        <!-- Summary as editorial descriptor -->
        <p class="mt-6 font-serif italic text-xl md:text-2xl leading-snug max-w-2xl" style="color: var(--ink-muted);">
          {summary}
        </p>

        <!-- Identifier line (mono) -->
        {aliases.length > 0 && (
          <p class="mt-5 text-sm" style="color: var(--ink-dim); font-family: var(--font-mono);">
            {aliases.join(' · ')}
          </p>
        )}
      </div>

      <!-- Right: verdict / evidence card -->
      <div class="lg:col-span-5">
        <div class="glass-card relative overflow-hidden p-6 h-full flex flex-col">
          <div class="absolute top-0 left-0 right-0 h-[3px]" style={`background: ${currentEvidence.color};`}></div>

          <div class="flex items-start justify-between">
            <span class="eyebrow">Research evidence</span>
            <Vial strength={evidenceStrength} size="lg" />
          </div>

          <!-- Verdict -->
          <div class="mt-3 flex items-center gap-3">
            <div class="flex gap-1.5">
              {[1, 2, 3, 4].map((n) => (
                <span class="w-2.5 h-2.5 rounded-full" style={`background: ${n <= currentEvidence.dots ? currentEvidence.color : 'var(--border-strong)'}`}></span>
              ))}
            </div>
            <span class="font-serif text-2xl" style="color: var(--ink); font-weight: 500;">{currentEvidence.label.replace(' Evidence', '')}</span>
          </div>
          <p class="mt-1.5 eyebrow" style="color: var(--ink-dim);">{verdictLine}</p>

          <!-- Evidence mix — real share of the cited source base -->
          <dl class="mt-6 space-y-3.5">
            {[
              { label: 'Preclinical', pct: preclinicalPct, color: 'var(--compound)' },
              { label: 'Clinical', pct: clinicalPct, color: 'var(--research)' },
            ].map((row) => (
              <div>
                <div class="flex items-center justify-between mb-1">
                  <dt class="eyebrow" style="font-size: 0.64rem;">{row.label}</dt>
                  <dd class="text-sm" style="color: var(--ink); font-family: var(--font-mono); font-weight: 500;">{row.pct}%</dd>
                </div>
                <div class="h-1.5 rounded-full overflow-hidden" style="background: var(--paper-2);">
                  <div class="h-full rounded-full" style={`width: ${Math.max(2, row.pct)}%; background: ${row.color};`}></div>
                </div>
              </div>
            ))}
          </dl>
          <p class="mt-3 eyebrow" style="color: var(--ink-dim); font-size: 0.62rem;">Based on {sources.count} cited sources</p>

          {(scoring || ratings) && (
            <div class="mt-5 pt-5" style="border-top: 1px solid var(--border-c);">
              <RatingCard scoring={scoring} ratings={ratings} />
            </div>
          )}

          <!-- Share button -->
          <button
            id="share-btn"
            class="btn btn-ink btn-md mt-6 w-full uppercase tracking-[0.1em] text-[0.72rem]"
            style="font-family: var(--font-mono);"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="18" cy="5" r="3"/>
              <circle cx="6" cy="12" r="3"/>
              <circle cx="18" cy="19" r="3"/>
              <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
              <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
            </svg>
            <span id="share-text">Share dossier</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Safety Banner -->
    <SafetyBanner
      peptideName={name}
      evidenceStrength={evidenceStrength}
      fdaStatus="Not FDA Approved"
      wadaStatus="WADA Prohibited"
    />

    <!-- Research Dossier — specimen-sheet sections -->
    <div class="dossier-sections">

      <!-- Overview -->
      <section id="overview" class="dossier-section">
        <SectionAside roman={romanById.get('overview')} eyebrow="Identification" title="Overview" note={`What is ${name}, and what does the research say?`} />
        <div class="dossier-body">
          <OverviewSection
            peptideName={name}
            summary={summary}
            aliases={aliases}
            category={category}
            molecularInfo={molecularInfo}
            evidenceStrength={evidenceStrength}
            hideHeader
          />
        </div>
      </section>

      <!-- Mechanism of action (MDX body) -->
      <section id="mechanism-of-action" class="dossier-section">
        <SectionAside roman={romanById.get('mechanism-of-action')} eyebrow="How it works" title="Mechanism of action" note="The proposed biological pathways — and how firmly each is established." />
        <div class="dossier-body prose prose-invert prose-lg max-w-none">
          <slot />
          {mechanismPathways && mechanismPathways.length > 0 && (
            <div class="mt-8">
              <MechanismPathways pathways={mechanismPathways} />
            </div>
          )}
        </div>
      </section>

      <!-- Evidence-chained benefits -->
      {evidenceChainedBenefits && evidenceChainedBenefits.length > 0 && (
        <section id="evidence-chain" class="dossier-section">
          <SectionAside roman={romanById.get('evidence-chain')} eyebrow="The literature" title="What the literature supports" note="Each claim traced from mechanism to the studies behind it." />
          <div class="dossier-body">
            <EvidenceChain benefits={evidenceChainedBenefits} peptideName={name} hideHeader />
          </div>
        </section>
      )}

      <!-- Community reports (anecdotal) -->
      {hasAnecdotal && (
        <section id="anecdotal" class="dossier-section">
          <SectionAside roman={romanById.get('anecdotal')} eyebrow="Outside the literature" title="Community reports" note="Unverified anecdote — not evidence, kept separate from the cited research." />
          <div class="dossier-body">
            <div class="grid md:grid-cols-2 gap-4">
              {anecdotalReports && anecdotalReports.positive && anecdotalReports.positive.length > 0 && (
                <div class="panel-inset p-5">
                  <p class="eyebrow mb-3" style="color: var(--research);">Reported positives</p>
                  <ul class="space-y-2.5">
                    {anecdotalReports.positive.map((item) => (
                      <li class="flex gap-2.5 text-sm" style="color: var(--ink-muted);">
                        <span class="signal-dot signal-dot--research mt-1.5 flex-none"></span>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
              {anecdotalReports && anecdotalReports.negative && anecdotalReports.negative.length > 0 && (
                <div class="panel-inset p-5">
                  <p class="eyebrow mb-3" style="color: var(--danger);">Reported negatives</p>
                  <ul class="space-y-2.5">
                    {anecdotalReports.negative.map((item) => (
                      <li class="flex gap-2.5 text-sm" style="color: var(--ink-muted);">
                        <span class="signal-dot signal-dot--danger mt-1.5 flex-none"></span>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
            </div>
            {anecdotalReports && anecdotalReports.communityNotes && (
              <p class="mt-5 font-serif italic text-lg leading-snug" style="color: var(--ink-muted);">“{anecdotalReports.communityNotes}”</p>
            )}
            <div class="mt-5 panel-inset p-4 flex items-start gap-3" style="border-left: 3px solid var(--compound);">
              <svg class="w-4 h-4 flex-none mt-0.5" style="color: #9a6418;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
              <p class="text-xs leading-relaxed" style="color: var(--ink-muted);">Self-reported, unverified accounts — not clinical evidence and no substitute for the cited research. Anecdotes are prone to selection bias and placebo effects.</p>
            </div>
          </div>
        </section>
      )}

      <!-- Where the case weakens (limitations) -->
      {hasLimitations && (
        <section id="limitations" class="dossier-section">
          <SectionAside roman={romanById.get('limitations')} eyebrow="Critique" title="Where the case weakens" note={`An honest accounting of the gaps in the evidence for ${name}.`} />
          <div class="dossier-body">
            <ol class="space-y-5">
              {limitations.map((lim, i) => (
                <li class="flex gap-4">
                  <span class="flex-none eyebrow pt-1" style="color: var(--compound); font-size: 0.72rem;">{String(i + 1).padStart(3, '0')}</span>
                  <p class="leading-relaxed" style="color: var(--ink);">{lim}</p>
                </li>
              ))}
            </ol>
          </div>
        </section>
      )}

      <!-- What is being studied now (clinical trials) -->
      {hasTrials && (
        <section id="trials" class="dossier-section">
          <SectionAside roman={romanById.get('trials')} eyebrow="Clinical trials" title="What is being studied now" note={`Registered human trials involving ${name}, from ClinicalTrials.gov.`} />
          <div class="dossier-body">
            <div class="glass-card overflow-hidden">
              <TrialTable trials={peptideTrials} />
            </div>
          </div>
        </section>
      )}

      <!-- Timeline of observations -->
      {timeline && timeline.length > 0 && (
        <section id="timeline" class="dossier-section">
          <SectionAside roman={romanById.get('timeline')} eyebrow="What to expect" title="Timeline of observations" note="Phases observed in published studies. Individual responses vary." />
          <div class="dossier-body">
            <Timeline timeline={timeline} peptideName={name} hideHeader />
          </div>
        </section>
      )}

      <!-- Quality checklist -->
      {qualityChecklist && (
        <section id="quality-checklist" class="dossier-section">
          <SectionAside roman={romanById.get('quality-checklist')} eyebrow="Sourcing" title="Quality checklist" note="Visual indicators for evaluating product quality." />
          <div class="dossier-body">
            <QualityChecklist checklist={qualityChecklist} peptideName={name} hideHeader />
          </div>
        </section>
      )}

      <!-- Peptide interactions -->
      {interactions && interactions.length > 0 && (
        <section id="peptide-interactions" class="dossier-section">
          <SectionAside roman={romanById.get('peptide-interactions')} eyebrow="Combinations" title="Interactions" note={`Known and theoretical interactions when combining ${name}.`} />
          <div class="dossier-body">
            <InteractionMatrix interactions={interactions} currentPeptide={name} hideHeader />
          </div>
        </section>
      )}

      <!-- References -->
      <section id="references" class="dossier-section">
        <SectionAside roman={romanById.get('references')} eyebrow="Sources" title="Cited works" note="Every factual claim traces back to a citation." />
        <div class="dossier-body">
                <div class="panel-inset p-6">
                  <div class="flex flex-wrap items-center gap-3 mb-6">
                    <span class="badge badge--success">{sources.count} Sources</span>
                    <span class="badge badge--primary">{sources.human} Human</span>
                    <span class="badge badge--warning">{sources.preclinical} Preclinical</span>
                  </div>

                  {evidenceChainedBenefits && evidenceChainedBenefits.length > 0 && (
                    <div class="space-y-4">
                      <h3 class="font-serif text-xl" style="color: var(--ink); font-weight: 500;">Key Studies Cited</h3>
                      <div class="grid gap-2">
                        {(() => {
                          // Collect unique studies from evidence chain
                          const studies = new Map();
                          evidenceChainedBenefits.forEach(benefit => {
                            benefit.evidence.keyFindings.forEach(finding => {
                              if (finding.pmid && !studies.has(finding.pmid)) {
                                studies.set(finding.pmid, {
                                  study: finding.study,
                                  type: finding.type,
                                  finding: finding.finding,
                                  pmid: finding.pmid
                                });
                              }
                            });
                          });
                          return Array.from(studies.values()).map(study => (
                            <a
                              href={`https://pubmed.ncbi.nlm.nih.gov/${study.pmid}/`}
                              target="_blank"
                              rel="noopener noreferrer"
                              class="flex items-center justify-between p-3 rounded-lg transition-all group"
                              style="background: var(--paper); border: 1px solid var(--border-c);"
                            >
                              <div class="flex items-center gap-3">
                                <span class="px-2 py-0.5 text-[10px] uppercase rounded" style={`font-family: var(--font-mono); ${
                                  study.type === 'human-rct' ? 'background: rgba(20,118,74,0.12); color: var(--research);' :
                                  study.type === 'meta-analysis' ? 'background: rgba(20,118,74,0.18); color: var(--research);' :
                                  study.type === 'human-observational' ? 'background: var(--primary-soft); color: var(--primary-c);' :
                                  study.type === 'review' ? 'background: var(--paper-2); color: var(--ink-muted);' :
                                  study.type === 'animal' ? 'background: rgba(203,135,52,0.14); color: #9a6418;' :
                                  'background: var(--paper-2); color: var(--ink-dim);'
                                }`}>
                                  {study.type === 'human-rct' ? 'RCT' :
                                   study.type === 'meta-analysis' ? 'Meta' :
                                   study.type === 'human-observational' ? 'Human' :
                                   study.type === 'review' ? 'Review' :
                                   study.type === 'animal' ? 'Animal' : 'In Vitro'}
                                </span>
                                <span class="text-sm font-medium" style="color: var(--ink);">{study.study}</span>
                              </div>
                              <div class="flex items-center gap-2 group-hover:text-[color:var(--primary-c)]" style="color: var(--ink-dim);">
                                <span class="text-xs">PMID:{study.pmid}</span>
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                </svg>
                              </div>
                            </a>
                          ));
                        })()}
                      </div>
                    </div>
                  )}

                  <p class="mt-6 text-sm" style="color: var(--ink-dim);">
                    Full reference list available on request. All citations link to PubMed for verification.
                  </p>
                </div>
        </div>
      </section>

      <!-- Methodology + disclaimer -->
      <section id="methodology-note" class="dossier-section">
        <SectionAside roman={methodologyRoman} eyebrow="How we rate" title="On reading this entry" note="How evidence strength is assessed across every entry." />
        <div class="dossier-body">
          <div class="panel-inset p-6">
            <p class="mb-4" style="color: var(--ink-muted);">
              This dossier synthesizes available evidence from peer-reviewed literature, regulatory documents, and clinical trial registries. Evidence strength ratings follow a modified GRADE approach.
            </p>
            <p style="color: var(--ink-muted);">
              For complete methodology details, see our <a href="/methodology" class="font-medium text-primary hover:underline">Methodology page</a>.
            </p>
          </div>

          <!-- Disclaimer -->
          <div class="mt-6 panel-inset p-6" style="border-left: 3px solid var(--compound);">
            <div class="flex gap-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg" style="background: rgba(203,135,52,0.15); color: #9a6418;">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
              </div>
              <div>
                <h4 class="eyebrow mb-1" style="color: #9a6418;">Important Disclaimer</h4>
                <p class="text-sm leading-relaxed" style="color: var(--ink-muted);">
                  This dossier is for <strong style="color: var(--ink);">educational purposes only</strong> and does not constitute medical advice. Always consult a qualified healthcare provider before making health decisions.
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>
    </div>

    <!-- Newsletter CTA -->
    <section class="mt-20">
      <NewsletterForm
        variant="full"
        heading="Get Research Alerts"
        description="New dossiers and major study summaries delivered to your inbox. Evidence-graded, citation-backed research you can trust."
      />
    </section>

    <!-- Compare Section -->
    {comparators.length > 0 && (
      <section id="compare" class="mt-20 scroll-mt-24">
        <div class="flex items-center justify-between pb-4 mb-8" style="border-bottom: 1px solid var(--border-c);">
          <h2 class="font-serif text-2xl" style="color: var(--ink); font-weight: 500;">Compare {name}</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {comparators.map(comp => {
            const comparisonSlug = findComparisonSlug(comp);
            const compName = peptideNameMap.get(comp) || comp.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
            return comparisonSlug ? (
              <a
                href={`/compare/${comparisonSlug}`}
                class="glass-card-hoverable p-5 flex items-center gap-4 group"
              >
                <div class="w-11 h-11 rounded-lg flex items-center justify-center transition-all group-hover:bg-[color:var(--primary-soft)]" style="background: var(--paper-2); border: 1px solid var(--border-c);">
                  <svg class="w-5 h-5 group-hover:text-primary transition-colors" style="color: var(--ink-dim);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M16 3h5v5M8 3H3v5M21 3L14 10M3 3l7 7M21 21l-7-7M3 21l7-7M16 21h5v-5M8 21H3v-5" />
                  </svg>
                </div>
                <div>
                  <div class="font-serif text-lg group-hover:text-primary transition-colors" style="color: var(--ink); font-weight: 500;">{name} vs {compName}</div>
                  <div class="text-sm" style="color: var(--ink-muted);">View comparison</div>
                </div>
              </a>
            ) : null;
          })}
        </div>
      </section>
    )}


    <!-- Related Peptides (same category) -->
    {(() => {
      const comparatorSlugs = new Set(comparators.map(c => c.toLowerCase().replace(/\s+/g, '-')));
      const related = allPeptides
        .filter(p => p.data.category === category && p.slug !== currentSlug && !comparatorSlugs.has(p.slug))
        .slice(0, 6);
      return related.length > 0 ? (
        <section class="mt-12">
          <div class="flex items-center justify-between pb-4 mb-8" style="border-bottom: 1px solid var(--border-c);">
            <h2 class="font-serif text-2xl" style="color: var(--ink); font-weight: 500;">Related Peptides</h2>
          </div>
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            {related.map(p => (
              <PeptideCard
                name={p.data.name}
                slug={p.slug}
                category={p.data.category}
                evidenceStrength={p.data.evidenceStrength}
                summary={p.data.summary}
                aliases={p.data.aliases}
              />
            ))}
          </div>
        </section>
      ) : null;
    })()}

    <!-- Related Content (Internal Linking) -->
    <RelatedEntities
      currentPeptide={name.toLowerCase().replace(/\s+/g, '-')}
      category={category}
      relatedPeptides={comparators.map(c => c.toLowerCase().replace(/\s+/g, '-'))}
    />
  </div>
</BaseLayout>

<style>
  /* Specimen-sheet two-column sections: 220px editorial margin + content */
  .dossier-sections {
    margin-top: 2.5rem;
  }

  .dossier-section {
    display: grid;
    gap: 1.5rem;
    padding-top: 2.5rem;
    margin-top: 2.5rem;
    border-top: 1px solid var(--border-c);
    scroll-margin-top: 6rem;
  }

  .dossier-section:first-child {
    border-top: none;
    margin-top: 0;
    padding-top: 0;
  }

  @media (min-width: 1024px) {
    .dossier-section {
      grid-template-columns: 220px minmax(0, 1fr);
      gap: 3rem;
    }
  }

  /* keep content from overflowing the grid track (tables, code blocks) */
  .dossier-body {
    min-width: 0;
  }

  .dossier-action {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 0.55rem;
    border-radius: 6px;
    color: var(--ink-dim);
    transition: color 0.15s, background 0.15s;
  }
  .dossier-action:hover { color: var(--ink); background: var(--paper-2); }
  .dossier-action.is-active { color: var(--primary-c); }
</style>

<script>
  // Share dossier button (verdict card)
  document.addEventListener('DOMContentLoaded', () => {
    // Share button functionality
    const shareBtn = document.getElementById('share-btn');
    const shareText = document.getElementById('share-text');

    if (shareBtn && shareText) {
      shareBtn.addEventListener('click', async () => {
        const url = window.location.href;
        const title = document.title;

        // Try native share API first (mobile)
        if (navigator.share) {
          try {
            await navigator.share({ title, url });
            return;
          } catch (err) {
            // User cancelled or share failed, fall back to clipboard
          }
        }

        // Fall back to clipboard copy
        try {
          await navigator.clipboard.writeText(url);
          shareText.textContent = 'Link Copied!';
          shareBtn.style.background = 'var(--research)';
          setTimeout(() => {
            shareText.textContent = 'Share dossier';
            shareBtn.style.background = '';
          }, 2000);
        } catch (err) {
          // Fallback for older browsers
          const textArea = document.createElement('textarea');
          textArea.value = url;
          document.body.appendChild(textArea);
          textArea.select();
          document.execCommand('copy');
          document.body.removeChild(textArea);
          shareText.textContent = 'Link Copied!';
          setTimeout(() => {
            shareText.textContent = 'Share Dossier';
          }, 2000);
        }
      });
    }
  });
</script>

<script>
  // Breadcrumb Cite / Share / Save actions
  document.addEventListener('DOMContentLoaded', () => {
    const group = document.querySelector('[data-citation]');
    const url = window.location.href;
    const saveKey = 'pepcodex-saved';

    function flash(btn: Element, msg: string) {
      const label = btn.querySelector('span');
      if (!label) return;
      const original = label.textContent;
      label.textContent = msg;
      btn.classList.add('is-active');
      setTimeout(() => { label.textContent = original; btn.classList.remove('is-active'); }, 1800);
    }

    async function copy(text: string) {
      try { await navigator.clipboard.writeText(text); return true; }
      catch { return false; }
    }

    // Reflect saved state on load
    const saveBtn = document.querySelector('[data-action="save"]');
    const saveLabel = document.querySelector('[data-save-label]');
    function getSaved(): string[] {
      try { return JSON.parse(localStorage.getItem(saveKey) || '[]'); } catch { return []; }
    }
    if (saveBtn && saveLabel) {
      if (getSaved().includes(url)) { saveLabel.textContent = 'Saved'; saveBtn.classList.add('is-active'); }
    }

    document.querySelectorAll('.dossier-action').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const action = btn.getAttribute('data-action');
        if (action === 'cite') {
          const citation = group?.getAttribute('data-citation') || url;
          if (await copy(citation)) flash(btn, 'Copied');
        } else if (action === 'share') {
          if ((navigator as any).share) {
            try { await (navigator as any).share({ title: document.title, url }); return; } catch {}
          }
          if (await copy(url)) flash(btn, 'Copied');
        } else if (action === 'save') {
          const saved = getSaved();
          const idx = saved.indexOf(url);
          if (idx >= 0) { saved.splice(idx, 1); if (saveLabel) saveLabel.textContent = 'Save'; btn.classList.remove('is-active'); }
          else { saved.push(url); if (saveLabel) saveLabel.textContent = 'Saved'; btn.classList.add('is-active'); }
          localStorage.setItem(saveKey, JSON.stringify(saved));
        }
      });
    });
  });
</script>
