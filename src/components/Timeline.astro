---
/**
 * Timeline.astro - "What to Expect" horizontal phase cards based on study observations.
 * All data is based on published research, not anecdotal reports.
 */
import { resolveCitation } from '../utils/citation';

interface TimelineEntry {
  period: string;           // "Week 1-2"
  effects: string;          // "Based on study observations..."
  source?: string;          // PMID reference
}

interface Props {
  timeline: TimelineEntry[];
  peptideName: string;
  hideHeader?: boolean;
}

const { timeline, peptideName, hideHeader = false } = Astro.props;
if (!timeline || timeline.length === 0) {
  return null;
}
const cols = Math.min(timeline.length, 4);
// Literal map so Tailwind's content scanner emits these classes
const gridLgClass = ({ 1: 'lg:grid-cols-1', 2: 'lg:grid-cols-2', 3: 'lg:grid-cols-3', 4: 'lg:grid-cols-4' } as Record<number, string>)[cols] || 'lg:grid-cols-4';
---

<section class="timeline-section">
  {!hideHeader && (
    <div class="mb-8">
      <p class="eyebrow" style="color: var(--ink-dim);">What to expect</p>
      <h3 class="text-3xl tracking-tight mt-1" style="font-family: var(--font-serif); font-weight: 500; color: var(--ink);">
        Timeline of observations
      </h3>
      <p class="mt-1 text-[color:var(--ink-muted)] text-sm">
        Phases observed in published studies on {peptideName}. Individual responses vary.
      </p>
    </div>
  )}

  <!-- Horizontal phase cards -->
  <div class={`grid grid-cols-1 sm:grid-cols-2 gap-4 ${gridLgClass}`}>
    {timeline.map((entry, i) => (
      <div class="glass-card relative overflow-hidden p-5 flex flex-col" data-timeline-entry>
        <div class="absolute top-0 left-0 right-0 h-[2px]" style="background: var(--primary-c); opacity: 0.5;"></div>
        <div class="flex items-center justify-between mb-3">
          <span class="eyebrow" style="color: var(--primary-c); font-size: 0.6rem;">Phase {String(i + 1).padStart(2, '0')}</span>
          <span class="flex h-6 w-6 items-center justify-center rounded-full text-[0.7rem]" style="background: var(--primary-soft); color: var(--primary-c); font-family: var(--font-mono);">{i + 1}</span>
        </div>
        <div class="font-serif text-xl leading-tight mb-2" style="color: var(--ink); font-weight: 500;">{entry.period}</div>
        <p class="text-sm leading-relaxed flex-grow" style="color: var(--ink-muted);">{entry.effects}</p>
        {(() => { const cite = resolveCitation(entry.source); return cite.href && (
          <a
            href={cite.href}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-4 inline-flex items-center gap-1.5 eyebrow transition-colors hover:text-[color:var(--primary-c)]"
            style="color: var(--ink-dim); font-size: 0.6rem;"
            title={cite.kind === 'nct' ? 'View trial on ClinicalTrials.gov' : 'View study on PubMed'}
          >
            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"></path>
              <polyline points="14,2 14,8 20,8"></polyline>
            </svg>
            {cite.label}
          </a>
        ); })()}
      </div>
    ))}
  </div>

  <!-- Disclaimer -->
  <div class="mt-8 p-4 rounded-xl bg-[rgba(203,135,52,0.12)] border border-[rgba(203,135,52,0.32)]">
    <div class="flex gap-3">
      <div class="flex-shrink-0 w-8 h-8 rounded-lg bg-[rgba(203,135,52,0.18)] flex items-center justify-center">
        <svg class="w-4 h-4 text-[#9a6418]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
          <line x1="12" y1="9" x2="12" y2="13"></line>
          <line x1="12" y1="17" x2="12.01" y2="17"></line>
        </svg>
      </div>
      <div>
        <p class="text-[#9a6418] text-sm font-medium mb-1">Research-based observations</p>
        <p class="text-[color:var(--ink-muted)] text-xs leading-relaxed">
          This timeline reflects observations from published clinical and preclinical studies.
          Individual responses may vary significantly. This is not a guarantee of effects or a dosing schedule.
          Consult qualified healthcare providers for personalized guidance.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .timeline-section [data-timeline-entry] {
    opacity: 0;
    transform: translateY(8px);
    animation: timeline-fade-in 0.45s ease-out forwards;
  }
  .timeline-section [data-timeline-entry]:nth-child(1) { animation-delay: 0.05s; }
  .timeline-section [data-timeline-entry]:nth-child(2) { animation-delay: 0.12s; }
  .timeline-section [data-timeline-entry]:nth-child(3) { animation-delay: 0.19s; }
  .timeline-section [data-timeline-entry]:nth-child(4) { animation-delay: 0.26s; }
  .timeline-section [data-timeline-entry]:nth-child(5) { animation-delay: 0.33s; }
  .timeline-section [data-timeline-entry]:nth-child(6) { animation-delay: 0.40s; }
  @keyframes timeline-fade-in {
    to { opacity: 1; transform: translateY(0); }
  }
</style>
