---
import HubLayout from '../../layouts/HubLayout.astro';
import TrialTable from '../../components/TrialTable.astro';
import fs from 'node:fs';
import path from 'node:path';

// Read all source pack JSON files to extract trials
interface SourcePackTrial {
  id?: string;
  nctId?: string;
  title: string;
  status?: string;
  phase?: string;
  conditions?: string[];
  interventions?: string[];
  enrollmentTarget?: number;
  startDate?: string;
  completionDate?: string;
}

interface SourcePack {
  peptide: string | {
    name: string;
    aliases?: string[];
    category: string;
  };
  trials?: SourcePackTrial[];
}

interface Trial {
  nctId: string;
  title: string;
  status: string;
  phase: string;
  conditions: string[];
  interventions: string[];
  enrollmentTarget?: number;
  startDate?: string;
  completionDate?: string;
  peptide: string;
}

// Get the source-packs directory path
const sourcePacksDir = path.join(process.cwd(), 'data', 'source-packs');

// Read all JSON files from source-packs directory
let allTrials: Trial[] = [];

try {
  const files = fs.readdirSync(sourcePacksDir);

  for (const file of files) {
    if (file.endsWith('.json')) {
      const filePath = path.join(sourcePacksDir, file);
      const content = fs.readFileSync(filePath, 'utf-8');
      const sourcePack: SourcePack = JSON.parse(content);

      if (sourcePack.trials && sourcePack.trials.length > 0) {
        // Handle peptide being either string or object
        const peptideName = typeof sourcePack.peptide === 'string'
          ? sourcePack.peptide
          : sourcePack.peptide.name;
        const trialsWithPeptide = sourcePack.trials.map(trial => ({
          nctId: trial.nctId || trial.id || 'Unknown',
          title: trial.title,
          status: trial.status || 'unknown',
          phase: trial.phase || 'N/A',
          conditions: trial.conditions || [],
          interventions: trial.interventions || [],
          enrollmentTarget: trial.enrollmentTarget,
          startDate: trial.startDate,
          completionDate: trial.completionDate,
          peptide: peptideName
        }));
        allTrials.push(...trialsWithPeptide);
      }
    }
  }
} catch (error) {
  console.error('Error reading source packs:', error);
}

// Sort by status (active first), then by completion date
const statusOrder: Record<string, number> = {
  'active': 0,
  'recruiting': 1,
  'not yet recruiting': 2,
  'completed': 3,
  'terminated': 4,
  'withdrawn': 5,
  'suspended': 6,
};

allTrials.sort((a, b) => {
  const statusA = statusOrder[(a.status || '').toLowerCase()] ?? 99;
  const statusB = statusOrder[(b.status || '').toLowerCase()] ?? 99;
  if (statusA !== statusB) return statusA - statusB;

  // Then sort by completion date
  const dateA = a.completionDate ? new Date(a.completionDate).getTime() : Infinity;
  const dateB = b.completionDate ? new Date(b.completionDate).getTime() : Infinity;
  return dateA - dateB;
});

// Get unique values for filters
const uniqueStatuses = [...new Set(allTrials.map(t => (t.status || 'unknown').toLowerCase()))];
const uniquePhases = [...new Set(allTrials.map(t => t.phase || 'N/A'))].sort();
const uniquePeptides = [...new Set(allTrials.map(t => t.peptide))].sort();

// Count by status for stats
const activeCount = allTrials.filter(t => (t.status || '').toLowerCase() === 'active' || (t.status || '').toLowerCase() === 'recruiting').length;
const completedCount = allTrials.filter(t => (t.status || '').toLowerCase() === 'completed').length;
---

<HubLayout
  title="Clinical Trial Tracker"
  description="Track ongoing and completed clinical trials for peptides. Filter by phase, status, and compound."
>
  <!-- Stats overview -->
  <div class="mb-8 grid grid-cols-2 gap-4 sm:grid-cols-4">
    <div class="rounded-xl border border-white/10 bg-gradient-to-br from-[var(--primary)]/10 to-transparent p-4 backdrop-blur-sm">
      <div class="text-2xl font-bold text-white">{allTrials.length}</div>
      <div class="text-sm text-white/70">Total Trials</div>
    </div>
    <div class="rounded-xl border border-emerald-500/20 bg-emerald-500/10 p-4 backdrop-blur-sm">
      <div class="text-2xl font-bold text-emerald-400">{activeCount}</div>
      <div class="text-sm text-white/70">Active/Recruiting</div>
    </div>
    <div class="rounded-xl border border-blue-500/20 bg-blue-500/10 p-4 backdrop-blur-sm">
      <div class="text-2xl font-bold text-blue-400">{completedCount}</div>
      <div class="text-sm text-white/70">Completed</div>
    </div>
    <div class="rounded-xl border border-white/10 bg-white/5 p-4 backdrop-blur-sm">
      <div class="text-2xl font-bold text-white">{uniquePeptides.length}</div>
      <div class="text-sm text-white/70">Peptides Tracked</div>
    </div>
  </div>

  <!-- Filters -->
  <div class="mb-6 flex flex-wrap items-center gap-4">
    <!-- Status filter -->
    <div class="flex items-center gap-2">
      <label for="filter-status" class="text-sm font-medium text-white/70">Status:</label>
      <select
        id="filter-status"
        class="filter-select rounded-lg bg-white/10 border border-white/20 px-3 py-2 text-sm text-white focus:outline-none focus:ring-2 focus:ring-[var(--primary)] focus:border-transparent cursor-pointer"
      >
        <option value="all">All Statuses</option>
        {uniqueStatuses.map((status) => (
          <option value={status}>{status.charAt(0).toUpperCase() + status.slice(1)}</option>
        ))}
      </select>
    </div>

    <!-- Phase filter -->
    <div class="flex items-center gap-2">
      <label for="filter-phase" class="text-sm font-medium text-white/70">Phase:</label>
      <select
        id="filter-phase"
        class="filter-select rounded-lg bg-white/10 border border-white/20 px-3 py-2 text-sm text-white focus:outline-none focus:ring-2 focus:ring-[var(--primary)] focus:border-transparent cursor-pointer"
      >
        <option value="all">All Phases</option>
        {uniquePhases.map((phase) => (
          <option value={phase}>{phase}</option>
        ))}
      </select>
    </div>

    <!-- Peptide filter -->
    <div class="flex items-center gap-2">
      <label for="filter-peptide" class="text-sm font-medium text-white/70">Peptide:</label>
      <select
        id="filter-peptide"
        class="filter-select rounded-lg bg-white/10 border border-white/20 px-3 py-2 text-sm text-white focus:outline-none focus:ring-2 focus:ring-[var(--primary)] focus:border-transparent cursor-pointer"
      >
        <option value="all">All Peptides</option>
        {uniquePeptides.map((peptide) => (
          <option value={peptide.toLowerCase()}>{peptide}</option>
        ))}
      </select>
    </div>

    <!-- Clear filters button -->
    <button
      id="clear-filters"
      class="text-sm font-medium text-white/50 hover:text-white transition-colors"
    >
      Clear filters
    </button>
  </div>

  <!-- Result count -->
  <p class="mb-4 text-sm text-white/70">
    Showing <span id="trial-count">{allTrials.length}</span> of {allTrials.length} trials
  </p>

  <!-- Trial table -->
  <div class="rounded-xl border border-white/10 bg-white/5 backdrop-blur-sm overflow-hidden">
    <TrialTable trials={allTrials} />
  </div>

  <!-- Empty state (hidden by default) -->
  <div id="empty-state" class="hidden py-16 text-center">
    <svg class="mx-auto h-12 w-12 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <p class="mt-4 text-lg text-white/60">No trials match your filters.</p>
    <button
      id="clear-filters-empty"
      class="mt-4 text-sm font-medium text-[var(--primary)] hover:text-[var(--accent)] transition-colors"
    >
      Clear all filters
    </button>
  </div>

  <!-- Data source note -->
  <div class="mt-8 rounded-xl border border-white/10 bg-gradient-to-r from-[var(--primary)]/5 to-transparent p-4 backdrop-blur-sm">
    <p class="text-sm text-white/70">
      <strong class="text-white">Data Source:</strong> Trial information is sourced from
      <a href="https://clinicaltrials.gov" target="_blank" rel="noopener noreferrer" class="text-[var(--primary)] hover:text-[var(--accent)] hover:underline transition-colors">ClinicalTrials.gov</a>
      and our curated source packs. Click any NCT ID to view the full trial record.
    </p>
  </div>
</HubLayout>

<script>
  const statusSelect = document.getElementById('filter-status') as HTMLSelectElement;
  const phaseSelect = document.getElementById('filter-phase') as HTMLSelectElement;
  const peptideSelect = document.getElementById('filter-peptide') as HTMLSelectElement;
  const trialRows = document.querySelectorAll('.trial-row');
  const trialCards = document.querySelectorAll('.trial-card');
  const trialCount = document.getElementById('trial-count');
  const emptyState = document.getElementById('empty-state');
  const tableContainer = document.querySelector('.rounded-xl.border');

  let activeFilters: Record<string, string> = {
    status: 'all',
    phase: 'all',
    peptide: 'all',
  };

  function applyFilters() {
    let visibleCount = 0;

    // Filter both rows and cards
    const allElements = [...trialRows, ...trialCards];

    allElements.forEach((item) => {
      const el = item as HTMLElement;
      const status = el.dataset.status;
      const phase = el.dataset.phase;
      const peptide = el.dataset.peptide;

      const matchesStatus = activeFilters.status === 'all' || status === activeFilters.status;
      const matchesPhase = activeFilters.phase === 'all' || phase === activeFilters.phase;
      const matchesPeptide = activeFilters.peptide === 'all' || peptide === activeFilters.peptide;

      if (matchesStatus && matchesPhase && matchesPeptide) {
        el.classList.remove('hidden');
        // Only count unique items (avoid double counting row + card)
        if (el.classList.contains('trial-row')) {
          visibleCount++;
        }
      } else {
        el.classList.add('hidden');
      }
    });

    // If only cards visible (mobile), count those instead
    if (visibleCount === 0) {
      trialCards.forEach((card) => {
        if (!card.classList.contains('hidden')) {
          visibleCount++;
        }
      });
    }

    // Update count
    if (trialCount) trialCount.textContent = String(visibleCount);

    // Show/hide empty state
    if (visibleCount === 0) {
      emptyState?.classList.remove('hidden');
      tableContainer?.classList.add('hidden');
    } else {
      emptyState?.classList.add('hidden');
      tableContainer?.classList.remove('hidden');
    }
  }

  // Add event listeners to select dropdowns
  statusSelect?.addEventListener('change', () => {
    activeFilters.status = statusSelect.value;
    applyFilters();
  });

  phaseSelect?.addEventListener('change', () => {
    activeFilters.phase = phaseSelect.value;
    applyFilters();
  });

  peptideSelect?.addEventListener('change', () => {
    activeFilters.peptide = peptideSelect.value;
    applyFilters();
  });

  // Clear filters function
  function clearAllFilters() {
    activeFilters = { status: 'all', phase: 'all', peptide: 'all' };
    if (statusSelect) statusSelect.value = 'all';
    if (phaseSelect) phaseSelect.value = 'all';
    if (peptideSelect) peptideSelect.value = 'all';
    applyFilters();
  }

  // Clear filters buttons (main and empty state)
  document.getElementById('clear-filters')?.addEventListener('click', clearAllFilters);
  document.getElementById('clear-filters-empty')?.addEventListener('click', clearAllFilters);
</script>

<style>
  /* Style select dropdown options for dark theme */
  .filter-select option {
    background-color: hsl(230 45% 8%);
    color: white;
  }
</style>
