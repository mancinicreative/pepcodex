---
/**
 * QualityChecklist.astro - Traffic light styled quality evaluation checklist
 * Helps researchers evaluate peptide product quality with visual indicators
 * Green = good signs, Yellow = warning signs, Red = bad signs
 */

interface QualityChecklistData {
  goodSigns: string[];
  warningSigns: string[];
  badSigns: string[];
}

interface Props {
  checklist: QualityChecklistData;
  peptideName: string;
}

const { checklist, peptideName } = Astro.props;

// Don't render if no checklist data
if (!checklist) {
  return null;
}

const { goodSigns, warningSigns, badSigns } = checklist;
---

<section class="quality-checklist-section my-12">
  <div class="space-y-2 mb-8">
    <h3 class="text-2xl font-bold text-white tracking-tight flex items-center gap-3" style="font-family: var(--font-display);">
      <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-emerald-500/20 to-green-500/20 border border-emerald-400/30 flex items-center justify-center">
        <svg class="w-5 h-5 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 11l3 3L22 4"></path>
          <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path>
        </svg>
      </div>
      Quality Checklist
    </h3>
    <p class="text-white/60 text-sm ml-13 pl-0.5">
      Visual indicators to help evaluate {peptideName} product quality
    </p>
  </div>

  <!-- Expandable Sections -->
  <div class="space-y-4">
    <!-- Good Signs (Green) -->
    {goodSigns && goodSigns.length > 0 && (
      <details class="quality-details group" open>
        <summary class="flex items-center gap-3 p-4 rounded-xl bg-emerald-500/10 border border-emerald-400/30 cursor-pointer hover:bg-emerald-500/15 transition-all duration-300 select-none">
          <div class="w-8 h-8 rounded-lg bg-emerald-500/20 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20,6 9,17 4,12"></polyline>
            </svg>
          </div>
          <div class="flex-1">
            <span class="font-bold text-emerald-300 text-base">Good Signs</span>
            <span class="text-emerald-400/60 text-sm ml-2">({goodSigns.length} indicators)</span>
          </div>
          <div class="w-6 h-6 rounded-full bg-emerald-500/20 flex items-center justify-center transition-transform duration-300 group-open:rotate-180">
            <svg class="w-4 h-4 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6,9 12,15 18,9"></polyline>
            </svg>
          </div>
        </summary>
        <div class="mt-3 pl-4 space-y-2">
          {goodSigns.map((sign) => (
            <div class="flex items-start gap-3 p-3 rounded-lg bg-white/[0.02] border border-white/5 hover:border-emerald-400/20 transition-colors">
              <div class="w-5 h-5 rounded-full bg-emerald-500/30 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-emerald-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                  <polyline points="20,6 9,17 4,12"></polyline>
                </svg>
              </div>
              <span class="text-white/80 text-[15px] leading-relaxed">{sign}</span>
            </div>
          ))}
        </div>
      </details>
    )}

    <!-- Warning Signs (Yellow/Amber) -->
    {warningSigns && warningSigns.length > 0 && (
      <details class="quality-details group">
        <summary class="flex items-center gap-3 p-4 rounded-xl bg-amber-500/10 border border-amber-400/30 cursor-pointer hover:bg-amber-500/15 transition-all duration-300 select-none">
          <div class="w-8 h-8 rounded-lg bg-amber-500/20 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-amber-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
              <line x1="12" y1="9" x2="12" y2="13"></line>
              <line x1="12" y1="17" x2="12.01" y2="17"></line>
            </svg>
          </div>
          <div class="flex-1">
            <span class="font-bold text-amber-300 text-base">Warning Signs</span>
            <span class="text-amber-400/60 text-sm ml-2">({warningSigns.length} indicators)</span>
          </div>
          <div class="w-6 h-6 rounded-full bg-amber-500/20 flex items-center justify-center transition-transform duration-300 group-open:rotate-180">
            <svg class="w-4 h-4 text-amber-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6,9 12,15 18,9"></polyline>
            </svg>
          </div>
        </summary>
        <div class="mt-3 pl-4 space-y-2">
          {warningSigns.map((sign) => (
            <div class="flex items-start gap-3 p-3 rounded-lg bg-white/[0.02] border border-white/5 hover:border-amber-400/20 transition-colors">
              <div class="w-5 h-5 rounded-full bg-amber-500/30 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-amber-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <line x1="12" y1="8" x2="12" y2="12"></line>
                  <line x1="12" y1="16" x2="12.01" y2="16"></line>
                </svg>
              </div>
              <span class="text-white/80 text-[15px] leading-relaxed">{sign}</span>
            </div>
          ))}
        </div>
      </details>
    )}

    <!-- Bad Signs (Red) -->
    {badSigns && badSigns.length > 0 && (
      <details class="quality-details group">
        <summary class="flex items-center gap-3 p-4 rounded-xl bg-red-500/10 border border-red-400/30 cursor-pointer hover:bg-red-500/15 transition-all duration-300 select-none">
          <div class="w-8 h-8 rounded-lg bg-red-500/20 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </div>
          <div class="flex-1">
            <span class="font-bold text-red-300 text-base">Bad Signs</span>
            <span class="text-red-400/60 text-sm ml-2">({badSigns.length} indicators)</span>
          </div>
          <div class="w-6 h-6 rounded-full bg-red-500/20 flex items-center justify-center transition-transform duration-300 group-open:rotate-180">
            <svg class="w-4 h-4 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6,9 12,15 18,9"></polyline>
            </svg>
          </div>
        </summary>
        <div class="mt-3 pl-4 space-y-2">
          {badSigns.map((sign) => (
            <div class="flex items-start gap-3 p-3 rounded-lg bg-white/[0.02] border border-white/5 hover:border-red-400/20 transition-colors">
              <div class="w-5 h-5 rounded-full bg-red-500/30 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                  <line x1="18" y1="6" x2="6" y2="18"></line>
                  <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
              </div>
              <span class="text-white/80 text-[15px] leading-relaxed">{sign}</span>
            </div>
          ))}
        </div>
      </details>
    )}
  </div>

  <!-- Traffic Light Legend -->
  <div class="mt-6 p-4 rounded-xl bg-white/[0.02] border border-white/10">
    <div class="flex flex-wrap items-center justify-center gap-6 text-sm">
      <div class="flex items-center gap-2">
        <div class="w-3 h-3 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.5)]"></div>
        <span class="text-white/60">Positive quality indicator</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="w-3 h-3 rounded-full bg-amber-500 shadow-[0_0_8px_rgba(245,158,11,0.5)]"></div>
        <span class="text-white/60">Requires evaluation</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="w-3 h-3 rounded-full bg-red-500 shadow-[0_0_8px_rgba(239,68,68,0.5)]"></div>
        <span class="text-white/60">Potential quality issue</span>
      </div>
    </div>
  </div>

  <!-- Disclaimer -->
  <div class="mt-6 p-4 rounded-xl bg-purple-500/5 border border-purple-400/20">
    <div class="flex gap-3">
      <div class="flex-shrink-0 w-8 h-8 rounded-lg bg-purple-500/10 flex items-center justify-center">
        <svg class="w-4 h-4 text-purple-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"></circle>
          <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
          <line x1="12" y1="17" x2="12.01" y2="17"></line>
        </svg>
      </div>
      <div>
        <p class="text-purple-200/90 text-sm font-medium mb-1">For Research Evaluation Only</p>
        <p class="text-white/60 text-xs leading-relaxed">
          These quality indicators are general guidelines based on typical peptide characteristics.
          Professional laboratory testing (HPLC, mass spectrometry) provides definitive quality verification.
          This checklist is for initial visual evaluation only.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .quality-details summary::-webkit-details-marker {
    display: none;
  }

  .quality-details summary::marker {
    display: none;
    content: '';
  }

  .quality-details[open] > summary {
    border-bottom-left-radius: 0.5rem;
    border-bottom-right-radius: 0.5rem;
  }

  /* Smooth animation for content */
  .quality-details > div {
    animation: quality-slide-down 0.3s ease-out;
  }

  @keyframes quality-slide-down {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Hover glow effect on individual items */
  .quality-details div:hover {
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.05);
  }
</style>
