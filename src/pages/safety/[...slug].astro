---
import { getCollection, getEntry } from 'astro:content';
import SafetyLayout from '../../layouts/SafetyLayout.astro';

export async function getStaticPaths() {
  const safety = await getCollection('safety');
  return safety.map((item) => ({
    params: { slug: item.slug },
    props: { safety: item },
  }));
}

// Support both static and SSR modes
let safety = Astro.props.safety;
if (!safety) {
  const { slug } = Astro.params;
  safety = await getEntry('safety', slug as string);
}

if (!safety) {
  return Astro.redirect('/404');
}

const { Content } = await safety.render();
---

<SafetyLayout
  title={safety.data.title}
  peptides={safety.data.peptides}
  lastUpdated={safety.data.lastUpdated}
  summary={safety.data.summary}
  sources={safety.data.sources}
>
  <Content />
</SafetyLayout>
