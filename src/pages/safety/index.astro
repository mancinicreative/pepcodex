---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const safetyPages = await getCollection('safety');

// Sort by title
const sortedSafetyPages = safetyPages.sort((a, b) =>
  a.data.title.localeCompare(b.data.title)
);
---

<BaseLayout
  title="Safety Profiles"
  description="Evidence-based safety information for peptides, including side effects, interactions, and regulatory status."
>
  <!-- Hero -->
  <div class="border-b border-[color:var(--border-c)]">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
      <span class="eyebrow">Safety</span>
      <h1 class="font-serif mt-4 text-4xl tracking-tight sm:text-5xl lg:text-6xl" style="color: var(--ink); font-weight: 500;">
        Safety Profiles
      </h1>
      <p class="mt-6 max-w-2xl text-xl leading-relaxed" style="color: var(--ink-muted);">
        Evidence-based safety information for peptides, including side effects, interactions, and regulatory status.
      </p>
    </div>
  </div>

  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Warning callout -->
    <div class="mb-8 rounded-xl p-6" style="border: 1px solid rgba(203,135,52,.3); background: rgba(203,135,52,.08);">
      <div class="flex gap-4">
        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl" style="background: rgba(203,135,52,.12); color: #9a6418;">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
        </div>
        <div>
          <h4 class="font-bold mb-1" style="color: #9a6418;">Important Notice</h4>
          <p class="text-sm leading-relaxed" style="color: var(--ink-muted);">
            This information is for <strong style="color: var(--ink);">educational purposes only</strong> and does not constitute medical advice. Always consult a qualified healthcare provider before making health decisions.
          </p>
        </div>
      </div>
    </div>

    <p class="mb-8" style="color: var(--ink-muted);">
      Showing <span class="font-bold" style="color: var(--ink);">{sortedSafetyPages.length}</span> safety profiles
    </p>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {sortedSafetyPages.map((safetyPage) => (
        <a
          href={`/safety/${safetyPage.slug}`}
          class="glass-card-interactive p-6 group"
        >
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-3">
                <div class="flex h-8 w-8 items-center justify-center rounded-lg" style="background: rgba(20,118,74,0.10); color: var(--research);">
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                  </svg>
                </div>
                <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-bold uppercase tracking-wider" style="color: var(--research); background: rgba(20,118,74,0.10); border: 1px solid rgba(20,118,74,0.28);">
                  Safety
                </span>
              </div>
              <h2 class="text-lg font-serif group-hover:text-[color:var(--primary-c)] transition-colors" style="color: var(--ink); font-weight: 500;">
                {safetyPage.data.title}
              </h2>
              <p class="mt-2 text-sm line-clamp-2" style="color: var(--ink-muted);">
                {safetyPage.data.summary}
              </p>
              {safetyPage.data.peptides.length > 0 && (
                <div class="mt-4 flex flex-wrap gap-1">
                  {safetyPage.data.peptides.slice(0, 3).map((peptide: string) => (
                    <span class="inline-block rounded-lg px-2 py-0.5 text-xs" style="background: var(--paper-2); border: 1px solid var(--border-c); color: var(--ink-muted);">
                      {peptide}
                    </span>
                  ))}
                  {safetyPage.data.peptides.length > 3 && (
                    <span class="inline-block rounded-lg px-2 py-0.5 text-xs" style="background: var(--paper-2); border: 1px solid var(--border-c); color: var(--ink-muted);">
                      +{safetyPage.data.peptides.length - 3} more
                    </span>
                  )}
                </div>
              )}
            </div>
            <div class="w-10 h-10 rounded-xl flex items-center justify-center transition-all flex-shrink-0" style="background: var(--paper-2); border: 1px solid var(--border-c);">
              <svg class="h-5 w-5 group-hover:text-primary group-hover:translate-x-0.5 transition-all" style="color: var(--ink-dim);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
