---
interface Source {
  id: string;
  title: string;
  authors?: string[];
  journal?: string;
  year: number;
  country?: string;
  studyType: string;
  keyFindings: string;
  access: 'open' | 'paywalled' | 'unknown';
  url?: string;
}

interface Props {
  sources: Source[];
  title?: string;
}

const { sources, title = 'Evidence Library' } = Astro.props;

// Access carries meaning: open = positive (research green), paywalled = caution (compound amber), unknown = neutral ink.
const accessBadge = {
  'open': { class: 'border', style: 'background: rgba(20,118,74,0.10); color: var(--research); border-color: rgba(20,118,74,0.30);', label: 'Open Access' },
  'paywalled': { class: 'border', style: 'background: rgba(203,135,52,0.12); color: #9a6418; border-color: rgba(203,135,52,0.32);', label: 'Paywalled' },
  'unknown': { class: 'border', style: 'background: var(--paper-2); color: var(--ink-muted); border-color: var(--border-c);', label: 'Unknown' },
};

// Study type is a category label, not a signal — render neutral ink on paper for all types.
const studyTypeStyle = 'background: var(--paper-2); color: var(--ink-muted); border-color: var(--border-c);';
---

<div class="my-8">
  <h2 id="evidence-library" class="text-2xl mb-4" style="font-family: var(--font-serif); font-weight: 500; color: var(--ink);">{title}</h2>

  <div class="overflow-x-auto rounded-lg border" style="border-color: var(--border-c); background: var(--paper);">
    <table class="min-w-full">
      <thead>
        <tr style="border-bottom: 1px solid var(--border-strong);">
          <th class="px-4 py-3 text-left text-xs uppercase" style="font-family: var(--font-mono); letter-spacing: .1em; color: var(--ink-muted);">Source</th>
          <th class="px-4 py-3 text-left text-xs uppercase" style="font-family: var(--font-mono); letter-spacing: .1em; color: var(--ink-muted);">Type</th>
          <th class="px-4 py-3 text-left text-xs uppercase" style="font-family: var(--font-mono); letter-spacing: .1em; color: var(--ink-muted);">Year</th>
          <th class="px-4 py-3 text-left text-xs uppercase" style="font-family: var(--font-mono); letter-spacing: .1em; color: var(--ink-muted);">Key Finding</th>
          <th class="px-4 py-3 text-left text-xs uppercase" style="font-family: var(--font-mono); letter-spacing: .1em; color: var(--ink-muted);">Access</th>
        </tr>
      </thead>
      <tbody>
        {sources.map((source) => (
          <tr class="citation-row transition-colors" style="border-top: 1px solid var(--border-c);">
            <td class="px-4 py-4">
              <div class="max-w-xs">
                {source.url ? (
                  <a
                    href={source.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-sm font-medium text-primary hover:underline transition-colors"
                  >
                    {source.title}
                  </a>
                ) : (
                  <span class="text-sm font-medium" style="color: var(--ink);">{source.title}</span>
                )}
                {source.journal && (
                  <div class="text-xs mt-1" style="color: var(--ink-muted);">{source.journal}</div>
                )}
                <div class="text-xs mt-0.5 font-mono" style="color: var(--ink-dim);">{source.id}</div>
              </div>
            </td>
            <td class="px-4 py-4">
              <span class="inline-flex rounded-full px-2 py-1 text-xs font-medium border" style={studyTypeStyle}>
                {source.studyType}
              </span>
            </td>
            <td class="px-4 py-4 text-sm" style="color: var(--ink-muted);">
              {source.year}
              {source.country && (
                <div class="text-xs" style="color: var(--ink-dim);">{source.country}</div>
              )}
            </td>
            <td class="px-4 py-4">
              <p class="text-sm max-w-md" style="color: var(--ink-muted);">{source.keyFindings}</p>
            </td>
            <td class="px-4 py-4">
              <span class={`inline-flex rounded-full px-2 py-1 text-xs font-medium ${accessBadge[source.access].class}`} style={accessBadge[source.access].style}>
                {accessBadge[source.access].label}
              </span>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <p class="mt-3 text-sm" style="color: var(--ink-muted);">
    Showing {sources.length} sources. Open access sources can be read freely; paywalled sources may require institutional access.
  </p>
</div>

<style>
  .citation-row:hover {
    background: var(--paper-2);
  }
</style>
