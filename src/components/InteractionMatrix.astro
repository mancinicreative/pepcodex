---
/**
 * InteractionMatrix.astro
 * Displays peptide interactions with color-coded badges
 * Types: synergistic (green), compatible (blue), caution (yellow), avoid (red)
 */

interface Interaction {
  peptide: string;
  type: 'synergistic' | 'compatible' | 'caution' | 'avoid';
  description: string;
  source?: string;
}

interface Props {
  interactions: Interaction[];
  currentPeptide: string;
  hideHeader?: boolean;
}

const { interactions, currentPeptide, hideHeader = false } = Astro.props;

// Sort interactions by type priority: synergistic > compatible > caution > avoid
const typePriority = { synergistic: 0, compatible: 1, caution: 2, avoid: 3 };
const sortedInteractions = [...interactions].sort((a, b) =>
  typePriority[a.type] - typePriority[b.type]
);

// Group interactions by type for organized display
const groupedInteractions = {
  synergistic: sortedInteractions.filter(i => i.type === 'synergistic'),
  compatible: sortedInteractions.filter(i => i.type === 'compatible'),
  caution: sortedInteractions.filter(i => i.type === 'caution'),
  avoid: sortedInteractions.filter(i => i.type === 'avoid'),
};

// Interaction types are inherently meaningful signals:
//   synergistic = positive (research green), compatible = neutral-affirmative (cobalt),
//   caution = caution (compound amber), avoid = negative (danger red).
// Styles are inline CSS strings (tints/borders/text in brand tokens) rather than Tailwind utilities.
const typeConfig = {
  synergistic: {
    label: 'Synergistic',
    description: 'May enhance effects when combined',
    bgStyle: 'background: rgba(20,118,74,0.10);',
    borderStyle: 'border-color: rgba(20,118,74,0.30);',
    textStyle: 'color: var(--research);',
    badgeStyle: 'background: rgba(20,118,74,0.10); color: var(--research); border-color: rgba(20,118,74,0.30);',
    dotStyle: 'background: var(--research);',
    icon: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>`,
  },
  compatible: {
    label: 'Compatible',
    description: 'Generally safe to combine based on known mechanisms',
    bgStyle: 'background: var(--primary-soft);',
    borderStyle: 'border-color: rgba(11,81,127,0.30);',
    textStyle: 'color: var(--primary-c);',
    badgeStyle: 'background: var(--primary-soft); color: var(--primary-c); border-color: rgba(11,81,127,0.30);',
    dotStyle: 'background: var(--primary-c);',
    icon: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg>`,
  },
  caution: {
    label: 'Caution',
    description: 'Potential interactions warrant careful consideration',
    bgStyle: 'background: rgba(203,135,52,0.12);',
    borderStyle: 'border-color: rgba(203,135,52,0.32);',
    textStyle: 'color: #9a6418;',
    badgeStyle: 'background: rgba(203,135,52,0.12); color: #9a6418; border-color: rgba(203,135,52,0.32);',
    dotStyle: 'background: var(--compound);',
    icon: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 9v4m0 4h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/></svg>`,
  },
  avoid: {
    label: 'Avoid',
    description: 'Known or theoretical contraindications',
    bgStyle: 'background: rgba(185,61,66,0.10);',
    borderStyle: 'border-color: rgba(185,61,66,0.28);',
    textStyle: 'color: var(--danger);',
    badgeStyle: 'background: rgba(185,61,66,0.10); color: var(--danger); border-color: rgba(185,61,66,0.28);',
    dotStyle: 'background: var(--danger);',
    icon: `<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12"/></svg>`,
  },
};

// Helper to format peptide slug to display name
function formatPeptideName(slug: string): string {
  return slug
    .split('-')
    .map(word => {
      // Handle special cases like "bpc", "ghk", "ghrp"
      if (['bpc', 'ghk', 'ghrp', 'cjc', 'mk', 'tb', 'pt', 'll', 'aod'].includes(word.toLowerCase())) {
        return word.toUpperCase();
      }
      // Handle roman numerals
      if (['ii', 'iii', 'iv'].includes(word.toLowerCase())) {
        return word.toUpperCase();
      }
      // Handle numbers
      if (/^\d+$/.test(word)) {
        return word;
      }
      // Capitalize first letter
      return word.charAt(0).toUpperCase() + word.slice(1);
    })
    .join('-');
}
---

{interactions.length > 0 && (
  <div>
    {!hideHeader && (
      <div class="mb-8">
        <p class="eyebrow" style="color: var(--ink-dim);">Interactions</p>
        <h3 class="text-3xl tracking-tight mt-1" style="font-family: var(--font-serif); font-weight: 500; color: var(--ink);">
          Peptide Interactions
        </h3>
        <p class="text-sm mt-1" style="color: var(--ink-muted);">
          Known and theoretical interactions when combining {currentPeptide} with other peptides. Based on published research and mechanistic considerations.
        </p>
      </div>
    )}

    <!-- Legend -->
    <div class="flex flex-wrap gap-3 mb-8">
      {Object.entries(typeConfig).map(([type, config]) => (
        <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg border" style={`${config.bgStyle} ${config.borderStyle}`}>
          <div class="w-2 h-2 rounded-full" style={config.dotStyle}></div>
          <span class="text-xs font-medium" style={config.textStyle}>{config.label}</span>
        </div>
      ))}
    </div>

    <!-- Interaction Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {sortedInteractions.map((interaction) => {
        const config = typeConfig[interaction.type];
        return (
          <div class="group relative rounded-xl border p-5 transition-all duration-300 hover:scale-[1.02]" style={`${config.bgStyle} ${config.borderStyle}`}>
            <!-- Header with peptide name and badge -->
            <div class="flex items-start justify-between gap-4 mb-3">
              <a
                href={`/peptides/${interaction.peptide}`}
                class="flex items-center gap-3 group/link"
              >
                <div class="w-10 h-10 rounded-lg border flex items-center justify-center group-hover/link:scale-110 transition-transform" style={`${config.bgStyle} ${config.borderStyle} ${config.textStyle}`}>
                  <Fragment set:html={config.icon} />
                </div>
                <div>
                  <h4 class="font-semibold group-hover/link:text-primary transition-colors" style="color: var(--ink);">
                    {formatPeptideName(interaction.peptide)}
                  </h4>
                  <span class="text-xs font-medium" style={config.textStyle}>
                    {config.label}
                  </span>
                </div>
              </a>

              <!-- Type badge -->
              <span class="shrink-0 px-3 py-1 rounded-full text-xs font-semibold border" style={config.badgeStyle}>
                {interaction.type.charAt(0).toUpperCase() + interaction.type.slice(1)}
              </span>
            </div>

            <!-- Description -->
            <p class="text-sm leading-relaxed mb-3" style="color: var(--ink-muted);">
              {interaction.description}
            </p>

            <!-- Source citation if available -->
            {interaction.source && (
              <div class="flex items-center gap-2 text-xs" style="color: var(--ink-dim);">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
                  <polyline points="14,2 14,8 20,8"/>
                </svg>
                <a
                  href={`https://pubmed.ncbi.nlm.nih.gov/${interaction.source}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:text-primary transition-colors"
                >
                  PMID: {interaction.source}
                </a>
              </div>
            )}

            <!-- Hover arrow indicator -->
            <div class="absolute bottom-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style={config.textStyle}>
                <path d="m9 18 6-6-6-6"/>
              </svg>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Disclaimer -->
    <div class="mt-8 rounded-lg border p-4" style="background: var(--paper-2); border-color: var(--border-c);">
      <div class="flex gap-3">
        <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg" style="background: var(--sand); color: var(--ink-muted);">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div>
          <p class="text-xs leading-relaxed" style="color: var(--ink-muted);">
            <strong style="color: var(--ink);">Research Note:</strong> Interaction data is based on published literature, mechanistic understanding, and theoretical considerations. Most peptide combinations lack direct clinical study. This information is for educational purposes only and does not constitute medical advice. Always consult qualified healthcare providers.
          </p>
        </div>
      </div>
    </div>
  </div>
)}
