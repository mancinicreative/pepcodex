---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

// Support both static and SSR modes
let post = Astro.props.post;
if (!post) {
  const { slug } = Astro.params;
  post = await getEntry('blog', slug as string);
}

if (!post) {
  return Astro.redirect('/404');
}

const { Content } = await post.render();
---

<BlogLayout
  title={post.data.title}
  publishDate={post.data.publishDate}
  lastUpdated={post.data.lastUpdated}
  author={post.data.author}
  category={post.data.category}
  excerpt={post.data.excerpt}
  tags={post.data.tags}
  relatedPeptides={post.data.relatedPeptides}
  relatedGlossary={post.data.relatedGlossary}
  sources={post.data.sources}
  evidenceLevel={post.data.evidenceLevel}
>
  <Content />
</BlogLayout>
