---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbSchema from '../../components/SEO/BreadcrumbSchema.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';

const allConditions = await getCollection('conditions');

// Sort alphabetically by condition name
const sortedConditions = allConditions.sort((a, b) =>
  a.data.conditionName.localeCompare(b.data.conditionName)
);

// Group by category
const categories = ['metabolic', 'repair-recovery', 'hormonal', 'cognitive', 'immune', 'longevity', 'other'] as const;

const conditionsByCategory = categories.reduce((acc, cat) => {
  acc[cat] = sortedConditions.filter(c => c.data.category === cat);
  return acc;
}, {} as Record<string, typeof allConditions>);

// Get all peptides to count how many are available for each condition
const allPeptides = await getCollection('peptides');

// Count peptides per condition
function countPeptidesForCondition(conditionSlug: string): number {
  return allPeptides.filter(p => {
    if (!p.data.conditions) return false;
    return p.data.conditions.some((c: { slug: string; name?: string }) =>
      c.slug === conditionSlug ||
      c.name?.toLowerCase().includes(conditionSlug.replace(/-/g, ' '))
    );
  }).length;
}

// Category display names and colors
const categoryConfig: Record<string, { name: string; color: string }> = {
  'metabolic': { name: 'Metabolic', color: 'var(--primary)' },
  'repair-recovery': { name: 'Repair & Recovery', color: 'var(--accent)' },
  'hormonal': { name: 'Hormonal', color: 'hsl(280 80% 60%)' },
  'cognitive': { name: 'Cognitive', color: 'hsl(200 80% 60%)' },
  'immune': { name: 'Immune', color: 'hsl(142 70% 45%)' },
  'longevity': { name: 'Longevity', color: 'hsl(45 90% 55%)' },
  'other': { name: 'Other', color: 'hsl(220 15% 60%)' },
};

const pageTitle = "Conditions & Health Goals | Peptide Research Overview";
const pageDescription = "Browse peptide research by condition or health goal. Evidence-based overviews of peptides studied for weight loss, healing, muscle growth, cognitive function, and more.";

const breadcrumbItems = [
  { name: 'Home', url: Astro.site?.toString() || 'https://pepcodex.com' },
  { name: 'Conditions', url: `${Astro.site || 'https://pepcodex.com'}conditions/` },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <BreadcrumbSchema items={breadcrumbItems} />

  <!-- Hero Section -->
  <div class="relative overflow-hidden border-b border-white/5">
    <div class="absolute inset-0 bg-gradient-to-br from-[var(--primary)]/10 via-transparent to-cyan-500/5"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-[var(--primary)]/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-cyan-500/10 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"></div>

    <div class="relative mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
      <nav class="flex items-center gap-2 text-sm text-white/60 mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="m9 18 6-6-6-6"/>
        </svg>
        <span class="text-white">Conditions</span>
      </nav>

      <h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl lg:text-6xl" style="font-family: var(--font-display);">
        Peptide Research by Condition
      </h1>
      <p class="mt-6 max-w-3xl text-xl text-white/80 leading-relaxed">
        Explore peptide research organized by health condition or goal. Each page summarizes the evidence landscape, lists studied peptides, and links to relevant research.
      </p>

      <div class="mt-8 flex items-center gap-4 text-sm text-white/60">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/>
            <rect x="9" y="3" width="6" height="4" rx="1"/>
            <path d="m9 12 2 2 4-4"/>
          </svg>
          <span>{sortedConditions.length} conditions</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-cyan-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"/>
            <path d="M8.5 2h7"/>
          </svg>
          <span>{allPeptides.length} peptides researched</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    {sortedConditions.length > 0 ? (
      <div class="space-y-12">
        {categories.map((cat) => {
          const conditions = conditionsByCategory[cat];
          if (conditions.length === 0) return null;

          const config = categoryConfig[cat];

          return (
            <section>
              <div class="flex items-center gap-3 mb-6">
                <span
                  class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider border"
                  style={`color: ${config.color}; background: ${config.color}15; border-color: ${config.color}30;`}
                >
                  {config.name}
                </span>
                <span class="text-sm text-white/50">
                  {conditions.length} condition{conditions.length !== 1 ? 's' : ''}
                </span>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                {conditions.map((condition) => {
                  const peptideCount = countPeptidesForCondition(condition.data.conditionSlug);

                  return (
                    <a
                      href={`/conditions/${condition.slug}`}
                      class="group glass-card-default p-6 hover:border-[var(--primary)]/50 transition-all"
                    >
                      <h3 class="font-bold text-white text-lg group-hover:text-primary transition-colors mb-2">
                        {condition.data.conditionName}
                      </h3>

                      <p class="text-sm text-white/60 line-clamp-2 mb-4">
                        {condition.data.description}
                      </p>

                      <div class="flex items-center justify-between">
                        <span class="text-xs text-white/40">
                          {peptideCount} peptide{peptideCount !== 1 ? 's' : ''} studied
                        </span>
                        <svg class="w-4 h-4 text-white/40 group-hover:text-primary transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="m9 18 6-6-6-6"/>
                        </svg>
                      </div>
                    </a>
                  );
                })}
              </div>
            </section>
          );
        })}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-white/60 text-lg">
          Condition hub pages are coming soon. Check back for research organized by health goal.
        </p>
        <a
          href="/peptides"
          class="inline-flex items-center gap-2 mt-4 text-primary hover:text-white transition-colors"
        >
          Browse all peptides
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="m9 18 6-6-6-6"/>
          </svg>
        </a>
      </div>
    )}

    <!-- Newsletter CTA -->
    <section class="mt-16">
      <NewsletterForm
        variant="compact"
        heading="Stay Updated on Peptide Research"
        description="Get evidence-based research summaries delivered to your inbox."
      />
    </section>
  </div>
</BaseLayout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
