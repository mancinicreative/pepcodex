---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';

interface Study {
  title: string;
  authors?: string;
  year: number;
  pmid?: string;
  studyType: 'human-rct' | 'human-observational' | 'animal' | 'in-vitro';
  dosesUsed: string;
  findings: string;
}

interface Props {
  title: string;
  description: string;
  peptides: string[];
  researchSummary: string;
  studies: Study[];
  mechanism: string;
  safetyNotes: string;
  disclaimer: string;
  lastUpdated: Date;
}

const { title, description, peptides, researchSummary, studies, mechanism, safetyNotes, disclaimer, lastUpdated } = Astro.props;

// Study type badge colors
const studyTypeBadges: Record<string, { bg: string; text: string; label: string }> = {
  'human-rct': { bg: 'bg-emerald-500/20', text: 'text-emerald-400', label: 'Human RCT' },
  'human-observational': { bg: 'bg-blue-500/20', text: 'text-blue-400', label: 'Human Observational' },
  'animal': { bg: 'bg-amber-500/20', text: 'text-amber-400', label: 'Animal Study' },
  'in-vitro': { bg: 'bg-purple-500/20', text: 'text-purple-400', label: 'In Vitro' },
};
---

<BaseLayout title={title} description={description}>
  <article class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <!-- Header -->
    <header class="mb-8 relative">
      <div class="absolute inset-0 bg-gradient-to-br from-[var(--primary)]/10 via-transparent to-transparent rounded-2xl -z-10"></div>
      <div class="p-6">
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span class="inline-flex items-center rounded-full bg-[var(--primary)]/20 px-3 py-1 text-xs font-medium text-primary border border-[var(--primary)]/30">
            <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Research Overview
          </span>
          <span class="inline-flex items-center rounded-full bg-white/10 px-3 py-1 text-xs font-medium text-white/70 border border-white/10">
            {studies.length} Studies Cited
          </span>
        </div>

        <h1 class="text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">
          {title}
        </h1>

        <p class="mt-4 text-xl text-white/80 leading-relaxed max-w-3xl">
          {description}
        </p>

        <p class="mt-4 text-sm text-white/70">
          Last updated: {lastUpdated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </p>
      </div>
    </header>

    <!-- Research-only disclaimer -->
    <div class="mb-8 rounded-xl border-2 border-blue-500/40 bg-blue-500/10 p-6 backdrop-blur-sm">
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0">
          <svg class="w-8 h-8 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div>
          <h2 class="text-lg font-semibold text-blue-400 mb-2">Research Documentation, Not Dosing Guidance</h2>
          <p class="text-blue-200/80">
            This page documents <strong class="text-blue-300">what researchers have studied</strong> in scientific literature.
            The doses mentioned are those used <strong class="text-blue-300">in specific studies</strong>, not recommendations.
            This is not a protocol guide and should not be used as dosing advice.
          </p>
        </div>
      </div>
    </div>

    <div class="grid gap-8 lg:grid-cols-[1fr,320px]">
      <!-- Main content -->
      <div class="space-y-8">
        <!-- Research Summary -->
        <section class="glass-card-default p-6">
          <h2 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Research Summary
          </h2>
          <p class="text-white/80 leading-relaxed">{researchSummary}</p>
        </section>

        <!-- Mechanism -->
        <section class="glass-card-default p-6">
          <h2 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-[var(--accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
            </svg>
            Proposed Mechanism of Combination
          </h2>
          <p class="text-white/80 leading-relaxed">{mechanism}</p>
        </section>

        <!-- MDX Content slot -->
        <div class="prose prose-invert prose-lg max-w-none">
          <slot />
        </div>

        <!-- Studies Table -->
        <section class="glass-card-default p-6">
          <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
            <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
            </svg>
            Studies Referenced
          </h2>

          <div class="space-y-4">
            {studies.map((study, index) => (
              <div class="border border-white/10 rounded-lg p-4 bg-white/5">
                <div class="flex flex-wrap items-start gap-2 mb-2">
                  <span class={`inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium ${studyTypeBadges[study.studyType].bg} ${studyTypeBadges[study.studyType].text} border border-current/20`}>
                    {studyTypeBadges[study.studyType].label}
                  </span>
                  <span class="text-white/60 text-sm">{study.year}</span>
                </div>

                <h3 class="text-white font-semibold mb-1">
                  {study.title}
                  {study.pmid && (
                    <a
                      href={`https://pubmed.ncbi.nlm.nih.gov/${study.pmid}/`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="ml-2 text-xs text-primary hover:underline"
                    >
                      PMID: {study.pmid}
                    </a>
                  )}
                </h3>

                {study.authors && (
                  <p class="text-white/60 text-sm mb-2">{study.authors}</p>
                )}

                <div class="mt-3 space-y-2">
                  <div>
                    <span class="text-xs uppercase tracking-wider text-white/50 font-medium">Doses Used in Study:</span>
                    <p class="text-white/80 text-sm mt-1">{study.dosesUsed}</p>
                  </div>
                  <div>
                    <span class="text-xs uppercase tracking-wider text-white/50 font-medium">Findings:</span>
                    <p class="text-white/80 text-sm mt-1">{study.findings}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- Safety Notes -->
        <section class="rounded-xl border-2 border-amber-500/40 bg-amber-500/10 p-6 backdrop-blur-sm">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0">
              <svg class="w-8 h-8 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
              </svg>
            </div>
            <div>
              <h2 class="text-lg font-semibold text-amber-400 mb-2">Safety Considerations from Research</h2>
              <p class="text-amber-200/80">{safetyNotes}</p>
            </div>
          </div>
        </section>
      </div>

      <!-- Sidebar -->
      <aside class="hidden lg:block">
        <div class="sticky top-24 space-y-6">
          <TableOfContents />

          <!-- Peptides Involved -->
          <div class="rounded-xl border border-white/10 bg-gradient-to-b from-[var(--primary)]/10 to-transparent p-4 backdrop-blur-sm">
            <h3 class="font-semibold text-white mb-3">Peptides in This Research</h3>
            <ul class="space-y-2">
              {peptides.map(peptide => (
                <li>
                  <a
                    href={`/peptides/${peptide}`}
                    class="text-sm text-primary hover:text-[var(--accent)] hover:underline transition-colors flex items-center gap-2"
                  >
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2" />
                    </svg>
                    {peptide.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join('-')} Dossier
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Study Type Legend -->
          <div class="rounded-xl border border-white/10 bg-white/5 p-4 backdrop-blur-sm">
            <h3 class="font-semibold text-white mb-3">Study Type Legend</h3>
            <ul class="space-y-2 text-sm">
              <li class="flex items-center gap-2">
                <span class="w-3 h-3 rounded-full bg-emerald-500"></span>
                <span class="text-white/80">Human RCT</span>
              </li>
              <li class="flex items-center gap-2">
                <span class="w-3 h-3 rounded-full bg-blue-500"></span>
                <span class="text-white/80">Human Observational</span>
              </li>
              <li class="flex items-center gap-2">
                <span class="w-3 h-3 rounded-full bg-amber-500"></span>
                <span class="text-white/80">Animal Study</span>
              </li>
              <li class="flex items-center gap-2">
                <span class="w-3 h-3 rounded-full bg-purple-500"></span>
                <span class="text-white/80">In Vitro</span>
              </li>
            </ul>
          </div>

          <!-- Quick Links -->
          <div class="rounded-xl border border-white/10 bg-white/5 p-4 backdrop-blur-sm">
            <h3 class="font-semibold text-white mb-3">Quick Links</h3>
            <ul class="space-y-2">
              <li>
                <a
                  href="/protocols"
                  class="text-sm text-primary hover:text-[var(--accent)] hover:underline transition-colors"
                >
                  All Research Overviews
                </a>
              </li>
              <li>
                <a
                  href="/methodology"
                  class="text-sm text-primary hover:text-[var(--accent)] hover:underline transition-colors"
                >
                  Our Methodology
                </a>
              </li>
              <li>
                <a
                  href="/editorial-policy"
                  class="text-sm text-primary hover:text-[var(--accent)] hover:underline transition-colors"
                >
                  Editorial Policy
                </a>
              </li>
            </ul>
          </div>
        </div>
      </aside>
    </div>

    <!-- Footer disclaimer -->
    <div class="mt-12 rounded-xl border-2 border-blue-500/40 bg-blue-500/10 p-6 backdrop-blur-sm">
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0">
          <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div>
          <p class="text-blue-200/80 text-sm">
            <strong class="text-blue-400">Disclaimer:</strong> {disclaimer}
          </p>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
