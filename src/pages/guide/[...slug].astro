---
import { getCollection, getEntry } from 'astro:content';
import GuideLayout from '../../layouts/GuideLayout.astro';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

// Support both static and SSR modes
let guide = Astro.props.guide;
if (!guide) {
  const { slug } = Astro.params;
  guide = await getEntry('guides', slug as string);
}

if (!guide) {
  return Astro.redirect('/404');
}

const { Content } = await guide.render();
---

<GuideLayout
  title={guide.data.title}
  peptide={guide.data.peptide}
  category={guide.data.category}
  lastUpdated={guide.data.lastUpdated}
  summary={guide.data.summary}
  sources={guide.data.sources}
  metaTitle={guide.data.metaTitle}
  metaDescription={guide.data.metaDescription}
>
  <Content />
</GuideLayout>
