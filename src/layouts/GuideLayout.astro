---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import RelatedEntities from '../components/RelatedEntities.astro';

interface Source {
  id: string;
  title: string;
  url?: string;
  type?: 'journal' | 'trial' | 'regulatory' | 'preprint' | 'news';
}

interface Props {
  title: string;
  peptide?: string;
  category?: string;
  lastUpdated: Date;
  summary: string;
  sources?: Source[];
}

const { title, peptide, category, lastUpdated, summary, sources = [] } = Astro.props;

const sourceTypeIcons: Record<string, string> = {
  'journal': 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253',
  'trial': 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  'regulatory': 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  'preprint': 'M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z',
  'news': 'M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z',
};

function getSourceUrl(source: Source): string {
  if (source.url) return source.url;
  const searchTerms = source.title.replace(/[^\w\s]/g, '').split(' ').slice(0, 6).join('+');
  return `https://pubmed.ncbi.nlm.nih.gov/?term=${encodeURIComponent(searchTerms)}`;
}

const categoryLabels: Record<string, string> = {
  'metabolic': 'Metabolic',
  'repair-recovery': 'Repair & Recovery',
  'hormonal': 'Hormonal',
  'longevity': 'Longevity',
  'other': 'Other',
};

const categoryColors: Record<string, string> = {
  'metabolic': 'bg-blue-500/20 text-blue-400 border border-blue-500/30',
  'repair-recovery': 'bg-emerald-500/20 text-emerald-400 border border-emerald-500/30',
  'hormonal': 'bg-purple-500/20 text-purple-400 border border-purple-500/30',
  'longevity': 'bg-amber-500/20 text-amber-400 border border-amber-500/30',
  'other': 'bg-white/20 text-white/80 border border-white/20',
};
---

<BaseLayout title={title} description={summary}>
  <article class="mx-auto max-w-5xl px-4 py-8 sm:px-6 lg:px-8">
    <!-- Header -->
    <header class="mb-8 relative">
      <div class="absolute inset-0 bg-gradient-to-br from-[var(--primary)]/10 via-transparent to-transparent rounded-2xl -z-10"></div>
      <div class="p-6">
        <div class="flex flex-wrap items-center gap-3 mb-4">
          {category && (
            <a
              href={`/category/${category}`}
              class={`inline-flex items-center rounded-full px-3 py-1 text-xs font-medium ${categoryColors[category] || categoryColors['other']}`}
            >
              {categoryLabels[category] || 'Other'}
            </a>
          )}
          <span class="inline-flex items-center rounded-full bg-[var(--primary)]/20 px-3 py-1 text-xs font-medium text-primary border border-[var(--primary)]/30">
            Guide
          </span>
        </div>

        <h1 class="text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">
          {title}
        </h1>

        <p class="mt-4 text-xl text-white/80 leading-relaxed">
          {summary}
        </p>

        {peptide && (
          <div class="mt-4">
            <a
              href={`/peptides/${peptide}`}
              class="inline-flex items-center text-primary hover:text-[var(--accent)] hover:underline text-sm font-medium transition-colors"
            >
              View full {peptide} dossier
              <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </div>
        )}

        <p class="mt-4 text-sm text-white/70">
          Last updated: {lastUpdated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </p>
      </div>
    </header>

    <div class="grid gap-8 lg:grid-cols-[1fr,250px]">
      <!-- Main content -->
      <div class="prose prose-invert prose-lg max-w-none">
        <slot />

        <!-- Sources Section -->
        {sources.length > 0 && (
          <section class="mt-12 not-prose">
            <h2 class="text-xl font-bold text-white mb-4 flex items-center gap-2" style="font-family: var(--font-display);">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
              </svg>
              Sources & Citations
            </h2>
            <div class="rounded-xl border border-white/10 bg-white/5 overflow-hidden">
              <ul class="divide-y divide-white/5">
                {sources.map((source, index) => (
                  <li class="p-4 hover:bg-white/5 transition-colors">
                    <div class="flex items-start gap-3">
                      <span class="flex-shrink-0 w-6 h-6 rounded-full bg-[var(--primary)]/20 text-primary text-xs flex items-center justify-center font-medium">
                        {index + 1}
                      </span>
                      <div class="flex-grow min-w-0">
                        <div class="flex items-center gap-2 mb-1">
                          {source.type && (
                            <svg class="w-4 h-4 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={sourceTypeIcons[source.type] || sourceTypeIcons['journal']}></path>
                            </svg>
                          )}
                          <span class="text-xs text-white/40 uppercase tracking-wide">{source.type || 'source'}</span>
                        </div>
                        <a
                          href={getSourceUrl(source)}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-primary hover:text-[var(--accent)] hover:underline transition-colors inline-flex items-center gap-1"
                        >
                          {source.title}
                          <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                          </svg>
                        </a>
                        <p class="text-xs text-white/40 mt-1">{source.id}</p>
                      </div>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          </section>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="hidden lg:block">
        <div class="sticky top-24 space-y-6">
          <TableOfContents />

          {peptide && (
            <div class="rounded-xl border border-white/10 bg-gradient-to-b from-[var(--primary)]/10 to-transparent p-4 backdrop-blur-sm">
              <h3 class="font-semibold text-white mb-3">Related Content</h3>
              <ul class="space-y-2">
                <li>
                  <a
                    href={`/peptides/${peptide}`}
                    class="text-sm text-primary hover:text-[var(--accent)] hover:underline transition-colors"
                  >
                    {peptide.charAt(0).toUpperCase() + peptide.slice(1)} Evidence Dossier
                  </a>
                </li>
                <li>
                  <a
                    href={`/safety/glp1-safety-overview`}
                    class="text-sm text-primary hover:text-[var(--accent)] hover:underline transition-colors"
                  >
                    GLP-1 Safety Overview
                  </a>
                </li>
              </ul>
            </div>
          )}

          <div class="rounded-xl border border-amber-500/30 bg-amber-500/10 p-4 backdrop-blur-sm">
            <h3 class="font-semibold text-amber-400 mb-2">Important Notice</h3>
            <p class="text-sm text-amber-200/80">
              This guide is for educational purposes only. It is not medical advice. Consult a healthcare provider before making health decisions.
            </p>
          </div>
        </div>
      </aside>
    </div>

    <!-- Related Content (Internal Linking) -->
    <RelatedEntities
      currentPeptide={peptide}
      category={category}
    />

    <!-- Disclaimer -->
    <div class="mt-12 rounded-xl border border-amber-500/30 bg-amber-500/10 p-6 backdrop-blur-sm">
      <p class="text-amber-200 text-sm">
        <strong class="text-amber-400">Disclaimer:</strong> This educational guide does not constitute medical advice. The information presented is based on current research but should not be used for diagnosis, treatment, or prevention of any disease. Always consult a qualified healthcare provider before making health decisions.
      </p>
    </div>
  </article>
</BaseLayout>
