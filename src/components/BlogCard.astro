---
interface Props {
  title: string;
  slug: string;
  category: string;
  publishDate: Date;
  excerpt: string;
  author?: string;
  tags?: string[];
  featured?: boolean;
}

const {
  title,
  slug,
  category,
  publishDate,
  excerpt,
  author = 'PepCodex Research Team',
  tags = [],
  featured = false
} = Astro.props;

const categoryLabels: Record<string, string> = {
  'weekly-briefing': 'Weekly Briefing',
  'research-digest': 'Research Digest',
  'deep-dive': 'Deep Dive',
  'regulatory': 'Regulatory',
  'explainer': 'Explainer',
};

const categoryColors: Record<string, string> = {
  'weekly-briefing': 'bg-[var(--primary)]/20 text-primary border-[var(--primary)]/30',
  'research-digest': 'bg-emerald-500/20 text-emerald-400 border-emerald-500/30',
  'deep-dive': 'bg-amber-500/20 text-amber-400 border-amber-500/30',
  'regulatory': 'bg-blue-500/20 text-blue-400 border-blue-500/30',
  'explainer': 'bg-cyan-500/20 text-cyan-400 border-cyan-500/30',
};

// Calculate reading time estimate
const readingTime = Math.ceil(excerpt.length / 200) + 5;
---

<a
  href={`/blog/${slug}`}
  class:list={[
    "glass-card glass-card--interactive group relative block h-full",
    featured && "ring-2 ring-[var(--primary)]/50"
  ]}
>
  <!-- Gradient overlay -->
  <div class="absolute inset-0 bg-gradient-to-br from-[var(--primary)]/10 via-[var(--primary)]/5 to-cyan-500/5 opacity-50 group-hover:opacity-100 group-hover:from-[var(--primary)]/25 group-hover:via-[var(--primary)]/15 transition-all duration-300 rounded-xl"></div>

  <!-- Featured badge -->
  {featured && (
    <div class="absolute top-5 right-4 z-20">
      <span class="inline-flex items-center rounded-full bg-[var(--primary)] px-3 py-1 text-xs font-medium text-white shadow-lg">
        Featured
      </span>
    </div>
  )}

  <!-- Decorative icon -->
  <div class="absolute top-0 right-0 p-4 opacity-5 group-hover:opacity-10 transition-opacity text-primary">
    <svg class="w-20 h-20 rotate-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
      <path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/>
      <path d="M18 14h-8"/>
      <path d="M18 18h-8"/>
      <path d="M18 10h-8"/>
    </svg>
  </div>

  <div class="relative z-10 p-6 flex flex-col h-full">
    <!-- Category and date -->
    <div class="flex flex-wrap items-center gap-2 mb-3">
      <span class={`inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium border ${categoryColors[category] || categoryColors['research-digest']}`}>
        {categoryLabels[category] || category}
      </span>
      <span class="text-xs" style="color: var(--text-low);">
        {publishDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
      </span>
    </div>

    <!-- Title -->
    <h3 class="text-xl font-bold group-hover:text-primary transition-colors line-clamp-2" style="color: var(--text-high); font-family: var(--font-display);">
      {title}
    </h3>

    <!-- Excerpt -->
    <p class="mt-3 text-sm line-clamp-3 leading-relaxed flex-grow" style="color: var(--text-medium);">
      {excerpt}
    </p>

    <!-- Tags -->
    {tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-1.5">
        {tags.slice(0, 3).map(tag => (
          <span class="inline-flex items-center rounded bg-white/5 px-2 py-0.5 text-xs" style="color: var(--text-low);">
            #{tag}
          </span>
        ))}
        {tags.length > 3 && (
          <span class="text-xs" style="color: var(--text-low);">+{tags.length - 3}</span>
        )}
      </div>
    )}

    <!-- Footer -->
    <div class="pt-4 mt-4 flex items-center justify-between" style="border-top: 1px solid var(--border-glass);">
      <div class="flex items-center gap-2 text-xs" style="color: var(--text-low);">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span>{readingTime} min read</span>
      </div>

      <!-- Arrow -->
      <svg
        class="h-4 w-4 group-hover:text-primary group-hover:translate-x-1 transition-all"
        style="color: var(--text-low);"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7" />
      </svg>
    </div>
  </div>
</a>
