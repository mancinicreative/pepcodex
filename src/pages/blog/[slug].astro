---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const sorted = posts.sort((a, b) =>
    b.data.publishDate.getTime() - a.data.publishDate.getTime()
  );
  return sorted.map((post, i) => ({
    params: { slug: post.slug },
    props: {
      post,
      prevPost: sorted[i + 1] ? { slug: sorted[i + 1].slug, title: sorted[i + 1].data.title } : null,
      nextPost: sorted[i - 1] ? { slug: sorted[i - 1].slug, title: sorted[i - 1].data.title } : null,
    },
  }));
}

// Support both static and SSR modes
let post = Astro.props.post;
if (!post) {
  const { slug } = Astro.params;
  post = await getEntry('blog', slug as string);
}

if (!post) {
  return Astro.redirect('/404');
}

const { Content } = await post.render();
---

<BlogLayout
  title={post.data.title}
  publishDate={post.data.publishDate}
  lastUpdated={post.data.lastUpdated}
  author={post.data.author}
  category={post.data.category}
  excerpt={post.data.excerpt}
  tags={post.data.tags}
  relatedPeptides={post.data.relatedPeptides}
  relatedGlossary={post.data.relatedGlossary}
  sources={post.data.sources}
  evidenceLevel={post.data.evidenceLevel}
  prevPost={Astro.props.prevPost}
  nextPost={Astro.props.nextPost}
>
  <Content />
</BlogLayout>
