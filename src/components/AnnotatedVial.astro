---
/**
 * Annotated specimen vial — the dossier "Scale 1:1" plate diagram.
 * Vial + annotation leaders + AA/MW caption in a single SVG coordinate space
 * so labels always align. Fill level/color encode evidence strength.
 */
interface Props {
  strength?: 'high' | 'moderate' | 'low' | 'very-low';
  chainLength?: number;
  weight?: string;
}
const { strength = 'low', chainLength, weight } = Astro.props;

const evidence: Record<string, { pct: number; color: string }> = {
  'high':     { pct: 90, color: 'var(--research)' },
  'moderate': { pct: 62, color: 'var(--primary-c)' },
  'low':      { pct: 38, color: 'var(--compound)' },
  'very-low': { pct: 16, color: 'var(--danger)' },
};
const { pct, color } = evidence[strength];

const bodyTop = 60, bodyBottom = 268, bodyH = bodyBottom - bodyTop;
const fillH = (pct / 100) * bodyH;
const fillY = bodyBottom - fillH;
const uid = `avial-${Math.random().toString(36).slice(2, 8)}`;

const caption = [chainLength ? `${chainLength} AA` : null, weight || null].filter(Boolean).join(' · ');
const MONO = "'Geist Mono', 'SF Mono', ui-monospace, monospace";
---

<svg viewBox="0 0 240 300" width="100%" style="max-width: 230px; height: auto;" role="img"
     aria-label={`Specimen vial, ${strength.replace('-', ' ')} evidence${caption ? `, ${caption}` : ''}`} fill="none">
  <defs>
    <clipPath id={uid}>
      <rect x="56" y="61" width="58" height="206" rx="9" />
    </clipPath>
  </defs>

  <!-- Scale label -->
  <text x="236" y="15" text-anchor="end" font-family={MONO} font-size="9" letter-spacing="1.2" fill="var(--ink-dim)">SCALE · 1:1</text>

  <!-- Cap + neck -->
  <rect x="70" y="30" width="30" height="14" rx="3" fill="var(--border-strong)" />
  <rect x="74" y="44" width="22" height="17" fill="var(--paper-2)" stroke="var(--ink-dim)" stroke-width="1.4" />

  <!-- Body -->
  <rect x="55" y="60" width="60" height="208" rx="10" fill="var(--paper)" stroke="var(--ink-dim)" stroke-width="1.8" />

  <!-- Liquid fill -->
  <g clip-path={`url(#${uid})`}>
    <rect x="55" y={fillY} width="60" height={fillH} fill={color} opacity="0.85" />
    <rect x="55" y={fillY} width="60" height="2.5" fill={color} />
  </g>

  <!-- Graduation ticks -->
  <g stroke="var(--ink-dim)" stroke-width="0.8" opacity="0.5">
    <line x1="107" y1={bodyTop + bodyH * 0.25} x2="113" y2={bodyTop + bodyH * 0.25} />
    <line x1="107" y1={bodyTop + bodyH * 0.5} x2="113" y2={bodyTop + bodyH * 0.5} />
    <line x1="107" y1={bodyTop + bodyH * 0.75} x2="113" y2={bodyTop + bodyH * 0.75} />
  </g>

  <!-- N-terminus leader -->
  <circle cx="85" cy="52" r="1.8" fill="var(--ink-dim)" />
  <line x1="85" y1="52" x2="150" y2="52" stroke="var(--ink-dim)" stroke-width="1" opacity="0.6" />
  <text x="154" y="55" font-family={MONO} font-size="9" letter-spacing="1" fill="var(--ink-muted)">N-TERMINUS</text>

  <!-- C-terminus leader -->
  <circle cx="85" cy="262" r="1.8" fill="var(--ink-dim)" />
  <line x1="85" y1="262" x2="150" y2="262" stroke="var(--ink-dim)" stroke-width="1" opacity="0.6" />
  <text x="154" y="265" font-family={MONO} font-size="9" letter-spacing="1" fill="var(--ink-muted)">C-TERMINUS</text>

  <!-- Bottom caption -->
  {caption && (
    <text x="85" y="290" text-anchor="middle" font-family={MONO} font-size="10.5" letter-spacing="0.5" fill="var(--ink)">{caption}</text>
  )}
</svg>
