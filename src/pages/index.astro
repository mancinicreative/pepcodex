---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchBar from '../components/SearchBar.astro';
import PeptideCard from '../components/PeptideCard.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import Vial from '../components/Vial.astro';
import EvidenceBadge from '../components/EvidenceBadge.astro';
import { getCollection } from 'astro:content';

const peptides = await getCollection('peptides');
const comparisons = await getCollection('comparisons');
const blogPosts = await getCollection('blog');
const glossaryTerms = await getCollection('glossary');

// Selected specimens — curated for relevance (the "plates")
const topPeptideSlugs = [
  'semaglutide',    // GLP-1 (Ozempic/Wegovy)
  'tirzepatide',    // GIP/GLP-1 (Mounjaro/Zepbound)
  'bpc-157',        // Recovery
  'tb-500',         // Healing/recovery
  'pt-141',         // Sexual health
  'ghk-cu',         // Skin/hair/longevity
];
const featuredPeptides = topPeptideSlugs
  .map(slug => peptides.find(p => p.slug === slug))
  .filter(Boolean);
const plateNumerals = ['I', 'II', 'III', 'IV', 'V', 'VI'];

// The "drawers" — categories A–F with live specimen counts
const drawerDefs = [
  { letter: 'A', name: 'Metabolic', slug: 'metabolic', description: 'GLP-1 agonists and metabolic regulators' },
  { letter: 'B', name: 'Recovery', slug: 'repair-recovery', description: 'Healing and tissue regeneration' },
  { letter: 'C', name: 'Hormonal', slug: 'hormonal', description: 'Growth hormone secretagogues' },
  { letter: 'D', name: 'Longevity', slug: 'longevity', description: 'Anti-aging bioregulators' },
  { letter: 'E', name: 'Cognitive', slug: 'cognitive', description: 'Nootropic and neuroprotective' },
  { letter: 'F', name: 'Immune', slug: 'immune', description: 'Immunomodulatory peptides' },
];
const evidenceRank: Record<string, number> = { 'high': 4, 'moderate': 3, 'low': 2, 'very-low': 1 };
const drawers = drawerDefs.map(d => {
  const inDrawer = peptides.filter(p => p.data.category === d.slug);
  const top = [...inDrawer]
    .sort((a, b) => (evidenceRank[b.data.evidenceStrength] - evidenceRank[a.data.evidenceStrength]) || a.data.name.localeCompare(b.data.name))
    .slice(0, 4);
  return { ...d, count: inDrawer.length, top };
});
const maxDrawerCount = Math.max(...drawers.map(d => d.count), 1);

const sourceCount = peptides.reduce((sum, p) => sum + p.data.sources.count, 0);
const stats = [
  { value: `${peptides.length}`, label: 'Dossiers', description: 'In-depth research profiles' },
  { value: sourceCount.toLocaleString(), label: 'Cited sources', description: 'Peer-reviewed papers' },
  { value: `${comparisons.length}`, label: 'Comparisons', description: 'Head-to-head analyses' },
  { value: `${blogPosts.length}`, label: 'Briefings', description: 'Research updates' },
];
const issue = 'Spring 2026';
---

<BaseLayout title="Evidence-Based Peptide Research">
  <!-- ============ MASTHEAD ============ -->
  <section class="pt-6 pb-12 md:pb-16">
    <div class="grid lg:grid-cols-[1fr_320px] gap-10 lg:gap-12 items-start">
      <!-- Headline -->
      <div>
        <span class="eyebrow">The PepCodex Catalogue · Vol. IV</span>
        <h1 class="font-serif mt-4 text-[2.75rem] leading-[1.02] md:text-[4.25rem] tracking-[-0.01em]" style="color: var(--ink); font-weight: 500;">
          A catalogue of <em class="italic" style="color: var(--primary-c);">peptides,</em> referenced.
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed" style="color: var(--ink-muted);">
          {peptides.length} dossiers. {sourceCount.toLocaleString()} cited sources. Distilled, classified,
          and indexed — so you can read the evidence, not the marketing.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/peptides" class="btn btn-ink btn-md uppercase tracking-[0.1em] text-[0.78rem]" style="font-family: var(--font-mono);">
            Browse the catalogue
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/methodology" class="btn btn-paper btn-md uppercase tracking-[0.1em] text-[0.78rem]" style="font-family: var(--font-mono);">
            Read the methodology
          </a>
        </div>
      </div>

      <!-- This Volume card -->
      <aside class="glass-card relative overflow-hidden p-6">
        <div class="signal-bar absolute top-0 left-0 right-0 rounded-none"></div>
        <div class="flex items-start justify-between">
          <span class="eyebrow">This volume</span>
          <Vial strength="high" size="md" />
        </div>
        <div class="font-serif leading-none mt-2 text-[5.5rem]" style="color: var(--primary-c); font-weight: 500;">IV</div>
        <dl class="mt-4 space-y-2.5 text-sm">
          {[
            ['Issue', issue],
            ['Dossiers', `${peptides.length}`],
            ['Cited sources', sourceCount.toLocaleString()],
            ['Comparisons', `${comparisons.length}`],
          ].map(([k, v]) => (
            <div class="flex items-center justify-between gap-3 pb-2" style="border-bottom: 1px solid var(--border-c);">
              <dt class="eyebrow" style="font-size: 0.66rem;">{k}</dt>
              <dd style="color: var(--ink); font-family: var(--font-mono); font-weight: 500;">{v}</dd>
            </div>
          ))}
        </dl>
      </aside>
    </div>

    <!-- Search -->
    <div class="mt-10 max-w-2xl">
      <SearchBar placeholder="Search peptides by name or condition…" size="lg" />
    </div>
  </section>

  <!-- ============ THE PLATES ============ -->
  {featuredPeptides.length > 0 && (
    <section class="py-10 md:py-14" style="border-top: 1px solid var(--border-c);">
      <div class="flex items-end justify-between gap-4 mb-2">
        <div class="section-header mb-0">
          <span class="section-header__bar"></span>
          <h2 class="section-header__title">The plates</h2>
        </div>
        <a href="/peptides" class="eyebrow inline-flex items-center gap-1 hover:text-[color:var(--primary-c)] transition-colors" style="color: var(--ink-dim);">
          All entries
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
      <p class="eyebrow mb-8" style="color: var(--ink-dim);">Selected specimens · Vol. IV</p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredPeptides.map((peptide, i) => (
          <div>
            <div class="eyebrow mb-2" style="color: var(--ink-dim);">Plate {plateNumerals[i]}</div>
            <PeptideCard
              name={peptide.data.name}
              slug={peptide.slug}
              category={peptide.data.category}
              compoundType={peptide.data.compoundType}
              evidenceStrength={peptide.data.evidenceStrength}
              summary={peptide.data.summary}
              aliases={peptide.data.aliases}
            />
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- ============ THE DRAWERS ============ -->
  <section class="py-10 md:py-14" style="border-top: 1px solid var(--border-c);">
    <div class="section-header mb-2">
      <span class="section-header__bar"></span>
      <h2 class="section-header__title">The drawers</h2>
    </div>
    <p class="eyebrow mb-8" style="color: var(--ink-dim);">Browse by classification</p>

    <div class="glass-card overflow-hidden">
      {drawers.map((d, i) => (
        <div class={`grid grid-cols-1 md:grid-cols-[250px_1fr] gap-5 md:gap-10 p-5 md:p-6 ${i > 0 ? 'border-t border-[color:var(--border-c)]' : ''}`}>
          <!-- Drawer identity -->
          <a href={`/category/${d.slug}`} class="group flex items-start gap-3.5 self-start">
            <span class="flex h-11 w-11 flex-none items-center justify-center rounded-md font-serif text-xl"
                  style="background: var(--primary-soft); color: var(--primary-c); font-weight: 500;">
              {d.letter}
            </span>
            <div class="min-w-0">
              <h3 class="font-serif text-lg leading-tight transition-colors group-hover:text-[color:var(--primary-c)]" style="color: var(--ink); font-weight: 500;">{d.name}</h3>
              <p class="mt-1 text-xs leading-snug" style="color: var(--ink-muted);">{d.description}</p>
              <span class="eyebrow mt-2 inline-flex items-center gap-1" style="color: var(--ink-dim); font-size: 0.6rem;">
                {d.count} specimens
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </div>
          </a>
          <!-- Top specimens in this drawer -->
          <div>
            {d.top.map((p, j) => (
              <a href={`/peptides/${p.slug}`} class={`flex items-start justify-between gap-4 py-2.5 group ${j > 0 ? 'border-t border-[color:var(--rule)]' : ''}`}>
                <div class="min-w-0">
                  <div class="font-serif text-[1rem] leading-tight transition-colors group-hover:text-[color:var(--primary-c)]" style="color: var(--ink);">{p.data.name}</div>
                  <div class="mt-0.5 text-xs line-clamp-1" style="color: var(--ink-dim);">{p.data.summary}</div>
                </div>
                <div class="flex-none pt-0.5"><EvidenceBadge strength={p.data.evidenceStrength} showLabel={false} /></div>
              </a>
            ))}
            {d.count === 0 && <p class="py-2.5 text-sm" style="color: var(--ink-dim);">No specimens catalogued yet.</p>}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ============ BY THE NUMBERS ============ -->
  <section class="py-10 md:py-14" style="border-top: 1px solid var(--border-c);">
    <div class="section-header mb-8">
      <span class="section-header__bar"></span>
      <h2 class="section-header__title">By the numbers</h2>
    </div>
    <div class="grid lg:grid-cols-2 gap-5">
      <!-- Distribution chart -->
      <div class="panel-inset p-6">
        <p class="eyebrow mb-5" style="color: var(--ink-dim);">Specimens per drawer</p>
        <div class="space-y-3">
          {drawers.map((d) => (
            <div class="flex items-center gap-3">
              <span class="eyebrow flex-none w-24 truncate" style="color: var(--ink-muted); font-size: 0.62rem;">{d.letter} · {d.name}</span>
              <div class="flex-1 h-2.5 rounded-full overflow-hidden" style="background: var(--paper-3);">
                <div class="h-full rounded-full" style={`width: ${Math.max(3, Math.round((d.count / maxDrawerCount) * 100))}%; background: var(--primary-c);`}></div>
              </div>
              <span class="flex-none w-7 text-right text-sm" style="font-family: var(--font-mono); color: var(--ink);">{d.count}</span>
            </div>
          ))}
        </div>
      </div>
      <!-- Stats -->
      <div class="panel-inset grid grid-cols-2">
        {stats.map((stat, i) => (
          <div class="p-6" style={`border-color: var(--border-c); ${i % 2 === 0 ? 'border-right: 1px solid var(--border-c);' : ''} ${i < 2 ? 'border-bottom: 1px solid var(--border-c);' : ''}`}>
            <div class="font-serif text-4xl md:text-5xl" style="color: var(--ink); font-weight: 500;">{stat.value}</div>
            <div class="eyebrow mt-2" style="color: var(--ink-muted);">{stat.label}</div>
            <div class="mt-1 text-xs" style="color: var(--ink-dim);">{stat.description}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ THE NEXT VOLUME (subscribe) ============ -->
  <section class="py-10 md:py-14" style="border-top: 1px solid var(--border-c);">
    <div class="glass-card relative overflow-hidden p-8 md:p-10">
      <div class="signal-bar absolute top-0 left-0 right-0 rounded-none"></div>
      <span class="eyebrow" style="color: var(--ink-dim);">The next volume</span>
      <h2 class="font-serif mt-2 text-3xl md:text-4xl" style="color: var(--ink); font-weight: 500;">No. 03 lands this summer.</h2>
      <p class="mt-3 max-w-xl text-sm leading-relaxed" style="color: var(--ink-muted);">
        Subscribe and we'll send you the next issue — plus the in-between revisions when a dossier is
        re-stamped. No marketing, no protocols, just receipts.
      </p>
      <div class="mt-6 max-w-xl">
        <NewsletterForm variant="full" />
      </div>
    </div>
  </section>

  <!-- ============ EDUCATIONAL USE ONLY ============ -->
  <section class="pb-12">
    <div class="panel-inset flex items-start gap-4 p-5" style="border-left: 3px solid var(--compound);">
      <span class="flex h-8 w-8 flex-none items-center justify-center rounded-full" style="background: rgba(203,135,52,0.15);">
        <svg class="w-4 h-4" style="color: #9a6418;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
      </span>
      <div>
        <h3 class="eyebrow" style="color: #9a6418;">Educational use only</h3>
        <p class="mt-1.5 text-sm leading-relaxed" style="color: var(--ink-muted);">
          This website provides educational information only. It is not medical advice and should not be
          used to diagnose, treat, or prevent any condition. Always consult a qualified healthcare provider
          before making health decisions. We do not provide dosing, protocols, or sourcing information.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
