---
import { getCollection, getEntry } from 'astro:content';
import GlossaryLayout from '../../layouts/GlossaryLayout.astro';

export async function getStaticPaths() {
  const glossary = await getCollection('glossary');
  return glossary.map((term) => ({
    params: { slug: term.slug },
    props: { term },
  }));
}

// Support both static and SSR modes
let term = Astro.props.term;
if (!term) {
  const { slug } = Astro.params;
  term = await getEntry('glossary', slug as string);
}

if (!term) {
  return Astro.redirect('/404');
}

const { Content } = await term.render();
---

<GlossaryLayout
  term={term.data.term}
  definition={term.data.definition}
  aliases={term.data.aliases}
  relatedPeptides={term.data.relatedPeptides}
  relatedTerms={term.data.relatedTerms}
  category={term.data.category}
  lastUpdated={term.data.lastUpdated}
  metaTitle={term.data.metaTitle}
  metaDescription={term.data.metaDescription}
>
  <Content />
</GlossaryLayout>
