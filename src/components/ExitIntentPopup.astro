---
import NewsletterForm from './NewsletterForm.astro';
---

<!-- Exit-intent popup overlay -->
<div
  id="exit-popup"
  role="dialog"
  aria-modal="true"
  aria-labelledby="exit-popup-heading"
  style="display: none; position: fixed; inset: 0; z-index: 9999; background: rgba(31,26,18,0.45); align-items: center; justify-content: center;"
>
  <!-- Inner card -->
  <div
    class="glass-card relative w-full max-w-lg mx-4 p-8"
    style="max-width: 480px;"
  >
    <!-- Close button -->
    <button
      data-close
      class="absolute top-4 right-4 w-8 h-8 rounded-full flex items-center justify-center transition-colors hover:bg-[color:var(--paper-2)]"
      style="color: var(--text-medium);"
      aria-label="Close popup"
    >
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6 6 18" />
        <path d="m6 6 12 12" />
      </svg>
    </button>

    <!-- Heading -->
    <h3 id="exit-popup-heading" class="font-serif text-xl font-medium mb-2" style="color: var(--text-high);">
      Before you go...
    </h3>

    <!-- Description -->
    <p class="text-sm mb-6" style="color: var(--text-medium);">
      Get evidence-based peptide research delivered to your inbox. No spam, just science.
    </p>

    <!-- Newsletter form -->
    <NewsletterForm variant="inline" />
  </div>
</div>

<script>
  // One-time newsletter prompt. Persisted across sessions via localStorage so it
  // only ever appears once per visitor — never on repeat page views or navigation.
  const SEEN_KEY = 'pep-newsletter-seen';

  if (!localStorage.getItem(SEEN_KEY)) {
    const popup = document.getElementById('exit-popup');
    let triggered = false;
    let armed = false;

    // Grace period: don't allow any trigger for the first few seconds, so it can
    // never fire on load or while the reader is still settling into the page.
    setTimeout(() => { armed = true; }, 6000);

    function markSeen() {
      try { localStorage.setItem(SEEN_KEY, '1'); } catch {}
    }

    function showPopup() {
      if (triggered || !armed) return;
      triggered = true;
      markSeen(); // mark seen the moment it shows — guarantees true one-time behaviour
      if (popup) popup.style.display = 'flex';
    }

    function hidePopup() {
      if (popup) popup.style.display = 'none';
      markSeen();
    }

    // Desktop: genuine exit intent (cursor leaves the top of the viewport)
    document.addEventListener('mouseleave', (e) => {
      if (e.clientY < 10) showPopup();
    });

    // Mobile/no-mouse: only after the reader has reached the very end of the page
    window.addEventListener('scroll', () => {
      const scrollPct = (window.scrollY + window.innerHeight) / document.documentElement.scrollHeight;
      if (scrollPct > 0.9) showPopup();
    }, { passive: true });

    // Close handlers
    if (popup) {
      const closeBtn = popup.querySelector('[data-close]');
      if (closeBtn) closeBtn.addEventListener('click', hidePopup);

      popup.addEventListener('click', (e) => {
        if (e.target === popup) hidePopup();
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && popup.style.display === 'flex') hidePopup();
      });
    }
  }
</script>
