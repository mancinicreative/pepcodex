---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Get popular peptides for suggestions
const peptides = await getCollection('peptides');
const popularPeptides = peptides
  .filter(p => p?.data?.sources?.count !== undefined)
  .sort((a, b) => (b?.data?.sources?.count || 0) - (a?.data?.sources?.count || 0))
  .slice(0, 6);

const categoryLabels: Record<string, string> = {
  'metabolic': 'Metabolic',
  'repair-recovery': 'Repair & Recovery',
  'hormonal': 'Hormonal',
  'longevity': 'Longevity',
  'other': 'Other',
};
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist." robots="noindex">
  <div class="min-h-[60vh] flex flex-col items-center justify-center text-center px-4">
    <!-- 404 Icon -->
    <div class="mb-8">
      <div class="relative">
        <div class="w-32 h-32 rounded-full bg-[var(--primary)]/10 flex items-center justify-center border border-[var(--primary)]/20">
          <svg class="w-16 h-16 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2" />
            <path d="M8.5 2h7" />
            <path d="M7 16h10" />
            <line x1="12" y1="12" x2="12" y2="14" stroke-linecap="round" />
            <circle cx="12" cy="16" r="0.5" fill="currentColor" />
          </svg>
        </div>
        <div class="absolute -bottom-2 -right-2 w-12 h-12 rounded-full bg-[var(--accent)]/20 flex items-center justify-center border border-[var(--accent)]/30">
          <span class="text-[var(--accent)] font-bold text-lg">?</span>
        </div>
      </div>
    </div>

    <!-- Error Message -->
    <h1 class="text-5xl md:text-7xl font-bold text-white mb-4" style="font-family: var(--font-display);">
      404
    </h1>
    <p class="text-xl text-white/80 mb-2">Page not found</p>
    <p class="text-white/60 max-w-md mb-8">
      The peptide you're looking for doesn't exist in our database, or the page may have been moved.
    </p>

    <!-- Search -->
    <div class="w-full max-w-md mb-12">
      <div class="relative">
        <input
          type="search"
          id="search-404"
          placeholder="Search peptides, guides, terms..."
          class="w-full px-4 py-3 pl-12 rounded-xl bg-white/5 border border-white/10 text-white placeholder-white/50 focus:outline-none focus:border-[var(--primary)]/50 focus:bg-white/10 transition-all"
        />
        <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-white/50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8" />
          <path d="m21 21-4.3-4.3" />
        </svg>
      </div>
    </div>

    <!-- Quick Links -->
    <div class="w-full max-w-2xl">
      <h2 class="text-sm font-bold uppercase tracking-wider text-white/60 mb-4">Popular Peptides</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
        {popularPeptides.map((peptide) => (
          <a
            href={`/peptides/${peptide.slug}`}
            class="glass-card-interactive p-4 text-left group"
          >
            <div class="font-bold text-white group-hover:text-primary transition-colors">
              {peptide.data.name}
            </div>
            <div class="text-xs text-white/60 mt-1">
              {categoryLabels[peptide.data.category]}
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- Navigation Links -->
    <div class="flex flex-wrap justify-center gap-4 mt-12">
      <a
        href="/"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-[var(--primary)] text-white font-medium hover:bg-[var(--primary)]/80 transition-colors"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
          <polyline points="9,22 9,12 15,12 15,22" />
        </svg>
        Go Home
      </a>
      <a
        href="/peptides"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-white/10 text-white font-medium hover:bg-white/5 transition-colors"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2" />
        </svg>
        Browse Peptides
      </a>
      <a
        href="/glossary"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-white/10 text-white font-medium hover:bg-white/5 transition-colors"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20" />
        </svg>
        Glossary
      </a>
    </div>
  </div>
</BaseLayout>

<script>
  // Track 404 error with the attempted URL for analytics
  (function() {
    const attemptedUrl = window.location.pathname + window.location.search;
    const referrer = document.referrer || 'direct';

    // Send to GA4 as custom event
    if (typeof gtag === 'function') {
      gtag('event', '404_error', {
        'page_path': attemptedUrl,
        'page_referrer': referrer,
        'page_location': window.location.href
      });
    }

    // Also log to console for debugging
    console.log('404 Error:', { attemptedUrl, referrer });
  })();

  // Basic search redirect
  const searchInput = document.getElementById('search-404') as HTMLInputElement;
  if (searchInput) {
    searchInput.addEventListener('keypress', (e) => {
      if (e.key === 'Enter' && searchInput.value.trim()) {
        // Redirect to peptides page with search (Pagefind will handle it)
        window.location.href = `/peptides?q=${encodeURIComponent(searchInput.value.trim())}`;
      }
    });
  }
</script>
