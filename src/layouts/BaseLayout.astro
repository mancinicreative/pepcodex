---
import '../styles/global.css';
import OrganizationSchema from '../components/SEO/OrganizationSchema.astro';
import DisclaimerBanner from '../components/DisclaimerBanner.astro';
import CookieConsent from '../components/CookieConsent.astro';
import SearchModal from '../components/SearchModal.astro';
import ExitIntentPopup from '../components/ExitIntentPopup.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  robots?: 'index' | 'noindex';
}

const {
  title,
  description = 'Evidence-based peptide research library. Comprehensive dossiers with citations, not advice.',
  ogImage,
  robots = 'index'
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteName = 'PepCodex';

// Google Analytics 4 - set in environment variable
const GA_TRACKING_ID = import.meta.env.PUBLIC_GA_TRACKING_ID;

// Get current path for nav highlighting
const currentPath = Astro.url.pathname;
const isActive = (path: string) => currentPath === path || (path !== '/' && currentPath.startsWith(path));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Self-hosted brand fonts: Geist (UI) · Geist Mono (labels) · Newsreader (editorial serif) -->
    <link rel="preload" href="/fonts/Newsreader-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Geist-Variable.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Google Search Console Verification -->
    <meta name="google-site-verification" content="8sNDsQp-DdfE1yFsY3N2xVcS2cnc4ecvACgyY6ON3LQ" />

    <!-- SEO -->
    <title>{title} | {siteName}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {robots === 'noindex' && <meta name="robots" content="noindex, nofollow" />}

    <!-- Structured Data -->
    <OrganizationSchema />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage || `${Astro.site}og-default.png`} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage || `${Astro.site}og-default.png`} />

    <!-- Google Analytics 4 -->
    {GA_TRACKING_ID && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_TRACKING_ID}`}></script>
        <script is:inline define:vars={{ GA_TRACKING_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', GA_TRACKING_ID);
        </script>
      </>
    )}
  </head>
  <body class="min-h-screen antialiased">
    <!-- Skip to main content -->
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <!-- Header -->
    <nav class="fixed top-0 left-0 right-0 z-50 border-b border-[color:var(--border-strong)] bg-[color:var(--bg)]/90 backdrop-blur-md" aria-label="Main navigation">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2.5 group">
          <span class="relative flex h-7 w-7 items-center justify-center rounded-md" style="background: var(--primary-c);">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="var(--ink-paper)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2" />
              <path d="M8.5 2h7" />
            </svg>
          </span>
          <span class="text-lg font-semibold tracking-tight" style="color: var(--ink);">PepCodex</span>
        </a>

        <!-- Desktop Nav -->
        <div class="hidden md:flex items-center gap-1 text-[0.78rem] uppercase tracking-[0.1em]" style="font-family: var(--font-mono);">
          <a
            href="/peptides"
            aria-current={isActive('/peptides') || isActive('/category') ? 'page' : undefined}
            class:list={[
              "px-3 py-2 rounded-md transition-colors duration-200",
              isActive('/peptides') || isActive('/category')
                ? "text-[color:var(--primary-c)]"
                : "text-[color:var(--ink-muted)] hover:text-[color:var(--ink)]"
            ]}
          >
            Peptides
          </a>
          <a
            href="/trials"
            aria-current={isActive('/trials') ? 'page' : undefined}
            class:list={[
              "px-3 py-2 rounded-md transition-colors duration-200",
              isActive('/trials')
                ? "text-[color:var(--primary-c)]"
                : "text-[color:var(--ink-muted)] hover:text-[color:var(--ink)]"
            ]}
          >
            Trials
          </a>
          <!-- Research Dropdown -->
          <div class="relative group">
            <button
              class:list={[
                "flex items-center gap-1.5 px-3 py-2 rounded-md transition-colors duration-200 uppercase tracking-[0.1em]",
                ['/compare', '/guide', '/safety', '/glossary', '/conditions', '/bioregulators'].some(p => currentPath.startsWith(p))
                  ? "text-[color:var(--primary-c)]"
                  : "text-[color:var(--ink-muted)] hover:text-[color:var(--ink)]"
              ]}
            >
              Research
              <svg class="w-3 h-3 transition-transform group-hover:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </button>
            <div class="absolute top-full left-0 mt-1 w-52 rounded-lg border border-[color:var(--border-c)] bg-[color:var(--paper)] shadow-[var(--shadow-raise)] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
              <div class="p-1.5">
                <a href="/compare" class:list={["block px-3 py-2 rounded-md transition-colors", isActive('/compare') ? "text-[color:var(--primary-c)] bg-[color:var(--primary-soft)]" : "text-[color:var(--ink-muted)] hover:text-[color:var(--ink)] hover:bg-[color:var(--paper-2)]"]}>Comparisons</a>
                <a href="/guide" class:list={["block px-3 py-2 rounded-md transition-colors", isActive('/guide') ? "text-[color:var(--primary-c)] bg-[color:var(--primary-soft)]" : "text-[color:var(--ink-muted)] hover:text-[color:var(--ink)] hover:bg-[color:var(--paper-2)]"]}>Guides</a>
                <a href="/safety" class:list={["block px-3 py-2 rounded-md transition-colors", isActive('/safety') ? "text-[color:var(--primary-c)] bg-[color:var(--primary-soft)]" : "text-[color:var(--ink-muted)] hover:text-[color:var(--ink)] hover:bg-[color:var(--paper-2)]"]}>Safety Profiles</a>
                <a href="/glossary" class:list={["block px-3 py-2 rounded-md transition-colors", isActive('/glossary') ? "text-[color:var(--primary-c)] bg-[color:var(--primary-soft)]" : "text-[color:var(--ink-muted)] hover:text-[color:var(--ink)] hover:bg-[color:var(--paper-2)]"]}>Glossary</a>
                <a href="/conditions" class:list={["block px-3 py-2 rounded-md transition-colors", isActive('/conditions') ? "text-[color:var(--primary-c)] bg-[color:var(--primary-soft)]" : "text-[color:var(--ink-muted)] hover:text-[color:var(--ink)] hover:bg-[color:var(--paper-2)]"]}>Conditions</a>
                <a href="/bioregulators" class:list={["block px-3 py-2 rounded-md transition-colors", isActive('/bioregulators') ? "text-[color:var(--primary-c)] bg-[color:var(--primary-soft)]" : "text-[color:var(--ink-muted)] hover:text-[color:var(--ink)] hover:bg-[color:var(--paper-2)]"]}>Bioregulators</a>
              </div>
            </div>
          </div>
          <a
            href="/blog"
            aria-current={isActive('/blog') ? 'page' : undefined}
            class:list={[
              "px-3 py-2 rounded-md transition-colors duration-200",
              isActive('/blog')
                ? "text-[color:var(--primary-c)]"
                : "text-[color:var(--ink-muted)] hover:text-[color:var(--ink)]"
            ]}
          >
            Blog
          </a>
          <a
            href="/directory"
            aria-current={isActive('/directory') ? 'page' : undefined}
            class:list={[
              "px-3 py-2 rounded-md transition-colors duration-200",
              isActive('/directory')
                ? "text-[color:var(--primary-c)]"
                : "text-[color:var(--ink-muted)] hover:text-[color:var(--ink)]"
            ]}
          >
            Directory
          </a>
        </div>

        <!-- Right side actions -->
        <div class="hidden md:flex items-center gap-2.5">
          <button id="header-search-btn" class="flex items-center gap-2 px-2.5 py-1.5 rounded-md border border-[color:var(--border-c)] text-[color:var(--ink-dim)] hover:text-[color:var(--ink)] hover:border-[color:var(--border-strong)] transition-colors" aria-label="Search (Ctrl+K)">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8" />
              <path d="m21 21-4.3-4.3" />
            </svg>
            <kbd class="text-[0.65rem] tracking-wider" style="font-family: var(--font-mono);">⌘K</kbd>
          </button>
          <a
            href="/contact"
            class="btn btn-paper btn-sm uppercase tracking-[0.1em] text-[0.72rem]"
            style="font-family: var(--font-mono);"
          >
            Contact
          </a>
          <a
            href="/newsletter"
            class="btn btn-cobalt btn-sm uppercase tracking-[0.1em] text-[0.72rem]"
            style="font-family: var(--font-mono);"
          >
            Subscribe
          </a>
        </div>

        <!-- Mobile Menu Button -->
        <button
          type="button"
          id="mobile-menu-btn"
          class="flex h-10 w-10 items-center justify-center rounded-lg text-[color:var(--ink)] md:hidden hover:bg-[color:var(--paper-2)] transition-colors"
          aria-expanded="false"
          aria-label="Open menu"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>

      <!-- Mobile navigation -->
      <div id="mobile-nav" class="mobile-nav-panel bg-[color:var(--bg)] border-t border-[color:var(--border-c)] p-4 md:hidden" aria-label="Mobile navigation">
        <div class="flex flex-col gap-1">
          <a
            href="/peptides"
            class:list={[
              "px-4 py-3 rounded-lg text-base transition-colors",
              isActive('/peptides')
                ? "text-[color:var(--primary-c)] bg-[color:var(--primary-soft)]"
                : "text-[color:var(--ink-muted)] hover:text-[color:var(--ink)] hover:bg-[color:var(--paper-2)]"
            ]}
          >
            Peptides
          </a>
          <a
            href="/trials"
            class:list={[
              "px-4 py-3 rounded-lg text-base transition-colors",
              isActive('/trials')
                ? "text-[color:var(--primary-c)] bg-[color:var(--primary-soft)]"
                : "text-[color:var(--ink-muted)] hover:text-[color:var(--ink)] hover:bg-[color:var(--paper-2)]"
            ]}
          >
            Trials
          </a>
          <a
            href="/blog"
            class:list={[
              "px-4 py-3 rounded-lg text-base transition-colors",
              isActive('/blog')
                ? "text-[color:var(--primary-c)] bg-[color:var(--primary-soft)]"
                : "text-[color:var(--ink-muted)] hover:text-[color:var(--ink)] hover:bg-[color:var(--paper-2)]"
            ]}
          >
            Blog
          </a>
          <a
            href="/directory"
            class:list={[
              "px-4 py-3 rounded-lg text-base transition-colors",
              isActive('/directory')
                ? "text-[color:var(--primary-c)] bg-[color:var(--primary-soft)]"
                : "text-[color:var(--ink-muted)] hover:text-[color:var(--ink)] hover:bg-[color:var(--paper-2)]"
            ]}
          >
            Directory
          </a>
          <!-- Research (expandable) -->
          <details class="group/research">
            <summary class:list={[
              "flex items-center justify-between px-4 py-3 rounded-lg text-base transition-colors cursor-pointer list-none",
              ['/compare', '/guide', '/safety', '/glossary', '/conditions', '/bioregulators'].some(p => currentPath.startsWith(p))
                ? "text-[color:var(--primary-c)] bg-[color:var(--primary-soft)]"
                : "text-[color:var(--ink-muted)] hover:text-[color:var(--ink)] hover:bg-[color:var(--paper-2)]"
            ]}>
              <span>Research</span>
              <svg class="w-4 h-4 transition-transform group-open/research:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </summary>
            <div class="pl-4 mt-1 space-y-1">
              <a href="/compare" class:list={["block px-4 py-2.5 rounded-lg text-sm transition-colors", isActive('/compare') ? "text-[color:var(--primary-c)]" : "text-[color:var(--ink-dim)] hover:text-[color:var(--ink)] hover:bg-[color:var(--paper-2)]"]}>Comparisons</a>
              <a href="/guide" class:list={["block px-4 py-2.5 rounded-lg text-sm transition-colors", isActive('/guide') ? "text-[color:var(--primary-c)]" : "text-[color:var(--ink-dim)] hover:text-[color:var(--ink)] hover:bg-[color:var(--paper-2)]"]}>Guides</a>
              <a href="/safety" class:list={["block px-4 py-2.5 rounded-lg text-sm transition-colors", isActive('/safety') ? "text-[color:var(--primary-c)]" : "text-[color:var(--ink-dim)] hover:text-[color:var(--ink)] hover:bg-[color:var(--paper-2)]"]}>Safety Profiles</a>
              <a href="/glossary" class:list={["block px-4 py-2.5 rounded-lg text-sm transition-colors", isActive('/glossary') ? "text-[color:var(--primary-c)]" : "text-[color:var(--ink-dim)] hover:text-[color:var(--ink)] hover:bg-[color:var(--paper-2)]"]}>Glossary</a>
              <a href="/conditions" class:list={["block px-4 py-2.5 rounded-lg text-sm transition-colors", isActive('/conditions') ? "text-[color:var(--primary-c)]" : "text-[color:var(--ink-dim)] hover:text-[color:var(--ink)] hover:bg-[color:var(--paper-2)]"]}>Conditions</a>
              <a href="/bioregulators" class:list={["block px-4 py-2.5 rounded-lg text-sm transition-colors", isActive('/bioregulators') ? "text-[color:var(--primary-c)]" : "text-[color:var(--ink-dim)] hover:text-[color:var(--ink)] hover:bg-[color:var(--paper-2)]"]}>Bioregulators</a>
            </div>
          </details>
          <div class="flex gap-2 mt-4 pt-4 border-t border-[color:var(--border-c)]">
            <a href="/contact" class="flex-1 btn btn-paper btn-md text-center">Contact</a>
            <a href="/newsletter" class="flex-1 btn btn-cobalt btn-md text-center">Subscribe</a>
          </div>
        </div>
      </div>
    </nav>

    <main id="main-content" class="pt-24 pb-12 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 min-h-[calc(100vh-4rem)]">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="mt-auto" style="background: var(--charcoal); color: var(--ink-paper);">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-10">
          <!-- Brand -->
          <div class="col-span-2 md:col-span-1">
            <div class="flex items-center gap-2.5 mb-4">
              <span class="flex h-6 w-6 items-center justify-center rounded" style="background: var(--primary-c);">
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="var(--ink-paper)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2" />
                  <path d="M8.5 2h7" />
                </svg>
              </span>
              <span class="text-lg font-semibold tracking-tight">PepCodex</span>
            </div>
            <p class="text-sm leading-relaxed" style="color: rgba(251,247,238,0.62);">
              Evidence-based peptide research catalogue. Synthesising peer-reviewed literature for informed decisions, one drawer at a time.
            </p>
            <a href="https://www.instagram.com/pepcodex/" target="_blank" rel="noopener noreferrer" class="inline-block mt-4 transition-colors hover:opacity-100" style="color: rgba(251,247,238,0.62);" aria-label="Follow us on Instagram">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            </a>
          </div>

          <!-- Drawers -->
          <div>
            <h4 class="eyebrow mb-4" style="color: rgba(251,247,238,0.5);">Drawers</h4>
            <ul class="space-y-2.5 text-sm" style="color: rgba(251,247,238,0.72);">
              <li><a href="/category/metabolic" class="transition-colors hover:text-[color:var(--compound)]">A · Metabolic</a></li>
              <li><a href="/category/repair-recovery" class="transition-colors hover:text-[color:var(--compound)]">B · Recovery</a></li>
              <li><a href="/category/hormonal" class="transition-colors hover:text-[color:var(--compound)]">C · Hormonal</a></li>
              <li><a href="/category/longevity" class="transition-colors hover:text-[color:var(--compound)]">D · Longevity</a></li>
              <li><a href="/category/cognitive" class="transition-colors hover:text-[color:var(--compound)]">E · Cognitive</a></li>
              <li><a href="/category/immune" class="transition-colors hover:text-[color:var(--compound)]">F · Immune</a></li>
            </ul>
          </div>

          <!-- Research -->
          <div>
            <h4 class="eyebrow mb-4" style="color: rgba(251,247,238,0.5);">Research</h4>
            <ul class="space-y-2.5 text-sm" style="color: rgba(251,247,238,0.72);">
              <li><a href="/peptides" class="transition-colors hover:text-[color:var(--compound)]">All Peptides</a></li>
              <li><a href="/trials" class="transition-colors hover:text-[color:var(--compound)]">Clinical Trials</a></li>
              <li><a href="/compare" class="transition-colors hover:text-[color:var(--compound)]">Comparisons</a></li>
              <li><a href="/guide" class="transition-colors hover:text-[color:var(--compound)]">Guides</a></li>
              <li><a href="/safety" class="transition-colors hover:text-[color:var(--compound)]">Safety Profiles</a></li>
              <li><a href="/glossary" class="transition-colors hover:text-[color:var(--compound)]">Glossary</a></li>
            </ul>
          </div>

          <!-- Colophon -->
          <div>
            <h4 class="eyebrow mb-4" style="color: rgba(251,247,238,0.5);">Colophon</h4>
            <ul class="space-y-2.5 text-sm" style="color: rgba(251,247,238,0.72);">
              <li><a href="/about" class="transition-colors hover:text-[color:var(--compound)]">About</a></li>
              <li><a href="/methodology" class="transition-colors hover:text-[color:var(--compound)]">Methodology</a></li>
              <li><a href="/editorial-policy" class="transition-colors hover:text-[color:var(--compound)]">Editorial Policy</a></li>
              <li><a href="/disclaimer" class="transition-colors hover:text-[color:var(--compound)]">Disclaimer</a></li>
              <li><a href="/fda-notice" class="transition-colors hover:text-[color:var(--compound)]">FDA Notice</a></li>
            </ul>
          </div>
        </div>

        <!-- Colophon line -->
        <div class="pt-8 flex flex-col md:flex-row justify-between items-center gap-4" style="border-top: 1px solid rgba(251,247,238,0.10);">
          <p class="eyebrow" style="color: rgba(251,247,238,0.45);">&copy; {new Date().getFullYear()} PepCodex · Vol. IV · All rights reserved</p>
          <div class="flex flex-wrap justify-center gap-4 text-xs" style="color: rgba(251,247,238,0.45);">
            <a href="/privacy" class="transition-colors hover:text-[color:var(--ink-paper)]">Privacy</a>
            <a href="/terms" class="transition-colors hover:text-[color:var(--ink-paper)]">Terms</a>
            <a href="/cookie-policy" class="transition-colors hover:text-[color:var(--ink-paper)]">Cookie Policy</a>
            <span class="italic" style="font-family: var(--font-serif);">Set in Geist &amp; Newsreader.</span>
          </div>
        </div>
      </div>
    </footer>

    <!-- Analytics -->
    <script>
      import { inject } from '@vercel/analytics';
      inject();
    </script>
    <script>
      import '../scripts/analytics';
    </script>

    <!-- Legal Components -->
    <DisclaimerBanner />
    <CookieConsent />
    <SearchModal />

    <!-- Mobile menu script -->
    <script>
      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileNav = document.getElementById('mobile-nav');

      function closeMobileMenu() {
        if (menuBtn && mobileNav) {
          menuBtn.setAttribute('aria-expanded', 'false');
          mobileNav.classList.remove('is-open');
          menuBtn.focus();
        }
      }

      function openMobileMenu() {
        if (menuBtn && mobileNav) {
          menuBtn.setAttribute('aria-expanded', 'true');
          mobileNav.classList.add('is-open');
          // Focus first link in menu after transition
          const firstLink = mobileNav.querySelector('a');
          if (firstLink) setTimeout(() => firstLink.focus(), 100);
        }
      }

      if (menuBtn && mobileNav) {
        menuBtn.addEventListener('click', () => {
          const isExpanded = menuBtn.getAttribute('aria-expanded') === 'true';
          if (isExpanded) {
            closeMobileMenu();
          } else {
            openMobileMenu();
          }
        });

        // ESC to close
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && menuBtn.getAttribute('aria-expanded') === 'true') {
            closeMobileMenu();
          }
        });

        // Focus trap within mobile nav
        mobileNav.addEventListener('keydown', (e) => {
          if (e.key !== 'Tab') return;
          const focusable = mobileNav.querySelectorAll('a, button, details > summary');
          const first = focusable[0] as HTMLElement;
          const last = focusable[focusable.length - 1] as HTMLElement;
          if (e.shiftKey && document.activeElement === first) {
            e.preventDefault();
            last.focus();
          } else if (!e.shiftKey && document.activeElement === last) {
            e.preventDefault();
            first.focus();
          }
        });
      }
    </script>

    <script>
      // Global Cmd+K handler
      document.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          document.dispatchEvent(new CustomEvent('open-search-modal'));
        }
      });

      // Header search button
      document.getElementById('header-search-btn')?.addEventListener('click', () => {
        document.dispatchEvent(new CustomEvent('open-search-modal'));
      });
    </script>

    <!-- Exit-intent newsletter popup (all pages) -->
    <ExitIntentPopup />
  </body>
</html>
