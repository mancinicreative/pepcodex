---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';

interface Source {
  id: string;
  title: string;
  url?: string;
  type?: 'journal' | 'trial' | 'regulatory' | 'preprint' | 'news';
}

interface Props {
  title: string;
  publishDate: Date;
  lastUpdated?: Date;
  author: string;
  category: string;
  excerpt: string;
  tags?: string[];
  relatedPeptides?: string[];
  relatedGlossary?: string[];
  sources?: Source[];
  evidenceLevel?: 'high' | 'moderate' | 'low' | 'very-low';
  prevPost?: { slug: string; title: string } | null;
  nextPost?: { slug: string; title: string } | null;
}

const {
  title,
  publishDate,
  lastUpdated,
  author,
  category,
  excerpt,
  tags = [],
  relatedPeptides = [],
  relatedGlossary = [],
  sources = [],
  evidenceLevel,
  prevPost,
  nextPost,
} = Astro.props;

const categoryLabels: Record<string, string> = {
  'weekly-briefing': 'Weekly Briefing',
  'research-digest': 'Research Digest',
  'deep-dive': 'Deep Dive',
  'regulatory': 'Regulatory Update',
  'explainer': 'Explainer',
};

const categoryColors: Record<string, string> = {
  'weekly-briefing': 'bg-[var(--primary)]/20 text-primary border border-[var(--primary)]/30',
  'research-digest': 'bg-emerald-500/20 text-emerald-400 border border-emerald-500/30',
  'deep-dive': 'bg-amber-500/20 text-amber-400 border border-amber-500/30',
  'regulatory': 'bg-blue-500/20 text-blue-400 border border-blue-500/30',
  'explainer': 'bg-cyan-500/20 text-cyan-400 border border-cyan-500/30',
};

const evidenceLabels: Record<string, { label: string; color: string }> = {
  'high': { label: 'High Evidence', color: 'bg-emerald-500/20 text-emerald-400 border-emerald-500/30' },
  'moderate': { label: 'Moderate', color: 'bg-blue-500/20 text-blue-400 border-blue-500/30' },
  'low': { label: 'Low Evidence', color: 'bg-amber-500/20 text-amber-400 border-amber-500/30' },
  'very-low': { label: 'Very Low', color: 'bg-white/20 text-white/70 border-white/20' },
};

const sourceTypeIcons: Record<string, string> = {
  'journal': 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253',
  'trial': 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  'regulatory': 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  'preprint': 'M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z',
  'news': 'M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z',
};

// Calculate reading time (rough estimate: 200 words per minute)
const readingTime = Math.ceil(excerpt.length / 200) + 5; // Base estimate

// Generate PubMed search URL from source title
function getSourceUrl(source: Source): string {
  if (source.url) return source.url;
  // Generate PubMed search URL from title
  const searchTerms = source.title
    .replace(/[^\w\s]/g, '')
    .split(' ')
    .slice(0, 6)
    .join('+');
  return `https://pubmed.ncbi.nlm.nih.gov/?term=${encodeURIComponent(searchTerms)}`;
}
---

<BaseLayout title={title} description={excerpt}>
  <article class="mx-auto max-w-5xl px-4 py-8 sm:px-6 lg:px-8">
    <!-- Header -->
    <header class="mb-8 relative">
      <div class="absolute inset-0 bg-gradient-to-br from-[var(--primary)]/10 via-transparent to-transparent rounded-2xl -z-10"></div>
      <div class="p-6">
        <!-- Breadcrumb -->
        <nav class="mb-4 text-sm" style="color: var(--text-low);">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          <span class="mx-2">/</span>
          <a href="/blog" class="hover:text-primary transition-colors">Blog</a>
          <span class="mx-2">/</span>
          <span style="color: var(--text-medium);">{title.slice(0, 40)}...</span>
        </nav>

        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span class={`inline-flex items-center rounded-full px-3 py-1 text-xs font-medium ${categoryColors[category] || categoryColors['research-digest']}`}>
            {categoryLabels[category] || category}
          </span>
          {evidenceLevel && (
            <span class={`inline-flex items-center rounded-full px-3 py-1 text-xs font-medium border ${evidenceLabels[evidenceLevel].color}`}>
              {evidenceLabels[evidenceLevel].label}
            </span>
          )}
        </div>

        <h1 class="text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl" style="font-family: var(--font-display);">
          {title}
        </h1>

        <p class="mt-4 text-xl text-white/80 leading-relaxed">
          {excerpt}
        </p>

        <!-- Meta info -->
        <div class="mt-6 flex flex-wrap items-center gap-4 text-sm" style="color: var(--text-medium);">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
            <span>{author}</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            <time datetime={publishDate.toISOString()}>
              {publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>{readingTime} min read</span>
          </div>
        </div>

        <!-- Tags -->
        {tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {tags.map(tag => (
              <span class="inline-flex items-center rounded-full bg-white/5 px-3 py-1 text-xs font-medium text-white/60 border border-white/10">
                #{tag}
              </span>
            ))}
          </div>
        )}
      </div>
    </header>

    <div class="grid gap-8 lg:grid-cols-[1fr,280px]">
      <!-- Main content -->
      <div class="prose prose-invert prose-lg max-w-none">
        <slot />

        <!-- Sources Section -->
        {sources.length > 0 && (
          <section class="mt-12 not-prose">
            <h2 class="text-xl font-bold text-white mb-4 flex items-center gap-2" style="font-family: var(--font-display);">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
              </svg>
              Sources & Citations
            </h2>
            <div class="rounded-xl border border-white/10 bg-white/5 overflow-hidden">
              <ul class="divide-y divide-white/5">
                {sources.map((source, index) => (
                  <li class="p-4 hover:bg-white/5 transition-colors">
                    <div class="flex items-start gap-3">
                      <span class="flex-shrink-0 w-6 h-6 rounded-full bg-[var(--primary)]/20 text-primary text-xs flex items-center justify-center font-medium">
                        {index + 1}
                      </span>
                      <div class="flex-grow min-w-0">
                        <div class="flex items-center gap-2 mb-1">
                          {source.type && (
                            <svg class="w-4 h-4 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={sourceTypeIcons[source.type] || sourceTypeIcons['journal']}></path>
                            </svg>
                          )}
                          <span class="text-xs text-white/40 uppercase tracking-wide">{source.type || 'source'}</span>
                        </div>
                        <a
                          href={getSourceUrl(source)}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="text-primary hover:text-[var(--accent)] hover:underline transition-colors inline-flex items-center gap-1"
                        >
                          {source.title}
                          <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                          </svg>
                        </a>
                        <p class="text-xs text-white/40 mt-1">{source.id}</p>
                      </div>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          </section>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="hidden lg:block">
        <div class="sticky top-24 space-y-6">
          <TableOfContents />

          <!-- Related Peptides -->
          {relatedPeptides.length > 0 && (
            <div class="rounded-xl border border-white/10 bg-gradient-to-b from-[var(--primary)]/10 to-transparent p-4 backdrop-blur-sm">
              <h3 class="font-semibold text-white mb-3 flex items-center gap-2">
                <svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2" />
                </svg>
                Related Peptides
              </h3>
              <ul class="space-y-2">
                {relatedPeptides.map(peptide => (
                  <li>
                    <a
                      href={`/peptides/${peptide}`}
                      class="text-sm text-primary hover:text-[var(--accent)] hover:underline transition-colors"
                    >
                      {peptide.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ')}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- Related Glossary -->
          {relatedGlossary.length > 0 && (
            <div class="rounded-xl border border-white/10 bg-white/5 p-4 backdrop-blur-sm">
              <h3 class="font-semibold text-white mb-3 flex items-center gap-2">
                <svg class="w-4 h-4 text-cyan-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20" />
                </svg>
                Key Terms
              </h3>
              <div class="flex flex-wrap gap-2">
                {relatedGlossary.map(term => (
                  <a
                    href={`/glossary/${term}`}
                    class="inline-flex items-center rounded-full bg-cyan-500/10 px-3 py-1 text-xs font-medium text-cyan-400 border border-cyan-500/20 hover:bg-cyan-500/20 transition-colors"
                  >
                    {term.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ')}
                  </a>
                ))}
              </div>
            </div>
          )}

          <!-- Newsletter CTA -->
          <div class="rounded-xl border border-[var(--primary)]/30 bg-[var(--primary)]/10 p-4 backdrop-blur-sm">
            <h3 class="font-semibold text-primary mb-2">Stay Updated</h3>
            <p class="text-sm text-white/70 mb-3">
              Get weekly peptide research briefings delivered to your inbox.
            </p>
            <a
              href="/newsletter"
              class="btn btn-primary btn-sm w-full text-center"
            >
              Subscribe
            </a>
          </div>

          <!-- Disclaimer -->
          <div class="rounded-xl border border-amber-500/30 bg-amber-500/10 p-4 backdrop-blur-sm">
            <h3 class="font-semibold text-amber-400 mb-2">Notice</h3>
            <p class="text-xs text-amber-200/80">
              Educational content only. Not medical advice. Consult a healthcare provider.
            </p>
          </div>
        </div>
      </aside>
    </div>

    <!-- Bottom Disclaimer -->
    <div class="mt-12 rounded-xl border border-amber-500/30 bg-amber-500/10 p-6 backdrop-blur-sm">
      <p class="text-amber-200 text-sm">
        <strong class="text-amber-400">Disclaimer:</strong> This article is for educational purposes only and does not constitute medical advice. The information presented is based on current research but should not be used for diagnosis, treatment, or prevention of any disease. Always consult a qualified healthcare provider before making health decisions.
      </p>
    </div>

    <!-- Post Navigation -->
    <nav class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-4" aria-label="Blog navigation">
      {prevPost ? (
        <a href={`/blog/${prevPost.slug}`} class="rounded-xl border border-white/10 bg-white/5 p-4 hover:bg-white/10 transition-colors group">
          <span class="text-xs text-white/50 mb-1 block flex items-center gap-1">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            Older
          </span>
          <span class="text-white group-hover:text-primary transition-colors line-clamp-2 text-sm font-medium">{prevPost.title}</span>
        </a>
      ) : (
        <a href="/blog" class="rounded-xl border border-white/10 bg-white/5 p-4 hover:bg-white/10 transition-colors group">
          <span class="text-xs text-white/50 mb-1 block flex items-center gap-1">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            Back
          </span>
          <span class="text-white group-hover:text-primary transition-colors text-sm font-medium">All Blog Posts</span>
        </a>
      )}
      {nextPost ? (
        <a href={`/blog/${nextPost.slug}`} class="rounded-xl border border-white/10 bg-white/5 p-4 hover:bg-white/10 transition-colors group text-right">
          <span class="text-xs text-white/50 mb-1 block flex items-center justify-end gap-1">
            Newer
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
            </svg>
          </span>
          <span class="text-white group-hover:text-primary transition-colors line-clamp-2 text-sm font-medium">{nextPost.title}</span>
        </a>
      ) : <div />}
    </nav>
  </article>
</BaseLayout>
