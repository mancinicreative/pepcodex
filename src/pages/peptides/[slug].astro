---
import { getCollection, getEntry } from 'astro:content';
import DossierLayout from '../../layouts/DossierLayout.astro';

export async function getStaticPaths() {
  const peptides = await getCollection('peptides');
  return peptides.map((peptide) => ({
    params: { slug: peptide.slug },
    props: { peptide },
  }));
}

// Support both static and SSR modes
let peptide = Astro.props.peptide;
if (!peptide) {
  const { slug } = Astro.params;
  peptide = await getEntry('peptides', slug as string);
}

if (!peptide) {
  return Astro.redirect('/404');
}

const { Content } = await peptide.render();
---

<DossierLayout
  name={peptide.data.name}
  aliases={peptide.data.aliases}
  category={peptide.data.category}
  evidenceStrength={peptide.data.evidenceStrength}
  lastUpdated={peptide.data.lastUpdated}
  summary={peptide.data.summary}
  sources={peptide.data.sources}
  comparators={peptide.data.comparators}
  interactions={peptide.data.interactions}
  molecularInfo={peptide.data.molecularInfo}
  evidenceChainedBenefits={peptide.data.evidenceChainedBenefits}
  timeline={peptide.data.timeline}
  qualityChecklist={peptide.data.qualityChecklist}
  regulatoryStatus={peptide.data.regulatoryStatus}
  ratings={peptide.data.ratings}
  metaTitle={peptide.data.metaTitle}
  metaDescription={peptide.data.metaDescription}
>
  <Content />
</DossierLayout>
