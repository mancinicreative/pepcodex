---
interface Props {
  variant?: 'inline' | 'card' | 'full';
  heading?: string;
  description?: string;
}

const {
  variant = 'card',
  heading = 'Stay Evidence-Based',
  description = 'Weekly synthesis of peptide research delivered to your inbox. No hype, just citations.'
} = Astro.props;
---

{variant === 'inline' && (
  <form
    class="flex gap-2"
    action="/api/subscribe"
    method="POST"
    data-newsletter-form
  >
    <input
      type="email"
      name="email"
      placeholder="your@email.com"
      required
      class="flex-1 rounded-xl px-4 py-2 text-sm text-white outline-none focus:ring-2 focus:ring-primary/30"
      style="background: var(--surface-glass); border: 1px solid var(--border-glass); --tw-placeholder-opacity: 1;"
    />
    <button
      type="submit"
      class="btn btn-primary btn-sm"
    >
      Subscribe
    </button>
  </form>
)}

{variant === 'card' && (
  <div class="glass-card p-6">
    <h3 class="text-lg font-semibold" style="color: var(--text-high);">{heading}</h3>
    <p class="mt-2 text-sm" style="color: var(--text-medium);">{description}</p>
    <form
      class="mt-4 flex gap-2"
      action="/api/subscribe"
      method="POST"
      data-newsletter-form
    >
      <input
        type="email"
        name="email"
        placeholder="your@email.com"
        required
        class="flex-1 rounded-xl px-4 py-2 text-sm text-white outline-none focus:ring-2 focus:ring-primary/30"
        style="background: var(--surface-glass); border: 1px solid var(--border-glass);"
      />
      <button
        type="submit"
        class="btn btn-primary btn-sm"
      >
        Subscribe
      </button>
    </form>
    <p class="mt-3 text-xs" style="color: var(--text-medium);">No spam. Unsubscribe anytime.</p>
  </div>
)}

{variant === 'full' && (
  <div class="relative rounded-2xl border border-primary/50 bg-gradient-to-br from-primary/30 via-primary/20 to-purple-600/20 backdrop-blur-xl p-8 overflow-hidden" style="box-shadow: var(--shadow-glow-md);">
    <!-- Decorative glows -->
    <div class="absolute inset-0 bg-gradient-to-br from-primary/40 via-purple-500/20 to-transparent pointer-events-none"></div>
    <div class="absolute -top-24 -right-24 w-64 h-64 bg-primary/40 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-24 -left-24 w-48 h-48 bg-purple-500/30 rounded-full blur-3xl"></div>

    <div class="relative max-w-xl mx-auto text-center">
      <h2 class="text-2xl font-bold" style="color: var(--text-high);">{heading}</h2>
      <p class="mt-3" style="color: var(--text-high);">{description}</p>
      <form
        class="mt-6 flex flex-col sm:flex-row gap-3 max-w-md mx-auto"
        action="/api/subscribe"
        method="POST"
        data-newsletter-form
      >
        <input
          type="email"
          name="email"
          placeholder="your@email.com"
          required
          class="flex-1 rounded-xl px-4 py-3 text-white outline-none focus:ring-2 focus:ring-white/30"
          style="background: rgba(255, 255, 255, 0.15); border: 1px solid rgba(255, 255, 255, 0.3);"
        />
        <button
          type="submit"
          class="btn btn-md rounded-xl bg-white text-primary font-bold hover:bg-white/90 transition-colors shadow-lg hover:shadow-xl"
        >
          Subscribe
        </button>
      </form>
      <p class="mt-4 text-xs" style="color: var(--text-high);">Join 1,000+ readers. Unsubscribe anytime.</p>
    </div>
  </div>
)}

<script>
  document.querySelectorAll('[data-newsletter-form]').forEach(form => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formEl = e.target as HTMLFormElement;
      const email = new FormData(formEl).get('email');
      const button = formEl.querySelector('button');
      const originalButtonText = button?.textContent || 'Subscribe';

      if (button) {
        button.textContent = 'Subscribing...';
        button.setAttribute('disabled', 'true');
      }

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, source: 'website_form' }),
        });

        const data = await res.json();

        if (data.success) {
          // Success - show confirmation message
          formEl.innerHTML = `<p class="text-[var(--accent)] font-medium py-2">${data.message}</p>`;
        } else {
          // API returned an error message
          if (button) {
            button.textContent = originalButtonText;
            button.removeAttribute('disabled');
          }
          // Show error below the form
          const existingError = formEl.querySelector('[data-error]');
          if (existingError) existingError.remove();
          const errorEl = document.createElement('p');
          errorEl.setAttribute('data-error', 'true');
          errorEl.className = 'text-red-400 text-sm mt-2';
          errorEl.textContent = data.message;
          formEl.appendChild(errorEl);
        }
      } catch (err) {
        if (button) {
          button.textContent = originalButtonText;
          button.removeAttribute('disabled');
        }
        // Show generic error
        const existingError = formEl.querySelector('[data-error]');
        if (existingError) existingError.remove();
        const errorEl = document.createElement('p');
        errorEl.setAttribute('data-error', 'true');
        errorEl.className = 'text-red-400 text-sm mt-2';
        errorEl.textContent = 'Something went wrong. Please try again.';
        formEl.appendChild(errorEl);
      }
    });
  });
</script>
