---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import presetData from '../../../../data/calculator-presets.json';

export function getStaticPaths() {
  return presetData.presets
    .filter(p => p.blend.commonPairings.length > 0)
    .map(preset => ({
      params: { peptide: preset.slug },
      props: {
        preset,
        pairings: preset.blend.commonPairings
          .map((slug: string) => presetData.presets.find((p: any) => p.slug === slug))
          .filter(Boolean),
      },
    }));
}

const { preset, pairings } = Astro.props;
const displayName = preset.name;
---

<BaseLayout
  title={`${displayName} Blend Calculator`}
  description={`Calculate multi-peptide blend volumes with ${displayName}. Common pairings pre-loaded.`}
>
  <!-- Breadcrumb -->
  <nav class="flex items-center gap-2 text-sm mb-8" style="color: var(--text-medium);">
    <a href="/calculator" class="hover:text-primary transition-colors">Calculators</a>
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <a href="/calculator/blend" class="hover:text-primary transition-colors">Blend</a>
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
    <span style="color: var(--text-high);">{displayName}</span>
  </nav>

  <!-- Header -->
  <section class="mb-12">
    <div class="flex items-center gap-4 mb-6">
      <div class="w-14 h-14 rounded-2xl bg-cyan-400/20 flex items-center justify-center">
        <svg class="w-7 h-7 text-cyan-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"/>
          <path d="M8.5 2h7"/><path d="M7 16h10"/>
        </svg>
      </div>
      <div>
        <h1 class="text-3xl font-bold font-display" style="color: var(--text-high);">{displayName} Blend Calculator</h1>
        <p class="text-sm" style="color: var(--text-medium);">Calculate volumes for {displayName} blends</p>
      </div>
    </div>
  </section>

  <!-- Blend calculator UI -->
  <div class="glass-card p-8 mb-12">
    <h2 class="text-lg font-bold mb-4 font-display" style="color: var(--text-high);">Common Pairings with {displayName}</h2>
    <p class="text-sm mb-6" style="color: var(--text-medium);">
      Select peptides to include in your blend. Each peptide's reconstitution values are pre-filled.
    </p>

    <!-- Primary peptide (always included) -->
    <div class="p-4 rounded-xl bg-primary/10 border border-primary/30 mb-4">
      <div class="flex items-center justify-between mb-3">
        <span class="font-bold text-white">{displayName}</span>
        <span class="text-xs text-primary font-medium">Primary</span>
      </div>
      <div class="grid grid-cols-3 gap-3">
        <div>
          <label class="block text-xs mb-1" style="color: var(--text-low);">Amount ({preset.reconstitution.unit})</label>
          <input type="number" class="blend-amount w-full px-3 py-2 rounded-lg bg-white/5 border border-white/10 text-white text-sm"
            value={preset.reconstitution.typicalVialSizes[0]} data-slug={preset.slug} />
        </div>
        <div>
          <label class="block text-xs mb-1" style="color: var(--text-low);">Water (mL)</label>
          <input type="number" class="blend-water w-full px-3 py-2 rounded-lg bg-white/5 border border-white/10 text-white text-sm"
            value={preset.reconstitution.typicalWaterVolume} data-slug={preset.slug} />
        </div>
        <div>
          <label class="block text-xs mb-1" style="color: var(--text-low);">Dose (mcg)</label>
          <input type="number" class="blend-dose w-full px-3 py-2 rounded-lg bg-white/5 border border-white/10 text-white text-sm"
            value="250" data-slug={preset.slug} />
        </div>
      </div>
    </div>

    <!-- Pairing peptides -->
    {pairings.map((pair: any) => (
      <div class="p-4 rounded-xl bg-white/5 border border-white/10 mb-4 blend-pair" data-slug={pair.slug}>
        <div class="flex items-center justify-between mb-3">
          <label class="flex items-center gap-2">
            <input type="checkbox" class="blend-toggle rounded" data-slug={pair.slug} />
            <span class="font-bold text-white">{pair.name}</span>
          </label>
          <a href={`/peptides/${pair.slug}`} class="text-xs text-primary hover:underline">View dossier</a>
        </div>
        <div class="grid grid-cols-3 gap-3 opacity-50 blend-inputs" data-slug={pair.slug}>
          <div>
            <label class="block text-xs mb-1" style="color: var(--text-low);">Amount ({pair.reconstitution.unit})</label>
            <input type="number" class="blend-amount w-full px-3 py-2 rounded-lg bg-white/5 border border-white/10 text-white text-sm"
              value={pair.reconstitution.typicalVialSizes[0]} disabled data-slug={pair.slug} />
          </div>
          <div>
            <label class="block text-xs mb-1" style="color: var(--text-low);">Water (mL)</label>
            <input type="number" class="blend-water w-full px-3 py-2 rounded-lg bg-white/5 border border-white/10 text-white text-sm"
              value={pair.reconstitution.typicalWaterVolume} disabled data-slug={pair.slug} />
          </div>
          <div>
            <label class="block text-xs mb-1" style="color: var(--text-low);">Dose (mcg)</label>
            <input type="number" class="blend-dose w-full px-3 py-2 rounded-lg bg-white/5 border border-white/10 text-white text-sm"
              value="250" disabled data-slug={pair.slug} />
          </div>
        </div>
      </div>
    ))}

    <!-- Summary -->
    <div class="mt-6 p-4 rounded-xl bg-white/5 border border-white/10">
      <h3 class="text-sm font-bold mb-3" style="color: var(--text-high);">Blend Summary</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div>
          <p class="text-xs" style="color: var(--text-low);">Total Peptides</p>
          <p class="text-lg font-bold text-primary" id="blendCount">1</p>
        </div>
        <div>
          <p class="text-xs" style="color: var(--text-low);">Total Water</p>
          <p class="text-lg font-bold text-cyan-400" id="blendWater">-</p>
        </div>
        <div>
          <p class="text-xs" style="color: var(--text-low);">Total Draw</p>
          <p class="text-lg font-bold text-purple-400" id="blendDraw">-</p>
        </div>
        <div>
          <p class="text-xs" style="color: var(--text-low);">Total Units</p>
          <p class="text-lg font-bold text-green-400" id="blendUnits">-</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Links -->
  <div class="flex flex-wrap gap-4 mb-12">
    <a href={`/peptides/${preset.slug}`} class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-primary/10 border border-primary/30 text-sm font-medium text-primary hover:bg-primary/20 transition-colors">
      {displayName} Evidence Dossier
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </a>
    <a href={`/calculator/reconstitution/${preset.slug}`} class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-white/5 border border-white/10 text-sm font-medium text-white hover:bg-white/10 transition-colors">
      Reconstitution Calculator
    </a>
    <a href={`/calculator/accumulation/${preset.slug}`} class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-white/5 border border-white/10 text-sm font-medium text-white hover:bg-white/10 transition-colors">
      Accumulation Calculator
    </a>
  </div>

  <!-- Disclaimer -->
  <section class="py-8">
    <div class="glass-card p-6" style="border-color: hsla(45, 90%, 55%, 0.3);">
      <div class="flex items-start gap-4">
        <div class="w-12 h-12 rounded-full flex items-center justify-center flex-shrink-0 bg-yellow-500/20 border border-yellow-500/30">
          <svg class="w-5 h-5 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
          </svg>
        </div>
        <div>
          <h3 class="text-sm font-bold text-yellow-400 uppercase tracking-wider mb-2">For Research Purposes Only</h3>
          <p class="text-sm leading-relaxed" style="color: var(--text-medium);">
            This calculator is for educational purposes only. Combining peptides carries additional risks. No dosing guidance is provided. Always consult healthcare professionals.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  function calculateBlend() {
    let count = 1;
    let totalWater = 0;
    let totalDraw = 0;

    // Primary peptide
    const primaryAmounts = document.querySelectorAll('.blend-amount:not([disabled])');
    const primaryWaters = document.querySelectorAll('.blend-water:not([disabled])');
    const primaryDoses = document.querySelectorAll('.blend-dose:not([disabled])');

    primaryAmounts.forEach((input, i) => {
      const amount = parseFloat((input as HTMLInputElement).value) || 0;
      const water = parseFloat((primaryWaters[i] as HTMLInputElement).value) || 0;
      const dose = parseFloat((primaryDoses[i] as HTMLInputElement).value) || 0;

      totalWater += water;
      if (amount > 0 && water > 0 && dose > 0) {
        const conc = amount / water;
        totalDraw += dose / (conc * 1000);
      }
    });

    // Count enabled pairs
    document.querySelectorAll('.blend-toggle:checked').forEach(() => count++);

    document.getElementById('blendCount')!.textContent = count.toString();
    document.getElementById('blendWater')!.textContent = totalWater.toFixed(1) + ' mL';
    document.getElementById('blendDraw')!.textContent = totalDraw.toFixed(4) + ' mL';
    document.getElementById('blendUnits')!.textContent = (totalDraw * 100).toFixed(1) + 'u';
  }

  // Toggle pair inputs
  document.querySelectorAll('.blend-toggle').forEach(toggle => {
    toggle.addEventListener('change', (e) => {
      const slug = (e.currentTarget as HTMLInputElement).dataset.slug;
      const inputs = document.querySelector(`.blend-inputs[data-slug="${slug}"]`) as HTMLElement;
      const checked = (e.currentTarget as HTMLInputElement).checked;

      if (inputs) {
        inputs.classList.toggle('opacity-50', !checked);
        inputs.querySelectorAll('input').forEach(input => {
          (input as HTMLInputElement).disabled = !checked;
        });
      }
      calculateBlend();
    });
  });

  // Recalculate on any input change
  document.querySelectorAll('.blend-amount, .blend-water, .blend-dose').forEach(input => {
    input.addEventListener('input', calculateBlend);
  });

  calculateBlend();
</script>
