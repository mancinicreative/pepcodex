---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';
import BreadcrumbSchema from '../components/SEO/BreadcrumbSchema.astro';

interface Study {
  title: string;
  authors?: string;
  year: number;
  pmid?: string;
  studyType: 'human-rct' | 'human-observational' | 'animal' | 'in-vitro';
  dosesUsed: string;
  findings: string;
}

interface Props {
  title: string;
  description: string;
  peptides: string[];
  researchSummary: string;
  studies: Study[];
  mechanism: string;
  safetyNotes: string;
  disclaimer: string;
  lastUpdated: Date;
}

const { title, description, peptides, researchSummary, studies, mechanism, safetyNotes, disclaimer, lastUpdated } = Astro.props;

// Study type badge colors — signal palette on paper
const studyTypeBadges: Record<string, { bg: string; text: string; label: string }> = {
  'human-rct': { bg: 'bg-[rgba(20,118,74,0.10)]', text: 'text-[color:var(--research)]', label: 'Human RCT' },
  'human-observational': { bg: 'bg-[color:var(--primary-soft)]', text: 'text-[color:var(--primary-c)]', label: 'Human Observational' },
  'animal': { bg: 'bg-[rgba(203,135,52,0.12)]', text: 'text-[#9a6418]', label: 'Animal Study' },
  'in-vitro': { bg: 'bg-[color:var(--paper-2)]', text: 'text-[color:var(--ink-dim)]', label: 'In Vitro' },
};

const siteBase = Astro.site?.toString() || 'https://www.pepcodex.com';
const breadcrumbItems = [
  { name: 'Home', url: siteBase },
  { name: 'Protocols', url: `${siteBase}protocols/` },
  { name: title, url: Astro.url.toString() },
];
---

<BaseLayout title={title} description={description}>
  <BreadcrumbSchema items={breadcrumbItems} />
  <article class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <!-- Header -->
    <header class="mb-8 relative">
      <div class="p-6">
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span class="badge badge--primary">
            <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Research Overview
          </span>
          <span class="badge badge--muted">
            {studies.length} Studies Cited
          </span>
        </div>

        <h1 class="text-3xl sm:text-4xl lg:text-5xl tracking-tight" style="font-family: var(--font-serif); font-weight: 500; color: var(--ink);">
          {title}
        </h1>

        <p class="mt-4 text-xl leading-relaxed max-w-3xl" style="color: var(--ink-muted);">
          {description}
        </p>

        <p class="mt-4 text-sm" style="color: var(--ink-dim);">
          Last updated: {lastUpdated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </p>
      </div>
    </header>

    <!-- Research-only disclaimer -->
    <div class="mb-8 rounded-xl p-6" style="background: var(--primary-soft); border: 1px solid var(--primary-border);">
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0">
          <svg class="w-8 h-8" style="color: var(--primary-c);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div>
          <h2 class="text-lg font-semibold mb-2" style="color: var(--primary-c);">Research Documentation, Not Dosing Guidance</h2>
          <p style="color: var(--ink-muted);">
            This page documents <strong style="color: var(--ink);">what researchers have studied</strong> in scientific literature.
            The doses mentioned are those used <strong style="color: var(--ink);">in specific studies</strong>, not recommendations.
            This is not a protocol guide and should not be used as dosing advice.
          </p>
        </div>
      </div>
    </div>

    <div class="grid gap-8 lg:grid-cols-[1fr,320px]">
      <!-- Main content -->
      <div class="space-y-8">
        <!-- Research Summary -->
        <section class="glass-card-default p-6">
          <h2 class="text-xl mb-4 flex items-center gap-2" style="font-family: var(--font-serif); font-weight: 500; color: var(--ink);">
            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            Research Summary
          </h2>
          <p class="leading-relaxed" style="color: var(--ink-muted);">{researchSummary}</p>
        </section>

        <!-- Mechanism -->
        <section class="glass-card-default p-6">
          <h2 class="text-xl mb-4 flex items-center gap-2" style="font-family: var(--font-serif); font-weight: 500; color: var(--ink);">
            <svg class="w-5 h-5" style="color: var(--primary-c);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
            </svg>
            Proposed Mechanism of Combination
          </h2>
          <p class="leading-relaxed" style="color: var(--ink-muted);">{mechanism}</p>
        </section>

        <!-- MDX Content slot -->
        <div class="prose prose-invert prose-lg max-w-none">
          <slot />
        </div>

        <!-- Studies Table -->
        <section class="glass-card-default p-6">
          <h2 class="text-xl mb-6 flex items-center gap-2" style="font-family: var(--font-serif); font-weight: 500; color: var(--ink);">
            <svg class="w-5 h-5" style="color: var(--research);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
            </svg>
            Studies Referenced
          </h2>

          <div class="space-y-4">
            {studies.map((study, index) => (
              <div class="rounded-lg p-4" style="border: 1px solid var(--border-c); background: var(--paper-2);">
                <div class="flex flex-wrap items-start gap-2 mb-2">
                  <span class={`inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium ${studyTypeBadges[study.studyType].bg} ${studyTypeBadges[study.studyType].text}`}>
                    {studyTypeBadges[study.studyType].label}
                  </span>
                  <span class="text-sm" style="color: var(--ink-dim);">{study.year}</span>
                </div>

                <h3 class="font-semibold mb-1" style="color: var(--ink);">
                  {study.title}
                  {study.pmid && (
                    <a
                      href={`https://pubmed.ncbi.nlm.nih.gov/${study.pmid}/`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="ml-2 text-xs text-primary hover:underline"
                    >
                      PMID: {study.pmid}
                    </a>
                  )}
                </h3>

                {study.authors && (
                  <p class="text-sm mb-2" style="color: var(--ink-dim);">{study.authors}</p>
                )}

                <div class="mt-3 space-y-2">
                  <div>
                    <span class="text-xs uppercase tracking-wider font-medium" style="color: var(--ink-dim);">Doses Used in Study:</span>
                    <p class="text-sm mt-1" style="color: var(--ink-muted);">{study.dosesUsed}</p>
                  </div>
                  <div>
                    <span class="text-xs uppercase tracking-wider font-medium" style="color: var(--ink-dim);">Findings:</span>
                    <p class="text-sm mt-1" style="color: var(--ink-muted);">{study.findings}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- Safety Notes -->
        <section class="rounded-xl p-6" style="background: rgba(203,135,52,0.10); border: 1px solid rgba(203,135,52,0.32);">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0">
              <svg class="w-8 h-8" style="color: #9a6418;" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
              </svg>
            </div>
            <div>
              <h2 class="text-lg font-semibold mb-2" style="color: #9a6418;">Safety Considerations from Research</h2>
              <p style="color: var(--ink-muted);">{safetyNotes}</p>
            </div>
          </div>
        </section>
      </div>

      <!-- Sidebar -->
      <aside class="hidden lg:block">
        <div class="sticky top-24 space-y-6">
          <TableOfContents />

          <!-- Peptides Involved -->
          <div class="panel-inset p-4">
            <h3 class="font-semibold mb-3" style="color: var(--ink);">Peptides in This Research</h3>
            <ul class="space-y-2">
              {peptides.map(peptide => (
                <li>
                  <a
                    href={`/peptides/${peptide}`}
                    class="text-sm text-primary hover:text-[color:var(--primary-deep)] hover:underline transition-colors flex items-center gap-2"
                  >
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2" />
                    </svg>
                    {peptide.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join('-')} Dossier
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Study Type Legend -->
          <div class="panel-inset p-4">
            <h3 class="font-semibold mb-3" style="color: var(--ink);">Study Type Legend</h3>
            <ul class="space-y-2 text-sm">
              <li class="flex items-center gap-2">
                <span class="w-3 h-3 rounded-full" style="background: var(--research);"></span>
                <span style="color: var(--ink-muted);">Human RCT</span>
              </li>
              <li class="flex items-center gap-2">
                <span class="w-3 h-3 rounded-full" style="background: var(--primary-c);"></span>
                <span style="color: var(--ink-muted);">Human Observational</span>
              </li>
              <li class="flex items-center gap-2">
                <span class="w-3 h-3 rounded-full" style="background: var(--compound);"></span>
                <span style="color: var(--ink-muted);">Animal Study</span>
              </li>
              <li class="flex items-center gap-2">
                <span class="w-3 h-3 rounded-full" style="background: var(--ink-dim);"></span>
                <span style="color: var(--ink-muted);">In Vitro</span>
              </li>
            </ul>
          </div>

          <!-- Quick Links -->
          <div class="panel-inset p-4">
            <h3 class="font-semibold mb-3" style="color: var(--ink);">Quick Links</h3>
            <ul class="space-y-2">
              <li>
                <a
                  href="/protocols"
                  class="text-sm text-primary hover:text-[color:var(--primary-deep)] hover:underline transition-colors"
                >
                  All Research Overviews
                </a>
              </li>
              <li>
                <a
                  href="/methodology"
                  class="text-sm text-primary hover:text-[color:var(--primary-deep)] hover:underline transition-colors"
                >
                  Our Methodology
                </a>
              </li>
              <li>
                <a
                  href="/editorial-policy"
                  class="text-sm text-primary hover:text-[color:var(--primary-deep)] hover:underline transition-colors"
                >
                  Editorial Policy
                </a>
              </li>
            </ul>
          </div>
        </div>
      </aside>
    </div>

    <!-- Footer disclaimer -->
    <div class="mt-12 rounded-xl p-6" style="background: var(--primary-soft); border: 1px solid var(--primary-border);">
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0">
          <svg class="w-6 h-6" style="color: var(--primary-c);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <div>
          <p class="text-sm" style="color: var(--ink-muted);">
            <strong style="color: var(--primary-c);">Disclaimer:</strong> {disclaimer}
          </p>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
