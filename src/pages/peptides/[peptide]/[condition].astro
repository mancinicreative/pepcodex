---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BreadcrumbSchema from '../../../components/SEO/BreadcrumbSchema.astro';
import ArticleSchema from '../../../components/SEO/ArticleSchema.astro';
import NewsletterForm from '../../../components/NewsletterForm.astro';

export async function getStaticPaths() {
  const peptides = await getCollection('peptides');
  const paths: any[] = [];

  for (const peptide of peptides) {
    if (peptide.data.conditions && peptide.data.conditions.length > 0) {
      for (const condition of peptide.data.conditions) {
        paths.push({
          params: {
            peptide: peptide.slug,
            condition: condition.slug,
          },
          props: {
            peptide,
            condition,
            allConditions: peptide.data.conditions,
          },
        });
      }
    }
  }

  return paths;
}

interface Condition {
  slug: string;
  name: string;
  researchSummary: string;
  relevantStudies: string[];
  relatedPeptides?: string[];
}

// Support both static and SSR modes
let peptide = Astro.props.peptide;
let condition = Astro.props.condition;
let allConditions = Astro.props.allConditions;

if (!peptide) {
  const { peptide: peptideSlug, condition: conditionSlug } = Astro.params;
  peptide = await getEntry('peptides', peptideSlug as string);

  if (!peptide) {
    return Astro.redirect('/404');
  }

  // Find condition from peptide data
  if (peptide.data.conditions) {
    condition = peptide.data.conditions.find((c: Condition) => c.slug === conditionSlug);
    allConditions = peptide.data.conditions;
  }
}

if (!condition) {
  return Astro.redirect('/404');
}

// Get all peptides for related peptide lookup
const allPeptides = await getCollection('peptides');

// Find related peptides that also have this condition
const relatedPeptidesWithCondition = condition.relatedPeptides
  ? allPeptides.filter(p =>
      condition.relatedPeptides?.includes(p.slug) &&
      p.slug !== peptide.slug
    )
  : [];

// SEO
const pageTitle = `${peptide.data.name} for ${condition.name}: Research Overview`;
const metaDescription = `Evidence-based research on ${peptide.data.name} for ${condition.name}. Scientific studies, mechanisms, and findings from peer-reviewed literature.`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// Breadcrumb data
const breadcrumbItems = [
  { name: 'Home', url: Astro.site?.toString() || 'https://www.pepcodex.com' },
  { name: 'Peptides', url: `${Astro.site || 'https://www.pepcodex.com'}peptides/` },
  { name: peptide.data.name, url: `${Astro.site || 'https://www.pepcodex.com'}peptides/${peptide.slug}/` },
  { name: condition.name, url: canonicalURL.toString() },
];

// Evidence badge colors — mapped to brand signals (meaningful)
const evidenceConfig: Record<string, { color: string; label: string }> = {
  'high': { color: 'var(--research)', label: 'High Evidence' },
  'moderate': { color: 'var(--primary-c)', label: 'Moderate Evidence' },
  'low': { color: '#9a6418', label: 'Low Evidence' },
  'very-low': { color: 'var(--danger)', label: 'Very Low Evidence' },
};

const currentEvidence = evidenceConfig[peptide.data.evidenceStrength];
---

<BaseLayout title={pageTitle} description={metaDescription}>
  <!-- Structured Data -->
  <ArticleSchema
    title={pageTitle}
    description={metaDescription}
    url={canonicalURL.toString()}
    dateModified={peptide.data.lastUpdated}
  />
  <BreadcrumbSchema items={breadcrumbItems} />

  <div class="max-w-5xl mx-auto pb-20">
    <!-- Breadcrumb Navigation -->
    <nav class="flex items-center gap-2 text-sm mb-8 flex-wrap" style="color: var(--ink-muted);" aria-label="Breadcrumb">
      <a href="/peptides" class="transition-colors hover:text-[color:var(--ink)]">Peptides</a>
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="m9 18 6-6-6-6"/>
      </svg>
      <a href={`/peptides/${peptide.slug}`} class="transition-colors hover:text-[color:var(--ink)]">{peptide.data.name}</a>
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="m9 18 6-6-6-6"/>
      </svg>
      <span style="color: var(--ink);">{condition.name}</span>
    </nav>

    <!-- Hero Section -->
    <header class="mb-12">
      <div class="flex items-center gap-3 mb-4">
        <span
          class="px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider"
          style={`background: var(--paper-2); border: 1px solid ${currentEvidence.color}; color: ${currentEvidence.color};`}
        >
          {currentEvidence.label}
        </span>
        <span class="badge badge--muted text-xs font-bold uppercase tracking-wider">
          Research Overview
        </span>
      </div>

      <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl mb-6 tracking-tight leading-tight" style="color: var(--ink); font-weight: 500;">
        {peptide.data.name} Research for {condition.name}
      </h1>

      <p class="text-xl max-w-3xl leading-relaxed" style="color: var(--ink-muted);">
        An evidence-based overview of research examining {peptide.data.name} in the context of {condition.name.toLowerCase()}. This page synthesizes findings from peer-reviewed literature.
      </p>
    </header>

    <!-- Main Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Main Content Column -->
      <div class="lg:col-span-2 space-y-8">
        <!-- Research Summary Card -->
        <section class="glass-card-default p-8">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: var(--primary-soft); border: 1px solid var(--primary-border);">
              <svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
                <polyline points="14,2 14,8 20,8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
                <line x1="10" y1="9" x2="8" y2="9"/>
              </svg>
            </div>
            <h2 class="font-serif text-2xl" style="color: var(--ink); font-weight: 500;">
              Research Summary
            </h2>
          </div>

          <div class="prose prose-lg max-w-none">
            {condition.researchSummary.split('\n\n').map((paragraph: string) => (
              <p class="leading-relaxed mb-4 last:mb-0" style="color: var(--ink);">
                {paragraph}
              </p>
            ))}
          </div>
        </section>

        <!-- Key Studies Section -->
        {condition.relevantStudies && condition.relevantStudies.length > 0 && (
          <section class="glass-card-default p-8">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: var(--primary-soft); border: 1px solid var(--primary-border);">
                <svg class="w-5 h-5" style="color: var(--primary-c);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"/>
                  <path d="M8.5 2h7"/>
                  <path d="M7 16h10"/>
                </svg>
              </div>
              <h2 class="font-serif text-2xl" style="color: var(--ink); font-weight: 500;">
                Referenced Studies
              </h2>
            </div>

            <div class="space-y-3">
              {condition.relevantStudies.map((pmid: string) => (
                <a
                  href={`https://pubmed.ncbi.nlm.nih.gov/${pmid}/`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center justify-between p-4 rounded-xl transition-all group hover:border-[color:var(--primary-border)]"
                  style="background: var(--paper-2); border: 1px solid var(--border-c);"
                >
                  <div class="flex items-center gap-3">
                    <span class="text-xs font-mono px-2 py-1 rounded" style="color: var(--ink-dim); background: var(--paper);">PMID</span>
                    <span class="font-medium group-hover:text-[color:var(--primary-c)] transition-colors" style="color: var(--ink);">{pmid}</span>
                  </div>
                  <svg class="w-4 h-4 group-hover:text-[color:var(--primary-c)] transition-colors" style="color: var(--ink-dim);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                    <polyline points="15 3 21 3 21 9"/>
                    <line x1="10" y1="14" x2="21" y2="3"/>
                  </svg>
                </a>
              ))}
            </div>

            <p class="mt-4 text-sm" style="color: var(--ink-dim);">
              Click any PMID to view the full study on PubMed.
            </p>
          </section>
        )}

        <!-- Related Peptides for This Condition -->
        {relatedPeptidesWithCondition.length > 0 && (
          <section class="glass-card-default p-8">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: var(--primary-soft); border: 1px solid var(--primary-border);">
                <svg class="w-5 h-5" style="color: var(--primary-c);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M16 3h5v5M8 3H3v5M21 3L14 10M3 3l7 7M21 21l-7-7M3 21l7-7M16 21h5v-5M8 21H3v-5"/>
                </svg>
              </div>
              <h2 class="font-serif text-2xl" style="color: var(--ink); font-weight: 500;">
                Other Peptides Studied for {condition.name}
              </h2>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {relatedPeptidesWithCondition.map((relatedPeptide) => {
                const relatedCondition = relatedPeptide.data.conditions?.find((c: Condition) => c.slug === condition.slug);
                return (
                  <a
                    href={relatedCondition ? `/peptides/${relatedPeptide.slug}/${condition.slug}` : `/peptides/${relatedPeptide.slug}`}
                    class="p-4 rounded-xl transition-all group hover:border-[color:var(--primary-border)]"
                    style="background: var(--paper-2); border: 1px solid var(--border-c);"
                  >
                    <div class="flex items-center justify-between">
                      <div>
                        <h3 class="font-bold group-hover:text-[color:var(--primary-c)] transition-colors" style="color: var(--ink);">
                          {relatedPeptide.data.name}
                        </h3>
                        <p class="text-sm mt-1" style="color: var(--ink-muted);">
                          {relatedCondition ? `View ${condition.name} research` : 'View dossier'}
                        </p>
                      </div>
                      <svg class="w-5 h-5 group-hover:text-[color:var(--primary-c)] transition-colors" style="color: var(--ink-dim);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="m9 18 6-6-6-6"/>
                      </svg>
                    </div>
                  </a>
                );
              })}
            </div>
          </section>
        )}

        <!-- Disclaimer -->
        <div class="rounded-xl p-6" style="border: 1px solid var(--primary-border); background: var(--primary-soft);">
          <div class="flex gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl" style="background: var(--paper-2); color: var(--primary-c);">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
              </svg>
            </div>
            <div>
              <h4 class="font-bold mb-1 text-base" style="color: var(--primary-c);">Important Disclaimer</h4>
              <p class="text-sm leading-relaxed" style="color: var(--ink-muted);">
                This page summarizes research findings and does not constitute medical advice. {peptide.data.name} {peptide.data.evidenceStrength === 'high' || peptide.data.evidenceStrength === 'moderate' ? 'may have' : 'has not received'} regulatory approval for some indications but should only be used under qualified medical supervision. Always consult a healthcare provider before making health decisions.
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <!-- Quick Navigation Card -->
        <div class="glass-card-default p-6 sticky top-24">
          <h3 class="text-sm font-bold uppercase tracking-wider mb-4" style="color: var(--ink-muted);">
            On This Page
          </h3>
          <nav class="space-y-2">
            <a href="#" class="block text-sm hover:text-primary transition-colors py-1" style="color: var(--ink);">
              Research Summary
            </a>
            {condition.relevantStudies && condition.relevantStudies.length > 0 && (
              <a href="#" class="block text-sm hover:text-primary transition-colors py-1" style="color: var(--ink);">
                Referenced Studies ({condition.relevantStudies.length})
              </a>
            )}
            {relatedPeptidesWithCondition.length > 0 && (
              <a href="#" class="block text-sm hover:text-primary transition-colors py-1" style="color: var(--ink);">
                Related Peptides
              </a>
            )}
          </nav>

          <div class="mt-6 pt-6" style="border-top: 1px solid var(--border-c);">
            <h3 class="text-sm font-bold uppercase tracking-wider mb-4" style="color: var(--ink-muted);">
              Other Conditions Studied
            </h3>
            <nav class="space-y-2 max-h-64 overflow-y-auto scrollbar-thin">
              {allConditions.filter((c: Condition) => c.slug !== condition.slug).map((c: Condition) => (
                <a
                  href={`/peptides/${peptide.slug}/${c.slug}`}
                  class="block text-sm hover:text-primary transition-colors py-1"
                  style="color: var(--ink-muted);"
                >
                  {c.name}
                </a>
              ))}
            </nav>
          </div>

          <div class="mt-6 pt-6" style="border-top: 1px solid var(--border-c);">
            <a
              href={`/peptides/${peptide.slug}`}
              class="btn btn-cobalt flex items-center justify-center gap-2 w-full py-3 rounded-xl text-sm uppercase tracking-wider"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="m12 19-7-7 7-7"/>
                <path d="M19 12H5"/>
              </svg>
              Full {peptide.data.name} Dossier
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Newsletter CTA -->
    <section class="mt-16">
      <NewsletterForm
        variant="compact"
        heading="Stay Updated on Peptide Research"
        description="Get evidence-based research summaries delivered to your inbox."
      />
    </section>
  </div>
</BaseLayout>

<style>
  .scrollbar-thin::-webkit-scrollbar {
    width: 4px;
  }
  .scrollbar-thin::-webkit-scrollbar-track {
    background: transparent;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb {
    background: var(--border-strong);
    border-radius: 2px;
  }
  .scrollbar-thin::-webkit-scrollbar-thumb:hover {
    background: var(--ink-dim);
  }
</style>
